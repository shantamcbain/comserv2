[% META
    title = "Stock Level Management"
    description = "How to manage stock levels, locations, and inventory transactions."
    roles = "admin"
    TemplateType = "Documentation"
    category = "Inventory"
    page_version = "1.00"
    last_updated = "2026-04-17"
    site_specific = "false"
%]
[% PageVersion = 'Documentation/Inventory/stock.tt v1.00 2026-04-17' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<div class="container">
    <h1 style="color:var(--text-color);font-family:var(--header-font)">Stock Level Management</h1>
    <div class="last-updated" style="color:var(--text-muted-color);font-size:var(--font-size-small)">Last Updated: 2026-04-17 | Version: 1.00 | Audience: Site Administrators</div>

    <!-- TOC -->
    <div id="toc" class="row" style="margin:var(--spacing-large) 0;background-color:var(--light-color);padding:var(--spacing-medium);border-left:4px solid var(--primary-color);border-radius:4px">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font);margin-top:0">Quick Navigation</h2>
            <div style="display:flex;flex-wrap:wrap;gap:var(--spacing-small)">
                <a href="#overview" style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Overview</a>
                <a href="#locations" style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Locations</a>
                <a href="#transactions" style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Transactions</a>
                <a href="#viewing" style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Viewing Stock</a>
                <a href="#alerts" style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Low-Stock Alerts</a>
                <a href="#troubleshooting" style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Troubleshooting</a>
            </div>
        </div>
    </div>

    <div id="overview" class="row">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font)">Overview</h2>
            <p style="color:var(--text-color);font-family:var(--body-font)">Stock levels are tracked per item at each storage location. Every change to stock levels is recorded as an audit transaction to ensure accountability and history tracking.</p>
        </div>
    </div>
    <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>

    <div id="locations" class="row">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font)">Storage Locations</h2>
            <p style="color:var(--text-color);font-family:var(--body-font)">Manage your physical storage areas at <code>/Inventory/locations</code>. Examples include "3D Lab Shelf A", "Freezer", or "Main Office".</p>
        </div>
    </div>
    <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>

    <div id="transactions" class="row">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font)">Transaction Types</h2>
            <ul style="color:var(--text-color);font-family:var(--body-font)">
                <li><strong>Receive:</strong> Incoming goods from a supplier.</li>
                <li><strong>Use:</strong> Internal consumption or usage.</li>
                <li><strong>Transfer:</strong> Moving items between locations.</li>
                <li><strong>Adjust:</strong> Corrections to stock levels.</li>
                <li><strong>Return:</strong> Customer returns.</li>
                <li><strong>Consignment:</strong> Tracking items sent to, sold by, or returned from partners.</li>
            </ul>
        </div>
    </div>
    <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>

    <div id="viewing" class="row">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font)">Viewing & Receiving Stock</h2>
            <ul style="color:var(--text-color);font-family:var(--body-font)">
                <li><strong>Stock View:</strong> <code>/Inventory/stock</code> shows all items and quantities per location.</li>
                <li><strong>Receiving:</strong> Manual via <code>/Inventory/stock/adjust</code> or automatically when saving a supplier invoice.</li>
                <li><strong>Adjustments:</strong> Use the "Adjust" button on the stock page; a reason note is always required.</li>
                <li><strong>Reports:</strong> Print stock reports at <code>/Inventory/print/stock</code>, with filters for low stock or categories.</li>
            </ul>
        </div>
    </div>
    <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>

    <div id="alerts" class="row">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font)">Low-Stock Alerts</h2>
            <p style="color:var(--text-color);font-family:var(--body-font)">The dashboard highlights items falling below their defined <code>reorder_point</code>. The <code>reorder_quantity</code> suggests the amount needed to replenish stock.</p>
        </div>
    </div>
    <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>

    <div id="troubleshooting" class="row">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font)">Troubleshooting</h2>
            <ul style="color:var(--text-color);font-family:var(--body-font)">
                <li><strong>Negative Stock:</strong> Occurs if sales are processed before stock is entered. Fix with a positive adjustment.</li>
                <li><strong>Print-on-demand:</strong> Items with <code>hide_stock_count</code> enabled do not require stock levels.</li>
            </ul>
        </div>
    </div>
    <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>

    <!-- SEE ALSO at bottom -->
    <div id="see-also" style="background-color:rgba(255,255,255,0.15);border-left:4px solid var(--success-color);padding:var(--spacing-medium);border-radius:4px;margin:var(--spacing-medium) 0">
        <h2 style="color:var(--success-color);font-family:var(--header-font);margin-top:0">See Also</h2>
        <ul style="color:var(--text-color);font-family:var(--body-font)">
            <li><a href="/Documentation/Inventory/index" style="color:var(--link-color)">Inventory System Overview</a></li>
            <li><a href="/Documentation/Inventory/items" style="color:var(--link-color)">Managing Inventory Items</a></li>
        </ul>
    </div>
</div>
