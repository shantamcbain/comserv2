                    <li><a href="/Documentation/Inventory/consignment" style="color:var(--link-color)">Consignment Tracking</a></li>
                    <li><a href="/Documentation/Inventory/shop"        style="color:var(--link-color)">Shop &amp; Marketplace</a></li>
                    <li><a href="/Documentation/Accounting/index"      style="color:var(--link-color)">Accounting System</a></li>
                    <li><a href="/admin"                               style="color:var(--link-color)">Admin Dashboard</a></li>
                </ul>
            </div>
            <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <div style="margin-top:var(--spacing-large);padding-top:var(--spacing-medium);border-top:1px solid var(--border-color);color:var(--text-muted-color);font-size:var(--font-size-small)">
                <p>For technical support contact your system administrator.</p>
                <p><em>This documentation is part of the Comserv Inventory &amp; Accounting system.</em></p>
            </div>
        </div>
    </div>
</div>
