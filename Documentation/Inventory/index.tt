[% META
    title = "Inventory System — Admin Guide"
    description = "Complete administrator guide for the Comserv Inventory System"
    roles = "admin"
    TemplateType = "Documentation"
    category = "Inventory"
    page_version = "1.00"
    last_updated = "2026-04-17"
    site_specific = "false"
%]
[% PageVersion = 'Documentation/Inventory/index.tt v1.00 2026-04-17 — Inventory System Admin Guide' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<div class="container">
    <h1 style="color:var(--text-color);font-family:var(--header-font)">Inventory System — Administrator Guide</h1>

    <div class="last-updated" style="color:var(--text-muted-color);font-size:var(--font-size-small)">
        Last Updated: 2026-04-17 | Version: 1.00 | Audience: Site Administrators &amp; Accounting
    </div>

    <div id="toc" class="row" style="margin:var(--spacing-large) 0;background-color:var(--light-color);padding:var(--spacing-medium);border-left:4px solid var(--primary-color);border-radius:4px">
        <div class="col-100">
            <h2 style="color:var(--text-color);font-family:var(--header-font);margin-top:0">Quick Navigation</h2>
            <div style="display:flex;flex-wrap:wrap;gap:var(--spacing-small)">
                <a href="#overview"     style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Overview</a>
                <a href="#access"       style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Access &amp; Roles</a>
                <a href="#modules"      style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Modules</a>
                <a href="#workflow"     style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Typical Workflows</a>
                <a href="#schema"       style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Data Model</a>
                <a href="#sitename"     style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">SiteName Isolation</a>
                <a href="#navigation"   style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">Navigation</a>
                <a href="#see-also"     style="color:var(--link-color);text-decoration:none;padding:4px 8px;border-radius:3px;background-color:var(--secondary-color);display:inline-block">See Also</a>
            </div>
        </div>
    </div>

    <!-- OVERVIEW -->
    <div class="row">
        <div class="col-100">
            <h2 id="overview" style="color:var(--text-color);font-family:var(--header-font)">1. Overview</h2>
            <p style="color:var(--text-color);font-family:var(--body-font)">
                The Inventory System tracks all physical goods, supplies, and equipment owned or managed by a SiteName.
                It is fully integrated with the Accounting (double-entry GL) module and the online Shop.
                Any SiteName can activate inventory management independently — each site sees only its own data.
            </p>
            <p style="color:var(--text-color);font-family:var(--body-font)">
                The system is inspired by SQL-Ledger / LedgerSMB accounting conventions and is designed to grow toward
                full ERP capability while remaining simple enough for small organisations to use day-to-day.
            </p>
            <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- ACCESS -->
    <div class="row">
        <div class="col-50">
            <h2 id="access" style="color:var(--text-color);font-family:var(--header-font)">2. Access &amp; Roles</h2>
            <p style="color:var(--text-color);font-family:var(--body-font)">
                All Inventory and Accounting pages require <strong>Admin</strong> role.
                Non-admin users are redirected to login.
            </p>
            <ul style="color:var(--text-color);font-family:var(--body-font)">
                <li><strong>Admin</strong> — full read/write access to all inventory, accounting, and shop management pages</li>
                <li><strong>Member / Public</strong> — can browse the public <a href="/shop" style="color:var(--link-color)">/shop</a> and place orders; cannot see inventory or accounting</li>
            </ul>
            <p style="color:var(--text-color);font-family:var(--body-font)">
                The admin top menu (<em>Inventory</em> dropdown) provides quick access to all sub-sections.
            </p>
        </div>
        <div class="col-50">
            <h2 id="modules" style="color:var(--text-color);font-family:var(--header-font)">3. Modules</h2>
            <ul style="color:var(--text-color);font-family:var(--body-font)">
                <li><strong><a href="/Documentation/Inventory/items" style="color:var(--link-color)">Items</a></strong> — SKUs, descriptions, categories, cost, shop visibility</li>
                <li><strong><a href="/Documentation/Inventory/stock" style="color:var(--link-color)">Stock Levels</a></strong> — locations, receive, use, adjust, low-stock alerts</li>
                <li><strong><a href="/Documentation/Inventory/suppliers" style="color:var(--link-color)">Suppliers &amp; AP Invoices</a></strong> — supplier records, purchase invoices, GL posting</li>
                <li><strong><a href="/Documentation/Inventory/bom" style="color:var(--link-color)">Bill of Materials (BOM)</a></strong> — assemblies, component costs, print wizard</li>
                <li><strong><a href="/Documentation/Inventory/consignment" style="color:var(--link-color)">Consignment</a></strong> — items sent to partner stores, settlement, GL</li>
                <li><strong><a href="/Documentation/Inventory/shop" style="color:var(--link-color)">Shop &amp; Marketplace</a></strong> — public store, cart, customer orders</li>
                <li><strong><a href="/Documentation/Accounting/index" style="color:var(--link-color)">Accounting</a></strong> — Chart of Accounts, General Ledger</li>
            </ul>
        </div>
    </div>
    <div class="row"><div class="col-100"><p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p></div></div>

    <!-- WORKFLOWS -->
    <div class="row">
        <div class="col-100">
            <h2 id="workflow" style="color:var(--text-color);font-family:var(--header-font)">4. Typical Workflows</h2>

            <h3 style="color:var(--text-color);font-family:var(--header-font);font-size:var(--font-size-large)">4.1 First-time Setup</h3>
            <ol style="color:var(--text-color);font-family:var(--body-font)">
                <li>Go to <strong>Admin → Accounting → Seed Accounts</strong> to populate the Chart of Accounts with standard double-entry accounts.</li>
                <li>Go to <strong>Admin → Inventory → Locations</strong> and create at least one storage location (e.g. "Main Shelf", "3D Lab").</li>
                <li>Go to <strong>Admin → Inventory → Suppliers</strong> and add your regular suppliers.</li>
                <li>Go to <strong>Admin → Inventory → Items</strong> and add your products/supplies. Assign COA accounts to each item.</li>
                <li>Use <strong>Stock → Receive</strong> to add opening stock quantities.</li>
                <li>To run an online store: go to <strong>Admin → Shop → Manage Store</strong> and toggle items visible.</li>
            </ol>

            <h3 style="color:var(--text-color);font-family:var(--header-font);font-size:var(--font-size-large)">4.2 Buying Stock (Purchasing)</h3>
            <ol style="color:var(--text-color);font-family:var(--body-font)">
                <li>Receive goods from a supplier.</li>
                <li>Go to <strong>Inventory → Supplier Invoices → New Invoice</strong>.</li>
                <li>Select supplier, add line items (item, qty, unit cost). Add tax and shipping if applicable.</li>
                <li>Save — stock levels are updated automatically and a GL double-entry is posted (DR Inventory/Expense, CR Accounts Payable).</li>
            </ol>

            <h3 style="color:var(--text-color);font-family:var(--header-font);font-size:var(--font-size-large)">4.3 Selling (Shop / Cart)</h3>
            <ol style="color:var(--text-color);font-family:var(--body-font)">
                <li>Enable eCommerce for your SiteName via <strong>Admin → SiteModules → Commerce</strong>.</li>
                <li>In <strong>Shop → Manage Store</strong>, toggle items to "Visible in shop". Set retail price, photos, options.</li>
                <li>Customers browse <strong>/shop</strong>, add to cart, and checkout. Order appears in <strong>Cart Orders</strong>.</li>
                <li>Admin fulfils order; payment is recorded in accounting.</li>
            </ol>

            <h3 style="color:var(--text-color);font-family:var(--header-font);font-size:var(--font-size-large)">4.4 Consignment</h3>
            <ol style="color:var(--text-color);font-family:var(--body-font)">
                <li>Set up consignment partner: <strong>Inventory → Consignment → Partners</strong>.</li>
                <li>Create a consignment batch: select partner, date, items &amp; quantities sent.</li>
                <li>Print the consignment slip (browser Print) to give to the partner.</li>
                <li>When the partner reports sales, record settlement: qty sold, qty returned. Optionally post GL entry.</li>
            </ol>

            <p style="text-align:right"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- DATA MODEL -->
    <div class="row">
        <div class="col-100">
            <h2 id="schema" style="color:var(--text-color);font-family:var(--header-font)">5. Data Model Summary</h2>
            <table style="width:100%;border-collapse:collapse;font-family:var(--body-font);font-size:0.9rem">
                <thead>
                    <tr style="background-color:var(--table-header-bg)">
                        <th style="padding:8px 10px;text-align:left;border:1px solid var(--border-color);color:var(--text-color)">Table</th>
                        <th style="padding:8px 10px;text-align:left;border:1px solid var(--border-color);color:var(--text-color)">Purpose</th>
                        <th style="padding:8px 10px;text-align:left;border:1px solid var(--border-color);color:var(--text-color)">Key Fields</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>inventory_items</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">All products, supplies, equipment</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">sku, name, sitename, unit_cost, unit_price, show_in_shop, is_assemblable</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>inventory_stock_levels</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">Quantity on hand per location</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">item_id, location_id, quantity</td></tr>
                    <tr><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>inventory_transactions</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">Audit trail of every stock movement</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">transaction_type, quantity, reference_number, performed_by</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>inventory_suppliers</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">Vendor/supplier records</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">name, contact, website, lead_time_days</td></tr>
                    <tr><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>inventory_supplier_invoices</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">Purchase (AP) invoices</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">supplier_id, invoice_number, total_amount, status, ap_account_id</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>inventory_item_bom</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">Bill of Materials (component links)</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">parent_item_id, component_item_id, quantity, unit</td></tr>
                    <tr><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>inventory_consignment_*</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">Consignment tracking (3 tables)</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">partner_id, date_sent, commission_percent, quantity_sent/sold/returned</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>coa_accounts</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">Chart of Accounts</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">accno, description, account_type (Asset/Liability/Equity/Income/Expense)</td></tr>
                    <tr><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)"><code>gl_entries / gl_entry_lines</code></td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">General Ledger double-entry</td><td style="padding:7px 10px;border:1px solid var(--border-color);color:var(--text-color)">entry_date, description, debit, credit, account_id</td></tr>
                </tbody>
            </table>
            <p style="text-align:right;margin-top:var(--spacing-small)"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- SITENAME ISOLATION -->
    <div class="row">
        <div class="col-100">
            <h2 id="sitename" style="color:var(--text-color);font-family:var(--header-font)">6. SiteName Isolation</h2>
            <p style="color:var(--text-color);font-family:var(--body-font)">
                Every inventory record is tagged with a <code>sitename</code> column. Queries always filter by the
                current session's SiteName so that the 3d SiteName never sees the CSC SiteName's inventory and vice versa.
                This means each organisation on the platform has a completely independent inventory, chart of accounts,
                and shop.
            </p>
            <div style="background-color:rgba(255,255,255,0.15);border-left:4px solid var(--info-color,#17a2b8);padding:var(--spacing-medium);border-radius:4px;margin:var(--spacing-small) 0">
                <p style="color:var(--text-color);font-family:var(--body-font);margin:0">
                    <strong>Note:</strong> The Marketplace (<code>/marketplace</code>) is the only cross-SiteName view —
                    items listed in the marketplace are visible to all sites. Individual shop pages (<code>/shop</code>)
                    show only the current site's items.
                </p>
            </div>
            <p style="text-align:right;margin-top:var(--spacing-small)"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- NAVIGATION -->
    <div class="row">
        <div class="col-100">
            <h2 id="navigation" style="color:var(--text-color);font-family:var(--header-font)">7. Navigation Reference</h2>
            <table style="width:100%;border-collapse:collapse;font-family:var(--body-font);font-size:0.9rem">
                <thead>
                    <tr style="background-color:var(--table-header-bg)">
                        <th style="padding:8px 10px;border:1px solid var(--border-color);color:var(--text-color)">URL</th>
                        <th style="padding:8px 10px;border:1px solid var(--border-color);color:var(--text-color)">Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Inventory" style="color:var(--link-color)">/Inventory</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Inventory dashboard</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Inventory/items" style="color:var(--link-color)">/Inventory/items</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Item list</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Inventory/item/add" style="color:var(--link-color)">/Inventory/item/add</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Add new item</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Inventory/stock" style="color:var(--link-color)">/Inventory/stock</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Stock levels &amp; transactions</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Inventory/suppliers" style="color:var(--link-color)">/Inventory/suppliers</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Supplier list</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Inventory/invoice" style="color:var(--link-color)">/Inventory/invoice</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Supplier invoices (AP)</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Inventory/consignment" style="color:var(--link-color)">/Inventory/consignment</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Consignment batches</td></tr>
                    <tr style="background-color:rgba(255,255,255,0.07)"><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/shop/admin" style="color:var(--link-color)">/shop/admin</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Shop / store manager</td></tr>
                    <tr><td style="padding:6px 10px;border:1px solid var(--border-color)"><a href="/Accounting" style="color:var(--link-color)">/Accounting</a></td><td style="padding:6px 10px;border:1px solid var(--border-color);color:var(--text-color)">Accounting dashboard</td></tr>
                </tbody>
            </table>
            <p style="text-align:right;margin-top:var(--spacing-small)"><a href="#toc" style="color:var(--link-color);font-size:var(--font-size-small)">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- SEE ALSO -->
    <div class="row">
        <div class="col-100">
            <div id="see-also" style="background-color:rgba(255,255,255,0.15);border-left:4px solid var(--success-color);padding:var(--spacing-medium);border-radius:4px;margin:var(--spacing-medium) 0">
                <h2 style="color:var(--success-color);font-family:var(--header-font);margin-top:0">8. See Also</h2>
