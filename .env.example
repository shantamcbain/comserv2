TZ=UTC

DB_HOST=database
DB_PORT=3306
DB_NAME=comserv
DB_USER=comserv
DB_PASSWORD=comserv_pass
DB_ROOT_PASSWORD=rootpassword
DB_HOST_PORT=127.0.0.1:3306
MYSQL_DATA_PATH=./.docker/mysql

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_DATA_PATH=./.docker/redis

CATALYST_ENV=development
CATALYST_DEBUG=1
WEB_PORT=3000
APP_MOUNT=.

WEB_CPU_LIMIT=2
WEB_CPU_REQUEST=0.5
WEB_MEMORY_LIMIT=1024M
WEB_MEMORY_REQUEST=512M

NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CACHE_PATH=./.docker/nginx_cache

COMSERV_LOGS_PATH=./.docker/logs
COMSERV_SESSIONS_PATH=./.docker/sessions
COMSERV_BACKUPS_PATH=./.docker/backups
