TZ=UTC

# Database Configuration (uses db_config.json + environment variable overrides)
# See: Comserv/root/Documentation/system/DATABASE_CONFIG_DOCKER_KUBERNETES.md
#
# For Docker development, override local database connection:
# COMSERV_DB_LOCAL_ENCY_HOST=database
# COMSERV_DB_LOCAL_ENCY_PORT=3306
# COMSERV_DB_LOCAL_ENCY_USERNAME=comserv
# COMSERV_DB_LOCAL_ENCY_PASSWORD=comserv_pass
# COMSERV_DB_LOCAL_ENCY_DATABASE=ency
#
# For production, override production connection:
# COMSERV_DB_PRODUCTION_SERVER_HOST=192.168.1.198
# COMSERV_DB_PRODUCTION_SERVER_PORT=3306
# COMSERV_DB_PRODUCTION_SERVER_USERNAME=prod_user
# COMSERV_DB_PRODUCTION_SERVER_PASSWORD=secure_password
# COMSERV_DB_PRODUCTION_SERVER_DATABASE=ency

DB_HOST=database
DB_PORT=3306
DB_NAME=comserv
DB_USER=comserv
DB_PASSWORD=comserv_pass
DB_ROOT_PASSWORD=rootpassword
DB_HOST_PORT=127.0.0.1:3306
MYSQL_DATA_PATH=./.docker/mysql

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_DATA_PATH=./.docker/redis

CATALYST_ENV=development
CATALYST_DEBUG=1
WEB_PORT=3000
APP_MOUNT=.

WEB_CPU_LIMIT=2
WEB_CPU_REQUEST=0.5
WEB_MEMORY_LIMIT=1024M
WEB_MEMORY_REQUEST=512M

NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CACHE_PATH=./.docker/nginx_cache

COMSERV_LOGS_PATH=./.docker/logs
COMSERV_SESSIONS_PATH=./.docker/sessions
COMSERV_BACKUPS_PATH=./.docker/backups
