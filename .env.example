# Comserv Development Environment Configuration
# Copy this file to .env and update values for your local environment

# Docker Compose Settings
APP_MOUNT=.
TZ=UTC

# Config Database (Local, for storing database_connections)
CONFIG_DB_ROOT_PASSWORD=your_root_password_here
CONFIG_DB_NAME=comserv_config
CONFIG_DB_USER=comserv_config
CONFIG_DB_PASSWORD=your_config_password_here

# Redis Cache
REDIS_PASSWORD=your_redis_password_here

# External Application Database (on 192.168.1.198)
# IMPORTANT: This is the EXTERNAL database, NOT the config database
DB_HOST=192.168.1.198
DB_PORT=3306
DB_USER=shanta_forager
DB_PASSWORD=your_database_password_here
DB_NAME=ency

# Docker Image Configuration (for CI/CD)
IMAGE_REGISTRY=ghcr.io/YOUR_GITHUB_USERNAME
IMAGE_TAG=latest

# Kubernetes Configuration (for Phase 4+)
K8S_NAMESPACE=default
K8S_CONTEXT=microk8s
K8S_REPLICAS=3

# Deployment Configuration
CATALYST_ENV=development
CATALYST_DEBUG=1
WEB_PORT=3000
LOG_LEVEL=debug

# Optional: Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: GitHub Container Registry
GHCR_USERNAME=YOUR_GITHUB_USERNAME
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
