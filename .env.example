# ===================================================================
# Comserv Docker Environment Configuration
# ===================================================================
# Copy this file to .env and customize for your environment
# Use .env.development for development or .env.production for production

# ===================================================================
# Timezone Configuration
# ===================================================================
TZ=UTC

# ===================================================================
# Database Configuration (MySQL)
# ===================================================================
DB_HOST=database
DB_PORT=3306
DB_NAME=comserv
DB_USER=comserv
DB_PASSWORD=comserv_pass
DB_ROOT_PASSWORD=rootpassword

# Expose database outside Docker (development only)
DB_HOST_PORT=127.0.0.1:3306

# Database data persistence path (relative to project root)
MYSQL_DATA_PATH=./.docker/mysql

# ===================================================================
# Redis Cache Configuration
# ===================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_DATA_PATH=./.docker/redis

# ===================================================================
# Catalyst Application Configuration
# ===================================================================
CATALYST_ENV=development
CATALYST_DEBUG=1

# Web server port
WEB_PORT=3000

# Application mount type (for development)
APP_MOUNT=.

# ===================================================================
# Resource Limits (Docker Compose v3.9+)
# ===================================================================
# CPU limits (e.g., "1", "2", "0.5")
WEB_CPU_LIMIT=2
WEB_CPU_REQUEST=0.5

# Memory limits (e.g., "512M", "1G", "2048M")
WEB_MEMORY_LIMIT=1024M
WEB_MEMORY_REQUEST=512M

# ===================================================================
# Nginx Configuration (if using reverse proxy)
# ===================================================================
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CACHE_PATH=./.docker/nginx_cache

# ===================================================================
# Persistent Data Paths
# ===================================================================
COMSERV_LOGS_PATH=./.docker/logs
COMSERV_SESSIONS_PATH=./.docker/sessions
COMSERV_BACKUPS_PATH=./.docker/backups

# ===================================================================
# Optional: Email Configuration (if using email features)
# ===================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=password
# SMTP_FROM=noreply@example.com

# ===================================================================
# Optional: External API Configuration
# ===================================================================
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here