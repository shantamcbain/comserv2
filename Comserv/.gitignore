comserv.psgi
workspace.xml
.idea/*
.idea/workspace.xml
.idea/vcs.xml
/db_config.json
.env
.env.*
*.log
/local/
/blib/
/pm_to_blib
/Makefile
/Makefile.old
/MYMETA.*
/inc/
/pretrained_models/
/whisper_venv/
/ency.db*

# AI session history and working files (not tracked)
root/Documentation/session_history/
*.md

# Dev workstation TLS certs (never commit private keys)
config/dev_tls/

# Auto-generated editor caches (runtime, re-creatable)
/.file_index_cache.json
/.route_map_cache.json

# Secrets: real credentials live ONLY in ~/.comserv/secrets (outside the repo).
# Never commit Comserv/secrets/ — it may contain live DB passwords.
/secrets/
