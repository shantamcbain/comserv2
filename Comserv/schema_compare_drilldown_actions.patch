+# NEW DRILL-DOWN ACTIONS (added after the lightweight schema_compare)
+
+sub schema_compare_server :Path('/admin/schema_compare/server') :Args(1) {
+    my ($self, $c, $server_name) = @_;
+    my $servers = $self->_get_server_structure($c);
+    my ($server) = grep { $_->{name} eq $server_name } @$servers;
+    unless ($server) {
+        $c->response->status(404);
+        $c->stash(template => 'error.tt', error => "Server not found: $server_name");
+        return;
+    }
+    my $dbs = $self->_get_databases_for_server($c, $server_name);
+    $c->stash(
+        template => 'admin/schema_compare/databases.tt',
+        server   => $server,
+        databases => $dbs
+    );
+}
+
+sub schema_compare_db :Path('/admin/schema_compare/server') :Args(3) {
+    my ($self, $c, $server_name, $db_literal, $db_name) = @_;
+    my $servers = $self->_get_server_structure($c);
+    my ($server) = grep { $_->{name} eq $server_name } @$servers;
+    unless ($server) {
+        $c->response->status(404);
+        return;
+    }
+    my $tables = $self->_get_tables_for_db($c, $server_name, $db_name);
+    $c->stash(
+        template => 'admin/schema_compare/tables.tt',
+        server   => $server,
+        db       => { name => $db_name },
+        tables   => $tables
+    );
+}
+
+sub schema_compare_table :Path('/admin/schema_compare/server') :Args(5) {
+    my ($self, $c, $server_name, $db_literal, $db_name, $table_literal, $table_name) = @_;
+    my $servers = $self->_get_server_structure($c);
+    my ($server) = grep { $_->{name} eq $server_name } @$servers;
+    unless ($server) {
+        $c->response->status(404);
+        return;
+    }
+    my $fields = $self->_get_fields_for_table($c, $server_name, $db_name, $table_name);
+    $c->stash(
+        template => 'admin/schema_compare/fields.tt',
+        server   => $server,
+        db       => { name => $db_name },
+        table    => { name => $table_name },
+        fields   => $fields
+    );
+}
