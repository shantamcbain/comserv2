[%#
  MarkerLegend.tt — include at the top of any ENCY add/edit form.
  Shows the field-entry conventions and marker codes. Always visible to both
  human editors and AI-filled forms (it renders outside all textareas).
%]
[% IF edit_mode %]
<div class="ency-entry-guide" style="background:#f8f9fa;border:1px solid #dee2e6;border-radius:4px;padding:0.75em 1em;margin-bottom:1.25em;font-size:0.88em;">
  <strong>Entry conventions for linked fields:</strong>
  <ul style="margin:0.4em 0 0.4em 1.2em;padding:0;">
    <li>Separate each term with a <strong>semicolon</strong>: <code>demulcent; diuretic; anti-inflammatory</code></li>
    <li>Use <strong>noun phrases</strong>, not prose sentences: <code>immune modulation</code> not <code>supports immune function</code></li>
    <li>Append <code>[?]</code> to flag a term for <strong>research</strong>: <code>adaptogen[?]</code>
        &mdash; a todo will be created automatically on save</li>
    <li>Append <code>[ref?]</code> to flag a term for <strong>reference verification</strong>: <code>demulcent[ref?]</code>
        &mdash; a reference-check todo will be created on save</li>
  </ul>
</div>
[% END %]
