[% IF is_admin %]
<div id="ency-ai-fill-panel" style="margin:1em 0;padding:1em;border:1px solid #acd;background:#f0f7ff;border-radius:4px;">
  <strong>Ask AI to Fill Form</strong>
  <span id="ency-ai-prompt-data" data-prompt="[% ency_ai_prompt | html %]" style="display:none;"></span>
  <div style="margin-top:0.5em;">
    <input type="text" id="ency-ai-entity-name" placeholder="Enter entity name to look up..." size="45" />
    <button type="button" id="ency-ai-ask-btn" onclick="encyAiFill()">Ask AI</button>
    <span id="ency-ai-status" style="margin-left:1em;color:#555;font-style:italic;"></span>
  </div>
  <div id="ency-ai-raw" style="display:none;margin-top:0.8em;">
    <strong>AI Raw Response:</strong>
    <pre id="ency-ai-raw-text" style="background:#eee;padding:0.5em;max-height:180px;overflow:auto;font-size:0.85em;"></pre>
    <button type="button" onclick="encyAiMarkReference()">Mark Reference as AI-generated</button>
    <span style="color:#888;font-size:0.85em;margin-left:0.5em;">Appends attribution to the Reference field.</span>
  </div>
</div>
<script>
(function() {
    function encyAiFill() {
        var name = document.getElementById('ency-ai-entity-name').value.trim();
        if (!name) { alert('Please enter an entity name to look up.'); return; }
        var promptEl = document.getElementById('ency-ai-prompt-data');
        var systemPrompt = promptEl ? promptEl.getAttribute('data-prompt') : '';
        var statusEl = document.getElementById('ency-ai-status');
        var btn = document.getElementById('ency-ai-ask-btn');
        btn.disabled = true;
        document.getElementById('ency-ai-raw').style.display = 'none';

        var providerSel = document.getElementById('ai-provider');
        var selectedProvider = providerSel ? providerSel.value : 'ollama';
        var providerParts = (selectedProvider || 'ollama').split('|');
        var providerName = providerParts[0] || 'ollama';
        var modelName = providerParts[1] || null;

        var isGrok = (providerName === 'grok');
        statusEl.textContent = isGrok
            ? 'Asking AI (Grok)\u2026'
            : 'Asking AI (Ollama \u2014 may take 30\u201390 seconds)\u2026';

        var controller = new AbortController();
        var timeoutMs = isGrok ? 30000 : 120000;
        var timeoutId = setTimeout(function() {
            controller.abort();
        }, timeoutMs);

        var payload = {
            prompt: 'Return ONLY a raw JSON object (no markdown, no code blocks, no explanation) with encyclopedia fields for: ' + name + '. Required fields: ' + systemPrompt,
            system: 'You are an encyclopedia data assistant. Return ONLY a raw JSON object with the requested fields filled in for the named entity. No markdown, no code fences, no prose \u2014 pure JSON only.',
            provider: providerName,
            page_path: window.location.pathname,
            page_title: document.title
        };
        if (modelName) { payload.model = modelName; }

        fetch('/ai/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            signal: controller.signal,
            body: JSON.stringify(payload)
        })
        .then(function(r) {
            return r.text().then(function(text) {
                try { return JSON.parse(text); }
                catch(e) { throw new Error('Server returned non-JSON (HTTP ' + r.status + ')'); }
            });
        })
        .then(function(data) {
            clearTimeout(timeoutId);
            btn.disabled = false;
            var modelUsed = data.model || (isGrok ? 'Grok' : 'Ollama');
            if (!data.success) {
                statusEl.textContent = 'AI error (' + modelUsed + '): ' + (data.error || 'unknown error');
                document.getElementById('ency-ai-raw-text').textContent = JSON.stringify(data, null, 2);
                document.getElementById('ency-ai-raw').style.display = '';
                return;
            }
            var raw = (data.response || '').trim();
            document.getElementById('ency-ai-raw-text').textContent = raw;
            document.getElementById('ency-ai-raw').style.display = '';
            var jsonStart = raw.indexOf('{');
            var jsonEnd   = raw.lastIndexOf('}');
            if (jsonStart === -1 || jsonEnd === -1) {
                statusEl.textContent = '[' + modelUsed + '] AI did not return JSON. See raw response above.';
                return;
            }
            try {
                var fields = JSON.parse(raw.substring(jsonStart, jsonEnd + 1));
                var filled = 0;
                var skipped = [];
                Object.keys(fields).forEach(function(key) {
                    var el = document.querySelector('[name="' + key + '"]');
                    if (!el || fields[key] === null || fields[key] === undefined || fields[key] === '') return;
                    var val = String(fields[key]);
                    if (el.tagName === 'SELECT') {
                        var matched = false;
                        for (var i = 0; i < el.options.length; i++) {
                            var optVal = el.options[i].value.toLowerCase();
                            var optText = el.options[i].text.toLowerCase();
                            var aiVal = val.toLowerCase();
                            if (optVal === aiVal || optText === aiVal ||
                                optVal === aiVal.replace(/\s*(only|required|status)\s*/gi,'').trim() ||
                                aiVal.indexOf(optVal) !== -1) {
                                el.selectedIndex = i;
                                matched = true;
                                filled++;
                                break;
                            }
                        }
                        if (!matched) { skipped.push(key + '=' + val); }
                    } else {
                        el.value = val;
                        filled++;
                    }
                });
                var msg = 'Model: ' + modelUsed + ' \u2014 Filled ' + filled + ' field(s). Review carefully \u2014 AI data may be approximate.';
                if (skipped.length) { msg += ' (Skipped: ' + skipped.join(', ') + ')'; }
                statusEl.textContent = msg;
            } catch(e) {
                statusEl.textContent = 'Could not parse JSON. See raw response above.';
            }
        })
        .catch(function(err) {
            clearTimeout(timeoutId);
            btn.disabled = false;
            if (err.name === 'AbortError') {
                statusEl.textContent = 'Request timed out (' + Math.round(timeoutMs/1000) + 's). Try switching to Grok in the chat widget, or try again.';
            } else {
                statusEl.textContent = 'Request failed: ' + err.message;
            }
        });
    }

    function encyAiMarkReference() {
        var refEl = document.querySelector('[name="reference"]');
        if (!refEl) { return; }
        var username = '[% c.session.username | html %]';
        var note = 'AI-generated, reviewed by ' + username;
        if (refEl.value && refEl.value.indexOf('AI-generated') === -1) {
            refEl.value = refEl.value + '\n' + note;
        } else if (!refEl.value) {
            refEl.value = note;
        }
    }

    window.encyAiFill = encyAiFill;
    window.encyAiMarkReference = encyAiMarkReference;
})();
</script>
[% END %]
