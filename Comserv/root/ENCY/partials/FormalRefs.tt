<div id="ency-formal-refs-section"></div>
<script>
(function() {
    function encyGetViewEntityInfo() {
        var path = window.location.pathname;
        // /ENCY/Animal/123, /ENCY/Drug/123, /ENCY/Constituent/123, etc.
        var m = path.match(/\/ENCY\/([A-Za-z]+)\/(\d+)/i);
        if (m) return { type: m[1].toLowerCase(), id: m[2] };
        // /ENCY/herb_detail/123
        m = path.match(/\/ENCY\/herb_detail\/(\d+)/i);
        if (m) return { type: 'herb', id: m[1] };
        return null;
    }

    function escHtml(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function encyLoadFormalRefs() {
        var info = encyGetViewEntityInfo();
        if (!info || !info.type || !info.id) return;
        var sec = document.getElementById('ency-formal-refs-section');
        if (!sec) return;

        fetch('/ENCY/api/entity_references?entity_type=' + encodeURIComponent(info.type) + '&entity_id=' + encodeURIComponent(info.id), { credentials: 'include' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.references || !data.references.length) return;
            var html = '<h3 style="margin-top:1.5em;border-top:1px solid var(--border-color, #ddd);padding-top:0.8em;">Cited References</h3>';
            html += '<div style="display:flex;flex-wrap:wrap;gap:0.4em;margin-top:0.5em;">';
            data.references.forEach(function(ref) {
                html += '<a href="/ENCY/Reference/' + ref.reference_id + '" target="_blank" '
                    + 'style="display:inline-block;padding:0.25em 0.7em;background:#e8f4f8;border:1px solid #4a90d9;'
                    + 'border-radius:12px;text-decoration:none;font-size:0.85em;color:#1a4a7a;" '
                    + 'title="' + escHtml(ref.author) + (ref.year ? ' (' + escHtml(ref.year) + ')' : '') + '">'
                    + '[' + ref.reference_id + '] ' + escHtml(ref.title)
                    + (ref.author ? ' <em style="font-weight:normal;">— ' + escHtml(ref.author) + '</em>' : '')
                    + (ref.year   ? ' <span style="color: var(--text-muted-color, #555);">(' + escHtml(ref.year) + ')</span>' : '')
                    + '</a>';
            });
            html += '</div>';
            sec.innerHTML = html;
        })
        .catch(function(){});
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', encyLoadFormalRefs);
    } else {
        encyLoadFormalRefs();
    }
})();
</script>
