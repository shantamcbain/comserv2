[% META
   title = "Herbs by Botanical Name - Encyclopedia of Biological Life"
   description = "Browse all herbs in the ENCY encyclopedia sorted by botanical name"
   roles = "public"
   TemplateType = "Application"
   category = "ENCY"
   page_version = "0.02"
   last_updated = "2026-04-02"
%]
[% PageVersion = 'ENCY/BotanicalNameView.tt,v 0.02 2026/04/02' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]
[% PROCESS 'ENCY/ImageHelper.tt' %]

[% IF c.flash.success_msg %]
<div class="alert alert-success">[% c.flash.success_msg | html %]</div>
[% END %]
[% IF c.flash.error_msg %]
<div class="alert alert-danger">[% c.flash.error_msg | html %]</div>
[% END %]





[% IF data.debug == 1 %]
 [%	ViewVersion %]
  [% embed  ('InheretedVariablesView') %]
[% END %]


	[% IF c.session.username %]

<h3 > Hello  [% first_name%]  [% last_name%]! Welcome to The Encyclopaedia of Biological life!</h3>
	  

	[% ELSE %]

	<h3>  Hello! Welcome to The Encyclopaedia of Biological life!</h3>

	[% END %]


<div ALIGN="center">
<A NAME="PageTop"></A>
</div>
     
        <h2>Herbs by Botanical name.</h2>
 <!-- Display the Add Herb button only for admin users -->
[% IF is_editor %]
    <a href="/ENCY/add_herb" class="btn btn-primary">Add Herb</a>
[% END %]

<form action="search" method="POST">
    <label for="search">Search our herbal Database:</label>
    <input type="text" id="search" name="search_string" value="">
    <input type="submit" value="Go">
</form>

<p>     <a href="ForumulaView"> Formulas.</a>

 <p> These Herbs are in the data base.
[% IF is_editor %]
    <a href="/ENCY/add_herb" class="btn btn-primary">Add new Herb</a>
    &nbsp;
    <button type="button" id="ncbi-bulk-btn" onclick="ncbiBulkLink()"
            style="background:#2a7ae2;color:#fff;border:none;padding:6px 14px;border-radius:4px;cursor:pointer;">
        Link all herbs to NCBI taxonomy
    </button>
    <div id="ncbi-bulk-panel" style="display:none;margin-top:0.8em;padding:0.8em;background:#f5f9ff;border:1px solid #c0d8f0;border-radius:4px;max-width:700px;">
        <strong>NCBI Bulk Link</strong>
        <div id="ncbi-bulk-status" style="margin:0.4em 0;color:#555;">Starting…</div>
        <div style="background:#e8e8e8;border-radius:3px;height:14px;width:100%;margin-bottom:0.5em;">
            <div id="ncbi-bulk-bar" style="background:#2a7ae2;height:14px;border-radius:3px;width:0%;transition:width 0.4s;"></div>
        </div>
        <div id="ncbi-bulk-log" style="font-size:0.82em;max-height:180px;overflow-y:auto;font-family:monospace;background:#fff;padding:0.4em;border:1px solid #ddd;border-radius:3px;"></div>
    </div>
    <script>
    function ncbiBulkLink() {
        var btn   = document.getElementById('ncbi-bulk-btn');
        var panel = document.getElementById('ncbi-bulk-panel');
        var bar   = document.getElementById('ncbi-bulk-bar');
        var status= document.getElementById('ncbi-bulk-status');
        var log   = document.getElementById('ncbi-bulk-log');
        btn.disabled = true;
        panel.style.display = 'block';
        var totalLinked = 0, totalNotFound = 0, totalErrors = 0, totalDone = 0, grandTotal = null;

        function runBatch() {
            status.textContent = 'Processing batch… (' + totalDone + ' done)';
            fetch('/ENCY/herb_ncbi_bulk_link', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'batch_size=10'
            })
            .then(function(r){ return r.json(); })
            .then(function(d) {
                if (!d.ok) { status.textContent = 'Error: ' + d.error; btn.disabled=false; return; }
                if (grandTotal === null) grandTotal = d.total_unlinked;
                totalLinked    += d.linked;
                totalNotFound  += d.not_found;
                totalErrors    += d.errors;
                totalDone      += d.processed;
                var pct = grandTotal > 0 ? Math.round(totalDone / grandTotal * 100) : 100;
                bar.style.width = Math.min(pct, 100) + '%';
                (d.details || []).forEach(function(r) {
                    var line = document.createElement('div');
                    var icon = r.status === 'linked' ? '✓' : r.status === 'not_found' ? '?' : '✗';
                    line.style.color = r.status === 'linked' ? '#267326' : r.status === 'not_found' ? '#888' : '#c00';
                    line.textContent = icon + ' ' + r.botanical_name + ': ' + r.message;
                    log.appendChild(line);
                    log.scrollTop = log.scrollHeight;
                });
                if (d.remaining > 0) {
                    status.textContent = totalDone + ' of ' + grandTotal + ' processed — ' + totalLinked + ' linked, ' + totalNotFound + ' not found, ' + totalErrors + ' errors. Continuing…';
                    setTimeout(runBatch, 500);
                } else {
                    bar.style.width = '100%';
                    status.textContent = 'Complete. ' + totalLinked + ' linked, ' + totalNotFound + ' not in NCBI, ' + totalErrors + ' errors. Reload the page to see updated taxonomy.';
                    btn.disabled = false;
                    btn.textContent = 'Re-run NCBI link';
                }
            })
            .catch(function(e) { status.textContent = 'Network error: ' + e; btn.disabled=false; });
        }
        runBatch();
    }
    </script>
[% END %]

<table>
   <tr>
        <th width="50%">Plant</th>
        <th width="50%">Image</th>
    </tr>

 [% FOREACH link IN herbal_data %]
    <tr>
        <td>
            <span style="font-size: 30px;"> Botanical Name:</span> [% link.botanical_name %]<br>
             <span style="font-size: 30px;">Common Name:</span> [% link.common_names %]<br>
             <span style="font-size: 30px;">Idententifing Character:</span> [% link.ident_character %]<br>
            <span style="font-size: 30px;"> Distribution:</span> [% link.distribution %]<br>
            <span style="font-size: 30px;" >Medical Uses:</span> [% link.medical_uses %]<br>
           <a href="/ENCY/herb_detail/[% link.record_id %]" title="details">Details</a>

        </td>
        <td>
            [% ency_img_tag(link.image, 300, 325) %]
        </td>
    </tr>
[% END %]
</table>
      
