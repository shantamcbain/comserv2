[% META
   title = "Diseases - Encyclopedia of Biological Life"
   description = "Browse all diseases in the ENCY encyclopedia"
   roles = "public"
   TemplateType = "Application"
   category = "ENCY"
   page_version = "0.01"
   last_updated = "2026-04-02"
%]
[% PageVersion = 'ENCY/DiseaseList.tt,v 0.01 2026/04/02' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

[% IF c.flash.success_msg %]
<div class="alert alert-success">[% c.flash.success_msg | html %]</div>
[% END %]
[% IF c.flash.error_msg %]
<div class="alert alert-danger">[% c.flash.error_msg | html %]</div>
[% END %]

<h1>Diseases</h1>

<p><a href="[% c.uri_for('/ENCY') %]">&larr; Back to Encyclopedia</a></p>

[% roles = c.session.roles;
   is_admin = 0;
   FOREACH r IN roles;
     IF r == 'admin'; is_admin = 1; END;
   END;
%]
[% IF is_admin %]
<a href="[% c.uri_for('/ENCY/Disease/add') %]" class="btn btn-primary">Add Disease</a>
[% END %]

<form method="get" action="[% c.uri_for('/ENCY/Disease') %]">
    <label>Host Type:
        <select name="host_type">
            <option value="">-- All --</option>
            <option value="human"[% IF host_type == 'human' %] selected="selected"[% END %]>Human</option>
            <option value="animal"[% IF host_type == 'animal' %] selected="selected"[% END %]>Animal</option>
            <option value="plant"[% IF host_type == 'plant' %] selected="selected"[% END %]>Plant</option>
            <option value="insect"[% IF host_type == 'insect' %] selected="selected"[% END %]>Insect</option>
        </select>
    </label>
    <label>Disease Type:
        <input type="text" name="disease_type" value="[% disease_type | html %]" size="20" />
    </label>
    <input type="submit" value="Filter" class="btn btn-default" />
    <a href="[% c.uri_for('/ENCY/Disease') %]">Clear</a>
</form>

[% IF diseases && diseases.size %]
<table border="1" cellpadding="4" cellspacing="0">
    <tr>
        <th>Common Name</th>
        <th>Disease Type</th>
        <th>Host Type</th>
        <th>ICD Code</th>
        <th></th>
    </tr>
    [% FOREACH disease IN diseases %]
    <tr>
        <td>[% disease.common_name | html %]</td>
        <td>[% disease.disease_type | html %]</td>
        <td>[% disease.host_type | html %]</td>
        <td>[% disease.icd_code | html %]</td>
        <td><a href="[% c.uri_for('/ENCY/Disease', disease.record_id) %]">Details</a></td>
    </tr>
    [% END %]
</table>
[% ELSE %]
<p>No diseases found in the database.</p>
[% END %]
