[%# ── AI SEARCH PANEL ────────────────────────────────────────── %]
<div class="ency-ai-panel">
  <strong>Ask AI</strong> — Can't find what you need in the database?
  <div class="ency-ai-search">
    <input type="text" id="ency-ai-query" placeholder="Ask about any herb, condition, ingredient, formula..." />
    <button class="btn-ai" type="button" onclick="encyAskAI()">Ask AI</button>
  </div>
</div>
<script>
function encyAskAI() {
    var q = document.getElementById('ency-ai-query').value.trim();
    if (!q) return;
    var ctx = '[% IF site_lc == "bmaster" %]bee health, bee forage plants, and apiary management[% ELSIF site_lc == "forager" %]wild plant foraging, edible and medicinal plants[% ELSIF site_lc == "usbm" %]the Universal System of Biological Medicine, herbal formulas, and multi-practitioner healthcare[% ELSE %]the Encyclopedia of Biological Life covering herbs, animals, diseases, constituents, and natural health[% END %]';
    var fullQuery = 'In the context of ' + ctx + ', tell me about: ' + q;

    var chatBtn  = document.getElementById('chat-button');
    var msgInput = document.getElementById('message-input');
    var sendBtn  = document.getElementById('send-message');

    if (chatBtn && msgInput) {
        if (chatBtn.style.display !== 'none') { chatBtn.click(); }
        setTimeout(function() {
            msgInput.value = fullQuery;
            msgInput.dispatchEvent(new Event('input'));
            msgInput.focus();
        }, 150);
    } else {
        window.open('/ai?prompt=' + encodeURIComponent(fullQuery), '_blank');
    }
}
document.getElementById('ency-ai-query').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') encyAskAI();
});
</script>

[%# ── ADMIN QUICK-ADD BAR ─────────────────────────────────────── %]
[% IF is_editor %]
<div class="ency-admin-bar">
  <strong>Admin:</strong>
  <a href="[% c.uri_for('/ENCY/Herb/add') %]">+ Herb</a> |
  <a href="[% c.uri_for('/ENCY/Animal/add') %]">+ Animal</a> |
  <a href="[% c.uri_for('/ENCY/Insect/add') %]">+ Insect</a> |
  <a href="[% c.uri_for('/ENCY/Disease/add') %]">+ Disease</a> |
  <a href="[% c.uri_for('/ENCY/Symptom/add') %]">+ Symptom</a> |
  <a href="[% c.uri_for('/ENCY/Constituent/add') %]">+ Constituent</a> |
  <a href="[% c.uri_for('/ENCY/Formula/add') %]">+ Formula</a> |
  <a href="[% c.uri_for('/ENCY/Drug/add') %]">+ Drug</a> |
  <a href="[% c.uri_for('/ENCY/Glossary/add') %]">+ Glossary Term</a>
</div>
[% END %]

[%# ── DISCLAIMER ──────────────────────────────────────────────── %]
<div class="ency-disclaimer">
  <p>All references to uses are for informational purposes only. Consult your healthcare practitioner team before using any products for your health. This applies to all treatments and therapies you may be considering.</p>
  <p>Last Updated: [% SiteLastUpdate | html %]</p>
</div>

</div>[%# end .ency-site-* %]

