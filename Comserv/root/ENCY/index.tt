[% META
   title = "Encyclopedia of Biological Life"
   description = "ENCY: A comprehensive reference for herbs, animals, insects, diseases, symptoms, constituents, and formulas"
   roles = "public"
   TemplateType = "Application"
   category = "ENCY"
   page_version = "0.04"
   last_updated = "2026-04-04"
%]
[% PageVersion = 'ENCY/index.tt,v 0.04 2026/04/04' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]
<link rel="stylesheet" href="/static/css/ency-index.css">

[% IF c.flash.success_msg %]
<div class="alert alert-success">[% c.flash.success_msg | html %]</div>
[% END %]
[% IF c.flash.error_msg %]
<div class="alert alert-danger">[% c.flash.error_msg | html %]</div>
[% END %]

[%# ── Resolve site context ────────────────────────────────────── %]
[% SET site = SiteName || c.stash.SiteName || c.session.SiteName || 'ENCY' %]
[% SET site_lc = site.lower %]

<div class="ency-site-[% site_lc | html %]">

[%# ── HERO — adapts per site ──────────────────────────────────── %]
<div class="ency-hero">
[% IF c.session.username %]
  <h2>Welcome back, [% c.session.first_name || c.session.username | html %]!</h2>
[% ELSE %]
  <h2>Welcome to
    [% IF site_lc == 'bmaster' %]
      Bee Health &amp; Forage Reference
    [% ELSIF site_lc == 'forager' %]
      The Forager's Plant Encyclopedia
    [% ELSIF site_lc == 'usbm' %]
      The Universal System of Biological Medicine
    [% ELSE %]
      The Encyclopedia of Biological Life
    [% END %]
  </h2>
[% END %]

[% IF site_lc == 'bmaster' %]
  <p>A specialist reference for beekeepers: bee forage plants, pollinator health, hive diseases, and the ecology of bees and the plants they depend on.</p>
[% ELSIF site_lc == 'forager' %]
  <p>Your guide to wild edible and medicinal plants — identification, harvesting seasons, preparation, and safe foraging practice.</p>
[% ELSIF site_lc == 'usbm' %]
  <p>ENCY is the encyclopedic reference library of the USBM system — covering herbs, formulas, constituents, diseases, symptoms, and the full multi-practitioner treatment perspective.</p>
[% ELSE %]
  <p>A comprehensive, evolving reference to biological life — herbs, animals, insects, diseases, symptoms, chemical constituents, herbal formulas, and the connections between them. Drawn from herbals, medical texts, scientific journals, growers, foragers, and herbalists.</p>
[% END %]
</div>

[%# ── UNIFIED SEARCH ──────────────────────────────────────────── %]
<form method="post" action="[% c.uri_for('/ENCY/search') %]" class="ency-search-form">
  <input type="text" name="search_string"
    placeholder="[% IF site_lc == 'bmaster' %]Search bee forage, bee diseases, pollinator plants...[% ELSIF site_lc == 'forager' %]Search plants, herbs, edibles, preparation...[% ELSE %]Search herbs, animals, insects, diseases, symptoms, constituents, formulas...[% END %]" />
  <button type="submit">Search</button>
</form>

