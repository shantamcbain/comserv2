[% META title = "Graft Calendar" %]
[% PageVersion = 'BMaster/graft_calendar.tt,v 0.02 2026/03/17 shanta Exp shanta' %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
    [% INCLUDE 'debug.tt' %]
[% END %]

<div class="app-container">

    <div class="page-header">
        <h1>Graft Calendar</h1>
    </div>

    <div class="content-container">
        <div class="content-primary">

            <div class="app-section">
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Graft #</th>
                                <th>Description / Event</th>
                            </tr>
                        </thead>
                        <tbody>
                            [% FOREACH event IN events %]
                            <tr>
                                <td>[% event.date | html %]</td>
                                <td>[% event.graft | html %]</td>
                                <td>[% event.event | html %]</td>
                            </tr>
                            [% END %]
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="app-section">
                <h2>Send Calendar by Email</h2>
                [% SET mailing_list = [
                    { value => 'anu_user_list@anucollective.beemaster.ca', label => 'ANU User List' },
                    { value => 'anubeekeeping@anucollective.beemaster.ca', label => 'ANU BMaster' },
                    { value => 'apis_discussion_beemaster@beemaster.ca', label => 'APIS Discussion BeeMaster' },
                    { value => 'beemaster@beemaster.ca', label => 'BeeMaster' },
                    { value => 'beetalklive@beemaster.ca', label => 'BeeTalk Live' },
                    { value => 'breeder@beemaster.ca', label => 'Breeder' }
                ]; %]
                <div class="form-container">
                    <form action="/mail/send_email" method="post" class="app-form">
                        <input type="hidden" name="calendar_data" value="[% calendar_data | uri %]">

                        <div class="form-section">
                            <div class="form-row">
                                <div class="form-field">
                                    <label for="from">From:</label>
                                    <input type="text" id="from" name="from" placeholder="Enter sender email address" class="form-input">
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-field">
                                    <label for="mailing_list">Mailing List:</label>
                                    <select id="mailing_list" name="mailing_list[]" multiple class="form-input">
                                        [% FOREACH item IN mailing_list %]
                                            <option value="[% item.value | html %]">[% item.label | html %]</option>
                                        [% END %]
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-field">
                                    <label for="custom_emails">Custom Emails (comma-separated):</label>
                                    <textarea id="custom_emails" name="custom_emails" class="form-input"></textarea>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-field">
                                    <label for="subject">Subject:</label>
                                    <textarea id="subject" name="subject" class="form-input"></textarea>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-field">
                                    <label for="body">Body:</label>
                                    <input type="text" id="body" name="body" placeholder="Enter message body" class="form-input">
                                </div>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">Send Calendar Email</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="page-footer">
                <div class="footer-actions">
                    <a href="/BMaster/Queens" class="btn btn-secondary">Back to Queen Rearing</a>
                    <a href="/BMaster" class="btn btn-secondary">Back to BMaster Home</a>
                </div>
            </div>

        </div>
    </div>

</div>
