            <li><a href="/Documentation/Z-100Plus">Z-100Plus Autotuner</a></li>
            <li><a href="/Documentation/WolfriverCoil">Wolfriver Coil Antenna</a></li>
        </ul>

        <h4>Test Equipment</h4>
        <ul>
            <li><a href="/Documentation/NanoVNA">NanoVNA-H Network Analyzer</a></li>
            <li><a href="/Documentation/HeathkitIM-2410">Heathkit Digital Frequency Counter IM-2410</a></li>
            <li><a href="/Documentation/Textronixtype422">Tektronix Type 422 Oscilloscope</a></li>
            <li><a href="/Documentation/BKModle2050">B&amp;K Model 2050 RF Generator</a></li>
        </ul>

        <h4>Modes of Operation</h4>
