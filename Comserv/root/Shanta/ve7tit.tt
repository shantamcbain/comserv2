            <li><a href="/Documentation/CW">CW</a></li>
            <li><a href="/Documentation/DigitalModes">Digital Modes</a>
                <ul>
                    <li><a href="/Documentation/SignalinkUSB">SignaLink USB Integrated USB Sound Card</a></li>
                </ul>
            </li>
            <li><a href="/Documentation/Voice">Voice communications</a></li>
        </ul>

        <h4>Electronics</h4>
