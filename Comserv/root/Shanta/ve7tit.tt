[% PageVersion = 'Shanta/ve7tit.tt,v 0.04 2026/03/17 shanta Exp shanta ' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<div class="app-container">

    [% IF username == 'Shanta' %]
    <div class="app-section">
        <h2>Welcome, [% firstname %]!</h2>
        <p><a href="/todo">My Todo List</a></p>
    </div>
    [% ELSIF username %]
    <div class="app-section">
        <h3>Hello [% firstname %] [% lastname %]! Welcome to VE7TIT Shack!</h3>
    </div>
    [% END %]

    <div class="app-section">
        <p>We are proud to sponsor <a href="https://usbm.ca" target="_blank">The Universal School of Biological Life Site</a>.</p>
    </div>

    <div class="app-section">
        <h3>Our Current List of Equipment</h3>

        <h4>Radio Equipment</h4>
        <ul>
            <li><a href="/Documentation/FT-897">Yaesu HT/VHF/UHF all mode transceiver FT-897</a></li>
            <li><a href="/Documentation/FT-891">Yaesu HT/50MHz transceiver FT-891</a></li>
            <li><a href="/Documentation/Baofeng">Baofeng</a> — only used for back-country work as they transmit too widely and will interfere with another radio on nearby frequencies.</li>
            <li><a href="/Documentation/IC-2at">ICOM IC-2AT</a></li>
            <li><a href="/Documentation/IC-H10">ICOM IC-H10</a></li>
            <li><a href="/Documentation/IC-F3-2">ICOM IC-F3-2</a></li>
            <li><a href="/Documentation/TaitTP8110B-B100">Tait TP8110B-B100</a></li>
        </ul>

        <h4>Antenna Equipment</h4>
