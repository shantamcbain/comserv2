[% PageVersion = 'user/profile.tt,v 0.02 2026/02/22 shanta Exp shanta ' %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

[% META title = 'User Profile' %]

<!-- Main Application Container -->
<div class="app-container">
    
    <!-- Page Header -->
    <div class="page-header">
        <h1>User Profile</h1>
        <h2 class="page-subtitle">View and manage your account information</h2>
    </div>
    
    <!-- Main Content Area -->
    <div class="content-container">
        
        <!-- Primary Content Section -->
        <div class="content-primary">
            
            <!-- Account Information Section -->
            <div class="content-section">
                <h3>Account Information</h3>
                
                <div class="data-container">
                    <table class="data-table">
                        <tbody>
                            <tr>
                                <td><strong>Username:</strong></td>
                                <td>[% user.username | html %]</td>
                            </tr>
                            <tr>
                                <td><strong>Name:</strong></td>
                                <td>[% user.first_name | html %] [% user.last_name | html %]</td>
                            </tr>
                            <tr>
                                <td><strong>Email:</strong></td>
                                <td>[% user.email | html %]</td>
                            </tr>
                            <tr>
                                <td><strong>Status:</strong></td>
                                <td>
                                    [% SET user_status = user.status || 'active' %]
                                    [% IF user_status == 'active' %]
                                        <span class="badge-success">[% user_status | ucfirst %]</span>
                                    [% ELSIF user_status == 'suspended' %]
                                        <span class="badge-danger">[% user_status | ucfirst %]</span>
                                    [% ELSE %]
                                        <span class="badge-warning">[% user_status | ucfirst %]</span>
                                    [% END %]
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Roles:</strong></td>
                                <td>
                                    [% IF user.roles && user.roles.size %]
                                        [% FOREACH role IN user.roles %]
                                            <span class="badge-primary">[% role | html %]</span>
                                        [% END %]
                                    [% ELSE %]
                                        <span class="badge-primary">normal</span>
                                    [% END %]
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- Site Access Section -->
            [% IF user.site_roles && user.site_roles.size > 0 %]
            <div class="content-section">
                <h3>Site Access</h3>
                
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Site Name</th>
                                <th>Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            [% FOREACH site_role IN user.site_roles %]
                            <tr>
                                <td>[% site_role.sitename | html %]</td>
                                <td><span class="badge-primary">[% site_role.role_name | html %]</span></td>
                            </tr>
                            [% END %]
                        </tbody>
                    </table>
                </div>
            </div>
            [% END %]
            
            <!-- Profile Actions -->
            <div class="form-actions">
                <a href="[% c.uri_for('/user/settings') %]" class="btn btn-primary">Edit Profile</a>
                <a href="[% c.uri_for('/user/change_password') %]" class="btn btn-secondary">Change Password</a>
            </div>
            
        </div>
        
    </div>
    
</div>
