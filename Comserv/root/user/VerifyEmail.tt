[% PageVersion = 'verify_email.tt,v 0.01 2026/02/21 AI Assistant Exp AI Assistant ' %]
[% IF c.session.debug_mode == 1 %]
  [% PageVersion %]

[% END %]

<h2>Create Account - Step 2 of 3</h2>

<div class="info-box">
    <p><strong>A verification code has been sent to your email address.</strong></p>
    <p>Please check your inbox and enter the 6-digit code below.</p>
    <p style="margin-top: 10px;"><em>Tip: If you don't see the email, please check your spam/junk folder.</em></p>
</div>

[% IF c.stash.error_msg %]
    <p class="error">[% c.stash.error_msg %]</p>
[% END %]

<form method="post" action="/user/verify_email">
    <label for="code">Verification Code (6 digits)</label>
    <input type="text" id="code" name="code" maxlength="6" pattern="\d{6}" placeholder="000000" required><br>

    <input type="submit" value="Verify">
</form>

<p><a href="/user/register">Start over</a></p>

<style>
    .error {
        color: red;
        font-weight: bold;
        padding: 10px;
        background: #ffe6e6;
        border: 1px solid red;
        border-radius: 4px;
        margin-bottom: 15px;
    }
    
    .info-box {
        background: #e6f3ff;
        border: 1px solid #007bff;
        border-radius: 4px;
        padding: 15px;
        margin-bottom: 20px;
    }
    
    .info-box strong {
        color: #0056b3;
    }
    
    form {
        max-width: 400px;
        margin: 20px 0;
    }
    
    label {
        display: block;
        margin-top: 10px;
        font-weight: bold;
    }
    
    input[type="text"] {
        width: 100%;
        padding: 8px;
        margin-top: 5px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 18px;
        text-align: center;
        letter-spacing: 5px;
    }
    
    input[type="submit"] {
        margin-top: 15px;
        padding: 10px 20px;
        background: #28a745;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }
    
    input[type="submit"]:hover {
        background: #218838;
    }
</style>
