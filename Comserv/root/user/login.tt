[% META
   title = "Login"
   description = "Sign in to your account"
   roles = ""
   TemplateType = "Application"
   category = "User"
   page_version = "0.02"
   last_updated = "2026-02-23"
%]
[% PageVersion = 'user/login.tt,v 0.02 2026/02/23 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">

    <div class="page-header">
        <h1>Sign In</h1>
        <h2 class="page-subtitle">Enter your credentials to access your account</h2>
    </div>

    <div class="content-container">

        <div class="content-primary">

            [% IF c.session.success_msg %]
                <div class="success">[% c.session.success_msg %]</div>
            [% END %]
            [% IF c.flash.success_msg %]
                <div class="success">[% c.flash.success_msg %]</div>
            [% END %]
            [% IF c.flash.error_msg %]
                <div class="error">[% c.flash.error_msg %]</div>
            [% END %]
            [% IF c.stash.error_msg %]
                <div class="error">[% c.stash.error_msg %]</div>
            [% END %]

            <div class="form-container">
                <form method="POST" action="/user/do_login" class="app-form">
                    <input type="hidden" name="form_source" value="login_form">

                    <div class="form-section">
                        <div class="form-row">
                            <div class="form-field">
                                <label for="username">Username or Email</label>
                                <input type="text" id="username" name="username" class="form-input" required autofocus>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="password">Password</label>
                                <input type="password" id="password" name="password" class="form-input">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="verification_code">Verification Code <small>(if you received one by email)</small></label>
                                <input type="text" id="verification_code" name="verification_code" class="form-input"
                                       maxlength="6" pattern="\d{6}" placeholder="6-digit code"
                                       autocomplete="one-time-code">
                                <small style="color:#666;">Enter your 6-digit code <em>instead of</em> your password if this is your first time logging in.</small>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Sign In</button>
                        <a href="/user/register" class="btn btn-secondary">Create Account</a>
                    </div>

                    <div style="margin-top: 12px; text-align: center;">
                        <a href="/user/change_password_request">Forgot your password?</a>
                    </div>

                </form>
            </div>

        </div>

    </div>

</div>
