[% META title = 'Reset Password' %]
[% PageVersion = 'reset_password.tt,v 0.02 2026/02/22 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">
    
    <div class="page-header">
        <h1>Reset Password</h1>
        <h2 class="page-subtitle">Enter your new password below</h2>
    </div>
    
    <div class="content-container">
        
        <div class="content-primary">
            
            [% IF c.flash.success_msg %]
                <div class="success">[% c.flash.success_msg %]</div>
            [% END %]

            [% IF c.flash.error_msg %]
                <div class="error">[% c.flash.error_msg %]</div>
            [% END %]

            [% IF c.stash.error_msg %]
                <div class="error">[% c.stash.error_msg %]</div>
            [% END %]

            [% IF debug_mode == 1 && c.session.reset_token %]
                <div class="alert-info">
                    <strong>Testing Mode:</strong> Reset token from session: [% c.session.reset_token %]<br>
                    Email: [% c.session.reset_email %]<br>
                    <a href="[% c.uri_for('/user/reset_password', { token => c.session.reset_token }) %]">Use this token</a>
                </div>
            [% END %]

            [% IF c.stash.token %]
            <div class="form-container">
                <form method="post" action="[% c.uri_for('/user/reset_password', { token => c.stash.token }) %]" class="app-form">
                    <input type="hidden" name="token" value="[% c.stash.token %]">
                    
                    <div class="form-section">
                        <div class="form-row">
                            <div class="form-field">
                                <label for="new_password">New Password (minimum 8 characters)</label>
                                <input type="password" id="new_password" name="new_password" class="form-input" minlength="8" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="password_confirm">Confirm New Password</label>
                                <input type="password" id="password_confirm" name="password_confirm" class="form-input" minlength="8" required>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Reset Password</button>
                    </div>
                </form>
            </div>
            [% END %]
            
            <div class="page-footer">
                <div class="footer-actions">
                    <a href="[% c.uri_for('/user/login') %]" class="btn btn-secondary">Back to Login</a>
                    <a href="[% c.uri_for('/user/forgot_password') %]" class="btn btn-secondary">Request New Reset Link</a>
                </div>
            </div>
            
        </div>
        
    </div>
    
</div>
