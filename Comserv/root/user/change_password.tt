[% META
   title = "Change Password"
   description = "Change your account password"
   roles = ""
   TemplateType = "Application"
   category = "User"
   page_version = "0.03"
   last_updated = "2026-02-23"
%]
[% PageVersion = 'user/change_password.tt,v 0.03 2026/02/23 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">

    <div class="page-header">
        <h1>Change Password</h1>
        <h2 class="page-subtitle">Enter your current password and choose a new one</h2>
    </div>

    <div class="content-container">

        <div class="content-primary">

            [% IF c.flash.success_msg %]
                <div class="success">[% c.flash.success_msg %]</div>
            [% END %]
            [% IF c.flash.error_msg %]
                <div class="error">[% c.flash.error_msg %]</div>
            [% END %]
            [% IF c.stash.error_msg %]
                <div class="error">[% c.stash.error_msg %]</div>
            [% END %]

            <div class="form-container">
                <form method="POST" action="/user/do_change_password" class="app-form">
                    <input type="hidden" name="csrf_token" value="[% csrf_token | html %]">

                    <div class="form-section">
                        <div class="form-row">
                            <div class="form-field">
                                <label for="current_password">Current Password</label>
                                <input type="password" id="current_password" name="current_password"
                                       class="form-input" required autofocus>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="new_password">New Password <small>(minimum 8 characters)</small></label>
                                <input type="password" id="new_password" name="new_password"
                                       class="form-input" minlength="8" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="new_password_confirm">Confirm New Password</label>
                                <input type="password" id="new_password_confirm" name="new_password_confirm"
                                       class="form-input" minlength="8" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Change Password</button>
                        <a href="/user/profile" class="btn btn-secondary">Cancel</a>
                    </div>

                </form>
            </div>

        </div>

    </div>

</div>
