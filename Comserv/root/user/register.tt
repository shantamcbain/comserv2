[% META
   title = "Create Account"
   description = "Register a new account - Step 1 of 3"
   roles = ""
   TemplateType = "Application"
   category = "User"
   page_version = "0.03"
   last_updated = "2026-02-23"
%]
[% PageVersion = 'user/register.tt,v 0.03 2026/02/23 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">

    <div class="page-header">
        <h1>Create Account</h1>
        <h2 class="page-subtitle">Step 1 of 3 — Enter your username and email</h2>
        <p class="page-subtitle" style="font-size: var(--font-size-small); margin-top: 4px;">
            <a href="/Documentation/UserRegistrationGuide" target="_blank" style="color: var(--link-color);">&#9432; Registration Help &amp; Tutorial</a>
        </p>
    </div>

    <div class="content-container">

        <div class="content-primary">

            [% IF c.stash.error_msg %]
                <div class="error">[% c.stash.error_msg %]</div>
            [% END %]

            <div class="form-container">
                <form method="POST" action="/user/do_create_account" class="app-form">
                    <input type="hidden" name="csrf_token" value="[% csrf_token | html %]">

                    <div class="form-section">
                        <div class="form-row">
                            <div class="form-field">
                                <label for="username">Username</label>
                                <input type="text" id="username" name="username"
                                       value="[% username | html %]" class="form-input" required autofocus>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="email">Email</label>
                                <input type="email" id="email" name="email"
                                       value="[% email | html %]" class="form-input" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Continue</button>
                        <a href="/user/login" class="btn btn-secondary">Already have an account?</a>
                    </div>

                </form>
            </div>

        </div>

    </div>

</div>
