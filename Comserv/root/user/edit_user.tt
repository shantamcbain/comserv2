[% META
   title = "Edit User"
   description = "Admin interface for editing user account details"
   roles = "admin"
   TemplateType = "Application"
   category = "User"
   page_version = "0.04"
   last_updated = "2026-02-23"
%]
[% PageVersion = 'user/edit_user.tt,v 0.04 2026/02/23 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

[% SET current_roles = {} %]
[% IF user.roles %]
    [% FOREACH r IN user.roles.split(',') %]
        [% r = r.trim %]
        [% current_roles.$r = 1 %]
    [% END %]
[% END %]

<div class="app-container">

    <div class="page-header">
        <h1>Edit User</h1>
        <h2 class="page-subtitle">[% user.username || user.email | html %]</h2>
    </div>

    <div class="content-container">

        <div class="content-primary">

            [% IF error_msg %]
                <div class="error">[% error_msg %]</div>
            [% END %]
            [% IF c.flash.success_msg %]
                <div class="success">[% c.flash.success_msg %]</div>
            [% END %]

            <div class="form-container">
                <form method="POST" action="[% c.uri_for('/user/do_edit_user', user.id) %]" class="app-form">
                    <input type="hidden" name="csrf_token" value="[% csrf_token | html %]">

                    <div class="form-section">
                        <h3>Account Details</h3>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="username">Username</label>
                                <input type="text" id="username" name="username"
                                       value="[% user.username | html %]" class="form-input">
                            </div>
                            <div class="form-field">
                                <label for="email">Email *</label>
                                <input type="email" id="email" name="email"
                                       value="[% user.email | html %]" class="form-input" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="first_name">First Name</label>
                                <input type="text" id="first_name" name="first_name"
                                       value="[% user.first_name | html %]" class="form-input">
                            </div>
                            <div class="form-field">
                                <label for="last_name">Last Name</label>
                                <input type="text" id="last_name" name="last_name"
                                       value="[% user.last_name | html %]" class="form-input">
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3>Roles</h3>

                        <div class="form-field">
                            [% IF available_roles.default_roles.size > 0 %]
                            <div class="check-pill-group">
                                [% FOREACH role IN available_roles.default_roles %]
                                <label class="check-pill">
                                    <input type="checkbox" name="roles" value="[% role | html %]"
                                        [% IF current_roles.$role %]checked[% END %]>
                                    [% role | ucfirst | html %]
                                </label>
                                [% END %]
                            </div>
                            [% END %]

                            [% IF available_roles.site_roles.size > 0 %]
                            <div style="margin-top: 8px;">
                                <small><strong>Site-Specific Roles:</strong></small>
                                <div class="check-pill-group">
                                    [% FOREACH sr IN available_roles.site_roles %]
                                    [% SET sr_name = sr.name %]
                                    <label class="check-pill">
                                        <input type="checkbox" name="roles" value="[% sr.name | html %]"
                                            [% IF current_roles.$sr_name %]checked[% END %]>
                                        [% sr.name | html %][% IF is_csc_admin %] <small>([% sr.sitename | html %])</small>[% END %]
                                    </label>
                                    [% END %]
                                </div>
                            </div>
                            [% END %]
                        </div>
                    </div>

                    <div class="form-section">
                        <h3>Site Access</h3>
                        <p>Select sites this user should have access to. Removing a site revokes all their roles for that site.</p>

                        <div class="form-field">
                            [% IF all_sites.size > 0 %]
                            <div class="check-pill-group">
                                [% FOREACH site IN all_sites %]
                                [% SET sid = site.id %]
                                <label class="check-pill">
                                    <input type="checkbox" name="sitenames" value="[% site.name | html %]"
                                        [% IF user_site_ids.item(sid) %]checked[% END %]>
                                    [% site.name | html %]
                                </label>
                                [% END %]
                            </div>
                            [% ELSE %]
                            <p class="empty-state">No sites available.</p>
                            [% END %]
                        </div>
                    </div>

                    <div class="form-section">
                        <h3>Status</h3>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="status">Account Status</label>
                                <select id="status" name="status" class="form-input">
                                    [% SET cur_status = user.status || 'active' %]
                                    <option value="active"               [% IF cur_status == 'active'               %]selected[% END %]>Active</option>
                                    <option value="suspended"            [% IF cur_status == 'suspended'            %]selected[% END %]>Suspended</option>
                                    <option value="pending_verification" [% IF cur_status == 'pending_verification' %]selected[% END %]>Pending Verification</option>
                                    <option value="pending_setup"        [% IF cur_status == 'pending_setup'        %]selected[% END %]>Pending Setup</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a href="[% c.uri_for('/admin/users') %]" class="btn btn-secondary">Cancel</a>
                    </div>

                </form>
            </div>

            <div class="admin-actions-panel">
                <h3>Admin Actions</h3>
                <p class="user-status-line">
                    Account status: <strong>[% user.status || 'active' | html %]</strong>
                    &nbsp;·&nbsp; Email: <strong>[% user.email | html %]</strong>
                </p>

                [% SET cur_uid = user.id %]
                [% SET return_here = c.uri_for('/user/edit_user', cur_uid) %]

                [% IF user.status == 'pending_verification' OR user.status == 'pending_setup' %]
                <div class="admin-action-row">
                    <div>
                        <strong>Resend Verification Code</strong>
                        <p>Send a fresh 6-digit verification code to the user's email address.</p>
                    </div>
                    <a href="[% c.uri_for('/user/admin_resend_verification', { user_id = cur_uid, return_to = return_here }) %]"
                       class="btn btn-warning"
                       onclick="return confirm('Send a new verification code to [% user.email | html %]?')">
                        Send Verification Code
                    </a>
                </div>
                [% END %]

                <div class="admin-action-row">
                    <div>
                        <strong>Send Password Reset Email</strong>
                        <p>Send a secure password-reset link to the user's email address.</p>
                    </div>
                    <a href="[% c.uri_for('/user/admin_send_password_reset', { user_id = cur_uid, return_to = return_here }) %]"
                       class="btn btn-secondary"
                       onclick="return confirm('Send a password reset email to [% user.email | html %]?')">
                        Send Reset Email
                    </a>
                </div>
            </div>

        </div>

    </div>

</div>

<style>
.admin-actions-panel {
    margin-top: 2rem;
    padding: 1.25rem;
    background: #f0f4ff;
    border: 1px solid #b0c4de;
    border-radius: 6px;
}
.admin-actions-panel h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.05rem;
}
.user-status-line {
    margin: 0 0 1rem 0;
    font-size: 0.95rem;
    color: #444;
}
.admin-action-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid #c8d8f0;
}
.admin-action-row > div p {
    margin: 2px 0 0 0;
    font-size: 0.88rem;
    color: #555;
}
.btn-warning {
    background: #f0a020;
    color: white;
    border: none;
    padding: 8px 14px;
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    font-size: 0.9rem;
}
.btn-warning:hover { background: #d08800; color: white; }
.check-pill-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 6px;
}
.check-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    border: 1px solid #bbb;
    border-radius: 20px;
    background: #f8f9fa;
    cursor: pointer;
    font-size: 0.9em;
    transition: background 0.15s, border-color 0.15s;
    user-select: none;
}
.check-pill:hover {
    background: #e9ecef;
    border-color: #888;
}
.check-pill input[type="checkbox"] {
    margin: 0;
    cursor: pointer;
}
.check-pill:has(input:checked) {
    background: #d0e8ff;
    border-color: #0066cc;
    font-weight: bold;
}
</style>
