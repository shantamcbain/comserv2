[% META
   title = "Forgot Password"
   description = "Request a password reset link"
   roles = ""
   TemplateType = "Application"
   category = "User"
   page_version = "0.02"
   last_updated = "2026-02-25"
%]
[% PageVersion = 'user/forgot_password.tt,v 0.02 2026/02/25 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">

    <div class="page-header">
        <h1>Forgot Password</h1>
        <h2 class="page-subtitle">Enter your username or email and we'll send reset instructions</h2>
    </div>

    <div class="content-container">

        <div class="content-primary">

            [% IF c.flash.error_msg %]
                <div class="error">[% c.flash.error_msg | html %]</div>
            [% END %]
            [% IF c.stash.error_msg %]
                <div class="error">[% c.stash.error_msg | html %]</div>
            [% END %]
            [% IF c.stash.success_msg %]
                <div class="success">[% c.stash.success_msg | html %]</div>
                [% IF debug_mode == 1 && c.session.reset_token %]
                    <div class="content-section" style="margin-top: 12px;">
                        <strong>Testing Mode — Reset Token:</strong><br>
                        Token: [% c.session.reset_token | html %]<br>
                        Email: [% c.session.reset_email | html %]<br>
                        <a href="[% c.uri_for('/user/reset_password', { token => c.session.reset_token }) %]">Click here to reset password</a>
                    </div>
                [% END %]
            [% END %]

            <div class="form-container">
                <form method="POST" action="[% c.uri_for('/user/forgot_password') %]" class="app-form">
                    <input type="hidden" name="csrf_token" value="[% csrf_token | html %]">

                    <div class="form-section">
                        <div class="form-row">
                            <div class="form-field">
                                <label for="email">Username or Email</label>
                                <input type="text" id="email" name="email" class="form-input"
                                       value="[% prefill_email | html %]"
                                       required autofocus autocomplete="email">
                                <small style="color: var(--text-muted-color, #666); display: block; margin-top: 4px;">
                                    Enter the username or email address associated with your account.
                                </small>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Send Reset Instructions</button>
                        <a href="[% c.uri_for('/user/login') %]" class="btn btn-secondary">Back to Login</a>
                    </div>

                </form>
            </div>

        </div>

    </div>

</div>
