[% META
   title = "System Cost Tracking"
   description = "Track operational costs vs membership revenue"
   roles = "admin,site_admin"
   TemplateType = "Application"
   category = "Membership"
   page_version = "0.02"
   last_updated = "2026-03-18"
%]
[% PageVersion = 'membership/admin/CostTracking.tt,v 0.02 2026/03/18' %]
[% IF debug_mode == 1 %][% PageVersion %][% END %]

[% IF error_msg %]<div class="error">[% error_msg | html %]</div>[% END %]
[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
[% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

<div class="app-container">
  <div class="page-header">
    <h1>System Cost Tracking</h1>
    [% IF site %]<p>Site: <strong>[% site.name | html %]</strong></p>[% END %]
  </div>

  <div class="content-container">
    <div class="content-primary">

      <div class="content-section">
        <a href="[% c.uri_for('/membership/admin') %]" class="btn btn-secondary">← Back to Admin</a>
      </div>

      <div class="content-section">
        <h2>Financial Summary</h2>
        <div class="form-row">
          <div class="form-field">
            <strong>Total Logged Costs (period)</strong>
            <div class="stat-value [% IF total_cost > 0 %]text-danger[% END %]">
              [% total_cost %] [% default_currency || 'CAD' %]
            </div>
          </div>
          <div class="form-field">
            <strong>Est. Monthly Revenue</strong>
            <div class="stat-value [% IF total_revenue > 0 %]text-success[% END %]">
              [% total_revenue %] [% default_currency || 'CAD' %]
            </div>
          </div>
          <div class="form-field">
            <strong>Net (Revenue − Costs)</strong>
            <div class="stat-value [% IF net >= 0 %]text-success[% ELSE %]text-danger[% END %]">
              [% net %] [% default_currency || 'CAD' %]
            </div>
          </div>
          [% IF monthly_cost_per_member %]
          <div class="form-field">
            <strong>Monthly Cost / Active Member</strong>
            <div class="stat-value">
              [% monthly_cost_per_member %] [% default_currency || 'CAD' %]
            </div>
          </div>
          [% END %]
          [% IF break_even_members %]
          <div class="form-field">
            <strong>Paid Members Needed to Break Even</strong>
            <div class="stat-value [% IF active_member_count >= break_even_members %]text-success[% ELSE %]text-danger[% END %]">
              [% break_even_members %]
              <small style="font-size:0.7em;display:block;">
                ([% active_member_count %] active now — based on avg $[% avg_plan_price || 15 %]/mo Pro rate + [% overhead_pct %]% overhead)
              </small>
            </div>
          </div>
          [% END %]
          [% IF benefactor_total_cad %]
          <div class="form-field">
            <strong>Total Benefactor Contributions</strong>
            <div class="stat-value text-success">
              [% benefactor_total_cad %] [% default_currency || 'CAD' %]
            </div>
          </div>
          [% END %]
        </div>
      </div>

      <div class="content-section">
        <h2>Benefactor Contributions — Shanta McBain</h2>
        <p style="font-size:0.9em;color:#555;">
          Shanta is the founding benefactor of this platform: she covers all operating expenses,
          performs all programming and system administration, and donates her labour. Each logged
          contribution is credited to her internal coin account at 1 coin = 1 CAD.
        </p>
        <div style="margin-bottom:0.75rem;">
          <a href="[% c.uri_for('/membership/admin/benefactor_contribution') %]" class="btn btn-primary">
            Log a Contribution
          </a>
        </div>
        [% IF benefactor_contribs.size %]
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Benefactor</th>
                <th>Type</th>
                <th>Description</th>
                <th>Value (CAD)</th>
                <th>Hours</th>
                <th>Coins Credited</th>
              </tr>
            </thead>
            <tbody>
              [% FOREACH bc IN benefactor_contribs %]
              <tr>
                <td>[% bc.contribution_date | html %]</td>
                <td>[% bc.user.first_name | html %] [% bc.user.last_name | html %]</td>
                <td>[% bc.contribution_type | html %]</td>
                <td>[% bc.description | html %]</td>
                <td>[% bc.amount_cad %]</td>
                <td>[% bc.hours > 0 ? bc.hours : '—' %]</td>
                <td>[% bc.coins_credited %]</td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
        [% ELSE %]
        <p class="empty-state">No benefactor contributions logged yet.</p>
        [% END %]
      </div>

      [% IF category_totals %]
      <div class="content-section">
        <h2>Cost Breakdown by Category</h2>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr><th>Category Group</th><th>Monthly Equivalent</th><th>% of Total</th></tr>
            </thead>
            <tbody>
              [% FOREACH ct IN category_totals %]
              <tr>
                <td>[% ct.label | html %]</td>
                <td>[% ct.monthly %] [% default_currency || 'CAD' %]</td>
                <td>
                  [% IF total_monthly_cost > 0 %]
                    [% (ct.monthly / total_monthly_cost * 100) | format('%d') %]%
                  [% ELSE %]—[% END %]
                </td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
      </div>
      [% END %]

      [% IF pricing_recommendation %]
      <div class="content-section">
        <h2>Pricing Recommendation</h2>
        <p style="color:#666;font-size:0.9em;">
          Based on [% active_member_count || 0 %] active members and [% total_monthly_cost %] [% default_currency || 'CAD' %]/mo in costs.
          Overhead factor: [% overhead_pct || 30 %]% added for sustainability.
        </p>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Plan</th>
                <th>Suggested Min. Monthly</th>
                <th>Suggested Annual</th>
                <th>Notes</th>
              </tr>
            </thead>
            <tbody>
              [% FOREACH pr IN pricing_recommendation %]
              <tr>
                <td><strong>[% pr.name | html %]</strong></td>
                <td>[% pr.monthly %] [% default_currency || 'CAD' %]</td>
                <td>[% pr.annual %] [% default_currency || 'CAD' %]</td>
                <td style="font-size:0.85em;color:#666;">[% pr.notes | html %]</td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
      </div>
      [% END %]

      <div class="content-section">
        <h2>Add Cost Entry</h2>
        <form method="post" action="[% c.uri_for('/membership/admin/cost_tracking') %]">
          <div class="form-row">
            <div class="form-field">
              <label for="cost_category">Category *</label>
              <select id="cost_category" name="cost_category" required>
                <option value="">-- Select Category --</option>

                <optgroup label="Facility &amp; Power">
                  <option value="power_electricity">Electricity / Power Bill</option>
                  <option value="cooling_hvac">Cooling / HVAC</option>
                  <option value="server_room_rent">Server Room / Office Rent</option>
                  <option value="hardware_ups">UPS / Power Conditioning</option>
                </optgroup>

                <optgroup label="Hardware">
                  <option value="hardware_servers">Servers (purchase / lease)</option>
                  <option value="hardware_network">Network Equipment (switches, routers, cables)</option>
                  <option value="hardware_storage">Storage / NAS / Backup Drives</option>
                  <option value="hardware_workstations">Workstations / Dev Hardware</option>
                </optgroup>

                <optgroup label="Connectivity">
                  <option value="isp_primary">ISP — Primary Internet Connection</option>
                  <option value="isp_backup">ISP — Backup / Failover Connection</option>
                  <option value="ip_addressing">Static IP / IP Block</option>
                  <option value="cdn">CDN / Content Delivery</option>
                </optgroup>

                <optgroup label="Hosting &amp; Domains">
                  <option value="hosting_cloud">Cloud / VPS Hosting (AWS, etc.)</option>
                  <option value="domain_registration">Domain Registration / Renewal</option>
                  <option value="ssl_certificates">SSL / TLS Certificates</option>
                  <option value="backup_services">Offsite Backup Services</option>
                </optgroup>

                <optgroup label="AI &amp; Compute">
                  <option value="ai_ollama_gpu">Ollama / Local AI GPU Compute</option>
                  <option value="ai_xai">xAI (Grok) API</option>
                  <option value="ai_openai">OpenAI API</option>
                  <option value="ai_anthropic">Anthropic (Claude) API</option>
                  <option value="ai_other">Other AI / ML API</option>
                </optgroup>

                <optgroup label="Software &amp; Licensing">
                  <option value="software_os">OS / Server Licenses</option>
                  <option value="software_licenses">Software Subscriptions / Licenses</option>
                  <option value="software_monitoring">Monitoring &amp; Alerting Tools</option>
                  <option value="software_security">Security / Antivirus / WAF</option>
                </optgroup>

                <optgroup label="Communication">
                  <option value="email_service">Email Service (hosting / relay)</option>
                  <option value="sms_notifications">SMS / Push Notification Service</option>
                </optgroup>

                <optgroup label="Personnel &amp; Services">
                  <option value="programming_labor">Programming / Development</option>
                  <option value="sysadmin_labor">System Administration</option>
                  <option value="customer_support">Customer Support</option>
                  <option value="accounting_legal">Accounting / Legal</option>
                </optgroup>

                <optgroup label="Compliance &amp; Risk">
                  <option value="insurance">Business / Cyber Insurance</option>
                  <option value="security_audit">Security Audit / Penetration Testing</option>
                </optgroup>

                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-field">
              <label for="amount">Amount *</label>
              <input type="number" id="amount" name="amount" step="0.01" min="0" required>
            </div>
            <div class="form-field">
              <label for="currency">Currency</label>
              <select id="currency" name="currency">
                <option value="CAD">CAD</option>
                <option value="USD">USD</option>
                <option value="EUR">EUR</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="period_start">Period Start *</label>
              <input type="date" id="period_start" name="period_start" required>
            </div>
            <div class="form-field">
              <label for="period_end">Period End *</label>
              <input type="date" id="period_end" name="period_end" required>
            </div>
            <div class="form-field">
              <label><input type="checkbox" name="is_recurring" value="1"> Recurring Monthly</label>
            </div>
            <div class="form-field">
              <label><input type="checkbox" name="is_global" value="1"> Global (shared across all sites)</label>
            </div>
          </div>
          <div class="form-row">
            <div class="form-field">
              <label for="vendor">Vendor</label>
              <input type="text" id="vendor" name="vendor" placeholder="e.g. Shaw Business, xAI, Namecheap">
            </div>
            <div class="form-field">
              <label for="invoice_reference">Invoice / Reference</label>
              <input type="text" id="invoice_reference" name="invoice_reference">
            </div>
          </div>
          <div class="form-field">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="2"
              placeholder="e.g. Monthly Shaw Business fiber 300/300 Mbps — server room feed"></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Add Cost Entry</button>
        </form>
      </div>

      <div class="content-section">
        <h2>Cost History</h2>
        [% IF costs.size %]
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Category</th>
                <th>Description</th>
                <th>Amount</th>
                <th>Period</th>
                <th>Recurring</th>
                <th>Vendor</th>
                <th>Scope</th>
              </tr>
            </thead>
            <tbody>
              [% FOREACH cost IN costs %]
              <tr>
                <td>[% cost.cost_category | html %]</td>
                <td>[% cost.description | html %]</td>
                <td>[% cost.currency | html %] [% cost.amount %]</td>
                <td>[% cost.period_start | html %] – [% cost.period_end | html %]</td>
                <td>[% cost.is_recurring ? 'Yes' : 'No' %]</td>
                <td>[% cost.vendor | html %]</td>
                <td>[% cost.site_id ? 'Site' : 'Global' %]</td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
        [% ELSE %]
        <p class="empty-state">No cost entries recorded yet. Add your first entry above.</p>
        [% END %]
      </div>

    </div>

    <div class="content-secondary">
      <div class="content-section">
        <h3>Typical Server Room Costs (Reference)</h3>
        <ul style="font-size:0.85em;line-height:1.8;">
          <li><strong>Power:</strong> ~$0.12–0.18/kWh; 1U server ≈ 100–400W</li>
          <li><strong>Cooling:</strong> 30–40% of power cost</li>
          <li><strong>Fiber ISP:</strong> $100–500/mo business</li>
          <li><strong>Backup ISP:</strong> $50–150/mo cable/DSL</li>
          <li><strong>Hardware amortize:</strong> divide purchase price by 36–60 months</li>
          <li><strong>Ollama GPU:</strong> consumer GPU $0 extra if owned; cloud GPU $0.50–2/hr</li>
          <li><strong>xAI Grok:</strong> ~$5/M tokens input / $15/M output</li>
          <li><strong>OpenAI GPT-4o:</strong> ~$5/M input / $15/M output</li>
          <li><strong>SSL (Let's Encrypt):</strong> free</li>
          <li><strong>Domain:</strong> $10–20/yr per domain</li>
          <li><strong>Insurance:</strong> $50–200/mo cyber liability</li>
        </ul>
      </div>
      <div class="content-section">
        <h3>Break-even Rule of Thumb</h3>
        <p style="font-size:0.85em;line-height:1.8;">
          <strong>Min price/member =</strong><br>
          (Total monthly costs × 1.3) ÷ active members<br><br>
          The ×1.3 adds 30% overhead for growth, support, and unexpected costs.
          Free-tier members should not count toward break-even math — they are subsidized by paid tiers.
        </p>
      </div>
    </div>

  </div>
</div>
