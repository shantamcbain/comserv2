[% META
   title = "PayPal Settings"
   description = "Configure PayPal payment integration"
   roles = "admin"
   TemplateType = "Application"
   category = "Admin"
   page_version = "0.01"
   last_updated = "2026-03-19"
%]
[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
[% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

<div class="app-container">
  <div class="page-header">
    <h1>PayPal Settings</h1>
    <p>Configure how the site connects to PayPal for coin and membership payments.</p>
  </div>

  <div class="content-container">

    <!-- ── Settings Form ─────────────────────────────── -->
    <div class="content-primary">

      <div class="content-section">
        <h2>Connection Settings</h2>
        <form method="post" action="[% c.uri_for('/membership/admin/paypal_settings') %]">

          <div class="form-field" style="margin-bottom:1.2rem">
            <label style="display:flex;align-items:center;gap:0.6rem;cursor:pointer">
              <input type="checkbox" name="paypal_sandbox" value="1"
                     [% 'checked' IF current.paypal_sandbox %]
                     style="width:1.1rem;height:1.1rem">
              <span><strong>Sandbox / Test Mode</strong></span>
            </label>
            <p class="form-hint" style="margin:0.25rem 0 0 1.7rem;font-size:0.88em;color:#666">
              Check this while testing. Uncheck when you are ready to accept real payments.
            </p>
          </div>

          <div class="form-field" style="margin-bottom:1.2rem">
            <label for="paypal_business"><strong>PayPal Business Email</strong></label>
            <input type="email" id="paypal_business" name="paypal_business"
                   value="[% current.paypal_business | html %]"
                   placeholder="yourname@example.com"
                   style="width:100%;max-width:420px;padding:0.5rem;border:1px solid var(--border-color,#ccc);border-radius:4px">
            <p class="form-hint" style="font-size:0.88em;color:#666;margin:0.2rem 0 0">
              The email address of your PayPal Business account. Payments go here.
            </p>
          </div>

          <div class="form-field" style="margin-bottom:1.2rem">
            <label for="paypal_currency"><strong>Currency Code</strong></label>
            <select id="paypal_currency" name="paypal_currency"
                    style="padding:0.5rem;border:1px solid var(--border-color,#ccc);border-radius:4px">
              [% FOR code IN ['USD','CAD','AUD','GBP','EUR'] %]
              <option value="[% code %]" [% 'selected' IF current.paypal_currency == code %]>[% code %]</option>
              [% END %]
            </select>
          </div>

          <hr style="margin:1.5rem 0;border:none;border-top:1px solid var(--border-color,#ddd)">
          <h3 style="margin:0 0 0.5rem">REST API Credentials <span style="font-weight:normal;font-size:0.85em">(optional — for future subscription billing)</span></h3>

          <div class="form-field" style="margin-bottom:1.2rem">
            <label for="paypal_client_id"><strong>Client ID</strong></label>
            <input type="text" id="paypal_client_id" name="paypal_client_id"
                   value="[% current.paypal_client_id | html %]"
                   placeholder="AaBbCcDd…"
                   style="width:100%;max-width:520px;padding:0.5rem;border:1px solid var(--border-color,#ccc);border-radius:4px;font-family:monospace">
          </div>

          <div class="form-field" style="margin-bottom:1.5rem">
            <label for="paypal_secret"><strong>Secret</strong></label>
            <input type="password" id="paypal_secret" name="paypal_secret"
                   value="[% current.paypal_secret | html %]"
                   placeholder="EeFfGgHh…"
                   style="width:100%;max-width:520px;padding:0.5rem;border:1px solid var(--border-color,#ccc);border-radius:4px;font-family:monospace">
            <p class="form-hint" style="font-size:0.88em;color:#666;margin:0.2rem 0 0">
              Stored encrypted in the database. Leave blank to keep the existing value unchanged.
            </p>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Settings</button>
            <a href="[% c.uri_for('/membership/admin') %]" class="btn btn-secondary">← Back</a>
          </div>
        </form>
      </div>

    </div>

    <!-- ── Instructions Sidebar ──────────────────────── -->
    <div class="content-secondary">

      <div class="content-section">
        <h2>How to Set Up PayPal</h2>

        <h3 style="font-size:1em;margin:1rem 0 0.25rem">Step 1 — Create a Business Account</h3>
        <ol style="padding-left:1.2rem;margin:0 0 0.75rem;font-size:0.9em">
          <li>Go to <a href="https://www.paypal.com/bizsignup" target="_blank" rel="noopener">paypal.com/bizsignup</a></li>
          <li>Choose <strong>Business Account</strong></li>
          <li>Complete identity verification</li>
          <li>Your business email becomes the <strong>Business Email</strong> above</li>
        </ol>

        <h3 style="font-size:1em;margin:1rem 0 0.25rem">Step 2 — Test with Sandbox First</h3>
        <ol style="padding-left:1.2rem;margin:0 0 0.75rem;font-size:0.9em">
          <li>Go to <a href="https://developer.paypal.com" target="_blank" rel="noopener">developer.paypal.com</a></li>
          <li>Log in with your PayPal account</li>
          <li>Under <strong>Sandbox → Accounts</strong>, note the test <em>business</em> email</li>
          <li>Enter that test email above and keep <strong>Sandbox Mode</strong> checked</li>
          <li>Use sandbox buyer credentials from the same page to test a purchase</li>
        </ol>

        <h3 style="font-size:1em;margin:1rem 0 0.25rem">Step 3 — Go Live</h3>
        <ol style="padding-left:1.2rem;margin:0 0 0.75rem;font-size:0.9em">
          <li>Replace the business email with your <strong>real PayPal Business email</strong></li>
          <li>Uncheck <strong>Sandbox Mode</strong></li>
          <li>Save — payments are now live</li>
        </ol>

        <h3 style="font-size:1em;margin:1rem 0 0.25rem">REST API (optional)</h3>
        <ol style="padding-left:1.2rem;margin:0;font-size:0.9em">
          <li>At <a href="https://developer.paypal.com/dashboard/applications" target="_blank" rel="noopener">developer.paypal.com/dashboard/applications</a></li>
          <li>Create an app and copy the <strong>Client ID</strong> and <strong>Secret</strong></li>
          <li>Use <em>Sandbox</em> credentials while testing, <em>Live</em> when ready</li>
        </ol>
      </div>

      <div class="content-section" style="background:rgba(255,253,231,0.95);border-color:#f0ad4e">
        <h2 style="color:#7a5700">IPN / Return URL</h2>
        <p style="font-size:0.88em">PayPal will send payment notifications to:</p>
        <code style="word-break:break-all;font-size:0.82em;display:block;padding:0.4rem;background:#fff;border:1px solid #ddd;border-radius:4px">
          [% c.uri_for('/payment/paypal/ipn') %]
        </code>
        <p style="font-size:0.88em;margin-top:0.5rem">
          No configuration needed in PayPal — the URL is sent automatically with each transaction.
          For production, this URL must be publicly reachable (not localhost).
        </p>
      </div>

    </div>

  </div>
</div>
