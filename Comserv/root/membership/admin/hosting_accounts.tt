[% META title = "CSC Hosting Accounts" TemplateType = "Application" %]

[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
[% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

<div class="app-container hosting-accounts-page">
  <div class="page-header">
    <h1>&#127760; CSC Hosting Accounts</h1>
    <div class="admin-actions hosting-admin-actions">
      <a href="[% c.uri_for('/membership/admin') %]" class="btn btn-secondary">← Membership Admin</a>
      <a href="/Inventory/sales" class="btn btn-secondary">Sales Invoices (AR)</a>
      <a href="[% c.uri_for('/membership/admin/backfill_hosting_invoices') %]"
         class="btn btn-warning"
         onclick="return confirm('Create missing CSC sales invoices for all active hosting accounts?');">
        &#x1F504; Backfill Missing Invoices
      </a>
      <a href="[% c.uri_for('/membership/admin/sync_invoice_payments') %]"
         class="btn btn-info"
         onclick="return confirm('Sync payment status from client invoices to CSC sales invoices?');">
        &#x2714; Sync Payments
      </a>
    </div>
  </div>

  <div class="content-container">
    <div class="content-primary">
      <div class="content-section">
        [% IF accounts.size %]
        <div class="table-container hosting-accounts-table-wrap">
          <table class="data-table hosting-accounts-table">
            <thead>
              <tr>
                <th>Site</th>
                <th>Plan</th>
                <th>Domain</th>
                <th>Email</th>
                <th>Monthly</th>
                <th>Status</th>
                <th>Public</th>
                <th>Submitted</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              [% FOREACH acct IN accounts %]
              <tr>
                <td class="col-sitename"><strong>[% acct.sitename | html %]</strong></td>
                <td class="col-plan">[% acct.plan_slug | html %]</td>
                <td class="col-domain">[% acct.domain | html %][% IF acct.domain_type %] <small class="text-muted">([% acct.domain_type | html %])</small>[% END %]</td>
                <td class="col-email">[% acct.contact_email | html %]</td>
                <td class="col-monthly">CAD [% acct.monthly_cost || '0.00' %]</td>
                <td class="col-status">
                  <span class="badge badge-[% acct.status == 'active' ? 'success' : acct.status == 'pending' ? 'warning' : 'danger' %]">
                    [% acct.status | html %]
                  </span>
                </td>
                <td class="col-public">
                  [% SET list_pub = acct.list_publicly.defined ? acct.list_publicly : 1 %]
                  <div class="public-list-cell">
                    [% IF list_pub %]
                      <span class="badge badge-success" title="Listed in public Hosted menu and /hosted">Public</span>
                    [% ELSE %]
                      <span class="badge badge-secondary" title="Hidden from guests; members/admins only">Members</span>
                    [% END %]
                    [% IF acct.status == 'active' %]
                    <form method="post" action="[% c.uri_for('/membership/admin/hosting_accounts') %]" class="inline-form">
                      <input type="hidden" name="account_id" value="[% acct.id %]">
                      <input type="hidden" name="action" value="toggle_list_publicly">
                      <button type="submit" class="btn btn-sm btn-outline-secondary"
                              title="[% IF list_pub %]Hide from public Hosted menu and /hosted[% ELSE %]Show in public Hosted catalogue[% END %]">
                        [% IF list_pub %]Hide[% ELSE %]Show[% END %]
                      </button>
                    </form>
                    [% END %]
                  </div>
                </td>
                <td class="col-submitted">[% acct.created_at | html %]</td>
                <td class="action-cell">
                  <div class="hosting-action-group">
                    <a href="[% c.uri_for('/membership/admin/hosting_account_edit/' _ acct.id) %]"
                       class="btn btn-sm btn-primary">Edit</a>
                    [% IF acct.status == 'pending' %]
                      [% SET suggested = plan_price.item(acct.plan_slug) || acct.monthly_cost || 10 %]
                      <form method="post" action="[% c.uri_for('/membership/admin/hosting_accounts') %]" class="inline-form approve-form">
                        <input type="hidden" name="account_id" value="[% acct.id %]">
                        <input type="hidden" name="action" value="approve">
                        <label class="approve-cost-label">CAD
                          <input type="number" name="monthly_cost" value="[% suggested %]"
                            step="0.01" min="0" class="approve-cost-input">
                        </label>
                        <button type="submit" class="btn btn-primary btn-sm"
                          onclick="return confirm('Approve hosting for [% acct.sitename | html %] and send email notification?')">
                          Approve</button>
                      </form>
                    [% ELSIF acct.status == 'active' %]
                      <form method="post" action="[% c.uri_for('/membership/admin/hosting_accounts') %]" class="inline-form">
                        <input type="hidden" name="account_id" value="[% acct.id %]">
                        <input type="hidden" name="action" value="suspend">
                        <button type="submit" class="btn btn-sm btn-secondary"
                          onclick="return confirm('Suspend hosting for [% acct.sitename | html %]?')">Suspend</button>
                      </form>
                    [% ELSIF acct.status == 'suspended' %]
                      <form method="post" action="[% c.uri_for('/membership/admin/hosting_accounts') %]" class="inline-form">
                        <input type="hidden" name="account_id" value="[% acct.id %]">
                        <input type="hidden" name="action" value="approve">
                        <input type="hidden" name="monthly_cost" value="[% acct.monthly_cost %]">
                        <button type="submit" class="btn btn-sm btn-primary">Reactivate</button>
                      </form>
                    [% END %]
                    [% UNLESS acct.status == 'cancelled' %]
                    <form method="post" action="[% c.uri_for('/membership/admin/hosting_accounts') %]" class="inline-form">
                      <input type="hidden" name="account_id" value="[% acct.id %]">
                      <input type="hidden" name="action" value="cancel">
                      <button type="submit" class="btn btn-sm btn-danger"
                        onclick="return confirm('Cancel hosting for [% acct.sitename | html %]?')">Cancel</button>
                    </form>
                    [% END %]
                    [% IF acct.notes %]
                    <span class="hosting-notes-icon" title="[% acct.notes | html %]">Notes</span>
                    [% END %]
                  </div>
                </td>
              </tr>
              [% IF acct.requested_addons %]
              <tr>
                <td colspan="9" style="background:#fffde7;padding:0.4rem 1rem;font-size:0.88rem;border-top:none;">
                  <strong>🧩 Requested add-ons:</strong>
                  [% FOREACH addon_name IN acct.requested_addons.split(',') %]
                    <span style="display:inline-block;background:#fff9c4;border:1px solid #f9a825;border-radius:4px;padding:0.1rem 0.5rem;margin:0.1rem;">[% addon_name | html %]</span>
                  [% END %]
                  [% IF acct.status == 'pending' %]
                    <span style="color:#c62828;font-style:italic;margin-left:0.5rem;">— awaiting CSC confirmation</span>
                  [% END %]
                </td>
              </tr>
              [% END %]
              [% END %]
            </tbody>
          </table>
        </div>
        [% ELSE %]
        <p class="empty-state">No hosting account registrations yet.</p>
        [% END %]
      </div>
    </div>
  </div>
</div>
