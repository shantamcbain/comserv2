[% META
   title = "Subscribe"
   description = "Choose a payment method to activate your membership"
   roles = "user,admin"
   TemplateType = "Application"
   category = "Membership"
   page_version = "0.01"
   last_updated = "2026-03-18"
%]
[% PageVersion = 'membership/Subscribe.tt,v 0.01 2026/03/18 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

[% IF error_msg %]<div class="error">[% error_msg | html %]</div>[% END %]
[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
[% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

<div class="app-container">
  <div class="page-header">
    <h1>Subscribe[% IF plan %]: [% plan.name | html %][% END %]</h1>
  </div>

  <div class="content-container">
    <div class="content-primary">

      [% IF plan %]
      <div class="content-section">
        <h2>Plan Details</h2>
        <div class="form-row">
          <div class="form-field">
            <strong>Monthly:</strong> [% plan.price_currency | html %] [% plan.price_monthly %]
          </div>
          <div class="form-field">
            <strong>Annual:</strong> [% plan.price_currency | html %] [% plan.price_annual %]
            [% IF plan.annual_discount_pct > 0 %](save [% plan.annual_discount_pct %]%)[% END %]
          </div>
        </div>
        [% IF plan.description %]
        <p>[% plan.description | html %]</p>
        [% END %]
      </div>

      <div class="content-section">
        <h2>Choose Billing Cycle</h2>
        <div class="form-row">
          <label><input type="radio" name="billing_cycle" value="monthly" checked> Monthly</label>
          <label><input type="radio" name="billing_cycle" value="annual"> Annual (best value)</label>
        </div>
      </div>

      <div class="content-section">
        <h2>Choose Payment Method</h2>
        <div class="form-row">
          <div class="form-field">
            <a href="[% c.uri_for('/payment/paypal/checkout', { plan_id => plan.id }) %]"
               class="btn btn-primary">Pay with PayPal</a>
          </div>
          <div class="form-field">
            <a href="[% c.uri_for('/payment/patreon/connect', { plan_id => plan.id }) %]"
               class="btn btn-primary">Link Patreon</a>
          </div>
          <div class="form-field">
            <a href="[% c.uri_for('/payment/internal/checkout', { plan_id => plan.id }) %]"
               class="btn btn-primary">Use Site Credits</a>
          </div>
        </div>
      </div>
      [% ELSE %]
      <div class="content-section">
        <p class="empty-state">No plan selected. <a href="[% c.uri_for('/membership') %]">View available plans</a>.</p>
      </div>
      [% END %]

      <div class="form-actions">
        <a href="[% c.uri_for('/membership') %]" class="btn">Back to Plans</a>
      </div>

    </div>
  </div>
</div>
