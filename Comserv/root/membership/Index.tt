[% META
   title = "Membership Plans"
   description = "View and join membership plans for this site"
   roles = "guest,user,admin"
   TemplateType = "Application"
   category = "Membership"
   page_version = "0.01"
   last_updated = "2026-03-18"
%]
[% PageVersion = 'membership/Index.tt,v 0.01 2026/03/18 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

[% IF error_msg %]<div class="error">[% error_msg | html %]</div>[% END %]
[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
[% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

<div class="app-container">
  <div class="page-header">
    <h1>Membership Plans</h1>
    <p>[% site_name | html %] membership gives you access to advanced features, AI models, hosting, and more.</p>
    [% IF is_admin %]
    <div class="admin-actions" style="margin-top:0.75rem;">
      <a href="[% c.uri_for('/membership/admin') %]" class="btn btn-primary">Admin Dashboard</a>
      <a href="[% c.uri_for('/membership/admin/manage_plans') %]" class="btn btn-secondary">Manage Plans</a>
      <a href="[% c.uri_for('/membership/admin/subscribers') %]" class="btn btn-secondary">All Subscribers</a>
      <a href="[% c.uri_for('/membership/admin/cost_tracking') %]" class="btn btn-secondary">Cost Tracking</a>
    </div>
    [% END %]
  </div>

  <div class="content-container">
    <div class="content-primary">

      [% IF is_admin AND all_members.size %]
      <div class="content-section">
        <h2>Current Members — [% site_name | html %]</h2>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Username</th>
                <th>Name</th>
                <th>Plan</th>
                <th>Status</th>
                <th>Billing</th>
                <th>Expires</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              [% FOREACH m IN all_members %]
              <tr>
                <td>[% m.user.username | html %]</td>
                <td>[% m.user.first_name | html %] [% m.user.last_name | html %]</td>
                <td>[% m.plan.name | html %]</td>
                <td><span class="badge badge-[% m.status | html %]">[% m.status | html %]</span></td>
                <td>[% m.billing_cycle | html %]</td>
                <td>[% m.expires_at || 'Never' | html %]</td>
                <td class="action-cell">
                  <a href="[% c.uri_for('/membership/admin/subscribers') %]" class="btn btn-sm">View</a>
                </td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
      </div>
      [% ELSIF is_admin %]
      <div class="content-section">
        <p class="empty-state">No members yet for [% site_name | html %].</p>
      </div>
      [% END %]

      [% IF user_membership %]
      <div class="content-section">
        <h2>Your Current Plan</h2>
        <div class="table-container">
          <table class="data-table">
            <tr>
              <th>Plan</th>
              <th>Status</th>
              <th>Billing</th>
              <th>Expires</th>
              <th>Actions</th>
            </tr>
            <tr>
              <td>[% user_membership.plan.name | html %]</td>
              <td>[% user_membership.status | html %]</td>
              <td>[% user_membership.billing_cycle | html %]</td>
              <td>[% user_membership.expires_at || 'Never' | html %]</td>
              <td class="action-cell">
                <a href="[% c.uri_for('/membership/account') %]" class="btn btn-primary">Manage</a>
              </td>
            </tr>
          </table>
        </div>
      </div>
      [% END %]

      [%# ── CSC Site Registration (admin only, non-CSC SiteNames) ──────────── %]
      [% IF is_admin AND !site_is_csc %]
      <div class="content-section" style="border:1px solid #b0c4de;border-radius:8px;padding:1.2rem 1.4rem;background:#f4f8ff;">
        <h2 style="margin-top:0;">&#127760; [% site_name | html %] — CSC Hosting Registration</h2>

        [% IF csc_not_registered %]
        <div style="border:2px solid #e67e22;border-radius:6px;padding:1rem 1.2rem;background:#fff8f0;margin-bottom:1rem;">
          <strong style="color:#e67e22;">&#9888; [% site_name | html %] is not yet registered with CSC</strong>
          <p style="margin:0.5rem 0 0;">Register to unlock hosting services for your members.
          CSC handles domain setup, server maintenance, and billing —
          [% site_name | html %] earns a referral commission on every hosting payment.</p>
          <div style="margin-top:0.8rem;">
            <a href="[% c.uri_for('/membership/hosting_signup', { plan => 'hosting-subdomain', ref => 'membership' }) %]"
               class="btn btn-primary">Register [% site_name | html %] with CSC →</a>
            <a href="[% c.uri_for('/hosting') %]" class="btn btn-secondary" style="margin-left:0.5rem;">Learn More</a>
          </div>
        </div>
        [% ELSIF hosting_account %]
          [% IF hosting_account.status == 'active' %]
          <p style="color:#27ae60;margin:0 0 0.8rem;"><strong>&#10003; [% site_name | html %] is a registered CSC hosting partner.</strong>
          Members of this site can purchase hosting plans below.</p>
          [% ELSIF hosting_account.status == 'pending' %]
          <p style="color:#e67e22;margin:0 0 0.8rem;"><strong>&#8987; Registration pending CSC approval.</strong>
          Hosting plans will be available once CSC activates your account.</p>
          [% END %]
        [% END %]

        [% IF csc_hosting_plans.size %]
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem;">
          [% FOREACH hplan IN csc_hosting_plans %]
          <div style="border:1px solid #c8e6c9;border-radius:6px;padding:1rem;background:#f8fdf4[% IF hplan.is_featured %];border-color:#4a8c3f;border-width:2px[% END %]">
            [% IF hplan.is_featured %]
            <div style="background:#4a8c3f;color:#fff;text-align:center;padding:0.25rem;border-radius:3px;font-size:0.8em;margin-bottom:0.5rem;">&#9733; Most Popular</div>
            [% END %]
            <strong style="color:#2d5a27;">[% hplan.name | html %]</strong>
            <div style="font-size:1.2rem;font-weight:bold;color:#4a8c3f;margin:0.3rem 0;">
              [% IF hplan.price_monthly == 0 %]Free[% ELSE %][% hplan.price_currency | html %]&nbsp;[% hplan.price_monthly %]/mo[% END %]
            </div>
            [% IF hplan.description %]
            <p style="font-size:0.85rem;color:#555;margin:0.4rem 0;">[% hplan.description | html %]</p>
            [% END %]
            <ul style="font-size:0.85rem;padding-left:1.2em;margin:0.4rem 0;">
              [% IF hplan.has_subdomain %]<li>Subdomain on partner SiteName</li>[% END %]
              [% IF hplan.has_custom_domain %]<li>Custom domain support</li>[% END %]
              [% IF hplan.has_planning %]<li>Planning &amp; project tools</li>[% END %]
              [% IF hplan.ai_requests_per_day > 0 %]<li>[% hplan.ai_requests_per_day %] AI requests/day</li>[% END %]
            </ul>
          </div>
          [% END %]
        </div>
        [% END %]
      </div>
      [% END %][%# /IF is_admin AND !site_is_csc %]

      [% IF plans.size %]
      <div class="content-section">
        <h2>Available Plans</h2>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Plan</th>
                <th>Monthly</th>
                <th>Annual</th>
                <th>AI Models</th>
                <th>Email</th>
                <th>Hosting</th>
                <th>Beekeeping</th>
                <th>Planning</th>
                <th>Currency</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              [% FOREACH plan IN plans %]
              <tr[% IF plan.is_featured %] class="featured-plan"[% END %]>
                <td>
                  <strong>[% plan.name | html %]</strong>
                  [% IF plan.is_featured %]<span class="badge">Popular</span>[% END %]
                  [% IF plan.description %]<br><small>[% plan.description | html %]</small>[% END %]
                </td>
                <td>
                  [% IF plan.price_monthly == 0 %]
                    Free
                  [% ELSE %]
                    [% plan.price_currency | html %] [% plan.price_monthly %]/mo
                  [% END %]
                </td>
                <td>
                  [% IF plan.price_annual == 0 %]
                    Free
                  [% ELSE %]
                    [% plan.price_currency | html %] [% plan.price_annual %]/yr
                  [% END %]
                </td>
                <td>[% IF plan.ai_requests_per_day > 0 %][% plan.ai_requests_per_day %]/day[% ELSE %]—[% END %]</td>
                <td>[% IF plan.has_email %][% plan.email_addresses %] addr[% ELSE %]—[% END %]</td>
                <td>[% IF plan.has_hosting %][% plan.hosting_tier || 'Included' | html %][% ELSE %]—[% END %]</td>
                <td>[% plan.has_beekeeping ? '✓' : '—' %]</td>
                <td>[% plan.has_planning ? '✓' : '—' %]</td>
                <td>[% plan.has_currency ? '✓' : '—' %]</td>
                <td class="action-cell">
                  [% IF c.session.username %]
                    <a href="[% c.uri_for('/membership/subscribe', { plan_id => plan.id }) %]"
                       class="btn btn-primary">Join</a>
                  [% ELSE %]
                    <a href="[% c.uri_for('/user/login', { return_to => c.uri_for('/membership/subscribe', { plan_id => plan.id }) }) %]"
                       class="btn btn-primary">Join</a>
                  [% END %]
                </td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
      </div>
      [% ELSE %]
      <div class="content-section">
        <p class="empty-state">No membership plans have been configured for this site yet.</p>
        [% IF is_admin %]
        <p><a href="[% c.uri_for('/membership/admin') %]" class="btn btn-primary">Configure Plans</a></p>
        [% END %]
      </div>
      [% END %]

      <div class="content-section">
        <h2>Payment Options</h2>
        <div class="form-row">
          <div class="form-field">
            <strong>PayPal</strong> — Pay securely with your PayPal account or any credit / debit card.
          </div>
          [% IF patreon_cfg AND patreon_cfg.active %]
          <div class="form-field">
            <strong>Patreon</strong> — Support [% site_name | html %] through Patreon and receive membership benefits automatically.
            [% IF patreon_cfg.url %]<br><a href="[% patreon_cfg.url | html %]" target="_blank" rel="noopener">Visit our Patreon page →</a>[% END %]
          </div>
          [% END %]
          <div class="form-field">
            <strong>Site Coins</strong> <em style="font-size:0.85em;color:var(--warning-color,#e67e22)">(Promotional)</em>
            — Use your internal coin balance to pay for memberships and services offered by participating members.
            New accounts receive <strong>100 free coins</strong> to get started.
            <br><a href="[% c.uri_for('/payment/buy/coins') %]">Buy more coins →</a>
          </div>
        </div>
      </div>

      [% IF c.session.username %]
      <div class="content-section">
        <div class="form-actions">
          <a href="[% c.uri_for('/membership/account') %]" class="btn btn-primary">My Account</a>
        </div>
      </div>
      [% END %]



    </div>
  </div>
</div>
