[% META
   title = "Membership Plans"
   description = "View and join membership plans for this site"
   roles = "guest,user,admin"
   TemplateType = "Application"
   category = "Membership"
   page_version = "0.02"
   last_updated = "2026-04-26"
%]

[% IF error_msg %]<div class="error">[% error_msg | html %]</div>[% END %]
[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
[% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

<div class="app-container">
  <div class="page-header">
    <h1>Membership Plans</h1>
    <p>[% site_name | html %] membership gives you access to advanced features, AI models, hosting, and more.</p>
    [% IF is_admin %]
    <div class="admin-actions">
      <a href="[% c.uri_for('/membership/admin') %]" class="btn btn-primary">Admin Dashboard</a>
      <a href="[% c.uri_for('/membership/admin/manage_plans') %]" class="btn btn-secondary">Manage Plans</a>
      <a href="[% c.uri_for('/membership/admin/subscribers') %]" class="btn btn-secondary">All Subscribers</a>
      <a href="[% c.uri_for('/membership/admin/cost_tracking') %]" class="btn btn-secondary">Cost Tracking</a>
      [% IF c.session.SiteName == 'CSC' %]
      <a href="[% c.uri_for('/membership/admin/hosting_accounts') %]" class="btn btn-secondary">&#127760; Hosting Accounts</a>
      [% END %]
    </div>
    [% END %]
  </div>

  <div class="content-container">
    <div class="content-primary">

      [% IF is_admin AND all_members.size %]
      <div class="content-section">
        <h2>Current Members — [% site_name | html %]</h2>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Username</th><th>Name</th><th>Plan</th><th>Status</th><th>Billing</th><th>Expires</th><th>Actions</th>
              </tr>
            </thead>
            <tbody>
              [% FOREACH m IN all_members %]
              <tr>
                <td>[% m.user.username | html %]</td>
                <td>[% m.user.first_name | html %] [% m.user.last_name | html %]</td>
                <td>[% m.plan.name | html %]</td>
                <td><span class="badge badge-[% m.status | html %]">[% m.status | html %]</span></td>
                <td>[% m.billing_cycle | html %]</td>
                <td>[% m.expires_at || 'Never' | html %]</td>
                <td class="action-cell">
                  <a href="[% c.uri_for('/membership/admin/subscribers') %]" class="btn btn-sm">View</a>
                </td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
      </div>
      [% ELSIF is_admin %]
      <div class="content-section">
        <p class="empty-state">No members yet for [% site_name | html %].</p>
      </div>
      [% END %]

      [% IF user_membership %]
      <div class="content-section">
        <h2>Your Current Plan</h2>
        <div class="table-container">
          <table class="data-table">
            <tr><th>Plan</th><th>Status</th><th>Billing</th><th>Expires</th><th>Actions</th></tr>
            <tr>
              <td>[% user_membership.plan.name | html %]</td>
              <td>[% user_membership.status | html %]</td>
              <td>[% user_membership.billing_cycle | html %]</td>
              <td>[% user_membership.expires_at || 'Never' | html %]</td>
              <td class="action-cell">
                <a href="[% c.uri_for('/membership/account') %]" class="btn btn-primary">Manage</a>
              </td>
            </tr>
          </table>
        </div>
        [% IF user_membership.plan %]
        [% SET p = user_membership.plan %]
        <div style="margin-top:0.75rem;display:flex;flex-wrap:wrap;gap:0.5rem;">
          [% IF p.has_beekeeping %]<span class="badge badge-success">&#128027; Beekeeping Access</span>[% END %]
          [% IF p.has_planning %]<span class="badge badge-success">&#128203; Planning Tools</span>[% END %]
          [% IF p.has_hosting %]<span class="badge badge-success">&#127760; Hosting</span>[% END %]
          [% IF p.has_email %]<span class="badge badge-success">&#128231; Email</span>[% END %]
          [% IF p.has_currency %]<span class="badge badge-success">&#128176; Coins</span>[% END %]
          [% IF p.ai_requests_per_day > 0 %]<span class="badge badge-success">&#129302; AI ([% p.ai_requests_per_day %]/day)</span>[% END %]
        </div>
        [% END %]
      </div>
      [% END %]

      [%# ── SiteName Plans ──────────────────────────────────────────────────── %]
      [% IF plans.size %]
      <div class="content-section">
        <h2>[% site_name | html %] Plans</h2>
        <p class="text-muted">Choose the plan that fits your needs. Click <strong>Learn More</strong> to see full details and sign up.</p>
        <div class="plan-cards-grid">
          [% FOREACH plan IN plans %]
          [% SET display_price = plan.inventory_item ? plan.inventory_item.unit_price : plan.price_monthly %]
          <div class="plan-card[% IF plan.is_featured %] plan-card-featured[% END %]">
            [% IF plan.is_featured %]
            <div class="plan-card-badge">&#9733; Most Popular</div>
            [% END %]
            <h3 class="plan-card-name">[% plan.name | html %]</h3>
            <div class="plan-card-price">
              [% IF display_price == 0 %]Free
              [% ELSE %][% plan.price_currency | html %]&nbsp;[% display_price %]/mo[% END %]
            </div>
            [% IF plan.price_annual > 0 AND display_price > 0 %]
            <div class="plan-card-annual">or [% plan.price_currency | html %]&nbsp;[% plan.price_annual %]/yr
              [% SET saving = (display_price * 12) - plan.price_annual %]
              [% IF saving > 0 %]<span class="badge">Save [% plan.price_currency | html %][% saving | format('%.2f') %]</span>[% END %]
            </div>
            [% END %]
            [% IF plan.description %]<p class="plan-card-desc">[% plan.description | html %]</p>[% END %]
            <ul class="plan-card-features">
              [% IF plan.has_subdomain %]<li>&#127760; Subdomain included</li>[% END %]
              [% IF plan.has_custom_domain %]<li>&#127760; Custom domain support</li>[% END %]
              [% IF plan.has_email %]<li>&#9993; [% plan.email_addresses %] email address[% IF plan.email_addresses != 1 %]es[% END %]</li>[% END %]
              [% IF plan.has_hosting %]<li>&#128421; Hosting — [% plan.hosting_tier || 'Included' | html %]</li>[% END %]
              [% IF plan.ai_requests_per_day > 0 %]<li>&#129302; [% plan.ai_requests_per_day %] AI requests/day</li>[% END %]
              [% IF plan.has_planning %]<li>&#128203; Planning &amp; project tools</li>[% END %]
              [% IF plan.has_beekeeping %]<li>&#128029; Beekeeping module</li>[% END %]
              [% IF plan.has_currency %]<li>&#127881; [% plan.currency_bonus > 0 ? plan.currency_bonus _ ' bonus coins' : 'Site coins' %]</li>[% END %]
              [% IF plan.inventory_item AND plan.inventory_item.is_assemblable %]<li class="text-success"><strong>+ Optional add-ons</strong></li>[% END %]
            </ul>
            <div class="plan-card-actions">
              <a href="[% c.uri_for('/membership/plan_details/' _ plan.id) %]" class="btn btn-primary">
                Learn More &amp; Join &rarr;
              </a>
            </div>
          </div>
          [% END %]
        </div>
      </div>
      [% ELSE %]
      <div class="content-section">
        <p class="empty-state">No membership plans have been configured for this site yet.</p>
        [% IF is_admin %]
        <p><a href="[% c.uri_for('/membership/admin') %]" class="btn btn-primary">Configure Plans</a></p>
        [% END %]
      </div>
      [% END %]

      [%# ── CSC Site Registration (admin only, non-CSC SiteNames) ──────────── %]
      [% IF is_admin AND !site_is_csc %]
      <div class="content-section">
        <h2>&#127760; [% site_name | html %] — CSC Hosting Registration</h2>

        [% IF hosting_account AND hosting_account.status == 'active' AND !hosting_account.alert_dismissed %]
        <div class="alert alert-info">
          <strong>&#10003; CSC Hosting Active for [% site_name | html %]</strong>
          <p>Your site is registered and active with CSC hosting.
          Members can now purchase hosting plans.
          Monthly cost: <strong>CAD [% hosting_account.monthly_cost %]/mo</strong>.</p>
          <div style="margin-top:0.6rem;">
            <a href="[% c.uri_for('/membership/hosting_signup') %]" class="btn btn-secondary" style="font-size:0.85rem;">
              &#9998; Edit Hosting Registration
            </a>
          </div>
        </div>
        [% ELSIF hosting_account AND hosting_account.status == 'pending' %]
        <div class="alert alert-warning">
          <strong>&#8987; CSC Hosting Registration Pending</strong>
          <p>Your registration was submitted and is awaiting CSC approval.
          You will receive an email at <strong>[% hosting_account.contact_email | html %]</strong> when approved.</p>
          <div style="margin-top:0.6rem;">
            <a href="[% c.uri_for('/membership/hosting_signup') %]" class="btn btn-secondary" style="font-size:0.85rem;">
              &#9998; Edit Hosting Registration
            </a>
          </div>
        </div>
        [% END %]

        [% IF csc_not_registered %]
        <div class="alert alert-warning">
          <strong>&#9888; [% site_name | html %] is not yet registered with CSC for paid hosting</strong>
          <p>Free and Basic plans let your members self-manage a subdomain without CSC involvement.
          Register with CSC to unlock managed domain hosting, cPanel accounts, and referral commissions.</p>
          <div class="form-actions">
            <a href="[% c.uri_for('/membership/hosting_signup', { plan => 'hosting-subdomain', ref => 'membership' }) %]"
               class="btn btn-primary">Register [% site_name | html %] with CSC &rarr;</a>
            <a href="[% c.uri_for('/hosting') %]" class="btn btn-secondary">Learn More</a>
          </div>
        </div>
        [% ELSIF hosting_account %]
          [% IF hosting_account.status == 'active' %]
          <p class="text-success"><strong>&#10003; [% site_name | html %] is a registered CSC hosting partner.</strong>
          Members of this site can purchase hosting plans below.</p>
          [% ELSIF hosting_account.status == 'pending' %]
          <p class="text-warning"><strong>&#8987; Registration pending CSC approval.</strong>
          Hosting plans will be available once CSC activates your account.</p>
          [% END %]
          <div class="form-actions">
            <a href="[% c.uri_for('/membership/hosting_signup') %]" class="btn btn-secondary">&#9998; Edit Hosting Registration</a>
          </div>
        [% END %]

      </div>
      [% END %][%# /IF is_admin AND !site_is_csc %]

      [%# CSC account management link for logged-in members on non-CSC sites %]
      [% IF !site_is_csc AND c.session.username AND hosting_account AND hosting_account.status == 'active' %]
      <div class="content-section">
        <h3>&#127760; My CSC Account</h3>
        <p class="text-muted">View your CSC hosting subscription, point balance, and renewal options.</p>
        <div class="form-actions">
          <a href="[% c.uri_for('/membership/csc_account') %]" class="btn btn-primary">Manage CSC Account</a>
          <a href="[% c.uri_for('/membership/account') %]" class="btn btn-secondary">My Local Account</a>
        </div>
      </div>
      [% END %]

      [%# CSC hosting plan cards — visible to all users when site is an active hosting partner %]
      [% IF !site_is_csc AND hosting_account AND hosting_account.status == 'active' AND csc_hosting_plans.size %]
      <div class="content-section">
        <h2>&#127760; CSC Hosting Plans</h2>
        <p class="text-muted">
          [% site_name | html %] is a CSC hosting partner. Members can add managed cloud hosting with domain support.
        </p>
        <div class="plan-cards-grid">
          [% FOREACH hplan IN csc_hosting_plans %]
          <div class="plan-card[% IF hplan.is_featured %] plan-card-featured[% END %]">
            [% IF hplan.is_featured %]
            <div class="plan-card-badge">&#9733; Most Popular</div>
            [% END %]
            <h3 class="plan-card-name">[% hplan.name | html %]</h3>
            <div class="plan-card-price">
              [% IF hplan.price_monthly == 0 %]Free[% ELSE %][% hplan.price_currency | html %]&nbsp;[% hplan.price_monthly %]/mo[% END %]
            </div>
            [% IF hplan.description %]<p class="plan-card-desc">[% hplan.description | html %]</p>[% END %]
            <ul class="plan-card-features">
              [% IF hplan.has_subdomain %]<li>&#127760; Subdomain on CSC domain</li>[% END %]
              [% IF hplan.has_custom_domain %]<li>&#127760; Custom domain support</li>[% END %]
              [% IF hplan.has_planning %]<li>&#128203; Planning &amp; project tools</li>[% END %]
              [% IF hplan.ai_requests_per_day > 0 %]<li>&#129302; [% hplan.ai_requests_per_day %] AI requests/day</li>[% END %]
            </ul>
            <a href="[% c.uri_for('/membership/plan_details/' _ hplan.id) %]" class="btn btn-primary">
              Learn More &amp; Join &rarr;
            </a>
          </div>
          [% END %]
        </div>
      </div>
      [% END %]

      <div class="content-section">
        <h2>Payment Options</h2>
        <div class="form-row">
          <div class="form-field">
            <strong>PayPal</strong> — Pay securely with your PayPal account or any credit / debit card.
          </div>
          [% IF patreon_cfg AND patreon_cfg.active %]
          <div class="form-field">
            <strong>Patreon</strong> — Support [% site_name | html %] through Patreon and receive membership benefits automatically.
            [% IF patreon_cfg.url %]<br><a href="[% patreon_cfg.url | html %]" target="_blank" rel="noopener">Visit our Patreon page →</a>[% END %]
          </div>
          [% END %]
          <div class="form-field">
            <strong>Site Coins</strong> <em class="text-warning">(Promotional)</em>
            — Use your internal coin balance. New accounts receive <strong>100 free coins</strong> to get started.
            <br><a href="[% c.uri_for('/payment/buy/coins') %]">Buy more coins →</a>
          </div>
        </div>
      </div>

      [% IF c.session.username %]
      <div class="content-section">
        <div class="form-actions">
          <a href="[% c.uri_for('/membership/account') %]" class="btn btn-primary">My Account</a>
        </div>
      </div>
      [% END %]

    </div>
  </div>
</div>
