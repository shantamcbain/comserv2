<h1>Accounting</h1>
<p>General Ledger and Chart of Accounts — modeled on SQL-Ledger/LedgerSMB.</p>

<table border="1" cellpadding="8">
  <tr>
    <th>Chart of Accounts</th>
    <td>[% acct_count %] active accounts</td>
    <td><a href="/Accounting/coa">Browse COA</a></td>
  </tr>
  <tr>
    <th>General Ledger</th>
    <td>[% entry_count %] journal entries</td>
    <td><a href="/Accounting/gl">Browse GL</a></td>
  </tr>
  <tr>
    <th>AI Usage &amp; Cost Allocation</th>
    <td>Allocate API costs by usage %</td>
    <td><a href="/Accounting/ai_usage">AI Usage Report</a></td>
  </tr>
</table>
