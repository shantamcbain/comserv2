[% PageVersion = 'Accounting/coa/list.tt,v 0.01 2026/04/10 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Chart of Accounts</h1>
<p><a href="/Accounting">← Accounting</a></p>

[% SET cat_labels = {A='Asset', L='Liability', Q='Equity', I='Income', E='Expense'} %]
[% FOREACH cat IN ['A','L','Q','I','E'] %]
  [% SET cat_accounts = accounts.grep(item => item.category == cat) %]
  [% IF cat_accounts.size %]
  <h2>[% cat_labels.$cat %]</h2>
  <table border="1" cellpadding="4">
    <thead>
      <tr><th>Account #</th><th>Description</th><th>Section</th><th>Contra</th></tr>
    </thead>
    <tbody>
    [% FOREACH acct IN cat_accounts %]
      <tr>
        <td><a href="/Accounting/coa/view/[% acct.id %]">[% acct.accno %]</a></td>
        <td>[% acct.description %]</td>
        <td>[% acct.heading ? acct.heading.description : '-' %]</td>
        <td>[% acct.is_contra ? 'Yes' : '' %]</td>
      </tr>
    [% END %]
    </tbody>
  </table>
  [% END %]
[% END %]
