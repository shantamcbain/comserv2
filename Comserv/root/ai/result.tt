[% META
   title = "AI Query Result"
   description = "Detailed AI response view"
   roles = "user,admin,developer"
   category = "AI Module"
   page_version = "0.06"
   last_updated = "Fri Jan 23 15:00:00 UTC 2026"
%]

[% PageVersion = 'ai/result.tt,v 0.06 2026/01/23 15:00:00 CleanupAgent Exp - Implemented CSS isolation and imported ai-common.js'; %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="ai-result-container">
    <h1>AI Query Result</h1>

    [% IF error %]
    <div class="error-box">
        <h2>Error</h2>
        <p>[% error %]</p>
        <div class="error-actions">
            <a href="/ai" class="button">Try Again</a>
        </div>
    </div>
    [% ELSE %]
    
    <div class="query-section">
        <h2>Your Question</h2>
        <div class="query-content">
            [% prompt %]
        </div>
    </div>

    <div class="response-section">
        <h2>AI Response</h2>
        <div class="response-meta">
            <span class="meta-item"><strong>Model:</strong> [% response_metadata.model || 'Unknown' %]</span>
            <span class="meta-item"><strong>Generated:</strong> [% USE date; date.format(date.now, '%Y-%m-%d %H:%M:%S') %]</span>
            [% IF conversation_id %]
            <span class="meta-item"><strong>Conversation ID:</strong> <code>#[% conversation_id %]</code></span>
            [% END %]
        </div>
        <div class="response-content" id="ai-response-content">
            [% ai_response | html %]
        </div>
    </div>
    
    [% IF conversation_id %]
    <div class="conversation-saved-notice">
        <strong>✓ Conversation Saved</strong> 
        <p>This conversation has been saved to your history with ID #[% conversation_id %]. You can review it later or use it as context for future searches.</p>
    </div>
    [% END %]

    <div class="action-buttons">
        <button type="button" id="copy-btn" class="button secondary">Copy Response</button>
        <a href="/ai/query_form" class="button">New Query</a>
        <a href="/ai/conversations" class="button secondary">View Conversations</a>
        <a href="/ai" class="button primary">Back to AI Home</a>
        <a href="/" class="button return-menu">Return to Menu</a>
    </div>

    [% END %]
</div>

<script src="/static/js/ai-common.js"></script>

<style>
.ai-result-container {
    max-width: 1000px;
    margin: 20px auto;
    padding: 20px;
}

.error-box {
    background-color: var(--warning-color);
    opacity: 0.9;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
}

.error-box h2 {
    color: var(--text-color);
    margin-top: 0;
}

.error-box p {
    color: var(--text-color);
    margin: 15px 0;
}

.error-actions {
    margin-top: 20px;
}

.query-section,
.response-section {
    background-color: var(--background-color);
    color: var(--text-color);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: var(--dropdown-shadow);
}

.query-section h2,
.response-section h2 {
    margin-top: 0;
    color: var(--text-color);
    border-bottom: 2px solid var(--success-color);
    padding-bottom: 10px;
}

.query-content {
    background-color: rgba(255,255,255,0.12);
    color: var(--text-color);
    padding: 15px;
    border-radius: 4px;
    border-left: 4px solid var(--success-color);
    white-space: pre-wrap;
    font-family: 'Courier New', monospace;
    font-size: 14px;
    line-height: 1.6;
}

.response-meta {
    background-color: rgba(255,255,255,0.12);
    padding: 10px 15px;
    border-radius: 4px;
    margin-bottom: 15px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
}

.meta-item {
    color: var(--text-color);
    opacity: 0.8;
    font-size: 14px;
}

.response-content {
    background-color: var(--background-color);
    padding: 20px;
    border-radius: 4px;
    border: 1px solid var(--border-color);
    color: var(--text-color);
    white-space: pre-wrap;
    font-family: inherit;
    font-size: 14px;
    line-height: 1.8;
    max-height: 600px;
    overflow-y: auto;
}

.code-block {
    background-color: rgba(255,255,255,0.12);
    color: var(--text-color);
    border: 1px solid var(--border-color);
    padding: 10px;
    border-radius: 5px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 13px;
    margin: 10px 0;
    overflow-x: auto;
    white-space: pre;
    display: block;
}

.action-buttons {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 20px;
}

.button {
    padding: 12px 24px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s;
    text-align: center;
    background-color: rgba(255,255,255,0.12);
    color: var(--text-color);
}

.button.primary {
    background-color: var(--success-color);
    color: var(--text-color);
    border: none;
}

.button.primary:hover {
    opacity: 0.8;
}

.button.secondary {
    background-color: rgba(255,255,255,0.12);
    color: var(--text-color);
    border: 1px solid var(--border-color);
}

.button.secondary:hover {
    background-color: var(--background-color);
}

.button:not(.primary):not(.secondary) {
    background-color: var(--link-color);
    color: var(--text-color);
}

.button:not(.primary):not(.secondary):hover {
    opacity: 0.8;
}

.button.return-menu {
    background-color: rgba(255,255,255,0.12);
    color: var(--text-color);
}

.button.return-menu:hover {
    background-color: var(--background-color);
}

.conversation-saved-notice {
    background-color: rgba(255,255,255,0.12);
    border: 1px solid var(--border-color);
    border-left: 4px solid var(--success-color);
    border-radius: 4px;
    padding: 15px;
    margin-top: 20px;
    color: var(--text-color);
}

.conversation-saved-notice strong {
    color: var(--text-color);
    font-size: 16px;
}

.conversation-saved-notice p {
    margin: 8px 0 0 0;
    font-size: 14px;
}

.response-meta code {
    background-color: rgba(255,255,255,0.12);
    color: var(--text-color);
    padding: 2px 6px;
    border-radius: 3px;
    font-family: monospace;
    font-size: 13px;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const copyBtn = document.getElementById('copy-btn');
    
    if (copyBtn) {
        copyBtn.addEventListener('click', function() {
            const responseContent = document.getElementById('ai-response-content');
            if (responseContent) {
                const text = responseContent.getAttribute('data-raw-content') || responseContent.textContent;
                navigator.clipboard.writeText(text).then(function() {
                    const originalText = copyBtn.textContent;
                    copyBtn.textContent = 'Copied!';
                    copyBtn.style.background = 'var(--success-color)';
                    copyBtn.style.color = 'var(--text-color)';
                    
                    setTimeout(function() {
                        copyBtn.textContent = originalText;
                        copyBtn.style.background = '';
                        copyBtn.style.color = '';
                    }, 2000);
                }).catch(function(err) {
                    alert('Failed to copy: ' + err);
                });
            }
        });
    }

    // Format message content on load
    const responseEl = document.getElementById('ai-response-content');
    if (responseEl) {
        const rawContent = responseEl.textContent.trim();
        responseEl.setAttribute('data-raw-content', rawContent);
        responseEl.innerHTML = AIUtils.formatMessageContent(rawContent);
    }
});
</script>