[% META
   title = "AI Chat"
   description = "Interactive AI chat interface"
   roles = "user,admin,developer"
   category = "AI Module"
   page_version = "0.11"
   last_updated = "Fri Jan 23 15:00:00 UTC 2026"
%]

[% PageVersion = 'ai/index.tt,v 0.11 2026/01/23 15:00:00 CleanupAgent Exp - Consolidated message formatting and theme cleanup'; %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="ai-chat-container">
    <div class="page-header-actions">
        <h1>AI Assistant Chat</h1>
        <div id="conversation-info" class="conversation-info" style="display: none; font-size: 12px; color: var(--schema-text-muted); margin-right: auto;">
            Conversation #<span id="conversation-id-display">-</span>
        </div>
        <div class="header-buttons">
            <a href="/ai/conversations" class="header-btn conversations-btn">📋 Conversations</a>
            <a href="/" class="return-to-menu-btn">← Return to Menu</a>
        </div>
    </div>
    
    <!-- Model Selector (Admin/Developer/Users with API keys) -->
    [% IF can_select_model || (external_models && external_models.size > 0) %]
    <div class="model-selector-section">
        <label for="model-select">Select Model:</label>
        <select id="model-select" class="model-dropdown">
            [% IF installed_models && installed_models.size > 0 %]
                <optgroup label="Ollama (Local)">
                [% FOREACH model IN installed_models %]
                    <option value="[% model.name %]" data-provider="ollama" [% IF model.name == current_model %]selected[% END %]>
                        [% model.name %]
                        [% IF model.details && model.details.parameter_size %]
                            ([% model.details.parameter_size %])
                        [% END %]
                    </option>
                [% END %]
                </optgroup>
            [% END %]
            [% IF external_models && external_models.size > 0 %]
                <optgroup label="External AI">
                [% FOREACH ext_model IN external_models %]
                    <option value="[% ext_model.name %]" data-provider="[% ext_model.provider %]">
                        [% ext_model.label %]
                    </option>
                [% END %]
                </optgroup>
            [% END %]
            [% IF (!installed_models || installed_models.size == 0) && (!external_models || external_models.size == 0) %]
                <option value="">No models available</option>
            [% END %]
        </select>
        <a href="/ai/models" class="manage-models-link">Manage Models</a>
    </div>
    [% ELSE %]
    <div class="current-model-display">
        <span class="model-label">Current Model:</span>
        <span class="model-name">[% current_model || 'llama3.1' %]</span>
    </div>
    [% END %]
    
    <!-- Host Selector (Admin/Developer Only) -->
    [% IF can_select_model %]
    <div class="host-selector-section">
        <label for="host-select">Ollama Server:</label>
        <select id="host-select" class="host-dropdown">
            <option value="localhost" [% IF current_host == 'localhost' || current_host == '127.0.0.1' %]selected[% END %]>
                Localhost (127.0.0.1)
            </option>
            <option value="192.168.1.171" [% IF current_host == '192.168.1.171' %]selected[% END %]>
                Remote Server (192.168.1.171)
            </option>
        </select>
        <span id="connection-status" class="connection-status">
            <span class="status-indicator" id="status-indicator"></span>
            <span id="status-text">Connected to [% current_host || 'localhost' %]:[% current_port || '11434' %]</span>
        </span>
        <button id="start-server-btn" class="start-server-button" style="display: none;" title="Start Ollama Server">
            Start Server
        </button>
    </div>
    [% ELSE %]
    <div class="current-host-display">
        <span class="host-label">Server:</span>
        <span class="host-name">[% current_host || 'localhost' %]:[% current_port || '11434' %]</span>
    </div>
    [% END %]
    
    <!-- Chat Messages Container -->
    <div class="chat-messages" id="chat-messages">
        <div class="welcome-message">
            <h2>Welcome to AI Assistant!</h2>
            <p>Ask me anything. I'm here to help you with your questions.</p>
        </div>
    </div>
    
    <!-- Chat Input Form -->
    <div class="chat-input-container">
        <form id="chat-form" class="chat-form">
            <textarea 
                id="user-input" 
                name="prompt" 
                class="chat-input" 
                placeholder="Type your message here..."
                rows="3"
                required
            ></textarea>
            <div class="chat-controls">
                <button type="button" id="clear-chat" class="button secondary">Clear Chat</button>
                <button type="submit" id="send-button" class="button primary">
                    <span class="button-text">Send</span>
                    <span class="button-spinner" style="display: none;">⏳</span>
                </button>
            </div>
        </form>
    </div>
    
    <!-- Status Messages -->
    <div id="status-container" class="status-container"></div>
</div>

<style>
.ai-chat-container {
    max-width: 1200px;
    margin: 10px auto;
    padding: 15px;
    display: flex;
    flex-direction: column;
    height: calc(100vh - 160px);
    min-height: 500px;
}

.page-header-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    gap: 15px;
}

.page-header-actions h1 {
    margin: 0;
    flex: 1;
    text-align: center;
}

.header-buttons {
    display: flex;
    gap: 10px;
    align-items: center;
}

.header-btn {
    padding: 8px 16px;
    background-color: var(--link-color);
    color: var(--text-color);
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    transition: background 0.3s;
    white-space: nowrap;
}

.header-btn:hover {
    opacity: 0.8;
}

.return-to-menu-btn {
    padding: 10px 20px;
    background-color: var(--secondary-color);
    color: var(--text-color);
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    transition: background 0.3s;
    white-space: nowrap;
}

.return-to-menu-btn:hover {
    background-color: var(--background-color);
}

.ai-chat-container h1 {
    margin: 0 0 20px 0;
    color: var(--text-color);
    text-align: center;
}

/* Model Selector Styles */
.model-selector-section {
    background-color: var(--secondary-color);
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    border: 1px solid var(--border-color);
}

.model-selector-section label {
    font-weight: bold;
    color: var(--text-color);
}

.model-dropdown {
    flex: 1;
    min-width: 200px;
    padding: 8px 12px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 14px;
    background-color: var(--background-color);
    color: var(--text-color);
}

.manage-models-link {
    padding: 8px 16px;
    background-color: var(--link-color);
    color: var(--text-color);
    text-decoration: none;
    border-radius: 4px;
    font-size: 14px;
    transition: background 0.3s;
}

.manage-models-link:hover {
    opacity: 0.8;
}

.current-model-display {
    background-color: var(--secondary-color);
    padding: 12px 15px;
    border-radius: 8px;
    margin-bottom: 20px;
    border-left: 4px solid var(--link-color);
}

.model-label {
    font-weight: bold;
    color: var(--text-color);
    margin-right: 8px;
}

.model-name {
    color: var(--link-color);
    font-family: monospace;
    font-size: 14px;
}

/* Host Selector Styles */
.host-selector-section {
    margin: 15px 0;
    padding: 15px;
    background-color: var(--secondary-color);
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    border: 1px solid var(--border-color);
}

.host-selector-section label {
    font-weight: 600;
    color: var(--text-color);
    margin-right: 5px;
}

.host-dropdown {
    padding: 8px 12px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 14px;
    background-color: var(--background-color);
    color: var(--text-color);
    cursor: pointer;
    min-width: 200px;
}

.host-dropdown:hover {
    border-color: var(--link-color);
}

.host-dropdown:focus {
    outline: none;
    border-color: var(--link-color);
    box-shadow: 0 0 0 0.2rem var(--nav-hover-bg);
}

.connection-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background-color: var(--background-color);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 13px;
    color: var(--text-color);
}

.status-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--success-color);
    animation: pulse 2s infinite;
}

.status-indicator.connecting {
    background-color: var(--warning-color);
}

.status-indicator.error {
    background-color: var(--warning-color);
    animation: none;
}

@keyframes pulse {
    0%, 100% {
        opacity: 1;
    }
    50% {
        opacity: 0.5;
    }
}

.start-server-button {
    padding: 8px 16px;
    background-color: var(--accent-color);
    color: var(--button-text);
    border: none;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.2s;
    white-space: nowrap;
}

.start-server-button:hover {
    background-color: var(--accent-color);
    opacity: 0.9;
    transform: translateY(-2px);
}

.start-server-button:active {
    transform: translateY(0);
}

.start-server-button:disabled {
    background-color: var(--border-color);
    cursor: not-allowed;
    transform: none;
}

.start-server-button.loading {
    opacity: 0.7;
    cursor: wait;
}

.current-host-display {
    margin: 10px 0;
    padding: 10px;
    background-color: var(--secondary-color);
    border-radius: 4px;
    font-size: 14px;
}

.current-host-display .host-label {
    font-weight: 600;
    color: var(--schema-text-muted);
    margin-right: 8px;
}

.current-host-display .host-name {
    color: var(--text-color);
    font-family: monospace;
}

/* Chat Messages Styles */
.chat-messages {
    flex: 1;
    overflow-y: auto;
    background-color: var(--background-color);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.welcome-message {
    text-align: center;
    color: var(--text-color);
    opacity: 0.7;
    padding: 40px 20px;
}

.welcome-message h2 {
    color: var(--success-color);
    margin-bottom: 10px;
}

.chat-message {
    display: flex;
    flex-direction: column;
    max-width: 80%;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.chat-message.user {
    align-self: flex-end;
}

.chat-message.assistant {
    align-self: flex-start;
}

.message-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 5px;
    font-size: 12px;
    color: var(--text-color);
    opacity: 0.8;
}

.message-role {
    font-weight: bold;
}

.message-role.user {
    color: var(--link-color);
}

.message-role.assistant {
    color: var(--success-color);
}

.message-timestamp {
    font-size: 11px;
    color: var(--text-color);
    opacity: 0.6;
}

.copy-message-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    padding: 2px 5px;
    margin-left: auto;
    opacity: 0.6;
    transition: opacity 0.2s;
    border-radius: 3px;
    color: var(--text-color);
}

.copy-message-btn:hover {
    opacity: 1;
    background-color: var(--secondary-color);
}

.message-content {
    padding: 12px 16px;
    border-radius: 12px;
    line-height: 1.6;
    white-space: pre-wrap;
    word-wrap: break-word;
}

.chat-message.user .message-content {
    background-color: var(--link-color);
    color: var(--text-color);
    border-bottom-right-radius: 4px;
}

.chat-message.assistant .message-content {
    background-color: var(--secondary-color);
    color: var(--text-color);
    border: 1px solid var(--border-color);
    border-bottom-left-radius: 4px;
}

.message-loading {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background-color: var(--secondary-color);
    border-radius: 12px;
    border-bottom-left-radius: 4px;
    color: var(--text-color);
    opacity: 0.8;
    font-style: italic;
}

.loading-spinner {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

/* Chat Input Styles */
.chat-input-container {
    background-color: var(--background-color);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 15px;
}

.chat-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.chat-input {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-size: 14px;
    font-family: inherit;
    background-color: var(--background-color);
    color: var(--text-color);
    resize: vertical;
    min-height: 60px;
    max-height: 200px;
    overflow-y: auto;
}

.code-block {
    background-color: var(--secondary-color);
    color: var(--text-color);
    border: 1px solid var(--border-color);
    padding: 10px;
    border-radius: 5px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 13px;
    margin: 10px 0;
    overflow-x: auto;
    white-space: pre;
    display: block;
}

.chat-message.assistant .code-block {
    background-color: var(--secondary-color);
}

.chat-input:focus {
    outline: none;
    border-color: var(--success-color);
    box-shadow: 0 0 0 2px var(--nav-hover-bg);
}

.chat-controls {
    display: flex;
    justify-content: space-between;
    gap: 10px;
}

.button {
    padding: 10px 20px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    gap: 8px;
    background-color: var(--secondary-color);
    color: var(--text-color);
}

.button.primary {
    background-color: var(--success-color);
    color: var(--text-color);
    border: none;
}

.button.primary:hover:not(:disabled) {
    opacity: 0.8;
}

.button.primary:disabled {
    background-color: var(--secondary-color);
    opacity: 0.5;
    cursor: not-allowed;
}

.button.secondary {
    background-color: var(--secondary-color);
    color: var(--text-color);
    border: 1px solid var(--border-color);
}

.button.secondary:hover {
    background-color: var(--background-color);
}

/* Status Messages */
.status-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1000;
    max-width: 400px;
}

.status-message {
    padding: 15px;
    margin-bottom: 10px;
    border-radius: 5px;
    box-shadow: var(--dropdown-shadow);
    animation: slideIn 0.3s ease;
}

.status-message.success {
    background-color: var(--secondary-color);
    border: 1px solid var(--success-color);
    color: var(--text-color);
}

.status-message.error {
    background-color: var(--secondary-color);
    border: 1px solid var(--warning-color);
    color: var(--text-color);
}

.status-message.info {
    background-color: var(--secondary-color);
    border: 1px solid var(--link-color);
    color: var(--text-color);
}

@keyframes slideIn {
    from {
        transform: translateX(400px);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

/* Scrollbar Styles */
.chat-messages::-webkit-scrollbar {
    width: 8px;
}

.chat-messages::-webkit-scrollbar-track {
    background-color: var(--secondary-color);
    border-radius: 4px;
}

.chat-messages::-webkit-scrollbar-thumb {
    background-color: var(--border-color);
    border-radius: 4px;
}

.chat-messages::-webkit-scrollbar-thumb:hover {
    background-color: var(--text-color);
    opacity: 0.5;
}
</style>

<script src="/static/js/ai-common.js"></script>
<script>
// Chat state management
let conversationHistory = [];
let isProcessing = false;
let currentConversationId = null;

// DOM elements
const chatForm = document.getElementById('chat-form');
const userInput = document.getElementById('user-input');
const chatMessages = document.getElementById('chat-messages');
const sendButton = document.getElementById('send-button');
const clearChatButton = document.getElementById('clear-chat');
const modelSelect = document.getElementById('model-select');
const hostSelect = document.getElementById('host-select');
const statusIndicator = document.getElementById('status-indicator');
const statusText = document.getElementById('status-text');
const startServerBtn = document.getElementById('start-server-btn');

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    // Load conversation history and conversation ID from sessionStorage
    loadConversationHistory();
    loadConversationId();
    
    // Set up event listeners
    chatForm.addEventListener('submit', handleSubmit);
    clearChatButton.addEventListener('click', clearChat);
    
    // Allow Ctrl+Enter to submit
    userInput.addEventListener('keydown', function(e) {
        if (e.ctrlKey && e.key === 'Enter') {
            e.preventDefault();
            chatForm.dispatchEvent(new Event('submit'));
        }
    });
    
    // Auto-resize textarea
    userInput.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = (this.scrollHeight) + 'px';
    });
    
    // Handle host selection change
    if (hostSelect) {
        hostSelect.addEventListener('change', handleHostChange);
    }
    
    // Handle server start button
    if (startServerBtn) {
        startServerBtn.addEventListener('click', startOllamaServer);
        // Check server status on page load
        checkServerStatus();
        // Check server status every 60 seconds (reduced from 5s to avoid hammering)
        setInterval(checkServerStatus, 60000);
    }
});

// Handle host change
async function handleHostChange() {
    const newHost = hostSelect.value;
    
    // Update UI to show connecting state
    if (statusIndicator) {
        statusIndicator.classList.add('connecting');
        statusIndicator.classList.remove('error');
    }
    if (statusText) {
        statusText.textContent = `Connecting to ${newHost}...`;
    }
    
    try {
        const response = await fetch('/ai/set_host', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ host: newHost })
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Update UI to show success
            if (statusIndicator) {
                statusIndicator.classList.remove('connecting', 'error');
            }
            if (statusText) {
                const connInfo = data.connection_info;
                statusText.textContent = `Connected to ${connInfo.host}:${connInfo.port}`;
            }
            
            // Show success message
            addMessage('system', `Successfully switched to ${newHost}. Model: ${data.connection_info.model}`);
            
            // Clear conversation history when switching hosts
            conversationHistory = [];
            currentConversationId = null;
            saveConversationHistory();
            try {
                sessionStorage.removeItem('ai_current_conversation_id');
            } catch (e) {
                console.error('Failed to clear conversation ID:', e);
            }
            document.getElementById('conversation-info').style.display = 'none';
            document.getElementById('conversation-id-display').textContent = '-';
            
        } else {
            // Show error
            if (statusIndicator) {
                statusIndicator.classList.remove('connecting');
                statusIndicator.classList.add('error');
            }
            if (statusText) {
                statusText.textContent = `Connection failed: ${data.error}`;
            }
            
            // Revert selection
            const currentHost = '[% current_host || "localhost" %]';
            hostSelect.value = currentHost;
            
            // Show error message
            addMessage('system', `Failed to switch host: ${data.error}`);
        }
        
    } catch (error) {
        console.error('Error changing host:', error);
        
        // Update UI to show error
        if (statusIndicator) {
            statusIndicator.classList.remove('connecting');
            statusIndicator.classList.add('error');
        }
        if (statusText) {
            statusText.textContent = 'Connection error';
        }
        
        // Revert selection
        const currentHost = '[% current_host || "localhost" %]';
        hostSelect.value = currentHost;
        
        // Show error message
        addMessage('system', `Error changing host: ${error.message}`);
    }
}

// Check Ollama server status
async function checkServerStatus() {
    // Skip Ollama check if an external provider (Grok etc.) is selected
    const selectedModel = document.getElementById('model-select');
    if (selectedModel && selectedModel.value && selectedModel.value.startsWith('grok')) {
        return;
    }
    const currentHost = hostSelect ? hostSelect.value : '[% current_host || "localhost" %]';
    
    // Only show button for localhost
    if (currentHost !== 'localhost' && currentHost !== '127.0.0.1') {
        if (startServerBtn) {
            startServerBtn.style.display = 'none';
        }
        return;
    }
    
    try {
        const response = await fetch('/ai/server_status', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ host: currentHost })
        });
        
        const data = await response.json();
        
        if (data.running) {
            // Server is running, hide button
            if (startServerBtn) {
                startServerBtn.style.display = 'none';
            }
            if (statusIndicator) {
                statusIndicator.classList.remove('error', 'connecting');
            }
        } else {
            // Server is not running, show button
            if (startServerBtn) {
                startServerBtn.style.display = 'inline-block';
            }
            if (statusIndicator) {
                statusIndicator.classList.add('error');
            }
        }
    } catch (error) {
        console.error('Error checking server status:', error);
        // On error, show button in case server is down
        if (startServerBtn) {
            startServerBtn.style.display = 'inline-block';
        }
        if (statusIndicator) {
            statusIndicator.classList.add('error');
        }
    }
}

// Start Ollama server
async function startOllamaServer() {
    if (!startServerBtn) return;
    
    const currentHost = hostSelect ? hostSelect.value : '[% current_host || "localhost" %]';
    
    // Add loading state
    startServerBtn.disabled = true;
    startServerBtn.classList.add('loading');
    const originalText = startServerBtn.textContent;
    startServerBtn.textContent = 'Starting...';
    
    try {
        const response = await fetch('/ai/start_server', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ 
                startup_method: 'command',
                host: currentHost 
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            showStatus('success', 'Ollama server started successfully!');
            
            // Wait a moment for server to fully start
            await new Promise(resolve => setTimeout(resolve, 2000));
            
            // Check status again
            await checkServerStatus();
            
            // Restore connection status
            if (statusIndicator) {
                statusIndicator.classList.remove('error');
            }
            if (statusText) {
                statusText.textContent = `Connected to ${currentHost}:11434`;
            }
        } else {
            showStatus('error', data.message || 'Failed to start server');
        }
    } catch (error) {
        console.error('Error starting server:', error);
        showStatus('error', 'Error: ' + error.message);
    } finally {
        startServerBtn.disabled = false;
        startServerBtn.classList.remove('loading');
        startServerBtn.textContent = originalText;
    }
}

// Handle form submission
async function handleSubmit(e) {
    e.preventDefault();
    
    if (isProcessing) return;
    
    const prompt = userInput.value.trim();
    if (!prompt) return;
    
    // Get selected model (if available)
    const selectedModel = modelSelect ? modelSelect.value : null;
    
    // Add user message to chat
    addMessage('user', prompt);
    
    // Clear input
    userInput.value = '';
    userInput.style.height = 'auto';
    
    // Show loading state
    isProcessing = true;
    updateSendButton(true);
    const loadingId = addLoadingMessage();
    
    try {
        // Send request to server
        const requestBody = {
            prompt: prompt,
            model: selectedModel,
            history: conversationHistory.slice(-10) // Send last 10 messages for context
        };
        
        // Include conversation ID if we're continuing an existing conversation
        console.log('DEBUG: Before sending request - currentConversationId:', currentConversationId);
        if (currentConversationId) {
            requestBody.conversation_id = currentConversationId;
            console.log('DEBUG: Adding conversation_id to request body:', currentConversationId);
        } else {
            console.log('DEBUG: No currentConversationId - will create NEW conversation');
        }
        console.log('DEBUG: Full request body:', requestBody);
        
        const response = await fetch('/ai/chat', {
            method: 'POST',
            credentials: 'include',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(requestBody)
        });
        
        const data = await response.json();
        
        // Remove loading message
        removeLoadingMessage(loadingId);
        
        if (data.success) {
            // Update conversation ID if returned (first message in conversation)
            if (data.conversation_id) {
                currentConversationId = data.conversation_id;
                saveConversationId();
                document.getElementById('conversation-id-display').textContent = data.conversation_id;
                document.getElementById('conversation-info').style.display = 'block';
                showStatus('success', `Conversation #${data.conversation_id} saved`);
            }
            // Add AI response to chat
            addMessage('assistant', data.response, data.model);
        } else {
            showStatus('error', data.error || 'Failed to get response');
            // Remove the user message if request failed
            conversationHistory.pop();
            renderMessages();
        }
    } catch (error) {
        removeLoadingMessage(loadingId);
        showStatus('error', 'Network error: ' + error.message);
        // Remove the user message if request failed
        conversationHistory.pop();
        renderMessages();
    } finally {
        isProcessing = false;
        updateSendButton(false);
        userInput.focus();
    }
}

// Add message to conversation
function addMessage(role, content, model = null) {
    const message = {
        role: role,
        content: content,
        timestamp: new Date().toISOString(),
        model: model
    };
    
    conversationHistory.push(message);
    saveConversationHistory();
    renderMessages();
    scrollToBottom();
}

// Render all messages
function renderMessages() {
    // Clear existing messages except welcome
    const welcomeMessage = chatMessages.querySelector('.welcome-message');
    chatMessages.innerHTML = '';
    
    if (conversationHistory.length === 0 && welcomeMessage) {
        chatMessages.appendChild(welcomeMessage);
        return;
    }
    
    conversationHistory.forEach(message => {
        const messageDiv = createMessageElement(message);
        chatMessages.appendChild(messageDiv);
    });
}

// Create message element
function createMessageElement(message) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `chat-message ${message.role}`;
    
    const timestamp = new Date(message.timestamp).toLocaleTimeString();
    
    messageDiv.innerHTML = `
        <div class="message-header">
            <span class="message-role ${message.role}">
                ${message.role === 'user' ? 'You' : 'AI Assistant'}
            </span>
            <span class="message-timestamp">${timestamp}</span>
            ${message.model ? `<span class="message-model">(${message.model})</span>` : ''}
            ${message.role === 'assistant' ? `<button class="copy-message-btn" onclick="copyMessageText(this)" title="Copy message content">📋</button>` : ''}
        </div>
        <div class="message-content" data-raw-content="${AIUtils.escapeHtml(message.content)}">${AIUtils.formatMessageContent(message.content)}</div>
    `;
    
    return messageDiv;
}

// Add loading message
function addLoadingMessage() {
    const loadingId = 'loading-' + Date.now();
    const loadingDiv = document.createElement('div');
    loadingDiv.id = loadingId;
    loadingDiv.className = 'chat-message assistant';
    loadingDiv.innerHTML = `
        <div class="message-loading">
            <span class="loading-spinner">⏳</span>
            <span>AI is thinking...</span>
        </div>
    `;
    chatMessages.appendChild(loadingDiv);
    scrollToBottom();
    return loadingId;
}

// Remove loading message
function removeLoadingMessage(loadingId) {
    const loadingDiv = document.getElementById(loadingId);
    if (loadingDiv) {
        loadingDiv.remove();
    }
}

// Update send button state
function updateSendButton(loading) {
    const buttonText = sendButton.querySelector('.button-text');
    const buttonSpinner = sendButton.querySelector('.button-spinner');
    
    if (loading) {
        sendButton.disabled = true;
        buttonText.style.display = 'none';
        buttonSpinner.style.display = 'inline';
    } else {
        sendButton.disabled = false;
        buttonText.style.display = 'inline';
        buttonSpinner.style.display = 'none';
    }
}

// Clear chat
async function clearChat() {
    if (confirm('Are you sure you want to clear the chat history?')) {
        // Clear server session
        try {
            await fetch('/ai/reset_conversation', { method: 'POST' });
        } catch (e) {
            console.error('Failed to reset conversation on server:', e);
        }

        conversationHistory = [];
        currentConversationId = null;
        saveConversationHistory();
        try {
            sessionStorage.removeItem('ai_current_conversation_id');
        } catch (e) {
            console.error('Failed to clear conversation ID:', e);
        }
        document.getElementById('conversation-info').style.display = 'none';
        document.getElementById('conversation-id-display').textContent = '-';
        renderMessages();
        showStatus('info', 'Chat history cleared');
    }
}

// Save conversation to sessionStorage
function saveConversationHistory() {
    try {
        sessionStorage.setItem('ai_chat_history', JSON.stringify(conversationHistory));
    } catch (e) {
        console.error('Failed to save conversation history:', e);
    }
}

// Load conversation from sessionStorage
function loadConversationHistory() {
    try {
        const saved = sessionStorage.getItem('ai_chat_history');
        if (saved) {
            conversationHistory = JSON.parse(saved);
            renderMessages();
        }
    } catch (e) {
        console.error('Failed to load conversation history:', e);
    }
}

// Save conversation ID to sessionStorage
function saveConversationId() {
    try {
        if (currentConversationId) {
            sessionStorage.setItem('ai_current_conversation_id', currentConversationId);
            console.log('DEBUG: Saved conversationId to sessionStorage:', currentConversationId);
        } else {
            console.warn('DEBUG: Attempted saveConversationId but currentConversationId is:', currentConversationId);
        }
    } catch (e) {
        console.error('Failed to save conversation ID:', e);
    }
}

// Load conversation ID from sessionStorage
function loadConversationId() {
    try {
        const saved = sessionStorage.getItem('ai_current_conversation_id');
        console.log('DEBUG: loadConversationId() - saved value:', saved);
        if (saved) {
            currentConversationId = saved;
            const displayEl = document.getElementById('conversation-id-display');
            const infoEl = document.getElementById('conversation-info');
            if (displayEl && infoEl) {
                displayEl.textContent = currentConversationId;
                infoEl.style.display = 'block';
            }
            console.log('DEBUG: Loaded conversationId from sessionStorage:', currentConversationId);
        } else {
            console.log('DEBUG: No conversation ID in sessionStorage - will create new conversation');
        }
    } catch (e) {
        console.error('Failed to load conversation ID:', e);
    }
}

// Scroll to bottom of chat
function scrollToBottom() {
    chatMessages.scrollTop = chatMessages.scrollHeight;
}

// Copy message text
function copyMessageText(btn) {
    const messageDiv = btn.closest('.chat-message');
    const contentDiv = messageDiv.querySelector('.message-content');
    
    // Find the message in history or extract from textContent
    // Using textContent might be slightly off if formatted, better to find in history
    // But since history is global, we can use it.
    
    // Find which index this is
    const messages = Array.from(chatMessages.querySelectorAll('.chat-message'));
    const index = messages.indexOf(messageDiv);
    
    let textToCopy = '';
    if (index !== -1 && conversationHistory[index]) {
        textToCopy = conversationHistory[index].content;
    } else {
        textToCopy = contentDiv.textContent;
    }
    
    navigator.clipboard.writeText(textToCopy).then(() => {
        const originalText = btn.textContent;
        btn.textContent = '✅';
        setTimeout(() => {
            btn.textContent = originalText;
        }, 2000);
    }).catch(err => {
        console.error('Failed to copy text: ', err);
        showStatus('error', 'Failed to copy text');
    });
}

// Show status message
function showStatus(type, message) {
    const statusContainer = document.getElementById('status-container');
    const statusDiv = document.createElement('div');
    statusDiv.className = `status-message ${type}`;
    statusDiv.textContent = message;
    
    statusContainer.appendChild(statusDiv);
    
    setTimeout(() => {
        statusDiv.style.opacity = '0';
        setTimeout(() => statusDiv.remove(), 300);
    }, 5000);
}
</script>