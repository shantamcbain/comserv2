[% META
   title = "AI Chat"
   description = "Interactive AI chat interface"
   roles = "user,admin,developer"
   category = "AI Module"
   page_version = "0.11"
   last_updated = "Fri Jan 23 15:00:00 UTC 2026"
%]

[% PageVersion = 'ai/index.tt,v 0.11 2026/01/23 15:00:00 CleanupAgent Exp - Consolidated message formatting and theme cleanup'; %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="ai-page-wrap">

    <!-- Top control bar -->
    <div class="ai-topbar">
        <div class="ai-topbar-left">
            <span class="ai-topbar-title">AI Assistant</span>
            <span id="conversation-info" class="ai-conv-badge" style="display:none;">
                #<span id="conversation-id-display">-</span>
            </span>
        </div>
        <div class="ai-topbar-center">
            [% IF (can_select_model || (external_models && external_models.size > 0)) && (username && !username.match('^Guest-')) %]
            <select id="model-select" class="ai-model-select" title="Select AI model">
                [% IF installed_models && installed_models.size > 0 %]
                    <optgroup label="Ollama (Local)">
                    [% FOREACH model IN installed_models %]
                        <option value="[% model.name %]" data-provider="ollama" [% IF model.name == current_model %]selected[% END %]>
                            [% model.name %][% IF model.details.parameter_size %] ([% model.details.parameter_size %])[% END %]
                        </option>
                    [% END %]
                    </optgroup>
                [% END %]
                [% IF external_models && external_models.size > 0 %]
                    <optgroup label="External AI">
                    [% FOREACH ext_model IN external_models %]
                        <option value="[% ext_model.name %]" data-provider="[% ext_model.provider %]">
                            [% ext_model.label %]
                        </option>
                    [% END %]
                    </optgroup>
                [% END %]
                [% IF (!installed_models || installed_models.size == 0) && (!external_models || external_models.size == 0) %]
                    <option value="">No models available</option>
                [% END %]
            </select>
            [% ELSE %]
            <span class="ai-model-name">[% current_model || 'AI' %]</span>
            [% END %]

            [% IF can_select_model %]
            <select id="host-select" class="ai-host-select" title="Ollama server">
                <option value="localhost" [% IF current_host == 'localhost' || current_host == '127.0.0.1' %]selected[% END %]>localhost</option>
                <option value="192.168.1.199" [% IF current_host == '192.168.1.199' %]selected[% END %]>192.168.1.199</option>
            </select>
            <span id="connection-status" class="ai-conn-status">
                <span class="status-indicator" id="status-indicator"></span>
                <span id="status-text">[% current_host || 'localhost' %]</span>
            </span>
            <button id="start-server-btn" class="ai-start-btn" style="display:none;">Start Ollama</button>
            [% END %]
        </div>
        <div class="ai-topbar-right">
            [% IF username && !username.match('^Guest-') %]
            <a href="/ai/manage_api_keys" class="ai-topbar-btn" title="Manage API keys">🔑</a>
            <a href="/ai/models" class="ai-topbar-btn" title="Manage models">⚙️</a>
            [% END %]
            <button type="button" id="dock-to-page-btn" class="ai-topbar-btn" title="Dock chat back to page" style="display:none;">⤡</button>
            <button type="button" id="clear-chat" class="ai-topbar-btn" title="New chat">✏️</button>
            <a href="/" class="ai-topbar-btn" title="Return to menu">🏠</a>
            [% IF username && !username.match('^Guest-') && can_select_model %]
            <button type="button" id="toggle-sidebar-btn" class="ai-topbar-btn ai-sidebar-toggle" title="Toggle history panel" aria-label="History">🕐</button>
            <button type="button" id="flip-sidebar-btn" class="ai-topbar-btn" title="Move sidebar to other side">⇄</button>
            [% END %]
        </div>
    </div>

    <!-- Body: main chat + right sidebar -->
    <div class="ai-body">

        <!-- Main chat column -->
        <div class="ai-main">
            <div class="chat-messages" id="chat-messages">
                <div class="welcome-message">
                    <div class="welcome-icon">🤖</div>
                    <h2>How can I help you today?</h2>
                    <p>Ask me anything. [% IF can_select_model %]Select a model above to use Ollama (local) or an external AI like Grok.[% END %]</p>
                </div>
            </div>

            <div class="ai-input-bar">
                <form id="chat-form" class="ai-input-form">
                    <textarea
                        id="user-input"
                        name="prompt"
                        class="ai-textarea"
                        placeholder="Message AI Assistant... (Enter to send, Shift+Enter for new line)"
                        rows="1"
                        required
                    ></textarea>
                    <button type="submit" id="send-button" class="ai-send-btn" title="Send message">
                        <span class="button-text">➤</span>
                        <span class="button-spinner" style="display:none;">⏳</span>
                    </button>
                </form>
                <div class="ai-input-hint">Shift+Enter for new line · Enter to send</div>
            </div>
        </div>

        <!-- Right sidebar -->
        [% IF can_select_model %]
        <div class="ai-sidebar" id="ai-sidebar">
            <nav class="sidebar-nav">
                <button class="sidebar-nav-btn active" data-panel="history" title="Conversation History">
                    🕐<span>History</span>
                </button>
                <button class="sidebar-nav-btn" data-panel="search" title="Search Conversations">
                    🔍<span>Search</span>
                </button>
                <button class="sidebar-nav-btn" data-panel="voice" title="Voice (coming soon)" disabled>
                    🎤<span>Voice</span>
                </button>
                <button class="sidebar-nav-btn" data-panel="image" title="Image Generation (coming soon)" disabled>
                    🖼️<span>Image</span>
                </button>
            </nav>

            <div class="sidebar-content">
                <!-- History panel -->
                <div class="sidebar-panel" id="panel-history">
                    <button id="new-chat-sidebar" class="sidebar-new-chat-btn">✏️ New Chat</button>
                    <div class="sidebar-section-title">Recent Conversations</div>
                    <div id="sidebar-history-list" class="sidebar-history-list">
                        <div class="sidebar-loading">Loading…</div>
                    </div>
                </div>

                <!-- Search panel -->
                <div class="sidebar-panel hidden" id="panel-search">
                    <input type="text" id="sidebar-search-input" class="sidebar-search-input" placeholder="Search conversations…">
                    <div id="sidebar-search-results" class="sidebar-history-list"></div>
                </div>

                <!-- Voice placeholder -->
                <div class="sidebar-panel hidden" id="panel-voice">
                    <div class="sidebar-coming-soon">🎤<br>Voice input<br><small>Coming soon</small></div>
                </div>

                <!-- Image placeholder -->
                <div class="sidebar-panel hidden" id="panel-image">
                    <div class="sidebar-coming-soon">🖼️<br>Image generation<br><small>Coming soon</small></div>
                </div>
            </div>
        </div>
        [% END %]

    </div><!-- /.ai-body -->

    <div id="status-container" class="status-container"></div>
</div>

<style>
/* Full-page chat layout */
.ai-page-wrap {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--page-top-offset, 90px));
    min-height: 500px;
    background-color: var(--background-color);
    color: var(--text-color);
}

/* Top bar */
.ai-topbar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    background-color: var(--secondary-color);
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
    flex-wrap: wrap;
}
.ai-topbar-left { display: flex; align-items: center; gap: 8px; }
.ai-topbar-title { font-weight: 700; font-size: 1rem; color: var(--text-color); }
.ai-conv-badge {
    font-size: 11px; color: var(--link-color);
    background: var(--background-color); border: 1px solid var(--border-color);
    padding: 2px 7px; border-radius: 10px;
}
.ai-topbar-center {
    display: flex; align-items: center; gap: 8px; flex: 1; flex-wrap: wrap;
}
.ai-model-select, .ai-host-select {
    padding: 5px 10px; border: 1px solid var(--border-color);
    border-radius: 6px; font-size: 13px;
    background-color: var(--background-color); color: var(--text-color);
    cursor: pointer;
}
.ai-model-select { min-width: 180px; }
.ai-host-select { min-width: 130px; }
.ai-model-name { font-size: 13px; color: var(--link-color); font-family: monospace; }
.ai-conn-status {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; color: var(--text-color); opacity: 0.8;
}
.ai-start-btn {
    padding: 4px 10px; font-size: 12px; border: 1px solid var(--border-color);
    border-radius: 4px; cursor: pointer;
    background-color: var(--accent-color); color: var(--button-text, #fff);
}
.ai-topbar-right { display: flex; align-items: center; gap: 4px; }
.ai-topbar-btn {
    padding: 5px 8px; font-size: 16px; border: none; background: transparent;
    cursor: pointer; border-radius: 6px; color: var(--text-color);
    text-decoration: none; transition: background 0.2s;
}
.ai-topbar-btn:hover { background-color: var(--background-color); }

/* Status indicator dot */
.status-indicator {
    width: 8px; height: 8px; border-radius: 50%;
    background-color: var(--success-color); animation: pulse 2s infinite;
}
.status-indicator.connecting { background-color: var(--warning-color); }
.status-indicator.error { background-color: var(--warning-color); animation: none; }
@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

/* Messages area */
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
}

.welcome-message {
    text-align: center; padding: 60px 20px; opacity: 0.75;
}
.welcome-icon { font-size: 48px; margin-bottom: 16px; }
.welcome-message h2 { margin: 0 0 8px; font-size: 1.4rem; color: var(--text-color); }
.welcome-message p { margin: 0; font-size: 14px; }

/* Chat messages */
.chat-message {
    display: flex; flex-direction: column;
    max-width: 80%; animation: fadeIn 0.25s ease;
}
@keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:none; } }
.chat-message.user { align-self: flex-end; }
.chat-message.assistant { align-self: flex-start; max-width: 90%; }

.message-header {
    display: flex; align-items: center; gap: 6px;
    margin-bottom: 4px; font-size: 11px; opacity: 0.7;
}
.message-role { font-weight: 600; }
.message-role.user { color: var(--link-color); }
.message-role.assistant { color: var(--success-color); }
.message-timestamp { font-size: 10px; }
.copy-message-btn {
    background: none; border: none; cursor: pointer; font-size: 12px;
    padding: 1px 5px; margin-left: auto; opacity: 0.5;
    border-radius: 3px; color: var(--text-color); transition: opacity 0.2s;
}
.copy-message-btn:hover { opacity: 1; background: var(--secondary-color); }

.message-content {
    padding: 10px 14px; border-radius: 14px;
    line-height: 1.65; white-space: pre-wrap; word-wrap: break-word;
    font-size: 14px;
}
.chat-message.user .message-content {
    background-color: var(--link-color); color: #fff;
    border-bottom-right-radius: 4px;
}
.chat-message.assistant .message-content {
    background-color: var(--secondary-color); color: var(--text-color);
    border: 1px solid var(--border-color); border-bottom-left-radius: 4px;
}

.code-block {
    background-color: var(--background-color); color: var(--text-color);
    border: 1px solid var(--border-color); padding: 10px 14px;
    border-radius: 6px; font-family: monospace; font-size: 13px;
    margin: 8px 0; overflow-x: auto; white-space: pre; display: block;
}

.message-loading {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px; background-color: var(--secondary-color);
    border-radius: 14px; border-bottom-left-radius: 4px;
    color: var(--text-color); opacity: 0.8; font-style: italic; font-size: 13px;
}
.loading-spinner { animation: spin 1s linear infinite; }
@keyframes spin { from { transform:rotate(0deg); } to { transform:rotate(360deg); } }

/* Input bar - sticky at bottom */
.ai-input-bar {
    flex-shrink: 0;
    padding: 12px 16px 8px;
    background-color: var(--background-color);
    border-top: 1px solid var(--border-color);
    max-width: 900px; width: 100%; margin: 0 auto; box-sizing: border-box;
}
.ai-input-form {
    display: flex; align-items: flex-end; gap: 8px;
    border: 1px solid var(--border-color); border-radius: 12px;
    padding: 8px 12px; background-color: var(--secondary-color);
}
.ai-textarea {
    flex: 1; border: none; background: transparent; resize: none;
    font-size: 14px; font-family: inherit; color: var(--text-color);
    line-height: 1.5; max-height: 200px; overflow-y: auto;
    outline: none; padding: 2px 0;
}
.ai-textarea::placeholder { color: var(--text-color); opacity: 0.5; }
.ai-send-btn {
    padding: 6px 12px; background-color: var(--link-color);
    color: #fff; border: none; border-radius: 8px;
    cursor: pointer; font-size: 16px; line-height: 1;
    transition: opacity 0.2s; flex-shrink: 0;
}
.ai-send-btn:hover:not(:disabled) { opacity: 0.85; }
.ai-send-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.ai-input-hint { font-size: 11px; color: var(--text-color); opacity: 0.5; margin-top: 4px; }
.ai-input-hint a { color: var(--link-color); }

/* Status toasts */
.status-container {
    position: fixed; top: 70px; right: 20px; z-index: 1100; max-width: 360px;
}
.status-message {
    padding: 12px 16px; margin-bottom: 8px; border-radius: 8px;
    box-shadow: var(--dropdown-shadow); animation: slideIn 0.3s ease;
    font-size: 13px;
}
.status-message.success { background: var(--secondary-color); border-left: 3px solid var(--success-color); }
.status-message.error   { background: var(--secondary-color); border-left: 3px solid var(--warning-color); }
.status-message.info    { background: var(--secondary-color); border-left: 3px solid var(--link-color); }
@keyframes slideIn { from { transform:translateX(380px); opacity:0; } to { transform:none; opacity:1; } }

/* Scrollbar */
.chat-messages::-webkit-scrollbar { width: 6px; }
.chat-messages::-webkit-scrollbar-track { background: transparent; }
.chat-messages::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 3px; }

/* Override any outer container padding that squishes the chat */
.app-container > .ai-page-wrap,
.content-container > .ai-page-wrap,
.page-content > .ai-page-wrap { margin: -10px -15px; }

/* Body row: main chat + sidebar */
.ai-body {
    display: flex;
    flex: 1;
    overflow: hidden;
}
.ai-main {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
}
.ai-main .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 24px 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
}
.ai-main .ai-input-bar {
    flex-shrink: 0;
    padding: 12px 16px 8px;
    background-color: var(--background-color);
    border-top: 1px solid var(--border-color);
    max-width: 820px;
    width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
}

/* Right sidebar */
.ai-sidebar {
    width: 260px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border-color);
    background-color: var(--secondary-color);
    overflow: hidden;
    transition: width 0.25s ease;
}
.ai-sidebar.collapsed { width: 0; border-left: none; border-right: none; }
.ai-sidebar.sidebar-left { border-left: none; border-right: 1px solid var(--border-color); }

.sidebar-nav {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 8px 6px;
    gap: 2px;
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
}
.sidebar-nav-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--text-color);
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    transition: background 0.15s;
    white-space: nowrap;
}
.sidebar-nav-btn:hover:not(:disabled) { background-color: var(--background-color); }
.sidebar-nav-btn.active { background-color: var(--background-color); font-weight: 600; color: var(--link-color); }
.sidebar-nav-btn:disabled { opacity: 0.4; cursor: not-allowed; }

.sidebar-content { flex: 1; overflow: hidden; display: flex; flex-direction: column; }
.sidebar-panel { flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 6px; }
.sidebar-panel.hidden { display: none; }

.sidebar-new-chat-btn {
    width: 100%;
    padding: 9px 12px;
    background-color: var(--link-color);
    color: #fff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    text-align: left;
    flex-shrink: 0;
}
.sidebar-new-chat-btn:hover { opacity: 0.85; }

.sidebar-section-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-color);
    opacity: 0.5;
    padding: 4px 4px 2px;
    flex-shrink: 0;
}

.sidebar-history-list { display: flex; flex-direction: column; gap: 2px; flex: 1; }
.sidebar-conv-item {
    padding: 8px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    line-height: 1.4;
    color: var(--text-color);
    transition: background 0.15s;
    border: none;
    background: transparent;
    text-align: left;
    width: 100%;
}
.sidebar-conv-item:hover { background-color: var(--background-color); }
.sidebar-conv-item.active { background-color: var(--background-color); border-left: 3px solid var(--link-color); padding-left: 7px; }
.sidebar-conv-title { font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.sidebar-conv-meta { font-size: 10px; opacity: 0.55; margin-top: 2px; }

.sidebar-loading, .sidebar-empty {
    font-size: 12px; color: var(--text-color); opacity: 0.5;
    padding: 16px 8px; text-align: center;
}
.sidebar-search-input {
    width: 100%; padding: 8px 10px; border: 1px solid var(--border-color);
    border-radius: 6px; background-color: var(--background-color);
    color: var(--text-color); font-size: 13px; box-sizing: border-box;
    flex-shrink: 0;
}
.sidebar-search-input:focus { outline: none; border-color: var(--link-color); }

.sidebar-coming-soon {
    text-align: center; padding: 40px 10px; font-size: 28px; opacity: 0.4;
    line-height: 1.8;
}
.sidebar-coming-soon small { font-size: 11px; display: block; }

/* Toggle button active state */
.ai-sidebar-toggle.sidebar-open { color: var(--link-color); }

@media (max-width: 640px) {
    .ai-sidebar { position: absolute; right: 0; top: 0; height: 100%; z-index: 200; }
    .ai-sidebar.collapsed { width: 0; }
}
</style>

<script>
// Tell local-chat.js to run in page mode (bind to this page's DOM, no floating widget)
window.AI_CHAT_PAGE_MODE = true;
window.AI_CHAT_USER_CONFIG = {
    username: '[% username || 'Guest' %]',
    isGuest:  [% (username && !username.match('^Guest-')) ? 'false' : 'true' %],
    isAdmin:  [% can_select_model ? 'true' : 'false' %]
};
</script>
<script src="/static/js/ai-common.js"></script>
<script>
// Sidebar-only state (core chat is handled by local-chat.js in page mode)
let currentConversationId = null;

// DOM elements needed by sidebar / server-status JS
const userInput = document.getElementById('user-input');
const chatMessages = document.getElementById('chat-messages');
const modelSelect    = document.getElementById('model-select');
const hostSelect     = document.getElementById('host-select');
const statusIndicator = document.getElementById('status-indicator');
const statusText     = document.getElementById('status-text');
const startServerBtn = document.getElementById('start-server-btn');

// ── Sidebar ──────────────────────────────────────────────────────────────────

const sidebarEl      = document.getElementById('ai-sidebar');
const toggleSidebarBtn = document.getElementById('toggle-sidebar-btn');
let sidebarOpen = true;    // start open by default

function setSidebar(open) {
    sidebarOpen = open;
    if (open) {
        sidebarEl.classList.remove('collapsed');
        toggleSidebarBtn.classList.add('sidebar-open');
        loadSidebarHistory();
    } else {
        sidebarEl.classList.add('collapsed');
        toggleSidebarBtn.classList.remove('sidebar-open');
    }
}

if (toggleSidebarBtn) {
    toggleSidebarBtn.addEventListener('click', function() { setSidebar(!sidebarOpen); });
}

// ── Sidebar flip (left/right) ─────────────────────────────────────────────────
const flipSidebarBtn = document.getElementById('flip-sidebar-btn');
const aiBody = document.querySelector('.ai-body');

function applySidebarPosition(pos) {
    if (pos === 'left') {
        sidebarEl.classList.add('sidebar-left');
        aiBody.insertBefore(sidebarEl, aiBody.firstChild);
    } else {
        sidebarEl.classList.remove('sidebar-left');
        aiBody.appendChild(sidebarEl);
    }
}

// Restore saved position
try {
    const savedPos = localStorage.getItem('ai_sidebar_pos');
    if (savedPos) applySidebarPosition(savedPos);
} catch(e) {}

if (flipSidebarBtn && sidebarEl) {
    flipSidebarBtn.addEventListener('click', function() {
        const isLeft = sidebarEl.classList.contains('sidebar-left');
        const newPos = isLeft ? 'right' : 'left';
        applySidebarPosition(newPos);
        try { localStorage.setItem('ai_sidebar_pos', newPos); } catch(e) {}
    });
}

// Sidebar tab switching
document.querySelectorAll('.sidebar-nav-btn:not([disabled])').forEach(function(btn) {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.sidebar-nav-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.sidebar-panel').forEach(p => p.classList.add('hidden'));
        btn.classList.add('active');
        const panelId = 'panel-' + btn.dataset.panel;
        const panel = document.getElementById(panelId);
        if (panel) panel.classList.remove('hidden');
    });
});

// New chat button in sidebar
const _newChatSidebar = document.getElementById('new-chat-sidebar');
if (_newChatSidebar) _newChatSidebar.addEventListener('click', function() {
    if (!confirm('Start a new chat? Current conversation will be saved.')) return;
    fetch('/ai/reset_conversation', { method: 'POST', credentials: 'include' }).catch(() => {});
    currentConversationId = null;
    // Clear bridge state and sessionStorage
    if (window.AIChatPageBridge) {
        window.AIChatPageBridge.setConversationId(null);
    }
    document.getElementById('conversation-info').style.display = 'none';
    document.getElementById('conversation-id-display').textContent = '-';
    // Clear messages area
    if (chatMessages) {
        chatMessages.innerHTML = '';
        const wEl = document.createElement('div');
        wEl.className = 'welcome-message';
        wEl.innerHTML = '<div class="welcome-icon">🤖</div><h2>How can I help you today?</h2><p>Ask me anything.</p>';
        chatMessages.appendChild(wEl);
    }
    document.querySelectorAll('.sidebar-conv-item').forEach(i => i.classList.remove('active'));
    if (userInput) userInput.focus();
});

// Load conversation list into sidebar
let _sidebarLoaded = false;
function loadSidebarHistory() {
    const list = document.getElementById('sidebar-history-list');
    fetch('/ai/get_conversation_list', { credentials: 'include' })
        .then(r => r.json())
        .then(function(data) {
            list.innerHTML = '';
            if (!data.success || !data.conversations || !data.conversations.length) {
                list.innerHTML = '<div class="sidebar-empty">No conversations yet</div>';
                return;
            }
            data.conversations.forEach(function(conv) {
                const btn = document.createElement('button');
                btn.className = 'sidebar-conv-item' + (currentConversationId && String(conv.id) === String(currentConversationId) ? ' active' : '');
                btn.dataset.convId = conv.id;
                btn.innerHTML = '<div class="sidebar-conv-title">' + escapeHtml(conv.title || 'Untitled') + '</div>'
                    + '<div class="sidebar-conv-meta">' + (conv.message_count || 0) + ' msgs · ' + formatRelativeTime(conv.updated_at) + '</div>';
                btn.addEventListener('click', function() { loadSidebarConversation(conv.id, btn); });
                list.appendChild(btn);
            });
            _sidebarLoaded = true;
        })
        .catch(function() {
            list.innerHTML = '<div class="sidebar-empty">Failed to load</div>';
        });
}

function loadSidebarConversation(convId, btnEl) {
    fetch('/ai/get_conversation_messages/' + convId, { credentials: 'include' })
        .then(r => r.json())
        .then(function(data) {
            if (!data.success) { showStatus('error', data.error || 'Failed to load'); return; }

            currentConversationId = convId;

            // Sync with local-chat.js bridge state
            if (window.AIChatPageBridge) {
                window.AIChatPageBridge.setConversationId(convId);
            }

            // Update badge
            const displayEl = document.getElementById('conversation-id-display');
            const infoEl    = document.getElementById('conversation-info');
            if (displayEl) displayEl.textContent = convId;
            if (infoEl)    infoEl.style.display   = 'block';

            // Re-render messages using local-chat.js msg-wrapper structure
            if (chatMessages) {
                chatMessages.innerHTML = '';
                (data.messages || []).forEach(function(m) {
                    const isUser = (m.role === 'user');
                    const wrapper = document.createElement('div');
                    wrapper.className = 'msg-wrapper msg-wrapper-' + (isUser ? 'user' : 'ai');
                    const lbl = document.createElement('div');
                    lbl.className = 'msg-label';
                    lbl.textContent = isUser ? (m.username || 'You') : (m.model_used || 'AI Assistant');
                    const el = document.createElement('div');
                    el.className = 'message ' + (isUser ? 'user-message' : 'ai-message');
                    if (!isUser && window.AIUtils) {
                        el.innerHTML = AIUtils.formatMessageContent(m.content || '');
                    } else {
                        el.textContent = m.content || '';
                    }
                    wrapper.appendChild(lbl);
                    wrapper.appendChild(el);
                    chatMessages.appendChild(wrapper);
                });
                scrollToBottom();
            }

            document.querySelectorAll('.sidebar-conv-item').forEach(i => i.classList.remove('active'));
            if (btnEl) btnEl.classList.add('active');
            showStatus('success', 'Loaded: ' + (data.conversation.title || 'Conversation #' + convId));
        })
        .catch(function(e) { showStatus('error', 'Network error: ' + e.message); });
}

// Search
const searchInput = document.getElementById('sidebar-search-input');
let _searchTimer;
if (searchInput) searchInput.addEventListener('input', function() {
    clearTimeout(_searchTimer);
    const q = this.value.trim().toLowerCase();
    _searchTimer = setTimeout(function() {
        const results = document.getElementById('sidebar-search-results');
        if (!q) { results.innerHTML = ''; return; }
        fetch('/ai/get_conversation_list', { credentials: 'include' })
            .then(r => r.json())
            .then(function(data) {
                results.innerHTML = '';
                if (!data.success || !data.conversations) return;
                const matches = data.conversations.filter(c => (c.title || '').toLowerCase().includes(q) || (c.preview || '').toLowerCase().includes(q));
                if (!matches.length) { results.innerHTML = '<div class="sidebar-empty">No results</div>'; return; }
                matches.forEach(function(conv) {
                    const btn = document.createElement('button');
                    btn.className = 'sidebar-conv-item';
                    btn.innerHTML = '<div class="sidebar-conv-title">' + escapeHtml(conv.title || 'Untitled') + '</div>'
                        + '<div class="sidebar-conv-meta">' + (conv.message_count || 0) + ' msgs</div>';
                    btn.addEventListener('click', function() { loadSidebarConversation(conv.id, btn); });
                    results.appendChild(btn);
                });
            }).catch(() => {});
    }, 300);
});

// Helpers
function escapeHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function formatRelativeTime(dateStr) {
    if (!dateStr) return '';
    try {
        const d = new Date(dateStr.replace(' ', 'T'));
        const diff = Date.now() - d.getTime();
        const mins = Math.floor(diff / 60000);
        if (mins < 2) return 'just now';
        if (mins < 60) return mins + 'm ago';
        const hrs = Math.floor(mins / 60);
        if (hrs < 24) return hrs + 'h ago';
        return Math.floor(hrs / 24) + 'd ago';
    } catch(e) { return ''; }
}

// ── Initialize ────────────────────────────────────────────────────────────────

// Initialize
document.addEventListener('DOMContentLoaded', function() {
    // Load conversation ID badge from sessionStorage
    loadConversationId();

    // Kick off sidebar (admin/editor only — sidebarEl may be null for guests)
    if (sidebarEl && toggleSidebarBtn) setSidebar(true);

    // Auto-resume conversation if URL ?resume=ID param present (e.g. from widget detach)
    try {
        const urlParams = new URLSearchParams(window.location.search);
        const resumeId = urlParams.get('resume');
        if (resumeId && !isNaN(resumeId)) {
            setTimeout(function() { loadSidebarConversation(resumeId, null); }, 800);
        }
    } catch(e) {}

    // Dock-back button: only show when this page is a popup opened by the widget
    const dockBtn = document.getElementById('dock-to-page-btn');
    if (dockBtn) {
        try {
            if (window.opener && !window.opener.closed) {
                dockBtn.style.display = '';
                dockBtn.addEventListener('click', function() {
                    // Tell the parent page to re-open the chat widget
                    window.opener.postMessage({ type: 'ai-dock-back' }, window.location.origin);
                    window.close();
                });
            }
        } catch(e) {}
    }

    // Wire up bridge callback so sidebar updates when local-chat.js creates a conversation
    // local-chat.js sets AIChatPageBridge in initPageMode() which runs before DOMContentLoaded
    // resolves, but we use a short timeout as safety margin.
    setTimeout(function() {
        if (window.AIChatPageBridge) {
            window.AIChatPageBridge.onConversationIdChange = function(convId) {
                currentConversationId = convId;
                const displayEl = document.getElementById('conversation-id-display');
                const infoEl    = document.getElementById('conversation-info');
                if (displayEl) displayEl.textContent = convId || '-';
                if (infoEl)    infoEl.style.display   = convId ? 'block' : 'none';
                if (convId && sidebarOpen) loadSidebarHistory();
            };
        }
    }, 200);

    // Host selection change
    if (hostSelect) hostSelect.addEventListener('change', handleHostChange);

    // Server start button
    if (startServerBtn) {
        startServerBtn.addEventListener('click', startOllamaServer);
        checkServerStatus();
        setInterval(checkServerStatus, 60000);
    }
});

// Handle host change
async function handleHostChange() {
    const newHost = hostSelect.value;
    
    // Update UI to show connecting state
    if (statusIndicator) {
        statusIndicator.classList.add('connecting');
        statusIndicator.classList.remove('error');
    }
    if (statusText) {
        statusText.textContent = `Connecting to ${newHost}...`;
    }
    
    try {
        const response = await fetch('/ai/set_host', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ host: newHost })
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Update UI to show success
            if (statusIndicator) {
                statusIndicator.classList.remove('connecting', 'error');
            }
            if (statusText) {
                const connInfo = data.connection_info;
                statusText.textContent = `Connected to ${connInfo.host}:${connInfo.port}`;
            }
            
            // Show success message
            addMessage('system', `Successfully switched to ${newHost}. Model: ${data.connection_info.model}`);
            
            // Clear conversation history when switching hosts
            conversationHistory = [];
            currentConversationId = null;
            saveConversationHistory();
            try {
                sessionStorage.removeItem('ai_current_conversation_id');
            } catch (e) {
                console.error('Failed to clear conversation ID:', e);
            }
            document.getElementById('conversation-info').style.display = 'none';
            document.getElementById('conversation-id-display').textContent = '-';
            
        } else {
            // Show error
            if (statusIndicator) {
                statusIndicator.classList.remove('connecting');
                statusIndicator.classList.add('error');
            }
            if (statusText) {
                statusText.textContent = `Connection failed: ${data.error}`;
            }
            
            // Revert selection
            const currentHost = '[% current_host || "localhost" %]';
            hostSelect.value = currentHost;
            
            // Show error message
            addMessage('system', `Failed to switch host: ${data.error}`);
        }
        
    } catch (error) {
        console.error('Error changing host:', error);
        
        // Update UI to show error
        if (statusIndicator) {
            statusIndicator.classList.remove('connecting');
            statusIndicator.classList.add('error');
        }
        if (statusText) {
            statusText.textContent = 'Connection error';
        }
        
        // Revert selection
        const currentHost = '[% current_host || "localhost" %]';
        hostSelect.value = currentHost;
        
        // Show error message
        addMessage('system', `Error changing host: ${error.message}`);
    }
}

// Check Ollama server status
async function checkServerStatus() {
    // Skip Ollama check if an external provider (Grok etc.) is selected
    const selectedModel = document.getElementById('model-select');
    if (selectedModel && selectedModel.value && selectedModel.value.startsWith('grok')) {
        return;
    }
    const currentHost = hostSelect ? hostSelect.value : '[% current_host || "localhost" %]';
    
    // Only show button for localhost
    if (currentHost !== 'localhost' && currentHost !== '127.0.0.1') {
        if (startServerBtn) {
            startServerBtn.style.display = 'none';
        }
        return;
    }
    
    try {
        const response = await fetch('/ai/server_status', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ host: currentHost })
        });
        
        const data = await response.json();
        
        if (data.running) {
            // Server is running, hide button
            if (startServerBtn) {
                startServerBtn.style.display = 'none';
            }
            if (statusIndicator) {
                statusIndicator.classList.remove('error', 'connecting');
            }
        } else {
            // Server is not running, show button
            if (startServerBtn) {
                startServerBtn.style.display = 'inline-block';
            }
            if (statusIndicator) {
                statusIndicator.classList.add('error');
            }
        }
    } catch (error) {
        console.error('Error checking server status:', error);
        // On error, show button in case server is down
        if (startServerBtn) {
            startServerBtn.style.display = 'inline-block';
        }
        if (statusIndicator) {
            statusIndicator.classList.add('error');
        }
    }
}

// Start Ollama server
async function startOllamaServer() {
    if (!startServerBtn) return;
    
    const currentHost = hostSelect ? hostSelect.value : '[% current_host || "localhost" %]';
    
    // Add loading state
    startServerBtn.disabled = true;
    startServerBtn.classList.add('loading');
    const originalText = startServerBtn.textContent;
    startServerBtn.textContent = 'Starting...';
    
    try {
        const response = await fetch('/ai/start_server', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ 
                startup_method: 'command',
                host: currentHost 
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            showStatus('success', 'Ollama server started successfully!');
            
            // Wait a moment for server to fully start
            await new Promise(resolve => setTimeout(resolve, 2000));
            
            // Check status again
            await checkServerStatus();
            
            // Restore connection status
            if (statusIndicator) {
                statusIndicator.classList.remove('error');
            }
            if (statusText) {
                statusText.textContent = `Connected to ${currentHost}:11434`;
            }
        } else {
            showStatus('error', data.message || 'Failed to start server');
        }
    } catch (error) {
        console.error('Error starting server:', error);
        showStatus('error', 'Error: ' + error.message);
    } finally {
        startServerBtn.disabled = false;
        startServerBtn.classList.remove('loading');
        startServerBtn.textContent = originalText;
    }
}

// Load conversation ID from sessionStorage into the badge display
function loadConversationId() {
    try {
        const saved = sessionStorage.getItem('ai_current_conversation_id')
            || sessionStorage.getItem('currentConversationId');
        if (saved) {
            currentConversationId = saved;
            const displayEl = document.getElementById('conversation-id-display');
            const infoEl    = document.getElementById('conversation-info');
            if (displayEl) displayEl.textContent = currentConversationId;
            if (infoEl)    infoEl.style.display   = 'block';
        }
    } catch (e) { }
}

// Scroll to bottom of chat
function scrollToBottom() {
    if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;
}

// Show status message
function showStatus(type, message) {
    const statusContainer = document.getElementById('status-container');
    const statusDiv = document.createElement('div');
    statusDiv.className = `status-message ${type}`;
    statusDiv.textContent = message;
    
    statusContainer.appendChild(statusDiv);
    
    setTimeout(() => {
        statusDiv.style.opacity = '0';
        setTimeout(() => statusDiv.remove(), 300);
    }, 5000);
}
</script>