[% META
    title = "AI Models Management"
    category = "AI"
    roles = "admin,developer,user"
    page_version = "1.07"
    last_updated = "Thu Jun 11 2026"
    description = "Manage Ollama models and xAI Grok models from your API account."
    keywords = "Ollama, models, pull, test, remove"
    author = "Comserv Team"
%]

[% PageVersion = 'ai/models.tt,v 1.07 2026/06/11 - xAI Grok model list + sync from API key'; %]

[% IF c.debug %]
    <div class="models-debug-info">
        <p>Debug Mode: User=[% username %] | Servers Count=[% servers.size %] | Can Manage=[% can_select_model %]</p>
    </div>
[% END %]

<style>
.models-container {
    padding: 20px;
    max-width: 1200px;
    margin: 0 auto;
}

.models-debug-info {
    background-color: var(--secondary-color, #f5f5f5);
    padding: 10px;
    border: 1px solid var(--border-color, #ccc);
    margin-bottom: 20px;
    font-size: 0.9em;
    color: var(--text-color, #333);
}

.models-toc {
    background-color: var(--secondary-color, #f5f5f5);
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
    border: 1px solid var(--border-color, #ccc);
    color: var(--text-color, #333);
}

.models-card {
    background-color: var(--secondary-color, #f5f5f5);
    border: 1px solid var(--border-color, #ccc);
    border-radius: 8px;
    margin-bottom: 20px;
    overflow: hidden;
}

.models-card-header {
    background-color: var(--nav-bg, #e0e0e0);
    color: var(--nav-text, var(--text-color, #000));
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-color, #ccc);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.models-card-header h5 {
    margin: 0;
    font-size: 1em;
    color: var(--nav-text, var(--text-color, #000));
}

.models-card-body {
    padding: 16px;
    color: var(--text-color, #333);
}

.models-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    gap: 20px;
}

.server-message {
    min-height: 20px;
    font-size: 0.9em;
    color: var(--text-color, #333);
    margin: 8px 0;
}

.models-badge {
    display: inline-block;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 0.78em;
    font-weight: bold;
    color: var(--text-color, #000);
}

.badge-connected    { background-color: var(--success-color, #4caf50); color: #fff; }
.badge-disconnected { background-color: var(--warning-color, #f44336); color: #fff; }
.badge-size         { background-color: var(--link-color, #2196f3);    color: #fff; }

.models-list {
    list-style: none;
    padding: 0;
    margin: 0;
}

.models-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-color, #ddd);
    gap: 8px;
    flex-wrap: wrap;
}

.models-list li:last-child { border-bottom: none; }

.model-name {
    flex: 1;
    min-width: 0;
    word-break: break-all;
    font-size: 0.9em;
}

.model-actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
}

.models-select {
    width: 100%;
    padding: 6px 8px;
    font-size: 0.85em;
    background-color: var(--background-color, #fff);
    color: var(--text-color, #333);
    border: 1px solid var(--border-color, #ccc);
    border-radius: 4px;
    margin-bottom: 8px;
    font-family: inherit;
}

.btn-block { width: 100%; margin-bottom: 8px; }

.btn-sm {
    padding: 3px 8px;
    font-size: 0.78em;
    border-radius: 3px;
    cursor: pointer;
    font-family: inherit;
    border: 1px solid transparent;
}

.btn-outline-success {
    background: none;
    color: var(--success-color, #4caf50);
    border-color: var(--success-color, #4caf50);
}
.btn-outline-success:hover {
    background-color: var(--success-color, #4caf50);
    color: #fff;
}

.btn-outline-danger {
    background: none;
    color: var(--warning-color, #f44336);
    border-color: var(--warning-color, #f44336);
}
.btn-outline-danger:hover {
    background-color: var(--warning-color, #f44336);
    color: #fff;
}

.models-alert-info {
    background-color: var(--secondary-color, #f5f5f5);
    border: 1px solid var(--link-color, #2196f3);
    color: var(--text-color, #333);
    padding: 8px 12px;
    border-radius: 4px;
    margin-bottom: 12px;
    font-size: 0.85em;
}

.models-alert-error {
    background-color: var(--secondary-color, #f5f5f5);
    border: 1px solid var(--warning-color, #f44336);
    color: var(--text-color, #333);
    padding: 8px 12px;
    border-radius: 4px;
    margin-bottom: 12px;
}

.models-footer {
    margin-top: 40px;
    padding: 16px;
    background-color: var(--secondary-color, #f5f5f5);
    color: var(--text-color, #333);
    text-align: center;
    border-top: 1px solid var(--border-color, #ccc);
    font-size: 0.85em;
    opacity: 0.7;
}

.models-section-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 16px;
}

.color-success { color: var(--success-color, #4caf50); }
.color-danger  { color: var(--warning-color, #f44336); }
.color-info    { color: var(--link-color, #2196f3); }
.color-muted   { opacity: 0.65; }

h6.section-subhead {
    margin: 12px 0 6px 0;
    font-size: 0.9em;
    color: var(--text-color, #333);
    opacity: 0.8;
}
</style>

<div class="models-container" data-page-date="2026-03-27">

    <!-- TOC -->
    <div class="models-toc">
        <h2>Table of Contents</h2>
        <ul>
            <li><a href="#overview">Overview</a></li>
            [% FOREACH server IN servers %]
            <li><a href="#server-[% loop.index %]">[% server.name %]</a></li>
            [% END %]
            <li><a href="#xai-grok">xAI Grok Models</a></li>
            <li><a href="#user-api-keys">Your API Keys</a></li>
            <li><a href="#troubleshooting">Troubleshooting</a></li>
        </ul>
    </div>

    <!-- Overview -->
    <section id="overview">
        <h1>AI Models Management</h1>
        <p>Hello, [% username %]. View and manage Ollama models per server and xAI Grok models from your API key. Ollama pull/test/remove requires admin/developer role; Grok models sync from <code>GET https://api.x.ai/v1/models</code> (not the SuperGrok X app subscription).</p>

        [% IF error %]
        <div class="models-alert-error">
            <strong>Error:</strong> [% error %]
        </div>
        [% END %]

        [% IF can_select_model %]
        <div style="margin:12px 0;padding:12px 16px;background:var(--secondary-color,#f5f5f5);border:1px solid var(--border-color,#ccc);border-radius:6px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
            <button id="sync-all-btn" class="btn btn-primary"
                    onclick="syncRecommendedModels()"
                    title="Pull all recommended models not yet installed and remove deprecated ones across all configured servers">
                ↻ Sync Recommended Models
            </button>
            <span style="font-size:0.85em;color:var(--text-color,#555);">Pulls all ★ recommended models &amp; removes old deprecated ones from every server.</span>
            [% IF is_csc_admin %]
            <button id="upgrade-ollama-btn" class="btn btn-warning" style="margin-left:auto;"
                    onclick="upgradeOllama()"
                    title="Run the official Ollama installer script to upgrade the Ollama binary to the latest version">
                ⬆ Upgrade Ollama
            </button>
            [% END %]
        </div>
        <div id="sync-log" style="display:none;margin:8px 0;padding:10px 14px;background:var(--background-color,#fff);border:1px solid var(--border-color,#ccc);border-radius:4px;font-size:0.82em;font-family:monospace;white-space:pre-wrap;max-height:260px;overflow-y:auto;"></div>
        [% END %]
    </section>

    <!-- Server cards -->
    <div class="models-grid">
        [% FOREACH server IN servers %]
        <div class="models-card" id="server-[% loop.index %]">
            <div class="models-card-header">
                <h5>[% server.name %] ([% server.location %])</h5>
                <div id="status-[% loop.index %]">
                    [% IF server.connected %]
                    <span class="models-badge badge-connected">Connected</span>
                    [% IF server.version %]
                    <span class="models-badge badge-size" style="background-color: var(--primary-color, #0077cc);">v[% server.version %]</span>
                    [% END %]
                    [% ELSE %]
                    <span class="models-badge badge-disconnected">Disconnected</span>
                    [% END %]
                </div>
            </div>
            <div class="models-card-body">
                [% IF server.error %]
                <div class="models-alert-error">[% server.error %]</div>
                [% END %]

                [% IF can_select_model %]
                <button class="btn btn-primary btn-block"
                        onclick="startServer([% loop.index %], '[% server.host %]', [% server.port %])">
                    [% IF NOT server.connected %]Start Server[% ELSE %]Restart[% END %]
                </button>
                <div id="message-[% loop.index %]" class="server-message"></div>
                [% ELSE %]
                <div class="models-alert-info">Management requires admin/developer role.</div>
                [% END %]

                [% IF can_select_model %]
                <h6 class="section-subhead">Currently Loaded in Memory
                    <button class="btn btn-sm" style="font-size:0.75em;margin-left:8px;"
                            onclick="refreshRunning([% loop.index %], '[% server.host %]', [% server.port %])">↺ Refresh</button>
                </h6>
                <ul class="models-list" id="running-[% loop.index %]">
                    <li><span class="color-muted">Loading…</span></li>
                </ul>
                [% END %]

                <h6 class="section-subhead">Installed Models</h6>
                <ul class="models-list">
                    [% IF server.installed_models.size %]
                    [% FOREACH model IN server.installed_models %]
                    <li>
                        <span class="model-name">[% model.name %]</span>
                        <span class="models-badge badge-size">[% model.size %]</span>
                        [% IF can_select_model %]
                        <div class="model-actions">
                            <button class="btn btn-sm btn-outline-success"
                                    onclick="testModel('[% model.name %]', '[% server.host %]', [% server.port %])">
                                Test
                            </button>
                            <button class="btn btn-sm" style="background:var(--link-color,#2196f3);color:#fff;"
                                    onclick="unloadModel('[% model.name %]', '[% server.host %]', [% server.port %], [% loop.index %])">
                                Unload
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    onclick="removeModel('[% model.name %]', '[% server.host %]', [% server.port %])">
                                Remove
                            </button>
                        </div>
                        [% END %]
                    </li>
                    [% END %]
                    [% ELSE %]
                    <li><span class="color-muted">No models installed</span></li>
                    [% END %]
                </ul>

                <h6 class="section-subhead">Available Models to Pull</h6>
                <select id="available-select-[% loop.index %]" class="models-select">
                    [% FOREACH avail IN server.available_models %]
                    <option value="[% avail.name %]">[% avail.name %][% IF avail.params %] ([% avail.params %][% IF avail.size %], [% avail.size %][% END %])[% END %][% IF avail.recommended %] ★[% END %]</option>
                    [% END %]
                </select>
                [% IF can_select_model %]
                <button class="btn btn-success btn-block"
                        onclick="pullModel([% loop.index %], '[% server.host %]', [% server.port %])">
                    Pull Selected Model
                </button>
                [% END %]
            </div>
        </div>
        [% END %]
    </div>

    <!-- xAI Grok -->
    <section id="xai-grok" style="margin: 20px 0;">
        <div class="models-card">
            <div class="models-card-header">
                <h5>xAI Grok (API models)</h5>
                [% IF grok_provider.configured %]
                <span class="models-badge badge-connected">API key configured</span>
                [% ELSE %]
                <span class="models-badge badge-disconnected">No API key</span>
                [% END %]
            </div>
            <div class="models-card-body">
                [% IF grok_provider.sync_message %]
                <div class="models-alert-info">[% grok_provider.sync_message %]</div>
                [% END %]

                [% IF grok_provider.error %]
                <div class="models-alert-error">[% grok_provider.error %]</div>
                [% END %]

                [% IF grok_provider.using_fallbacks %]
                <div class="models-alert-error">
                    <strong>Showing defaults only.</strong> The list below (grok-4.3, grok-build-0.1) is a short fallback — not your full x.ai account. Reload this page to sync from xAI server-side.
                </div>
                [% END %]

                <p class="color-muted" style="font-size:0.9em;">[% grok_provider.note %]</p>

                [% IF grok_provider.synced_at_human %]
                <p style="font-size:0.85em;">Last synced: <strong>[% grok_provider.synced_at_human %]</strong>
                    — [% grok_provider.total_synced %] total
                    ([% grok_provider.text_model_count %] text/chat, [% grok_provider.media_model_count %] image/video)</p>
                [% END %]

                [% IF can_select_model %]
                <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
                    <button id="sync-grok-btn" class="btn btn-primary" type="button"
                            onclick="syncGrokModels()"
                            [% UNLESS grok_provider.configured %]disabled title="Add a Grok API key first"[% END %]>
                        ↻ Sync Grok Models (AJAX)
                    </button>
                    [% IF grok_provider.configured %]
                    <a href="/ai/models?sync_grok=1#xai-grok" class="btn btn-secondary"
                       title="Server-side sync — works when AJAX fails with NetworkError">
                        ↻ Sync via page reload
                    </a>
                    [% END %]
                </div>
                <div id="grok-sync-log" class="server-message"></div>
                [% END %]

                <h6 class="section-subhead">Models in chat / editor pickers</h6>
                <ul class="models-list" id="grok-chat-models">
                    [% IF grok_provider.models.size %]
                    [% FOREACH m IN grok_provider.models %]
                    <li>
                        <span class="model-name">[% m.id %]</span>
                        [% IF m.kind == 'media' %]
                        <span class="models-badge badge-size">image/video</span>
                        [% ELSE %]
                        <span class="models-badge badge-connected">text/chat</span>
                        [% END %]
                    </li>
                    [% END %]
                    [% ELSE %]
                    <li><span class="color-muted">No chat models — sync from xAI or add API key</span></li>
                    [% END %]
                </ul>

                [% IF grok_provider.synced_models.size %]
                <h6 class="section-subhead">Full list from last xAI sync</h6>
                <ul class="models-list">
                    [% FOREACH m IN grok_provider.synced_models %]
                    <li>
                        <span class="model-name">[% m.id %]</span>
                        [% IF m.in_picker %]
                        <span class="models-badge badge-connected">chat</span>
                        [% ELSIF m.retired %]
                        <span class="models-badge badge-disconnected">retired</span>
                        [% ELSIF m.media %]
                        <span class="models-badge badge-size">media</span>
                        [% ELSE %]
                        <span class="models-badge badge-size">other</span>
                        [% END %]
                    </li>
                    [% END %]
                </ul>
                [% END %]
            </div>
        </div>
    </section>

    <!-- User API Keys -->
    <section id="user-api-keys" style="margin: 20px 0;">
        <div class="models-card">
            <div class="models-card-header">
                <h5>Your AI Provider API Keys</h5>
                <a href="/ai/manage_api_keys" class="btn btn-secondary" style="padding: 5px 12px; text-decoration: none; font-size: 0.9em;">Manage API Keys</a>
            </div>
            <div class="models-card-body">
                [% IF user_api_keys.size %]
                <p>Configured providers for [% username %]:</p>
                <ul class="models-list">
                    [% FOREACH api_key IN user_api_keys %]
                    <li>
                        <span style="text-transform: capitalize;">[% api_key.service %]</span>
                        <span class="models-badge badge-connected">🔒 Configured</span>
                        <small class="color-muted">Added: [% api_key.created_at %]</small>
                    </li>
                    [% END %]
                </ul>
                [% ELSE %]
                <div style="text-align: center; padding: 20px;">
                    <p>No API keys configured yet.</p>
                    <p class="color-muted" style="font-size: 0.9em;">Add API keys for services like Grok to use them in the chat.</p>
                    <a href="/ai/manage_api_keys" class="btn btn-primary">Add API Keys</a>
                </div>
                [% END %]
            </div>
        </div>
    </section>

    <!-- Troubleshooting -->
    <section id="troubleshooting">
        <h2>Troubleshooting</h2>
        <div class="models-section-grid">
            <div>
                <h3>Common Issues</h3>
                <ul>
                    <li><strong>Server Offline:</strong> Use Start button; check firewall/port 11434.</li>
                    <li><strong>No Models:</strong> Pull from list; ensure disk space.</li>
                    <li><strong>Permission Error:</strong> Login as admin/developer.</li>
                </ul>
            </div>
            <div>
                <h3>Next Steps</h3>
                <ul>
                    <li><a href="/Documentation">AI Setup Guide</a></li>
                    <li><a href="/admin/view_log">View Logs</a></li>
                </ul>
            </div>
        </div>
    </section>
</div>

<div class="models-footer">
    <p>&copy; 2026 Comserv Team | Page Version 1.06</p>
</div>

<script>
var servers = [% IF servers_json %][% servers_json %][% ELSE %][][% END %];
var canSelectModel = [% can_select_model ? 'true' : 'false' %];

document.addEventListener('DOMContentLoaded', function() {
    servers.forEach(function(server, index) {
        checkServerStatus(index);
        if (canSelectModel) refreshRunning(index, server.host, server.port);
    });
    if (canSelectModel) {
        setInterval(function() {
            servers.forEach(function(s, i) { checkServerStatus(i); });
        }, 10000);
        setInterval(function() {
            servers.forEach(function(s, i) { refreshRunning(i, s.host, s.port); });
        }, 15000);
    }
});

function checkServerStatus(index) {
    var server = servers[index];
    if (!server) return;
    fetch('/ai/server_status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        credentials: 'include',
        body: 'host=' + encodeURIComponent(server.host) + '&port=' + encodeURIComponent(server.port)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        var indicator = document.getElementById('status-' + index);
        var msgDiv    = document.getElementById('message-' + index);
        if (data.running) {
            if (indicator) indicator.innerHTML = '<span class="models-badge badge-connected">Connected</span>';
            if (msgDiv)    msgDiv.innerHTML = '<span class="color-success">Active.</span>';
        } else {
            if (indicator) indicator.innerHTML = '<span class="models-badge badge-disconnected">Disconnected</span>';
            if (msgDiv)    msgDiv.innerHTML = '<span class="color-danger">Offline.</span>';
        }
    })
    .catch(function() {
        var indicator = document.getElementById('status-' + index);
        if (indicator) indicator.innerHTML = '<span class="models-badge badge-disconnected">Error</span>';
    });
}

function startServer(index, host, port) {
    var btn    = event.target;
    var msgDiv = document.getElementById('message-' + index);
    btn.disabled = true;
    btn.textContent = 'Starting...';
    if (msgDiv) msgDiv.innerHTML = '<span class="color-info">Starting server...</span>';

    fetch('/ai/start_server', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        credentials: 'include',
        body: 'host=' + encodeURIComponent(host) + '&port=' + encodeURIComponent(port) + '&method=systemctl&async=1'
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            if (msgDiv) msgDiv.innerHTML = '<span class="color-success">Started! Reloading...</span>';
            setTimeout(function() { location.reload(); }, 3000);
        } else {
            if (msgDiv) msgDiv.innerHTML = '<span class="color-danger">Failed: ' + (data.error || 'unknown') + '</span>';
            btn.disabled = false;
            btn.textContent = 'Start Server';
        }
    })
    .catch(function() {
        if (msgDiv) msgDiv.innerHTML = '<span class="color-danger">Request failed.</span>';
        btn.disabled = false;
        btn.textContent = 'Start Server';
    });
}

function pullModel(index, host, port) {
    var select = document.getElementById('available-select-' + index);
    var model  = select ? select.value : '';
    if (!model) { alert('Select a model to pull.'); return; }
    if (!confirm('Pull ' + model + ' to ' + host + ':' + port + '?')) return;

    fetch('/ai/pull_model', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ model: model, host: host, port: port })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            alert('Pulled successfully! Reloading page.');
            location.reload();
        } else {
            alert('Pull failed: ' + (data.error || 'unknown error'));
        }
    })
    .catch(function() { alert('Request failed.'); });
}

function testModel(model, host, port) {
    var url = '/ai/test_model?model=' + encodeURIComponent(model) + '&host=' + encodeURIComponent(host) + '&port=' + encodeURIComponent(port);
    fetch(url, { credentials: 'include' })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            alert('Test OK: ' + String(data.response || '').substring(0, 100) + '...');
        } else {
            alert('Test failed: ' + (data.error || 'unknown'));
        }
    })
    .catch(function() { alert('Test request failed.'); });
}

function removeModel(model, host, port) {
    if (!confirm('Remove ' + model + ' from ' + host + ':' + port + '?')) return;

    fetch('/ai/remove_model', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ model: model, host: host, port: port })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            alert('Removed! Reloading page.');
            location.reload();
        } else {
            alert('Remove failed: ' + (data.error || 'unknown error'));
        }
    })
    .catch(function() { alert('Request failed.'); });
}

function refreshRunning(index, host, port) {
    var list = document.getElementById('running-' + index);
    if (!list) return;
    fetch('/ai/running_models?host=' + encodeURIComponent(host) + '&port=' + encodeURIComponent(port), {
        credentials: 'include'
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (!data.success || !data.models || !data.models.length) {
            list.innerHTML = '<li><span class="color-muted">None (all unloaded)</span></li>';
            return;
        }
        list.innerHTML = data.models.map(function(m) {
            var sizeStr = m.size_vram ? ' — ' + Math.round(m.size_vram / 1024 / 1024) + ' MB VRAM' : '';
            var expiry  = m.expires_at ? ' · expires ' + new Date(m.expires_at).toLocaleTimeString() : '';
            return '<li>' +
                '<span class="model-name">' + m.name + '</span>' +
                '<span class="models-badge badge-connected">In memory' + sizeStr + expiry + '</span>' +
                '<button class="btn btn-sm" style="background:var(--link-color,#2196f3);color:#fff;" ' +
                    'onclick="unloadModel(\'' + m.name + '\',\'' + host + '\',' + port + ',' + index + ')">Unload</button>' +
                '</li>';
        }).join('');
    })
    .catch(function() {
        if (list) list.innerHTML = '<li><span class="color-muted">Could not query memory status</span></li>';
    });
}

function unloadModel(model, host, port, serverIndex) {
    if (!confirm('Unload ' + model + ' from memory on ' + host + ':' + port + '?\n(Model stays installed — just freed from RAM)')) return;
    fetch('/ai/unload_model', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ model: model, host: host, port: port })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            setTimeout(function() { refreshRunning(serverIndex, host, port); }, 1500);
        } else {
            alert('Unload failed: ' + (data.error || 'unknown'));
        }
    })
    .catch(function() { alert('Unload request failed.'); });
}

function upgradeOllama() {
    var btn = document.getElementById('upgrade-ollama-btn');
    var log = document.getElementById('sync-log');
    if (!btn || !log) return;
    if (!confirm('This will run the official Ollama installer script (curl -fsSL https://ollama.com/install.sh | sh) on the local server.\n\nThe server may restart briefly. Continue?')) return;
    btn.disabled = true;
    btn.textContent = '\u23f3 Upgrading\u2026';
    log.style.display = '';
    log.textContent = 'Running Ollama upgrade\u2026\n';
    fetch('/ai/upgrade_ollama', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({})
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        btn.disabled = false;
        btn.textContent = '\u2b06 Upgrade Ollama';
        if (!data.success) {
            log.textContent += '\u2717 Error: ' + (data.error || 'unknown') + '\n';
            return;
        }
        log.textContent = 'Before: ' + (data.version_before || '?') + '\n'
                        + 'After:  ' + (data.version_after  || '?') + '\n\n'
                        + (data.output || '') + '\n\nUpgrade complete.';
    })
    .catch(function(err) {
        btn.disabled = false;
        btn.textContent = '\u2b06 Upgrade Ollama';
        log.textContent += 'Request failed: ' + err + '\n';
    });
}

function syncGrokModels() {
    var btn = document.getElementById('sync-grok-btn');
    var log = document.getElementById('grok-sync-log');
    if (!btn || !log) return;
    btn.disabled = true;
    btn.textContent = '⏳ Syncing from xAI…';
    log.innerHTML = '<span class="color-info">Comserv is calling xAI /v1/models (may take up to 25s)…</span>';
    var ctrl = new AbortController();
    var timer = setTimeout(function() { ctrl.abort(); }, 45000);
    fetch('/ai/sync_models?service=grok', {
        method: 'GET',
        credentials: 'include',
        signal: ctrl.signal,
        headers: { 'Accept': 'application/json' }
    })
    .then(function(r) {
        if (!r.ok) {
            return r.text().then(function(t) {
                throw new Error('HTTP ' + r.status + (t ? ': ' + t.substring(0, 200) : ''));
            });
        }
        return r.json();
    })
    .then(function(data) {
        clearTimeout(timer);
        btn.disabled = false;
        btn.textContent = '↻ Sync Grok Models (AJAX)';
        if (!data.success) {
            log.innerHTML = '<span class="color-danger">Sync failed: ' + (data.error || 'unknown')
                + '. Try <a href="/ai/models?sync_grok=1#xai-grok">Sync via page reload</a>.</span>';
            return;
        }
        log.innerHTML = '<span class="color-success">Synced ' + (data.count || 0) + ' models. Reloading…</span>';
        setTimeout(function() { location.reload(); }, 1500);
    })
    .catch(function(err) {
        clearTimeout(timer);
        btn.disabled = false;
        btn.textContent = '↻ Sync Grok Models (AJAX)';
        var msg = (err && err.name === 'AbortError')
            ? 'Timed out waiting for Comserv (server may be busy).'
            : String(err);
        log.innerHTML = '<span class="color-danger">Request failed: ' + msg
            + ' Use <a href="/ai/models?sync_grok=1#xai-grok">Sync via page reload</a> — that runs on the server and does not need AJAX.</span>';
    });
}

function syncRecommendedModels() {
    var btn = document.getElementById('sync-all-btn');
    var log = document.getElementById('sync-log');
    if (!btn || !log) return;
    if (!confirm('This will pull all recommended models not yet installed and remove deprecated ones from every configured Ollama server.\n\nLarge models may take several minutes to download. Continue?')) return;

    btn.disabled = true;
    btn.textContent = '⏳ Syncing…';
    log.style.display = '';
    log.textContent = 'Starting model sync…\n';

    fetch('/ai/auto_sync_models', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({})
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        btn.disabled = false;
        btn.textContent = '↻ Sync Recommended Models';
        if (!data.success) {
            log.textContent += 'Error: ' + (data.error || 'unknown') + '\n';
            return;
        }
        log.textContent = '';
        (data.servers || []).forEach(function(srv) {
            log.textContent += '── ' + srv.host + ':' + srv.port + ' ──\n';
            if (srv.error) { log.textContent += '  ✗ ' + srv.error + '\n'; return; }
            (srv.pulled  || []).forEach(function(m) { log.textContent += '  ✓ Pulled: '   + m + '\n'; });
            (srv.removed || []).forEach(function(m) { log.textContent += '  🗑 Removed: ' + m + '\n'; });
            (srv.skipped || []).forEach(function(m) { log.textContent += '  · Skip: '    + m + '\n'; });
            (srv.errors  || []).forEach(function(e) { log.textContent += '  ✗ Error: '   + e + '\n'; });
        });
        log.textContent += '\nDone — pulled ' + (data.total_pulled || 0) + ', removed ' + (data.total_removed || 0) + '.';
        if ((data.total_pulled || 0) > 0 || (data.total_removed || 0) > 0) {
            setTimeout(function() { location.reload(); }, 3000);
        }
    })
    .catch(function(err) {
        btn.disabled = false;
        btn.textContent = '↻ Sync Recommended Models';
        log.textContent += 'Request failed: ' + err + '\n';
    });
}
</script>

[%# End of File %]
