[% META
    title = "Manage API Keys"
    category = "AI"
    roles = "user,developer,admin"
    description = "Manage your AI provider API keys"
%]

<style>
.api-keys-container {
    max-width: 900px;
    margin: 20px auto;
    padding: 20px;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
}

.btn-primary, .btn-secondary, .btn-danger {
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    text-decoration: none;
    display: inline-block;
}

.btn-primary {
    background: #007bff;
    color: white;
}

.btn-secondary {
    background: #6c757d;
    color: white;
}

.btn-danger {
    background: #dc3545;
    color: white;
}

.btn-primary:hover, .btn-secondary:hover, .btn-danger:hover {
    opacity: 0.8;
}

.api-keys-list {
    margin: 20px 0;
}

.api-key-card {
    background: var(--secondary-color);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 15px;
}

.key-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
}

.key-service {
    font-size: 18px;
    font-weight: bold;
    text-transform: capitalize;
    color: var(--text-color);
}

.key-status {
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 12px;
}

.status-active {
    background: #28a745;
    color: white;
}

.status-inactive {
    background: #6c757d;
    color: white;
}

.key-details {
    color: var(--text-color);
    opacity: 0.8;
    font-size: 13px;
    margin: 10px 0;
}

.key-actions {
    display: flex;
    gap: 10px;
    margin-top: 15px;
}

.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
}

.modal-content {
    background: var(--background-color);
    border-radius: 8px;
    width: 90%;
    max-width: 500px;
    padding: 0;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px;
    border-bottom: 1px solid var(--border-color);
}

.modal-header h2 {
    margin: 0;
    color: var(--text-color);
}

.modal-close {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: var(--text-color);
}

.modal-body {
    padding: 20px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: bold;
    color: var(--text-color);
}

.form-group input,
.form-group select {
    width: 100%;
    padding: 10px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    background: var(--secondary-color);
    color: var(--text-color);
    font-size: 14px;
}

.modal-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
    padding: 20px;
    border-top: 1px solid var(--border-color);
}

.alert {
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 20px;
}

.alert-info {
    background: #d1ecf1;
    border: 1px solid #bee5eb;
    color: #0c5460;
}

.no-keys {
    text-align: center;
    padding: 40px;
    color: var(--text-color);
}
</style>

<div class="api-keys-container">
    <div class="page-header">
        <h1>Manage API Keys</h1>
        <div>
            <button class="btn-primary" onclick="openAddModal()">+ Add API Key</button>
            <a href="/ai/models" class="btn-secondary">← Back to Models</a>
        </div>
    </div>

    <div class="alert alert-info">
        <strong>Secure Storage:</strong> Your API keys are encrypted using AES-256 and stored securely. They are only decrypted when needed for API requests.
    </div>

    <div class="api-keys-list">
        [% IF api_keys.size %]
            [% FOREACH key IN api_keys %]
            <div class="api-key-card" data-key-id="[% key.id %]">
                <div class="key-header">
                    <span class="key-service">[% key.service %]</span>
                    <span class="key-status [% key.is_active ? 'status-active' : 'status-inactive' %]">
                        [% key.is_active ? 'Active' : 'Inactive' %]
                    </span>
                </div>
                <div class="key-details">
                    <div>Created: [% key.created_at %]</div>
                    <div>Last Updated: [% key.updated_at %]</div>
                </div>
                <div class="key-actions">
                    <button class="btn-secondary" onclick="editKey([% key.id %], '[% key.service %]')">Edit Key</button>
                    <button class="btn-danger" onclick="deleteKey([% key.id %], '[% key.service %]')">Delete</button>
                </div>
            </div>
            [% END %]
        [% ELSE %]
            <div class="no-keys">
                <p>No API keys configured yet.</p>
                <p>Click "Add API Key" to get started.</p>
            </div>
        [% END %]
    </div>
</div>

<!-- Add/Edit Modal -->
<div id="key-modal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modal-title">Add API Key</h2>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body">
            <form id="key-form" onsubmit="saveKey(event)">
                <input type="hidden" id="key-id" name="id">
                
                <div class="form-group">
                    <label for="service">Service *</label>
                    <select id="service" name="service" required>
                        <option value="">Select a service...</option>
                        <option value="grok">Grok (X.AI)</option>
                        <option value="openai">OpenAI</option>
                        <option value="claude">Claude (Anthropic)</option>
                        <option value="gemini">Gemini (Google)</option>
                        <option value="anthropic">Anthropic</option>
                        <option value="cohere">Cohere</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="api-key">API Key *</label>
                    <input type="password" id="api-key" name="api_key"
                           placeholder="Enter your API key">
                    <small style="color: var(--text-color); opacity: 0.7;">Your key will be encrypted before storage</small>
                </div>
            </form>
        </div>
        <div class="modal-actions">
            <button class="btn-secondary" onclick="closeModal()">Cancel</button>
            <button class="btn-primary" onclick="document.getElementById('key-form').dispatchEvent(new Event('submit'))">Save</button>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
function openAddModal() {
    document.getElementById('modal-title').textContent = 'Add API Key';
    document.getElementById('key-form').reset();
    document.getElementById('key-id').value = '';
    document.getElementById('service').disabled = false;
    document.getElementById('key-modal').style.display = 'flex';
}

function editKey(keyId, service) {
    document.getElementById('modal-title').textContent = 'Edit API Key';
    document.getElementById('key-id').value = keyId;
    document.getElementById('service').value = service;
    document.getElementById('service').disabled = true;
    document.getElementById('api-key').value = '';
    document.getElementById('api-key').placeholder = 'Enter new API key (leave blank to keep existing)';
    document.getElementById('key-modal').style.display = 'flex';
}

function closeModal() {
    document.getElementById('key-modal').style.display = 'none';
}

function saveKey(event) {
    event.preventDefault();
    
    const formData = new FormData(event.target);
    const data = {};
    formData.forEach((value, key) => data[key] = value);
    
    console.log('Saving key with data:', data);
    
    // Validate: new keys require api_key
    if (!data.id && !data.api_key) {
        alert('API key is required for new entries');
        return;
    }
    
    // If editing and no new key provided, skip the update
    if (data.id && !data.api_key) {
        alert('No changes made - API key field is empty');
        closeModal();
        return;
    }
    
    $.ajax({
        url: '/ai/save_api_key',
        method: 'POST',
        data: data,
        dataType: 'json',
        success: function(response) {
            console.log('Save response:', response);
            if (response.success) {
                alert('API key saved successfully!');
                location.reload();
            } else {
                alert('Error: ' + (response.error || 'Unknown error'));
            }
        },
        error: function(xhr, status, error) {
            console.error('Save failed:', xhr.responseText, status, error);
            alert('Failed to save API key: ' + (xhr.responseText || error || 'Unknown error'));
        }
    });
}

function deleteKey(keyId, service) {
    if (!confirm(`Are you sure you want to delete the API key for ${service}?`)) {
        return;
    }
    
    $.ajax({
        url: '/ai/delete_api_key/' + keyId,
        method: 'POST',
        dataType: 'json',
        success: function(response) {
            if (response.success) {
                alert('API key deleted successfully!');
                location.reload();
            } else {
                alert('Error: ' + (response.error || 'Unknown error'));
            }
        },
        error: function() {
            alert('Failed to delete API key. Please try again.');
        }
    });
}

// Close modal on outside click
document.getElementById('key-modal').addEventListener('click', function(e) {
    if (e.target === this) {
        closeModal();
    }
});
</script>
