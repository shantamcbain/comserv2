[% PageVersion  = 'ai/query_form.tt. v 0.1 2025/10/05 Shanta Exp Shanta' %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="ai-query-container">
    <h1>AI Query Form</h1>
    <p class="subtitle">Submit your question to the AI assistant</p>

    <div class="query-form-wrapper">
        <form action="/ai/result" method="post">
            <div class="form-group">
                <label for="prompt">Your Question:</label>
                <textarea 
                    id="prompt" 
                    name="prompt" 
                    rows="8" 
                    placeholder="Enter your question or prompt here..."
                    required
                ></textarea>
            </div>

            <div class="form-group">
                <label for="system">System Prompt (Optional):</label>
                <textarea 
                    id="system" 
                    name="system" 
                    rows="3" 
                    placeholder="Optional: Set the AI's behavior or context"
                ></textarea>
            </div>

            <div class="form-group">
                <label for="format">Response Format:</label>
                <select id="format" name="format">
                    <option value="">Default (Text)</option>
                    <option value="json">JSON</option>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-button">Submit Query</button>
                <button type="reset" class="reset-button">Clear Form</button>
                <a href="/ai/conversations" class="back-link">View Conversations</a>
                <a href="/ai" class="back-link">Back to AI Home</a>
            </div>
        </form>
    </div>
</div>

<style>
.ai-query-container {
    max-width: 800px;
    margin: 20px auto;
    padding: 20px;
}

.subtitle {
    color: #666;
    margin-bottom: 30px;
}

.query-form-wrapper {
    background: #fff;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: bold;
    color: #333;
}

.form-group textarea,
.form-group select {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
    font-size: 14px;
}

.form-group textarea:focus,
.form-group select:focus {
    outline: none;
    border-color: #4caf50;
    box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.1);
}

.form-actions {
    display: flex;
    gap: 10px;
    align-items: center;
}

.submit-button,
.reset-button {
    padding: 12px 24px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    transition: all 0.3s;
}

.submit-button {
    background: #4caf50;
    color: white;
}

.submit-button:hover {
    background: #45a049;
}

.reset-button {
    background: #f5f5f5;
    color: #333;
}

.reset-button:hover {
    background: #e0e0e0;
}

.back-link {
    margin-left: auto;
    color: #4caf50;
    text-decoration: none;
    padding: 12px 24px;
}

.back-link:hover {
    text-decoration: underline;
}
</style>