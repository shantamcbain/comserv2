[% META
   title = "AI Query Form"
   description = "Form to submit AI queries"
   roles = "user,admin,developer"
   category = "AI Module"
   page_version = "0.06"
   last_updated = "Fri Jan 23 15:00:00 UTC 2026"
%]

[% PageVersion = 'ai/query_form.tt,v 0.06 2026/01/23 15:00:00 CleanupAgent Exp - Theme compliance and central variables migration'; %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="ai-query-container">
    <h1>AI Query Form</h1>
    <p class="subtitle">Submit your question to the AI assistant</p>

    <div class="query-form-wrapper">
        <form action="/ai/result" method="post">
            <div class="form-group">
                <label for="prompt">Your Question:</label>
                <textarea 
                    id="prompt" 
                    name="prompt" 
                    rows="8" 
                    placeholder="Enter your question or prompt here..."
                    required
                ></textarea>
            </div>

            <div class="form-group">
                <label for="system">System Prompt (Optional):</label>
                <textarea 
                    id="system" 
                    name="system" 
                    rows="3" 
                    placeholder="Optional: Set the AI's behavior or context"
                ></textarea>
            </div>

            <div class="form-group">
                <label for="format">Response Format:</label>
                <select id="format" name="format">
                    <option value="">Default (Text)</option>
                    <option value="json">JSON</option>
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-button">Submit Query</button>
                <button type="reset" class="reset-button">Clear Form</button>
                <a href="/ai/conversations" class="back-link">View Conversations</a>
                <a href="/ai" class="back-link">Back to AI Home</a>
            </div>
        </form>
    </div>
</div>

<style>
.ai-query-container {
    max-width: 800px;
    margin: 20px auto;
    padding: 20px;
}

.subtitle {
    color: var(--text-color);
    opacity: 0.7;
    margin-bottom: 30px;
}

.query-form-wrapper {
    background-color: var(--background-color);
    padding: 30px;
    border-radius: 8px;
    box-shadow: var(--dropdown-shadow);
    border: 1px solid var(--border-color);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: bold;
    color: var(--text-color);
}

.form-group textarea,
.form-group select {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    font-family: inherit;
    font-size: 14px;
    background-color: var(--background-color);
    color: var(--text-color);
}

.form-group textarea:focus,
.form-group select:focus {
    outline: none;
    border-color: var(--success-color);
    box-shadow: 0 0 0 2px var(--nav-hover-bg);
}

.form-actions {
    display: flex;
    gap: 10px;
    align-items: center;
}

.submit-button,
.reset-button {
    padding: 12px 24px;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    transition: all 0.3s;
}

.submit-button {
    background-color: var(--success-color);
    color: var(--text-color);
}

.submit-button:hover {
    opacity: 0.8;
}

.reset-button {
    background-color: var(--secondary-color);
    color: var(--text-color);
}

.reset-button:hover {
    background-color: var(--background-color);
}

.back-link {
    margin-left: auto;
    color: var(--link-color);
    text-decoration: none;
    padding: 12px 24px;
}

.back-link:hover {
    text-decoration: underline;
}
</style>