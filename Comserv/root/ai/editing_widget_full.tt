<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>AI Code Editor — [% username %]</title>
    <link rel="stylesheet" href="/static/css/ai-editing-widget-float.css">
    <style>
        #aew-launcher-wrap { display: none !important; }
        #aew-panel {
            display: flex !important;
            position: fixed !important;
            top: 0 !important; left: 0 !important;
            width: 100% !important; height: 100% !important;
            max-width: none !important; max-height: none !important;
            border-radius: 0 !important;
            bottom: auto !important;
        }
    </style>
</head>
<body>
    <script src="/static/js/ai-editing-widget-float.js?v=20260605i"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (window.AEW) AEW.open();
        });
    </script>
</body>
</html>