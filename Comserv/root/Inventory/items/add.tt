[% PageVersion = 'Inventory/items/add.tt,v 0.02 2026/04/10 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Add Inventory Item</h1>

[% IF error_msg %]<p class="error">[% error_msg %]</p>[% END %]

<form method="POST" action="/Inventory/item/add">
  <table>
    <tr>
      <th><label for="sku">SKU *</label></th>
      <td><input type="text" id="sku" name="sku" required maxlength="100"></td>
    </tr>
    <tr>
      <th><label for="name">Name *</label></th>
      <td><input type="text" id="name" name="name" required maxlength="255"></td>
    </tr>
    <tr>
      <th><label for="category">Category</label></th>
      <td><input type="text" id="category" name="category" maxlength="100" placeholder="Apiary, Garden, Hardware, 3D Print, Craft…"></td>
    </tr>
    <tr>
      <th><label for="item_origin">Origin / How Made</label></th>
      <td>
        <select id="item_origin" name="item_origin">
          [% FOREACH o IN ['purchased','manufactured','crafted','grown','foraged','harvested','3d_printed','other'] %]
          <option value="[% o %]">[% o %]</option>
          [% END %]
        </select>
      </td>
    </tr>
    <tr>
      <th><label for="is_assemblable">Has BOM / Recipe?</label></th>
      <td><input type="checkbox" id="is_assemblable" name="is_assemblable" value="1"> Yes — this item is assembled from components</td>
    </tr>
    <tr>
      <th><label for="description">Description</label></th>
      <td><textarea id="description" name="description" rows="3" cols="40"></textarea></td>
    </tr>
    <tr>
      <th><label for="unit_of_measure">Unit of Measure</label></th>
      <td>
        <select id="unit_of_measure" name="unit_of_measure">
          [% FOREACH u IN ['each','g','kg','ml','L','cm','m','sheet','box','case','lb','litre','metre','hour'] %]
          <option value="[% u %]">[% u %]</option>
          [% END %]
        </select>
      </td>
    </tr>
    <tr>
      <th><label for="unit_cost">Unit Cost</label></th>
      <td><input type="number" id="unit_cost" name="unit_cost" step="0.01" min="0"></td>
    </tr>
    <tr>
      <th><label for="reorder_point">Reorder Point</label></th>
      <td><input type="number" id="reorder_point" name="reorder_point" value="0" min="0"></td>
    </tr>
    <tr>
      <th><label for="reorder_quantity">Reorder Quantity</label></th>
      <td><input type="number" id="reorder_quantity" name="reorder_quantity" value="0" min="0"></td>
    </tr>
    <tr>
      <th><label for="status">Status</label></th>
      <td>
        <select id="status" name="status">
          [% FOREACH s IN ['active','inactive','discontinued'] %]
          <option value="[% s %]">[% s %]</option>
          [% END %]
        </select>
      </td>
    </tr>
    <tr>
      <th><label for="notes">Notes</label></th>
      <td><textarea id="notes" name="notes" rows="3" cols="40"></textarea></td>
    </tr>
  </table>

  [% IF coa_accounts && coa_accounts.size %]
  <h3>Accounting Links <small style="font-weight:normal">(optional — assign Chart of Accounts codes)</small></h3>
  <table>
    [% MACRO coa_select(fname, label, hint) BLOCK %]
    <tr>
      <th><label for="[% fname %]">[% label %]</label></th>
      <td>
        <select id="[% fname %]" name="[% fname %]">
          <option value="">— none —</option>
          [% FOREACH cat IN ['A','L','Q','I','E'] %]
            [% SET cat_label = {A='Asset', L='Liability', Q='Equity', I='Income', E='Expense'} %]
            <optgroup label="[% cat_label.$cat %]">
            [% FOREACH acct IN coa_accounts %]
              [% IF acct.category == cat %]
              <option value="[% acct.id %]">[% acct.accno %] — [% acct.description %]</option>
              [% END %]
            [% END %]
            </optgroup>
          [% END %]
        </select>
        <small>[% hint %]</small>
      </td>
    </tr>
    [% END %]
    [% coa_select('inventory_accno_id', 'Stock/Asset Account',  'e.g. 1200 Inventory — value of stock on hand') %]
    [% coa_select('income_accno_id',    'Income/Sales Account', 'e.g. 4000 Sales Revenue — when sold') %]
    [% coa_select('expense_accno_id',   'COGS/Expense Account', 'e.g. 5000 Cost of Goods Sold — when consumed') %]
    [% coa_select('returns_accno_id',   'Returns Account',      'e.g. 4100 Sales Returns — contra account') %]
  </table>
  [% END %]

  <p>
    <input type="submit" value="Create Item">
    <a href="/Inventory/items">Cancel</a>
  </p>
</form>
