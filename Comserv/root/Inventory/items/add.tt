[% PageVersion = 'Inventory/items/add.tt,v 0.01 2026/03/30 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Add Inventory Item</h1>

[% IF error_msg %]<p class="error">[% error_msg %]</p>[% END %]

<form method="POST" action="/Inventory/item/add[% IF is_popup %]?popup=1[% END %]">
  <table>
    <tr>
      <th><label for="sku">SKU *</label></th>
      <td><input type="text" id="sku" name="sku" required maxlength="100"></td>
    </tr>
    <tr>
      <th><label for="name">Name *</label></th>
      <td><input type="text" id="name" name="name" required maxlength="255"></td>
    </tr>
    <tr>
      <th><label for="category">Category</label></th>
      <td><input type="text" id="category" name="category" maxlength="100"></td>
    </tr>
    <tr>
      <th><label for="description">Description</label></th>
      <td><textarea id="description" name="description" rows="3" cols="40"></textarea></td>
    </tr>
    <tr>
      <th><label for="unit_of_measure">Unit of Measure</label></th>
      <td>
        <select id="unit_of_measure" name="unit_of_measure">
          <option value="each">Each</option>
          <option value="box">Box</option>
          <option value="case">Case</option>
          <option value="kg">kg</option>
          <option value="lb">lb</option>
          <option value="litre">Litre</option>
          <option value="metre">Metre</option>
          <option value="hour">Hour</option>
        </select>
      </td>
    </tr>
    <tr>
      <th><label for="unit_cost">Unit Cost</label></th>
      <td><input type="number" id="unit_cost" name="unit_cost" step="0.01" min="0"></td>
    </tr>
    <tr>
      <th><label for="reorder_point">Reorder Point</label></th>
      <td><input type="number" id="reorder_point" name="reorder_point" value="0" min="0"></td>
    </tr>
    <tr>
      <th><label for="reorder_quantity">Reorder Quantity</label></th>
      <td><input type="number" id="reorder_quantity" name="reorder_quantity" value="0" min="0"></td>
    </tr>
    <tr>
      <th><label for="status">Status</label></th>
      <td>
        <select id="status" name="status">
          <option value="active">Active</option>
          <option value="inactive">Inactive</option>
          <option value="discontinued">Discontinued</option>
        </select>
      </td>
    </tr>
    <tr>
      <th><label for="item_origin">Item Origin</label></th>
      <td>
        <select id="item_origin" name="item_origin">
          <option value="purchased">Purchased</option>
          <option value="manufactured">Manufactured</option>
          <option value="3d_printed">3D Printed</option>
          <option value="grown">Grown</option>
          <option value="foraged">Foraged</option>
          <option value="harvested">Harvested</option>
          <option value="crafted">Crafted</option>
          <option value="other">Other</option>
        </select>
      </td>
    </tr>
    <tr>
      <th><label for="is_consumable">Consumable?</label></th>
      <td><input type="checkbox" id="is_consumable" name="is_consumable" value="1">
          <small>Expensed when used (filament, wax, seed)</small></td>
    </tr>
    <tr>
      <th><label for="is_assemblable">Has BOM?</label></th>
      <td><input type="checkbox" id="is_assemblable" name="is_assemblable" value="1">
          <small>Made from other items (frame, box, printed part)</small></td>
    </tr>
    <tr>
      <th><label for="notes">Notes</label></th>
      <td><textarea id="notes" name="notes" rows="3" cols="40"></textarea></td>
    </tr>
    [% IF coa_accounts.size %]
    <tr><td colspan="2"><hr><strong>Accounting (optional)</strong></td></tr>
    <tr>
      <th><label for="inventory_accno_id">Inventory Account</label></th>
      <td>
        <select id="inventory_accno_id" name="inventory_accno_id">
          <option value="">— none —</option>
          [% FOREACH a IN coa_accounts %]
          <option value="[% a.id %]">[% a.accno %] [% a.description | html %]</option>
          [% END %]
        </select>
        <small>Asset account for stock value (e.g. 1200 Inventory Asset)</small>
      </td>
    </tr>
    <tr>
      <th><label for="income_accno_id">Income Account</label></th>
      <td>
        <select id="income_accno_id" name="income_accno_id">
          <option value="">— none —</option>
          [% FOREACH a IN coa_accounts %]
          <option value="[% a.id %]">[% a.accno %] [% a.description | html %]</option>
          [% END %]
        </select>
        <small>Income account when sold (e.g. 4000 Sales, 4210 3D Print Sales)</small>
      </td>
    </tr>
    <tr>
      <th><label for="expense_accno_id">Expense / COGS Account</label></th>
      <td>
        <select id="expense_accno_id" name="expense_accno_id">
          <option value="">— none —</option>
          [% FOREACH a IN coa_accounts %]
          <option value="[% a.id %]">[% a.accno %] [% a.description | html %]</option>
          [% END %]
        </select>
        <small>Expense/COGS account (e.g. 5000 COGS, 6210 3D Print Materials)</small>
      </td>
    </tr>
    <tr>
      <th><label for="returns_accno_id">Returns Account</label></th>
      <td>
        <select id="returns_accno_id" name="returns_accno_id">
          <option value="">— none —</option>
          [% FOREACH a IN coa_accounts %]
          <option value="[% a.id %]">[% a.accno %] [% a.description | html %]</option>
          [% END %]
        </select>
        <small>Returns/refund contra account (e.g. 4100 Sales Returns)</small>
      </td>
    </tr>
    [% END %]
    <tr>
      <td colspan="2">
        <input type="submit" value="Create Item">
        [% IF is_popup %]
        <button type="button" onclick="window.close()">Cancel</button>
        [% ELSE %]
        <a href="/Inventory/items">Cancel</a>
        [% END %]
      </td>
    </tr>
  </table>
</form>
[% IF is_popup %]
<script>
[% IF c.req.params.done %]
window.close();
[% END %]
</script>
[% END %]
[% PROCESS 'ai/partials/ai_form_assistant.tt'
   ai_form_entity_label = 'inventory item'
   ai_form_context      = 'inventory item management'
   ai_form_fields       = 'name, sku, description, category, item_origin, unit_of_measure, unit_cost, reorder_point, reorder_quantity, status, notes'
%]
