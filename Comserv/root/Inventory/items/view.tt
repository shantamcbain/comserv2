[% PageVersion = 'Inventory/items/view.tt,v 0.01 2026/03/30 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Item: [% item.name %]</h1>

[% IF c.flash.success_msg %]<p class="success">[% c.flash.success_msg %]</p>[% END %]

<div class="actions">
  <a href="/Inventory/item/edit/[% item.id %]">Edit</a>
  &nbsp;|&nbsp;
  <a href="/Inventory/stock/adjust?item_id=[% item.id %]">Adjust Stock</a>
  &nbsp;|&nbsp;
  <a href="/Inventory/items">Back to List</a>
</div>

<h2>Details</h2>
<table border="1" cellpadding="4">
  <tr><th>SKU</th><td>[% item.sku %]</td></tr>
  <tr><th>Name</th><td>[% item.name %]</td></tr>
  <tr><th>Category</th><td>[% item.category || '-' %]</td></tr>
  <tr><th>Description</th><td>[% item.description || '-' %]</td></tr>
  <tr><th>Unit of Measure</th><td>[% item.unit_of_measure %]</td></tr>
  <tr><th>Unit Cost</th><td>[% item.unit_cost ? item.unit_cost : '-' %]</td></tr>
  <tr><th>Reorder Point</th><td>[% item.reorder_point %]</td></tr>
  <tr><th>Reorder Quantity</th><td>[% item.reorder_quantity %]</td></tr>
  <tr><th>Status</th><td>[% item.status %]</td></tr>
  <tr><th>Notes</th><td>[% item.notes || '-' %]</td></tr>
  <tr><th>Created By</th><td>[% item.created_by || '-' %]</td></tr>
</table>

<h2>Stock Levels</h2>
[% IF item.stock_levels.count == 0 %]
  <p>No stock records. <a href="/Inventory/stock/adjust?item_id=[% item.id %]">Add stock</a>.</p>
[% ELSE %]
<table border="1" cellpadding="4">
  <thead>
    <tr>
      <th>Location</th>
      <th>On Hand</th>
      <th>Reserved</th>
      <th>On Order</th>
      <th>Available</th>
      <th>Last Count</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH sl IN item.stock_levels %]
    <tr>
      <td>[% sl.location.name %]</td>
      <td>[% sl.quantity_on_hand %]</td>
      <td>[% sl.quantity_reserved %]</td>
      <td>[% sl.quantity_on_order %]</td>
      <td>[% sl.quantity_on_hand - sl.quantity_reserved %]</td>
      <td>[% sl.last_count_date || '-' %]</td>
    </tr>
  [% END %]
  </tbody>
</table>
[% END %]

<h2>Suppliers</h2>
[% IF item.item_suppliers.count == 0 %]
  <p>No suppliers linked.</p>
[% ELSE %]
<table border="1" cellpadding="4">
  <thead>
    <tr>
      <th>Supplier</th>
      <th>Supplier SKU</th>
      <th>Unit Cost</th>
      <th>Preferred</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH is IN item.item_suppliers %]
    <tr>
      <td>[% is.supplier.name %]</td>
      <td>[% is.supplier_sku || '-' %]</td>
      <td>[% is.unit_cost || '-' %]</td>
      <td>[% is.is_preferred ? 'Yes' : 'No' %]</td>
    </tr>
  [% END %]
  </tbody>
</table>
[% END %]

<h2>Recent Transactions</h2>
[% IF transactions.size == 0 %]
  <p>No transactions recorded.</p>
[% ELSE %]
<table border="1" cellpadding="4">
  <thead>
    <tr>
      <th>Date</th>
      <th>Type</th>
      <th>Qty</th>
      <th>Location</th>
      <th>Reference</th>
      <th>By</th>
      <th>Notes</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH tx IN transactions %]
    <tr>
      <td>[% tx.transaction_date %]</td>
      <td>[% tx.transaction_type %]</td>
      <td>[% tx.quantity %]</td>
      <td>[% tx.location ? tx.location.name : '-' %]</td>
      <td>[% tx.reference_number || '-' %]</td>
      <td>[% tx.performed_by || '-' %]</td>
      <td>[% tx.notes || '-' %]</td>
    </tr>
  [% END %]
  </tbody>
</table>
[% END %]
