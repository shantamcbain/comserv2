[% PageVersion = 'Inventory/locations/list.tt,v 0.01 2026/03/30 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Inventory Locations</h1>

[% IF c.flash.success_msg %]<p class="success">[% c.flash.success_msg %]</p>[% END %]
[% IF c.flash.error_msg %]<p class="error">[% c.flash.error_msg %]</p>[% END %]

<div class="actions">
  <a href="/Inventory/location/add">Add Location</a>
  &nbsp;|&nbsp;
  <a href="/Inventory">Dashboard</a>
</div>

[% IF locations.size == 0 %]
  <p>No locations found. <a href="/Inventory/location/add">Add one now</a>.</p>
[% ELSE %]
<table border="1" cellpadding="4">
  <thead>
    <tr>
      <th>Name</th>
      <th>Type</th>
      <th>Description</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH loc IN locations %]
    <tr>
      <td>[% loc.name %]</td>
      <td>[% loc.location_type || '-' %]</td>
      <td>[% loc.description || '-' %]</td>
      <td>[% loc.status %]</td>
      <td>
        <a href="/Inventory/location/edit/[% loc.id %]">Edit</a>
      </td>
    </tr>
  [% END %]
  </tbody>
</table>
[% END %]

[% IF debug_errors && debug_errors.size > 0 %]
<div class="debug">[% FOREACH err IN debug_errors %]<p>[% err %]</p>[% END %]</div>
[% END %]
