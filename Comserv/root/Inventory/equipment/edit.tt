[% PROCESS 'pagetop.tt' title="Equipment Details — ${item.name}" %]

<div class="app-container">
<div class="content-container">

[% IF error_msg %]
<div style="background:#ffebee;border:1px solid #e57373;padding:8px 12px;border-radius:4px;margin-bottom:12px;color:#c62828">[% error_msg | html %]</div>
[% END %]

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1em">
  <h1 style="font-family:var(--header-font);color:var(--text-color);margin:0">
    Equipment Details: <em>[% item.name | html %]</em>
  </h1>
  <a href="/Inventory/item/view/[% item.id %]"
     style="padding:6px 14px;border:1px solid var(--border-color);color:var(--text-color);border-radius:4px;text-decoration:none;font-family:var(--body-font)">
    &larr; Back to Item
  </a>
</div>

<div style="background:#fff8e1;border:1px solid #ffe082;border-radius:4px;padding:8px 14px;margin-bottom:16px;font-size:0.88em;color:#5d4037">
  Equipment details are separate from the inventory item record.
  Fields here drive the <strong>3D Print Wizard</strong> cost calculations in the BOM.
</div>

<form method="POST" action="/Inventory/equipment/[% item.id %]">
  [% SET eq = item.equipment %]
  <table cellpadding="5" style="border-collapse:collapse;width:100%;max-width:700px">
    <tr>
      <th style="text-align:left;width:220px;padding:6px 8px;background:var(--secondary-color)">
        <label for="wattage">Rated Wattage (W)</label>
      </th>
      <td style="padding:6px 8px">
        <input type="number" id="wattage" name="wattage" min="0" step="1"
               value="[% eq.wattage IF eq %]" style="width:100px">
        <small style="color:var(--text-muted-color)"> rated max power draw (e.g. 400 for Kobra 3)</small>
      </td>
    </tr>
    <tr>
      <th style="text-align:left;padding:6px 8px;background:var(--secondary-color)">
        <label for="depreciation_per_hour">Depreciation ($/hr)</label>
      </th>
      <td style="padding:6px 8px">
        <input type="number" id="depreciation_per_hour" name="depreciation_per_hour"
               min="0" step="0.000001"
               value="[% eq.depreciation_per_hour IF eq %]" style="width:120px">
        <small style="color:var(--text-muted-color)"> purchase ÷ (years × hrs/yr) — e.g. $500 ÷ (3 × 2000) = $0.083333</small>
      </td>
    </tr>
    <tr>
      <th style="text-align:left;padding:6px 8px;background:var(--secondary-color)">
        <label for="serial_number">Serial Number</label>
      </th>
      <td style="padding:6px 8px">
        <input type="text" id="serial_number" name="serial_number" maxlength="100"
               value="[% eq.serial_number | html IF eq %]" style="width:220px">
      </td>
    </tr>
    <tr>
      <th style="text-align:left;padding:6px 8px;background:var(--secondary-color)">
        <label for="purchase_price">Purchase Price ($)</label>
      </th>
      <td style="padding:6px 8px">
        <input type="number" id="purchase_price" name="purchase_price"
               min="0" step="0.01"
               value="[% eq.purchase_price IF eq %]" style="width:100px">
      </td>
    </tr>
    <tr>
      <th style="text-align:left;padding:6px 8px;background:var(--secondary-color)">
        <label for="lease_from_sitename">Leased From SiteName</label>
      </th>
      <td style="padding:6px 8px">
        <input type="text" id="lease_from_sitename" name="lease_from_sitename" maxlength="100"
               value="[% eq.lease_from_sitename | html IF eq %]" style="width:180px">
        <small style="color:var(--text-muted-color)"> leave blank if owned outright</small>
      </td>
    </tr>
    <tr>
      <th style="text-align:left;padding:6px 8px;background:var(--secondary-color)">
        <label for="lease_term_months">Lease Term (months)</label>
      </th>
      <td style="padding:6px 8px">
        <input type="number" id="lease_term_months" name="lease_term_months"
               min="0" step="1"
               value="[% eq.lease_term_months IF eq %]" style="width:80px">
        <small style="color:var(--text-muted-color)"> e.g. 36 for 3 years</small>
      </td>
    </tr>
    <tr>
      <th style="text-align:left;padding:6px 8px;background:var(--secondary-color)">
        <label for="voltage">Voltage</label>
      </th>
      <td style="padding:6px 8px">
        <input type="text" id="voltage" name="voltage" maxlength="20"
               value="[% eq.voltage | html IF eq %]" style="width:100px"
               placeholder="110V">
      </td>
    </tr>
    <tr>
      <th style="text-align:left;padding:6px 8px;background:var(--secondary-color);vertical-align:top">
        <label for="eq_notes">Notes</label>
      </th>
      <td style="padding:6px 8px">
        <textarea id="eq_notes" name="notes" rows="3"
                  style="width:100%;max-width:420px">[% eq.notes | html IF eq %]</textarea>
      </td>
    </tr>
    <tr>
      <td></td>
      <td style="padding:8px">
        <input type="submit" value="Save Equipment Details"
               style="background:var(--primary-color);color:#fff;padding:7px 18px;border:none;border-radius:4px;cursor:pointer;font-family:var(--body-font);font-size:1rem">
        <a href="/Inventory/item/view/[% item.id %]"
           style="margin-left:10px;padding:7px 14px;border:1px solid var(--border-color);color:var(--text-color);border-radius:4px;text-decoration:none;font-family:var(--body-font)">
          Cancel
        </a>
      </td>
    </tr>
  </table>
</form>

[% PROCESS 'ai/partials/ai_form_assistant.tt'
   ai_form_entity_label = 'equipment details'
   ai_form_context      = 'Equipment technical specifications for cost accounting — wattage for electricity calculation, depreciation per hour for BOM cost wizard, lease details'
   ai_form_fields       = 'wattage, depreciation_per_hour, serial_number, purchase_price, lease_from_sitename, lease_term_months, voltage, notes'
%]

</div>
</div>
