[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Enter Supplier Invoice</h1>
<p><a href="/Inventory/invoice">← Invoices</a></p>

[% IF error_msg %]<p style="color:red;font-weight:bold">[% error_msg %]</p>[% END %]

[% IF is_admin || c.stash.is_admin || c.session.is_admin %]
<div id="ai-invoice-parser"
     style="margin:0 0 1.4em;padding:1em;border:1px solid #acd;background:#f0f7ff;border-radius:6px;">
  <strong style="font-size:1.05em;">📄 AI Invoice Parser</strong>
  <span style="font-size:0.85em;color:#555;margin-left:0.5em;">
    Paste any invoice text — AI will extract and fill the form fields automatically.
  </span>

  <div style="margin-top:0.7em;">
    <textarea id="invoice-paste-text" rows="7"
      placeholder="Paste your invoice text here (e.g. Freedom Mobile bill, hydro statement, supplier receipt)…"
      style="width:100%;padding:6px;border:1px solid #ccc;border-radius:4px;font-size:0.85em;resize:vertical;box-sizing:border-box;"></textarea>
  </div>

  <div style="margin-top:0.5em;display:flex;flex-wrap:wrap;gap:0.5em;align-items:center;">
    <select id="invoice-ai-model"
            style="font-size:0.9em;padding:3px 5px;border:1px solid #ccc;border-radius:4px;">
      <option value="">Loading models…</option>
    </select>
    <button type="button" id="invoice-parse-btn"
            style="padding:5px 14px;background:#0077cc;color:#fff;border:none;border-radius:4px;cursor:pointer;font-weight:bold;">
      Parse Invoice with AI
    </button>
    <span id="invoice-parse-status" style="color:#555;font-style:italic;font-size:0.9em;"></span>
  </div>

  <div id="invoice-parse-raw" style="display:none;margin-top:0.6em;">
    <strong style="font-size:0.85em;">AI Raw Response:</strong>
    <pre id="invoice-parse-raw-text"
         style="background:#eee;padding:0.5em;max-height:140px;overflow:auto;font-size:0.82em;white-space:pre-wrap;"></pre>
  </div>
</div>

<script>
(function() {
    function loadInvoiceModels() {
        var sel = document.getElementById('invoice-ai-model');
        if (!sel) return;
        fetch('/ai/get_user_providers', { method: 'GET', credentials: 'include' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var opts = [];
                if (data.providers) {
                    data.providers.forEach(function(p) {
                        if (p.service === 'ollama' && p.models) {
                            p.models.filter(function(m){ return m.id && !m.id.match(/embed|rerank/i); })
                                .forEach(function(m){ opts.push({ val: m.id+'|ollama', label: m.id+' (Ollama)' }); });
                        }
                        if (p.service === 'grok' && p.models) {
                            p.models.filter(function(m){ return m.id && !m.id.match(/imagine|video/i); })
                                .forEach(function(m){
                                    var lbl = m.id.replace(/-/g,' ').replace(/\b\w/g,function(c){return c.toUpperCase();});
                                    opts.push({ val: m.id+'|grok', label: lbl+' (Grok/xAI)' });
                                });
                        }
                    });
                }
                if (!opts.length) opts = [{ val: 'mistral:latest|ollama', label: 'mistral:latest (Ollama)' }];
                sel.innerHTML = '';
                opts.forEach(function(o, i) {
                    var opt = document.createElement('option');
                    opt.value = o.val; opt.textContent = o.label;
                    if (i === 0) opt.selected = true;
                    sel.appendChild(opt);
                });
            })
            .catch(function() {
                sel.innerHTML = '<option value="mistral:latest|ollama">mistral:latest (Ollama)</option>';
            });
    }
    loadInvoiceModels();

    document.getElementById('invoice-parse-btn').addEventListener('click', function() {
        var text = (document.getElementById('invoice-paste-text').value || '').trim();
        if (!text) { alert('Please paste the invoice text first.'); return; }

        var sel   = document.getElementById('invoice-ai-model');
        var parts = (sel && sel.value) ? sel.value.split('|') : ['mistral:latest', 'ollama'];
        var model = parts[0], provider = parts[1] || 'ollama';

        var btn      = document.getElementById('invoice-parse-btn');
        var statusEl = document.getElementById('invoice-parse-status');
        btn.disabled = true;
        statusEl.textContent = 'Parsing with ' + model + '…';
        document.getElementById('invoice-parse-raw').style.display = 'none';

        var SYSTEM = [
            'You are an accounting assistant that parses invoice/bill text and extracts structured data.',
            'Return ONLY a raw JSON object with these fields (omit any you cannot find):',
            '  supplier_name (string — exact company name on the bill),',
            '  invoice_number (string),',
            '  invoice_date (YYYY-MM-DD),',
            '  due_date (YYYY-MM-DD),',
            '  notes (brief description e.g. "Phone service 250-549-0126 Apr 2026"),',
            '  ap_accno (string — AP account number, almost always "2000"),',
            '  tax_amount (decimal number — total of GST+PST+HST, not individual amounts),',
            '  tax_accno (string — account number for input tax credits, e.g. "1310" or "2310"),',
            '  shipping_amount (decimal if any),',
            '  discount_amount (decimal if any — positive number, will be subtracted),',
            '  lines (array of objects, one per billing line item, each with:',
            '    description (string), quantity (number, default 1), unit_cost (decimal — use negative for discounts/credits),',
            '    expense_accno (string — COA account number for this line, e.g. "6500" for phone/telecom, "6100" for utilities, "6200" for office supplies, "5000" for inventory/COGS))',
            'Do not include markdown, code fences, or commentary. Return pure JSON only.',
            'For phone bills: group base plan separately from add-ons and discounts. expense_accno for all phone lines is "6500".',
            'Tax lines (GST/PST/HST) go in tax_amount, NOT in lines array.',
            'Common expense_accno mappings: phone/telecom=6500, utilities=6100, office supplies=6200, inventory=5000, shipping=6400.',
        ].join(' ');

        var timeoutMs = provider === 'grok' ? 45000 : 120000;
        var ctrl = new AbortController();
        var tid  = setTimeout(function() { ctrl.abort(); }, timeoutMs);

        fetch('/ai/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            signal: ctrl.signal,
            body: JSON.stringify({
                prompt:     'Parse this invoice and return structured JSON:\n\n' + text,
                system:     SYSTEM,
                provider:   provider,
                model:      model,
                agent_id:   'accounting',
                page_path:  window.location.pathname,
                page_title: document.title
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            clearTimeout(tid);
            btn.disabled = false;
            var rawEl = document.getElementById('invoice-parse-raw-text');
            var raw   = (data.response || '').trim();
            rawEl.textContent = raw;
            document.getElementById('invoice-parse-raw').style.display = '';

            if (!data.success) {
                statusEl.textContent = 'AI error: ' + (data.error || 'unknown');
                return;
            }

            var js = raw.indexOf('{'), je = raw.lastIndexOf('}');
            if (js === -1 || je === -1) {
                statusEl.textContent = 'AI did not return JSON. See raw response.';
                return;
            }

            var inv;
            try { inv = JSON.parse(raw.substring(js, je + 1)); }
            catch(e) { statusEl.textContent = 'Could not parse JSON: ' + e.message; return; }

            var filled = 0, warnings = [];

            function setField(id, val) {
                var el = document.getElementById(id);
                if (el && val !== undefined && val !== null && String(val).trim() !== '') {
                    el.value = val; filled++;
                }
            }

            // Look up a COA account ID by accno prefix (e.g. "6500" matches "6500 Telephone & Internet")
            function findCoaId(accno) {
                if (!accno) return null;
                var s = String(accno).trim();
                for (var i = 0; i < coaAccounts.length; i++) {
                    if (coaAccounts[i].label.indexOf(s) === 0 || coaAccounts[i].label.split(' ')[0] === s) {
                        return coaAccounts[i].id;
                    }
                }
                return null;
            }

            // Select a <select> option by COA account ID
            function selectCoaField(selId, accno) {
                var acctId = findCoaId(accno);
                if (!acctId) return;
                var sel = document.getElementById(selId);
                if (!sel) return;
                for (var i = 0; i < sel.options.length; i++) {
                    if (sel.options[i].value == acctId) { sel.selectedIndex = i; filled++; break; }
                }
            }

            // Supplier — try to match by name in dropdown
            if (inv.supplier_name) {
                var supSel = document.getElementById('supplier_id');
                if (supSel) {
                    var matched = false;
                    var nameLC  = inv.supplier_name.toLowerCase();
                    for (var i = 0; i < supSel.options.length; i++) {
                        if (supSel.options[i].text.toLowerCase().indexOf(nameLC) !== -1 ||
                            nameLC.indexOf(supSel.options[i].text.toLowerCase()) !== -1) {
                            supSel.selectedIndex = i; matched = true; filled++; break;
                        }
                    }
                    if (!matched) {
                        warnings.push('Supplier "' + inv.supplier_name + '" not found — '
                            + '<a href="/Inventory/supplier/add" target="_blank">add supplier</a> then refresh.');
                    }
                }
            }

            setField('invoice_number', inv.invoice_number);
            setField('invoice_date',   inv.invoice_date);
            setField('due_date',       inv.due_date);
            setField('notes',          inv.notes);
            setField('tax_amount',     inv.tax_amount);
            setField('shipping_amount', inv.shipping_amount);
            setField('discount_amount', inv.discount_amount);

            // AP account
            if (inv.ap_accno) selectCoaField('ap_account_id', inv.ap_accno);
            else selectCoaField('ap_account_id', '2000');

            // Tax account
            if (inv.tax_accno) selectCoaField('tax_account_id', inv.tax_accno);

            // Line items
            if (inv.lines && inv.lines.length) {
                // Clear existing blank first line if it exists
                var existingRows = document.querySelectorAll('#lines-body tr');
                var allBlank = true;
                existingRows.forEach(function(row) {
                    var desc = row.querySelector('[name^="description_"]');
                    if (desc && desc.value.trim()) allBlank = false;
                });
                if (allBlank) {
                    existingRows.forEach(function(r) { r.remove(); });
                }

                inv.lines.forEach(function(line) {
                    var acctId = findCoaId(line.expense_accno) || null;
                    addLine({
                        description: line.description || '',
                        quantity:    line.quantity    || 1,
                        unit_cost:   typeof line.unit_cost === 'number'
                                        ? line.unit_cost.toFixed(2)
                                        : (line.unit_cost || '0.00'),
                        account_id:  acctId
                    });
                });
                filled += inv.lines.length;
                calcTotal();
            }

            var msg = '✓ Filled ' + filled + ' fields.';
            if (warnings.length) msg += ' ⚠ ' + warnings.join(' ');
            statusEl.innerHTML = msg;
        })
        .catch(function(err) {
            clearTimeout(tid);
            document.getElementById('invoice-parse-btn').disabled = false;
            document.getElementById('invoice-parse-status').textContent =
                err.name === 'AbortError' ? 'Timed out — try a faster model.' : 'Error: ' + err.message;
        });
    });
})();
</script>
[% END %]

<form method="POST" action="/Inventory/invoice/new" id="invoice-form">

<table cellpadding="6">
  <tr>
    <th><label for="supplier_id">Supplier *</label></th>
    <td>
      <select id="supplier_id" name="supplier_id" required>
        <option value="">— select supplier —</option>
        [% FOREACH s IN suppliers %]
        <option value="[% s.id %]"[% IF submitted.supplier_id == s.id %] selected[% END %]>[% s.name | html %]</option>
        [% END %]
      </select>
      <button type="button" onclick="openItemPopup('/Inventory/supplier/add?popup=1', 'supplier')"
              style="margin-left:4px;" title="Add new supplier">+ Supplier</button>
    </td>
  </tr>
  <tr>
    <th><label for="invoice_number">Invoice Number</label></th>
    <td><input type="text" id="invoice_number" name="invoice_number" maxlength="100" value="[% submitted.invoice_number | html %]"></td>
  </tr>
  <tr>
    <th><label for="invoice_date">Invoice Date *</label></th>
    <td><input type="date" id="invoice_date" name="invoice_date" value="[% submitted.invoice_date || today %]" required></td>
  </tr>
  <tr>
    <th><label for="due_date">Due Date</label></th>
    <td><input type="date" id="due_date" name="due_date" value="[% submitted.due_date %]"></td>
  </tr>
  [% IF coa_accounts.size %]
  <tr>
    <th><label for="ap_account_id">AP Account</label></th>
    <td>
      <select id="ap_account_id" name="ap_account_id">
        <option value="">— none (no GL entry) —</option>
        [% FOREACH a IN coa_accounts %]
        <option value="[% a.id %]"[% IF submitted.ap_account_id ? (submitted.ap_account_id == a.id) : (a.accno == '2000') %] selected[% END %]>[% a.accno %] [% a.description | html %]</option>
        [% END %]
      </select>
      <small>Accounts Payable account. Use 2000 AP regardless of payment method (PayPal, cash, card).
      The payment method is recorded when you mark the invoice paid.</small>
    </td>
  </tr>
  [% END %]
  <tr>
    <th><label for="notes">Notes</label></th>
    <td><textarea id="notes" name="notes" rows="2" cols="50">[% submitted.notes | html %]</textarea></td>
  </tr>
</table>

<h2>Line Items</h2>
<p><small>Select an existing item or type a description. Add a location to update stock on hand.</small></p>
<p>
  <button type="button" onclick="openItemPopup('/Inventory/item/add?popup=1', 'item')" style="font-size:0.85em;">
    + Add New Item (opens popup)
  </button>
</p>

<table id="lines-table" border="1" cellpadding="5" style="border-collapse:collapse;width:100%;">
  <thead>
    <tr>
      <th>#</th>
      <th>Item</th>
      <th>Description</th>
      <th>Qty</th>
      <th>Unit Cost</th>
      <th>Total</th>
      [% IF coa_accounts.size %]<th>Expense Account</th>[% END %]
      <th>Location</th>
      <th></th>
    </tr>
  </thead>
  <tbody id="lines-body">
  </tbody>
</table>

<p>
  <button type="button" onclick="addLine()">+ Add Line</button>
</p>

<table cellpadding="5" style="margin-top:8px;">
  <tr>
    <th align="right">Lines Subtotal:</th>
    <td>$<span id="lines-subtotal">0.00</span></td>
  </tr>
  <tr>
    <th align="right"><label for="tax_amount">Tax:</label></th>
    <td>
      <input type="number" id="tax_amount" name="tax_amount" value="[% submitted.tax_amount || '0.00' %]" step="0.01" min="0" style="width:90px;" oninput="recalcGrandTotal()">
      [% IF coa_accounts.size %]
      <select id="tax_account_id" name="tax_account_id" style="margin-left:6px;">
        <option value="">— tax account —</option>
        [% FOREACH a IN coa_accounts %]
        <option value="[% a.id %]"[% IF submitted.tax_account_id ? (submitted.tax_account_id == a.id) : (a.accno == '6310') %] selected[% END %]>[% a.accno %] [% a.description | html %]</option>
        [% END %]
      </select>
      [% END %]
    </td>
  </tr>
  <tr>
    <th align="right"><label for="shipping_amount">Shipping:</label></th>
    <td>
      <input type="number" id="shipping_amount" name="shipping_amount" value="[% submitted.shipping_amount || '0.00' %]" step="0.01" min="0" style="width:90px;" oninput="recalcGrandTotal()">
      [% IF coa_accounts.size %]
      <select id="shipping_account_id" name="shipping_account_id" style="margin-left:6px;">
        <option value="">— shipping account —</option>
        [% FOREACH a IN coa_accounts %]
        <option value="[% a.id %]"[% IF submitted.shipping_account_id ? (submitted.shipping_account_id == a.id) : (a.accno == '6400') %] selected[% END %]>[% a.accno %] [% a.description | html %]</option>
        [% END %]
      </select>
      [% END %]
    </td>
  </tr>
  <tr>
    <th align="right"><label for="discount_amount">Discount:</label></th>
    <td>
      <input type="number" id="discount_amount" name="discount_amount" value="[% submitted.discount_amount || '0.00' %]" step="0.01" min="0" style="width:90px;" oninput="recalcGrandTotal()">
      [% IF coa_accounts.size %]
      <select id="discount_account_id" name="discount_account_id" style="margin-left:6px;">
        <option value="">— discount account —</option>
        [% FOREACH a IN coa_accounts %]
        <option value="[% a.id %]"[% IF submitted.discount_account_id ? (submitted.discount_account_id == a.id) : (a.accno == '5200') %] selected[% END %]>[% a.accno %] [% a.description | html %]</option>
        [% END %]
      </select>
      [% END %]
      <small style="margin-left:4px;">Subtracted from total</small>
    </td>
  </tr>
  <tr>
    <th align="right" style="font-size:1.1em;font-weight:bold;">Invoice Total:</th>
    <td style="font-size:1.1em;font-weight:bold;">$<span id="invoice-total">0.00</span></td>
  </tr>
</table>

<p>
  <input type="submit" value="Save Invoice" style="background:#007bff;color:white;padding:8px 18px;border:none;border-radius:4px;cursor:pointer;">
  <a href="/Inventory/invoice" style="margin-left:1em;">Cancel</a>
</p>
</form>

<script>
var lineIndex = 0;

var items = [
  [% FOREACH i IN items %]
  { id: [% i.id %], name: "[% i.name.replace('"', '&quot;') | html %]", sku: "[% i.sku | html %]",
    cost: "[% i.unit_cost || '' %]", expense_id: "[% i.expense_accno_id || '' %]" }[% ',' UNLESS loop.last %]
  [% END %]
];

var locations = [
  [% FOREACH l IN locations %]
  { id: [% l.id %], name: "[% l.name.replace('"', '&quot;') | html %]" }[% ',' UNLESS loop.last %]
  [% END %]
];

var coaAccounts = [
  [% FOREACH a IN coa_accounts %]
  { id: [% a.id %], label: "[% a.accno %] [% a.description.replace('"', '&quot;') | html %]" }[% ',' UNLESS loop.last %]
  [% END %]
];

function buildItemSelect(name, onchange, selectedId) {
  var s = '<select name="' + name + '" onchange="' + onchange + '" style="max-width:220px;">'
    + '<option value="">— select or leave blank —</option>';
  items.forEach(function(i) {
    var sel = (selectedId && i.id == selectedId) ? ' selected' : '';
    s += '<option value="' + i.id + '" data-cost="' + i.cost + '" data-expense="' + i.expense_id
       + '" data-name="' + i.name.replace(/"/g, '&quot;') + '"' + sel + '>'
       + i.name + ' [' + i.sku + ']</option>';
  });
  s += '</select>';
  return s;
}

function buildLocationSelect(name, selectedId) {
  var s = '<select name="' + name + '"><option value="">— none —</option>';
  locations.forEach(function(l) {
    var sel = (selectedId && l.id == selectedId) ? ' selected' : '';
    s += '<option value="' + l.id + '"' + sel + '>' + l.name + '</option>';
  });
  return s + '</select>';
}

function buildAccountSelect(name, selectedId) {
  var s = '<select name="' + name + '" style="max-width:200px;"><option value="">— none —</option>';
  coaAccounts.forEach(function(a) {
    var sel = (selectedId && a.id == selectedId) ? ' selected' : '';
    s += '<option value="' + a.id + '"' + sel + '>' + a.label + '</option>';
  });
  return s + '</select>';
}

function addLine(prefill) {
  var idx = lineIndex++;
  var hasCoa = coaAccounts.length > 0;
  prefill = prefill || {};
  var row = document.createElement('tr');
  row.id = 'line-' + idx;
  row.innerHTML = '<td>' + (idx + 1) + '</td>'
    + '<td>' + buildItemSelect('item_id_' + idx, 'itemChanged(this,' + idx + ')', prefill.item_id) + '</td>'
    + '<td><input type="text" name="description_' + idx + '" size="20" value="' + (prefill.description || '') + '"></td>'
    + '<td><input type="number" name="quantity_' + idx + '" value="' + (prefill.quantity || '1') + '" min="0.0001" step="any" size="6" oninput="calcLine(' + idx + ')"></td>'
    + '<td><input type="number" name="unit_cost_' + idx + '" value="' + (prefill.unit_cost || '0.00') + '" min="0" step="0.01" size="10" oninput="calcLine(' + idx + ')"></td>'
    + '<td id="total-' + idx + '" style="text-align:right">$' + (prefill.line_total || '0.00') + '</td>'
    + (hasCoa ? '<td id="acct-cell-' + idx + '">' + buildAccountSelect('account_id_' + idx, prefill.account_id) + '</td>' : '')
    + '<td>' + buildLocationSelect('location_id_' + idx, prefill.location_id) + '</td>'
    + '<td><button type="button" onclick="removeLine(' + idx + ')">&#x2715;</button></td>';
  document.getElementById('lines-body').appendChild(row);
}

function itemChanged(sel, idx) {
  var opt = sel.options[sel.selectedIndex];
  var cost      = opt ? (opt.getAttribute('data-cost')    || 0)  : 0;
  var expenseId = opt ? (opt.getAttribute('data-expense') || '') : '';
  var itemName  = opt ? (opt.getAttribute('data-name')    || '') : '';
  var costField = document.querySelector('[name="unit_cost_' + idx + '"]');
  if (costField && cost) costField.value = parseFloat(cost).toFixed(2);
  var descField = document.querySelector('[name="description_' + idx + '"]');
  if (descField && itemName && !descField.value) descField.value = itemName;
  if (expenseId) {
    var acctSel = document.querySelector('[name="account_id_' + idx + '"]');
    if (acctSel) {
      for (var i = 0; i < acctSel.options.length; i++) {
        if (acctSel.options[i].value == expenseId) { acctSel.selectedIndex = i; break; }
      }
    }
  }
  calcLine(idx);
}

function calcLine(idx) {
  var qty  = parseFloat(document.querySelector('[name="quantity_' + idx + '"]').value)  || 0;
  var cost = parseFloat(document.querySelector('[name="unit_cost_' + idx + '"]').value) || 0;
  document.getElementById('total-' + idx).textContent = '$' + (qty * cost).toFixed(2);
  calcTotal();
}

function calcTotal() {
  var subtotal = 0;
  document.querySelectorAll('[id^="total-"]').forEach(function(el) {
    subtotal += parseFloat(el.textContent.replace('$','')) || 0;
  });
  var subtotalEl = document.getElementById('lines-subtotal');
  if (subtotalEl) subtotalEl.textContent = subtotal.toFixed(2);
  recalcGrandTotal();
}

function recalcGrandTotal() {
  var subtotal  = parseFloat((document.getElementById('lines-subtotal')  || {}).textContent) || 0;
  var tax       = parseFloat((document.getElementById('tax_amount')      || {}).value)       || 0;
  var shipping  = parseFloat((document.getElementById('shipping_amount') || {}).value)       || 0;
  var discount  = parseFloat((document.getElementById('discount_amount') || {}).value)       || 0;
  document.getElementById('invoice-total').textContent = (subtotal + tax + shipping - discount).toFixed(2);
}

function removeLine(idx) {
  var row = document.getElementById('line-' + idx);
  if (row) row.remove();
  calcTotal();
}

// -----------------------------------------------------------------------
// Popup support — opens add-item or add-supplier in a new window.
// When the popup closes, refreshes ONLY the relevant dropdown via AJAX
// so all existing invoice data is preserved.
// -----------------------------------------------------------------------
function openItemPopup(url, type) {
  var w = window.open(url, 'inv_popup', 'width=920,height=720,scrollbars=yes');
  var timer = setInterval(function() {
    if (w.closed) {
      clearInterval(timer);
      if (type === 'item')     refreshItemsAjax();
      if (type === 'supplier') refreshSuppliersAjax();
    }
  }, 600);
}

function refreshItemsAjax() {
  fetch('/Inventory/api/items_with_accounts')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      items = data;
      // Rebuild every item select that still has no value chosen
      document.querySelectorAll('[name^="item_id_"]').forEach(function(sel) {
        var cur = sel.value;
        var idx = sel.name.replace('item_id_', '');
        sel.innerHTML = '<option value="">— select or leave blank —</option>';
        data.forEach(function(i) {
          var opt = document.createElement('option');
          opt.value = i.id;
          opt.textContent = i.name + ' [' + i.sku + ']';
          opt.setAttribute('data-cost',    i.unit_cost       || '');
          opt.setAttribute('data-expense', i.expense_accno_id || '');
          if (i.id == cur) opt.selected = true;
          sel.appendChild(opt);
        });
      });
    })
    .catch(function(e) { console.warn('refreshItemsAjax failed', e); });
}

function refreshSuppliersAjax() {
  fetch('/Inventory/api/suppliers')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var sel = document.getElementById('supplier_id');
      if (!sel) return;
      var cur = sel.value;
      sel.innerHTML = '<option value="">— select supplier —</option>';
      data.forEach(function(s) {
        var opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        if (s.id == cur) opt.selected = true;
        sel.appendChild(opt);
      });
      // Select the newest supplier (last in list) if nothing was selected
      if (!cur && data.length) sel.value = data[data.length - 1].id;
    })
    .catch(function(e) { console.warn('refreshSuppliersAjax failed', e); });
}

// Restore submitted lines on error, or add a blank first line
var submittedLines = [% IF submitted %][% SET max_idx = -1 %][% FOREACH key IN submitted.keys %][% IF key.match('^quantity_(\d+)$') %][% SET idx = key.replace('quantity_','') %][% IF idx > max_idx %][% SET max_idx = idx %][% END %][% END %][% END %][% IF max_idx >= 0 %]
  (function() {
    var lines = [];
    [% FOREACH n IN [0..max_idx] %]
    [% SET qk = "quantity_$n" %][% SET ck = "unit_cost_$n" %][% SET ik = "item_id_$n" %][% SET dk = "description_$n" %][% SET ak = "account_id_$n" %][% SET lk = "location_id_$n" %]
    [% IF submitted.$qk || submitted.$ik || submitted.$dk %]
    lines.push({ item_id: "[% submitted.$ik %]", description: "[% submitted.$dk.replace('"','&quot;') %]",
      quantity: "[% submitted.$qk || 1 %]", unit_cost: "[% submitted.$ck || '0.00' %]",
      account_id: "[% submitted.$ak %]", location_id: "[% submitted.$lk %]", line_total: "" });
    [% END %]
    [% END %]
    return lines;
  })()
[% ELSE %][][% END %][% ELSE %][][% END %];

if (submittedLines.length) {
  submittedLines.forEach(function(ln) { addLine(ln); });
  calcTotal();
} else {
  addLine();
  calcTotal();
}
</script>
