[% PageVersion = 'Inventory/print/labels_multi.tt,v 0.01 2026/04/14 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<style>
  @media print {
    .no-print { display: none !important; }
    body { margin: 0; padding: 0; }
  }

  body { font-family: Arial, sans-serif; background: #f5f5f5; }

  .print-controls {
    background: #333;
    color: #fff;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .print-controls a { color: #adf; text-decoration: none; }
  .print-controls button {
    background: #28a745;
    color: #fff;
    border: none;
    padding: 8px 18px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1em;
    font-weight: bold;
  }

  .label-page {
    display: flex;
    flex-wrap: wrap;
    gap: 5mm;
    padding: 8mm;
    max-width: 210mm;
    margin: 10px auto;
    background: #fff;
    box-shadow: 0 0 8px rgba(0,0,0,0.2);
  }

  .label {
    width: 62mm;
    height: 40mm;
    border: 1px solid #333;
    border-radius: 3px;
    padding: 3mm;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    page-break-inside: avoid;
    background: #fff;
    overflow: hidden;
  }

  .label-site {
    font-size: 6pt;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .label-name {
    font-size: 10pt;
    font-weight: bold;
    line-height: 1.2;
    max-height: 2.4em;
    overflow: hidden;
    flex: 1;
    margin: 1mm 0;
  }

  .label-sku {
    font-family: 'Courier New', monospace;
    font-size: 9pt;
    font-weight: bold;
    letter-spacing: 2px;
    border-top: 1px solid #ccc;
    padding-top: 1mm;
    text-align: center;
  }

  .label-sku-bars {
    font-family: 'Courier New', monospace;
    font-size: 16pt;
    letter-spacing: -1px;
    text-align: center;
    color: #000;
    line-height: 1;
    display: block;
  }

  .label-meta {
    font-size: 6.5pt;
    color: #555;
    display: flex;
    justify-content: space-between;
  }

  @media print {
    .label-page {
      box-shadow: none;
      margin: 0;
      padding: 5mm;
    }
    .label {
      border-color: #000;
    }
  }
</style>

<div class="no-print print-controls">
  <a href="/Inventory/items">&larr; Back to Items</a>
  &nbsp;|&nbsp;
  <strong>[% items.size %] label(s)</strong>
  &nbsp;
  <button onclick="window.print()">&#128438; Print All Labels</button>
  <span style="font-size:0.85em;color:#ccc;">Tip: Set paper size to A4, minimal margins, disable headers/footers</span>
</div>

<div class="label-page">
  [% IF items.size == 0 %]
  <p style="padding:20px;color:#666;">No items found for label printing.</p>
  [% END %]
  [% FOREACH item IN items %]
  <div class="label">
    <div class="label-site">[% item.sitename %]</div>
    <div class="label-name">[% item.name | html %]</div>
    <div class="label-meta">
      <span>[% item.category || '' %]</span>
      <span>[% item.unit_of_measure %]</span>
    </div>
    [% IF item.unit_price %]
    <div class="label-meta">
      <span style="font-weight:bold">$[% item.unit_price %]</span>
    </div>
    [% END %]
    <div class="label-sku">
      <span class="label-sku-bars">||||| ||| ||||||</span>
      [% item.sku %]
    </div>
  </div>
  [% END %]
</div>
