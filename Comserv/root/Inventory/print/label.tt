<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Labels — [% item.name | html %]</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, sans-serif; background: #f5f5f5; }

  .print-controls {
    background: #333; color: #fff; padding: 12px 20px;
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .print-controls a { color: #adf; text-decoration: none; }
  .print-controls button {
    background: #28a745; color: #fff; border: none;
    padding: 8px 18px; border-radius: 4px; cursor: pointer;
    font-size: 1em; font-weight: bold;
  }

  .label-page {
    display: flex; flex-wrap: wrap; gap: 6mm;
    padding: 10mm; max-width: 210mm;
    margin: 10px auto; background: #fff;
    box-shadow: 0 0 8px rgba(0,0,0,0.2);
  }

  .label {
    width: 62mm; height: 40mm;
    border: 1px solid #333; border-radius: 3px; padding: 3mm;
    display: flex; flex-direction: column; justify-content: space-between;
    page-break-inside: avoid; background: #fff; overflow: hidden;
  }

  .label-site { font-size: 6pt; color: #888; text-transform: uppercase; letter-spacing: 1px; }
  .label-name { font-size: 10pt; font-weight: bold; line-height: 1.2; max-height: 2.4em; overflow: hidden; flex: 1; margin: 1mm 0; }
  .label-sku { font-family: 'Courier New', monospace; font-size: 9pt; font-weight: bold; letter-spacing: 2px; border-top: 1px solid #ccc; padding-top: 1mm; text-align: center; }
  .label-sku-bars { font-family: 'Courier New', monospace; font-size: 16pt; letter-spacing: -1px; text-align: center; color: #000; line-height: 1; display: block; }
  .label-meta { font-size: 6.5pt; color: #555; display: flex; justify-content: space-between; }
  .label-location { font-size: 7pt; color: #444; margin-top: 1mm; }

  @media print {
    body { background: #fff; }
    .no-print { display: none !important; }
    .label-page { box-shadow: none; margin: 0; padding: 5mm; }
    .label { border-color: #000; }
  }
</style>
</head>
<body>

<div class="no-print print-controls">
  <a href="/Inventory/item/view/[% item.id %]">&larr; Back to Item</a>
  &nbsp;|&nbsp;
  <label>Copies:
    <input type="number" id="copies-input" value="[% copies %]" min="1" max="50" style="width:50px;"
           onchange="updateCopies(this.value)">
  </label>
  &nbsp;
  <button onclick="window.print()">&#128438; Print Labels</button>
  <span style="font-size:0.85em;color:#ccc;">Tip: Set paper size to A4, margins minimal, no headers/footers in browser print dialog</span>
</div>

<div class="label-page" id="label-page">
  [% BLOCK single_label %]
  <div class="label">
    <div class="label-site">[% item.sitename %]</div>
    <div class="label-name">[% item.name | html %]</div>
    <div class="label-meta">
      <span>[% item.category || '' %]</span>
      <span>[% item.unit_of_measure %]</span>
    </div>
    [% IF item.unit_price %]
    <div class="label-meta">
      <span style="font-weight:bold">$[% item.unit_price %]</span>
      [% IF item.barcode %]<span style="font-size:6pt">[% item.barcode %]</span>[% END %]
    </div>
    [% END %]
    <div class="label-sku">
      <span class="label-sku-bars">||||| ||| ||||||</span>
      [% item.sku %]
    </div>
  </div>
  [% END %]

  [% count = 0 %]
  [% WHILE count < copies %]
    [% PROCESS single_label %]
    [% count = count + 1 %]
  [% END %]
</div>

<script>
function updateCopies(n) {
  n = parseInt(n) || 1;
  if (n < 1) n = 1;
  if (n > 50) n = 50;
  window.location.href = '/Inventory/print/label/[% item.id %]?copies=' + n;
}
</script>
</body>
</html>
