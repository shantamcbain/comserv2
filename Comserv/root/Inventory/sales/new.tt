[% INCLUDE 'header.tt' %]

<h1>New Sales Invoice</h1>
<p><a href="/Inventory/sales">← Sales Invoices</a></p>

[% IF error_msg %]<p style="color:red;font-weight:bold">[% error_msg %]</p>[% END %]

[% IF orders.size %]
<p>
  <strong>Create from a customer order:</strong>
  <select id="order-prefill" onchange="prefillFromOrder(this)" style="margin-left:6px;">
    <option value="">— select order to prefill —</option>
    [% FOREACH o IN orders %]
    <option value="[% o.id %]"
            data-name="[% o.customer_name | html %]"
            data-email="[% o.customer_email | html %]"
            data-order-id="[% o.id %]">
      Order #[% o.id %] — [% o.customer_name | html %] ([% o.status %])
    </option>
    [% END %]
  </select>
  <small style="margin-left:6px;">or fill the form manually below</small>
</p>
[% END %]

<form method="POST" action="/Inventory/sales/new" id="sales-form">
<input type="hidden" name="customer_order_id" id="customer_order_id" value="[% submitted.customer_order_id || prefill_order.id %]">

<table cellpadding="6">
  <tr>
    <th><label for="customer_name">Customer Name *</label></th>
    <td><input type="text" id="customer_name" name="customer_name" required maxlength="255"
               value="[% submitted.customer_name || prefill_order.customer_name | html %]" style="width:260px;"></td>
  </tr>
  <tr>
    <th><label for="customer_email">Email</label></th>
    <td><input type="email" id="customer_email" name="customer_email" maxlength="255"
               value="[% submitted.customer_email || prefill_order.customer_email | html %]" style="width:260px;"></td>
  </tr>
  <tr>
    <th><label for="invoice_number">Invoice Number</label></th>
    <td><input type="text" id="invoice_number" name="invoice_number" maxlength="100"
               value="[% submitted.invoice_number | html %]"
               placeholder="Auto-generated if blank" style="width:200px;"></td>
  </tr>
  <tr>
    <th><label for="invoice_date">Invoice Date *</label></th>
    <td><input type="date" id="invoice_date" name="invoice_date" required
               value="[% submitted.invoice_date || today %]"></td>
  </tr>
  <tr>
    <th><label for="due_date">Due Date</label></th>
    <td><input type="date" id="due_date" name="due_date"
               value="[% submitted.due_date %]"></td>
  </tr>
  [% IF coa_accounts.size %]
  <tr>
    <th><label for="ar_account_id">AR Account</label></th>
    <td>
      <select id="ar_account_id" name="ar_account_id">
        <option value="">— none —</option>
        [% FOREACH a IN coa_accounts %]
        <option value="[% a.id %]"[% IF submitted.ar_account_id ? (submitted.ar_account_id == a.id) : (a.accno == '1100') %] selected[% END %]>
          [% a.accno %] [% a.description | html %]
        </option>
        [% END %]
      </select>
      <small>Accounts Receivable (1100)</small>
    </td>
  </tr>
  <tr>
    <th><label for="income_account_id">Default Income Account</label></th>
    <td>
      <select id="income_account_id" name="income_account_id">
        <option value="">— none / per-line —</option>
        [% FOREACH a IN coa_accounts %]
        <option value="[% a.id %]"[% IF submitted.income_account_id ? (submitted.income_account_id == a.id) : (a.accno == '4210') %] selected[% END %]>
          [% a.accno %] [% a.description | html %]
        </option>
        [% END %]
      </select>
      <small>Used when line item has no income account (e.g. 4210 3D Print Sales)</small>
    </td>
  </tr>
  <tr>
    <th><label for="tax_account_id">Tax Account</label></th>
    <td>
      <select id="tax_account_id" name="tax_account_id">
        <option value="">— none —</option>
        [% FOREACH a IN coa_accounts %]
        <option value="[% a.id %]"[% IF submitted.tax_account_id ? (submitted.tax_account_id == a.id) : (a.accno == '2300') %] selected[% END %]>
          [% a.accno %] [% a.description | html %]
        </option>
        [% END %]
      </select>
    </td>
  </tr>
  [% END %]
  <tr>
    <th><label for="notes">Notes</label></th>
    <td><textarea id="notes" name="notes" rows="2" cols="50">[% submitted.notes | html %]</textarea></td>
  </tr>
</table>

<h2>Line Items</h2>
<p><small>Select items to invoice. Unit Cost is the cost to produce (for COGS); Unit Price is what you charge the customer.</small></p>

<table id="lines-table" border="1" cellpadding="5" style="border-collapse:collapse;width:100%;">
  <thead>
    <tr style="background:#f0f0f0;">
      <th>#</th>
      <th>Item</th>
      <th>Description</th>
      <th>Qty</th>
      <th>Unit Cost<br><small>(COGS)</small></th>
      <th>Unit Price<br><small>(charged)</small></th>
      <th>Total</th>
      <th>Notes</th>
      <th></th>
    </tr>
  </thead>
  <tbody id="lines-body"></tbody>
</table>

<p><button type="button" onclick="addLine()">+ Add Line</button></p>

<table cellpadding="5" style="margin-top:8px;">
  <tr>
    <th align="right"><label for="tax_amount">Tax:</label></th>
    <td>
      <input type="number" id="tax_amount" name="tax_amount"
             value="[% submitted.tax_amount || '0.00' %]"
             step="0.01" min="0" style="width:90px;" oninput="recalcTotal()">
    </td>
  </tr>
  <tr>
    <th align="right" style="font-size:1.1em;font-weight:bold;">Invoice Total:</th>
    <td style="font-size:1.1em;font-weight:bold;">$<span id="invoice-total">0.00</span></td>
  </tr>
</table>

<p>
  <input type="submit" value="Save Invoice (Draft)"
         style="background:#007bff;color:white;padding:8px 18px;border:none;border-radius:4px;cursor:pointer;">
  <a href="/Inventory/sales" style="margin-left:1em;">Cancel</a>
</p>
</form>

<script>
var lineIndex = 0;

var items = [
[% FOREACH i IN items %]
  { id: [% i.id %],
    name: "[% i.name.replace('"','&quot;') | html %]",
    sku: "[% i.sku | html %]",
    unit_cost: "[% i.unit_cost || '0.00' %]",
    unit_price: "[% i.unit_price || '0.00' %]",
    description: "[% i.description.replace('"','&quot;').replace('\n',' ') | html %]",
    income_id: "[% i.income_accno_id || '' %]",
    cogs_id: "[% i.expense_accno_id || '' %]",
    inv_id: "[% i.inventory_accno_id || '' %]"
  }[% ',' UNLESS loop.last %]
[% END %]
];

function itemChanged(idx) {
  var sel = document.getElementById('item_sel_' + idx);
  var opt = sel ? sel.options[sel.selectedIndex] : null;
  if (!opt || !opt.value) return;
  var i = items.find(function(x){ return x.id == opt.value; });
  if (!i) return;
  var desc = document.getElementById('desc_' + idx);
  if (desc && !desc.value) desc.value = i.name;
  document.getElementById('unit_cost_' + idx).value  = i.unit_cost;
  document.getElementById('unit_price_' + idx).value = i.unit_price;
  document.getElementById('income_id_' + idx).value  = i.income_id;
  document.getElementById('cogs_id_' + idx).value    = i.cogs_id;
  document.getElementById('inv_id_' + idx).value     = i.inv_id;
  updateLine(idx);
}

function updateLine(idx) {
  var qty   = parseFloat(document.getElementById('qty_' + idx).value) || 0;
  var price = parseFloat(document.getElementById('unit_price_' + idx).value) || 0;
  var lt    = qty * price;
  document.getElementById('lt_' + idx).textContent = lt.toFixed(2);
  recalcTotal();
}

function recalcTotal() {
  var sum = 0;
  document.querySelectorAll('[id^="lt_"]').forEach(function(el){ sum += parseFloat(el.textContent) || 0; });
  var tax = parseFloat(document.getElementById('tax_amount').value) || 0;
  document.getElementById('invoice-total').textContent = (sum + tax).toFixed(2);
}

function removeLine(idx) {
  var r = document.getElementById('row_' + idx);
  if (r) r.remove();
  recalcTotal();
}

function buildItemSelect(idx) {
  var s = '<select id="item_sel_' + idx + '" name="item_id_' + idx + '" onchange="itemChanged(' + idx + ')" style="max-width:200px;">'
        + '<option value="">— item —</option>';
  items.forEach(function(i) {
    s += '<option value="' + i.id + '">' + i.name + ' [' + i.sku + ']</option>';
  });
  s += '</select>';
  return s;
}

function addLine(prefillItem) {
  var idx = lineIndex++;
  var tbody = document.getElementById('lines-body');
  var tr = document.createElement('tr');
  tr.id = 'row_' + idx;
  tr.innerHTML =
    '<td>' + (idx + 1) + '</td>'
    + '<td>' + buildItemSelect(idx) + '</td>'
    + '<td><input type="text" id="desc_' + idx + '" name="description_' + idx + '" style="width:140px;"></td>'
    + '<td><input type="number" id="qty_' + idx + '" name="quantity_' + idx + '" value="1" min="0.001" step="0.001" style="width:60px;" oninput="updateLine(' + idx + ')"></td>'
    + '<td><input type="number" id="unit_cost_' + idx + '" name="unit_cost_' + idx + '" value="0.00" step="0.01" min="0" style="width:80px;"></td>'
    + '<td><input type="number" id="unit_price_' + idx + '" name="unit_price_' + idx + '" value="0.00" step="0.01" min="0" style="width:80px;" oninput="updateLine(' + idx + ')"></td>'
    + '<td>$<span id="lt_' + idx + '">0.00</span></td>'
    + '<td><input type="text" name="notes_line_' + idx + '" style="width:110px;" placeholder="colour, size..."></td>'
    + '<input type="hidden" id="income_id_' + idx + '" name="income_account_id_' + idx + '">'
    + '<input type="hidden" id="cogs_id_' + idx + '" name="cogs_account_id_' + idx + '">'
    + '<input type="hidden" id="inv_id_' + idx + '" name="inventory_account_id_' + idx + '">'
    + '<td><button type="button" onclick="removeLine(' + idx + ')">✕</button></td>';
  tbody.appendChild(tr);
  if (prefillItem) {
    document.getElementById('item_sel_' + idx).value = prefillItem.id;
    itemChanged(idx);
    document.getElementById('desc_' + idx).value      = prefillItem.description || prefillItem.name;
    document.getElementById('qty_' + idx).value       = prefillItem.qty || 1;
    document.getElementById('unit_price_' + idx).value = prefillItem.price || '0.00';
    updateLine(idx);
  }
}

[% IF prefill_order %]
var prefillLines = [
  [% FOREACH l IN prefill_order.lines %]
  { id: [% l.item_id || 0 %], name: "[% l.item.name.replace('"','&quot;') | html %]",
    description: "[% l.description.replace('"','&quot;') | html %]",
    qty: [% l.quantity %], price: "[% l.unit_price %]",
    income_id: "[% l.item.income_accno_id || '' %]",
    cogs_id: "[% l.item.expense_accno_id || '' %]",
    inv_id: "[% l.item.inventory_accno_id || '' %]" }[% ',' UNLESS loop.last %]
  [% END %]
];
prefillLines.forEach(function(l){ addLine(l); });
[% ELSE %]
addLine();
[% END %]

var prefillOrders = {
[% FOREACH o IN orders %]
  [% o.id %]: { name: "[% o.customer_name.replace('"','&quot;') | html %]",
                email: "[% o.customer_email.replace('"','&quot;') | html %]",
                order_id: [% o.id %] }[% ',' UNLESS loop.last %]
[% END %]
};

function prefillFromOrder(sel) {
  var oid = sel.value;
  if (!oid) return;
  var o = prefillOrders[oid];
  if (!o) return;
  document.getElementById('customer_name').value  = o.name;
  document.getElementById('customer_email').value = o.email;
  document.getElementById('customer_order_id').value = o.order_id;
  window.location.href = '/Inventory/sales/new?from_order=' + oid;
}
</script>

[% INCLUDE 'footer.tt' %]
