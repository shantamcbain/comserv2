[% PageVersion = 'edit_link.tt,v 0.02 2026/06/12 Menu category + site scope on edit' %]
[% IF debug == 1 %]
    [% PageVersion %]
[% END %]

<div class="container nav-link-form">
    <h2><i class="icon-edit"></i> Edit Link</h2>

    [% IF error_msg %]
        <div class="alert alert-danger">[% error_msg %]</div>
    [% END %]
    [% IF success_msg %]
        <div class="alert alert-success">[% success_msg %]</div>
    [% END %]

    <form method="POST" action="/navigation/edit_link?id=[% link.id %]" id="edit-link-form">
        [% SET form = link %]
        [% INCLUDE 'Navigation/inc/link_scope_fields.tt' form = link %]
        [% INCLUDE 'Navigation/inc/link_submenu_field.tt' form = link %]
        [% INCLUDE 'Navigation/inc/link_public_visible_field.tt' form = link %]

        <div class="form-group">
            <label for="name">Link Name:</label>
            <input type="text" id="name" name="name" class="form-control"
                   value="[% link.name | html %]" required maxlength="100">
        </div>

        <div class="form-group">
            <label for="url">URL:</label>
            <input type="text" id="url" name="url" class="form-control"
                   value="[% link.url | html %]" required maxlength="255"
                   placeholder="/path or https://example.com">
        </div>

        <div class="form-group">
            <label for="target">Open In:</label>
            <select id="target" name="target" class="form-control">
                <option value="_self" [% IF link.target == '_self' || !link.target %]selected[% END %]>Same Window</option>
                <option value="_blank" [% IF link.target == '_blank' %]selected[% END %]>New Window</option>
            </select>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update Link</button>
            <a href="[% IF link.link_type == 'private' %]/navigation/manage_private_links[% ELSE %]/navigation/manage_links[% END %]" class="btn btn-secondary">Cancel</a>
            <a href="/navigation/delete_link?id=[% link.id %]"
               class="btn btn-danger"
               onclick="return confirm('Delete link [% link.name | html | js %]?')">Delete Link</a>
        </div>
    </form>
</div>

<script>
function syncExternalTargetDefault() {
    const urlEl = document.getElementById('url');
    const targetEl = document.getElementById('target');
    if (!urlEl || !targetEl) return;
    if (/^https?:\/\//i.test((urlEl.value || '').trim())) {
        targetEl.value = '_blank';
    }
}

function updateLinkScopeFields() {
    const linkType = document.getElementById('link_type');
    const crossSite = document.getElementById('cross_site');
    const sitename = document.getElementById('sitename');
    const category = document.getElementById('category');
    if (!category) return;

    const isPublic = linkType && linkType.value === 'public';
    category.querySelectorAll('[data-private-only="1"]').forEach(function(opt) {
        opt.hidden = isPublic;
        opt.disabled = isPublic;
        if (isPublic && category.value === 'Private_links') {
            const first = category.querySelector('option:not([data-private-only])');
            if (first) category.value = first.value;
        }
    });

    if (crossSite && sitename) {
        sitename.disabled = crossSite.checked;
    }

    var rowPublic = document.getElementById('row_public_visible');
    if (rowPublic) {
        rowPublic.style.display = isPublic ? '' : 'none';
    }
}
document.addEventListener('DOMContentLoaded', function() {
    updateLinkScopeFields();
    syncExternalTargetDefault();
    const urlEl = document.getElementById('url');
    if (urlEl) urlEl.addEventListener('input', syncExternalTargetDefault);
});
</script>

<style>
.nav-link-form {
    max-width: 640px;
}
.nav-link-form .form-group {
    margin-bottom: 1rem;
}
.nav-link-form label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--text-color, #333);
}
.nav-link-form .form-control {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-color, #ced4da);
    border-radius: 4px;
    background: var(--input-bg, #fff);
    color: var(--text-color, #333);
}
.site-scope-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}
.cross-site-toggle {
    font-weight: normal;
    font-size: 0.9rem;
    cursor: pointer;
}
.cross-site-toggle input {
    margin-right: 0.35rem;
}
.form-text.text-muted {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.85rem;
    color: var(--text-muted, #6c757d);
}
.form-actions {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color, #dee2e6);
}
.form-actions .btn {
    margin-right: 0.5rem;
    margin-bottom: 0.5rem;
}
</style>