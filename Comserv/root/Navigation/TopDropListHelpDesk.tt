[% PageVersion = 'Navigation/TopDropListHelpDesk.tt,v 0.02 2025/09/03 shanta Exp shanta ' %]

<li class="horizontal-dropdown">
    <a href="/HelpDesk" class="dropbtn"><i class="icon-helpdesk"></i>HelpDesk</a>
    <div class="dropdown-content">
        <!-- Core HelpDesk Services -->
        <a href="/HelpDesk" class="menu-item"><i class="icon-home"></i>HelpDesk Home</a>
        <a href="/HelpDesk/ticket/new" class="menu-item"><i class="icon-ticket"></i>Submit a Ticket</a>
        <a href="/HelpDesk/ticket/status" class="menu-item"><i class="icon-status"></i>Check Ticket Status</a>
        <a href="/HelpDesk/contact" class="menu-item"><i class="icon-contact"></i>Contact Support</a>
        
        [% IF c.session.username %]
        <div class="dropdown-divider"></div>
        <a href="/navigation/add_link?menu=HelpDesk" class="menu-item"><i class="icon-add"></i>Add HelpDesk Link</a>
        [% END %]
        
        <!-- Documentation & Knowledge Base -->
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-docs"></i>Documentation & Support</span>
            <div class="submenu">
                <a href="/Documentation" class="submenu-link"><i class="icon-docs"></i>Documentation</a>
                <a href="/HelpDesk/kb" class="submenu-link"><i class="icon-kb"></i>Knowledge Base</a>
                <a href="/faq" class="submenu-link"><i class="icon-faq"></i>FAQ</a>
                
                [% IF c.session.roles && c.session.roles.grep('^admin$').size %]
                <div class="submenu-section">
                    <span class="submenu-section-title">Admin Resources</span>
                    <a href="[% c.uri_for('/admin/dev-preview') %]" class="submenu-link"><i class="icon-flask"></i>Preview Upcoming Changes</a>
                    <a href="/HelpDesk/kb/linux_commands" class="submenu-link"><i class="icon-terminal"></i>Linux Commands</a>
                </div>
                [% END %]
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'HelpDesk_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'HelpDesk' %]
            </div>
        </div>
        
        <!-- IT Services (previously IT dropdown) -->
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-it"></i>IT Services</span>
            <div class="submenu">
                <a href="/it" class="submenu-link"><i class="icon-home"></i>IT Home</a>
                <a href="/it/resources" class="submenu-link"><i class="icon-resources"></i>Resources</a>
                <a href="/it/documentation" class="submenu-link"><i class="icon-docs"></i>Documentation</a>
                <a href="/it/support" class="submenu-link"><i class="icon-support"></i>Support</a>
                <a href="/it/tools" class="submenu-link"><i class="icon-tool"></i>Tools</a>
                <a href="/it/network" class="submenu-link"><i class="icon-network"></i>Network</a>
                <a href="/it/servers" class="submenu-link"><i class="icon-server"></i>Servers</a>
                <a href="/it/security" class="submenu-link"><i class="icon-security"></i>Security</a>
                [% IF c.session.username && c.stash.private_links %]
                    [% FOREACH link IN c.stash.private_links %]
                        [% IF link.category == 'IT_links' || link.category == 'HelpDesk_links' %]
                        [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                            row_href = link.url
                            row_label = link.name
                            row_target = link.target || '_blank'
                            row_icon = link.icon
                            row_extra_class = 'nav-link-private'
                            row_edit_kind = 'nav_link'
                            row_edit_id = link.id
                            row_can_edit = 1
                            row_link_type = 'private' %]
                        [% END %]
                    [% END %]
                [% END %]
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'HelpDesk_links'
                    add_link_submenu = 'it_services'
                    add_link_menu = 'HelpDesk' %]
            </div>
        </div>

        <!-- Admin Controls -->
        [% IF c.session.roles && c.session.roles.grep('^admin$').size %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-admin"></i>Admin Controls</span>
            <div class="submenu">
                <a href="/HelpDesk/admin" class="submenu-link"><i class="icon-admin"></i>HelpDesk Admin</a>
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'HelpDesk_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'HelpDesk' %]
            </div>
        </div>
        [% END %]
        
        <!-- Public HelpDesk Links (merged public + private) -->
        [% SET helpdesk_db_links = c.stash.nav_merged_links.HelpDesk_links || [] %]
        [% IF helpdesk_db_links.size %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-admin-links"></i>Additional Resources</span>
            <div class="submenu">
                [% INCLUDE 'Navigation/inc/menu_db_links.tt'
                    db_links = helpdesk_db_links
                    add_link_category = 'HelpDesk_links'
                    add_link_submenu = 'resources'
                    add_link_menu = 'HelpDesk' %]
            </div>
        </div>
        [% ELSIF c.session.username %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-admin-links"></i>Additional Resources</span>
            <div class="submenu">
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'HelpDesk_links'
                    add_link_submenu = 'resources'
                    add_link_menu = 'HelpDesk' %]
            </div>
        </div>
        [% END %]

        <!-- HelpDesk Pages (Dynamic & Legacy Support) -->
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-pages"></i>HelpDesk Pages</span>
            <div class="submenu">
                <!-- Dynamic Page-based links for HelpDesk menu -->
                [% FOREACH link = c.stash.dbi.query("SELECT * FROM page WHERE (LOWER(menu) = 'helpdesk' AND status = 'active') AND (sitename = '$SiteName' OR sitename = 'All' OR share_with = 'all' OR share_with LIKE '%$SiteName%') ORDER BY link_order") %]
                    [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                        row_href = '/page/' _ link.page_code
                        row_label = link.title
                        row_icon = 'fas fa-file-alt'
                        row_edit_kind = 'cms_page'
                        row_edit_id = link.id %]
                [% END %]
                
                <!-- Legacy Page-based links for HelpDesk menu -->
                [% FOREACH legacy_link = c.stash.dbi.query("SELECT * FROM page_tb WHERE (LOWER(menu) = 'helpdesk' AND status = 2) AND (sitename = '$SiteName' OR sitename = 'All') ORDER BY link_order") %]
                    [% SET is_migrated = c.stash.dbi.query("SELECT COUNT(*) as cnt FROM page WHERE page_code = '" _ legacy_link.page_code _ "'").0.cnt %]
                    [% IF is_migrated == 0 %]
                        [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                            row_href = '/cgi-bin/index.cgi?site=' _ SiteName _ '&' _ session_string _ '&page=' _ legacy_link.page_code
                            row_label = legacy_link.view_name
                            row_target = legacy_link.target
                            row_icon = 'fas fa-file-alt'
                            row_edit_kind = 'legacy_page'
                            row_edit_id = legacy_link.id %]
                    [% END %]
                [% END %]
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'HelpDesk_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'HelpDesk'
                    add_link_label = 'Add HelpDesk Page Link' %]
            </div>
        </div>
        
        <!-- Member Links (legacy support) -->
        [% IF member_links && member_links.size %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-member"></i>Member Resources</span>
            <div class="submenu">
                [% FOREACH link IN member_links %]
                    [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                        row_href = link.url
                        row_label = link.name
                        row_target = link.target || '_self'
                        row_icon = link.icon
                        row_edit_kind = 'nav_link'
                        row_edit_id = link.id
                        row_can_edit = link.can_edit
                        row_link_type = link.link_type
                        row_link_owner = link.owner
                        row_link_description = link.description %]
                [% END %]
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'HelpDesk_links'
                    add_link_submenu = 'member_resources'
                    add_link_menu = 'HelpDesk' %]
            </div>
        </div>
        [% END %]
        
        <!-- Private HelpDesk Links for logged in users -->
        [% IF c.session.username && c.stash.private_links %]
            [% SET has_private_helpdesk_links = 0 %]
            [% FOREACH link IN c.stash.private_links %]
                [% IF link.category == 'HelpDesk_links' || link.menu == 'HelpDesk' %]
                    [% SET has_private_helpdesk_links = 1 %]
                [% END %]
            [% END %]
            
            [% IF has_private_helpdesk_links %]
            <div class="dropdown-divider"></div>
            <div class="submenu-item">
                <span class="submenu-header"><i class="icon-user-help"></i>My HelpDesk Links</span>
                <div class="submenu">
                    [% FOREACH link IN c.stash.private_links %]
                        [% IF link.category == 'HelpDesk_links' || link.menu == 'HelpDesk' %]
                            [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                                row_href = link.url
                                row_label = link.name
                                row_target = link.target || '_self'
                                row_icon = link.icon
                                row_extra_class = 'nav-link-private'
                                row_edit_kind = 'nav_link'
                                row_edit_id = link.id
                                row_can_edit = 1
                                row_link_type = 'private' %]
                        [% END %]
                    [% END %]
                    [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                        add_link_category = 'HelpDesk_links'
                        add_link_submenu = 'top'
                        add_link_menu = 'HelpDesk' %]
                </div>
            </div>
            [% END %]
        [% END %]
        
        [% IF c.session.roles && c.session.roles.grep('^admin$').size %]
        <div class="dropdown-divider"></div>
        <a href="/navigation/manage_links?menu=HelpDesk" class="menu-item"><i class="icon-manage"></i>Manage HelpDesk Menu</a>
        [% END %]
    </div>
</li>

