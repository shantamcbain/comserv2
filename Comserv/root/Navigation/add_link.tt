[% PageVersion = 'add_link.tt,v 0.02 2026/06/12 Menu category + cross-site for private links' %]
[% IF debug == 1 %]
    [% PageVersion %]
[% END %]

<div class="container nav-link-form">
    <h2><i class="icon-add"></i> Add Link</h2>

    [% IF error_msg %]
        <div class="alert alert-danger">[% error_msg %]</div>
    [% END %]
    [% IF success_msg %]
        <div class="alert alert-success">[% success_msg %]</div>
    [% END %]

    <form method="POST" action="/navigation/add_link" id="add-link-form">
        [% IF preset_return_url %]
            <input type="hidden" name="return_url" value="[% preset_return_url | html %]">
        [% END %]

        [% SET form = {
            link_type  => form_data.link_type || preset_link_type || 'private',
            category   => form_data.category || preset_category || 'Member_links',
            sitename   => form_data.sitename || preset_sitename || permissions.available_sites.0,
            cross_site => form_data.cross_site ? 1 : 0,
            submenu    => form_data.submenu || preset_submenu
        } %]
        [% INCLUDE 'Navigation/inc/link_scope_fields.tt' form = form %]
        [%# Submenu is no longer shown to the user; it is passed as a hidden field so the link knows its exact location %]
        [% IF preset_submenu %]
            <input type="hidden" name="submenu" value="[% preset_submenu | html %]">
        [% ELSIF form.submenu %]
            <input type="hidden" name="submenu" value="[% form.submenu | html %]">
        [% END %]
        [% INCLUDE 'Navigation/inc/link_public_visible_field.tt' form = form %]

        <div class="form-group">
            <label for="name">Link Name:</label>
            <input type="text" id="name" name="name" class="form-control"
                   value="[% form_data.name | html %]" required maxlength="100">
        </div>

        <div class="form-group">
            <label for="url">URL:</label>
            <input type="text" id="url" name="url" class="form-control"
                   value="[% form_data.url | html %]" required maxlength="255"
                   placeholder="/path or https://example.com">
        </div>

        <div class="form-group">
            <label for="target">Open In:</label>
            <select id="target" name="target" class="form-control">
                <option value="_self" [% IF (form_data.target == '_self' || !form_data.target) %]selected[% END %]>Same Window</option>
                <option value="_blank" [% IF form_data.target == '_blank' %]selected[% END %]>New Window</option>
            </select>
        </div>

        [% UNLESS permissions.can_create_public %]
        <div class="info-note">
            <strong>Note:</strong> Your link will be private and appear in the menu you select above. Contact an administrator to create public site links.
        </div>
        [% END %]

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Add Link</button>
            <a href="/navigation/manage_links" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
[% PROCESS 'ai/partials/ai_form_assistant.tt'
   ai_form_entity_label = 'navigation link'
   ai_form_context      = 'site navigation menu link management'
   ai_form_fields       = 'link_text, url, description, category'
%]
</div>

<script>
function syncExternalTargetDefault() {
    const urlEl = document.getElementById('url');
    const targetEl = document.getElementById('target');
    if (!urlEl || !targetEl) return;
    if (/^https?:\/\//i.test((urlEl.value || '').trim())) {
        targetEl.value = '_blank';
    }
}

function updateLinkScopeFields() {
    const linkType = document.getElementById('link_type');
    const crossSite = document.getElementById('cross_site');
    const sitename = document.getElementById('sitename');
    const category = document.getElementById('category');
    if (!category) return;

    const isPublic = linkType && linkType.value === 'public';
    const isAdmin = [% IF permissions.can_create_public %]true[% ELSE %]false[% END %];
    category.querySelectorAll('[data-admin-only="1"]').forEach(function(opt) {
        // Admins may add private bookmarks to the Admin menu as well as public site links.
        const show = isPublic || isAdmin;
        opt.style.display = show ? '' : 'none';
        opt.disabled = !show;
    });
    category.querySelectorAll('[data-legacy-cat="1"]').forEach(function(opt) {
        opt.style.display = 'none';
    });
    category.querySelectorAll('[data-private-only="1"]').forEach(function(opt) {
        opt.hidden = isPublic;
        opt.disabled = isPublic;
    });
    if (isPublic && category.value === 'Private_links') {
        const first = category.querySelector('option:not([data-private-only]):not([data-legacy-cat]):not([style*="none"])');
        if (first) category.value = first.value;
    }
    if (category.querySelector('[value="' + category.value + '"][data-legacy-cat="1"]')) {
        const first = category.querySelector('option:not([data-legacy-cat]):not([style*="none"])');
        if (first) category.value = first.value;
    }

    if (crossSite && sitename) {
        sitename.disabled = crossSite.checked;
    }

    var rowPublic = document.getElementById('row_public_visible');
    if (rowPublic) {
        rowPublic.style.display = isPublic ? '' : 'none';
    }
}
document.addEventListener('DOMContentLoaded', function() {
    updateLinkScopeFields();
    syncExternalTargetDefault();
    const urlEl = document.getElementById('url');
    if (urlEl) urlEl.addEventListener('input', syncExternalTargetDefault);
});
</script>

<style>
.nav-link-form { max-width: 640px; }
.nav-link-form .form-group { margin-bottom: 1rem; }
.nav-link-form label {
    display: block; font-weight: 600; margin-bottom: 0.35rem;
    color: var(--text-color, #333);
}
.nav-link-form .form-control {
    width: 100%; padding: 0.5rem 0.75rem;
    border: 1px solid var(--border-color, #ced4da); border-radius: 4px;
    background: var(--input-bg, #fff); color: var(--text-color, #333);
}
.site-scope-row { display: flex; flex-direction: column; gap: 0.5rem; }
.cross-site-toggle { font-weight: normal; font-size: 0.9rem; cursor: pointer; }
.cross-site-toggle input { margin-right: 0.35rem; }
.form-text.text-muted {
    display: block; margin-top: 0.25rem; font-size: 0.85rem;
    color: var(--text-muted, #6c757d);
}
.info-note {
    background: var(--bg-secondary, #e7f3ff);
    border: 1px solid var(--border-color, #b8daff);
    padding: 10px; border-radius: 5px; margin-bottom: 15px;
}
.form-actions {
    margin-top: 1.5rem; padding-top: 1rem;
    border-top: 1px solid var(--border-color, #dee2e6);
}
.form-actions .btn { margin-right: 0.5rem; }
</style>