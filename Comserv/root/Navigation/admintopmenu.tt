        [% INCLUDE 'Navigation/inc/admin_dynamic_submenu_sections.tt' %]

        <!-- Debug Options -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-debug"></i>Debug Options</span>
            <div class="submenu">
                [% IF c.session.debug_mode == 1 %]
                    <a href="[% c.req.uri %]?debug=0"><i class="icon-toggle-off"></i>Toggle Debug Mode OFF</a>
                [% ELSE %]
                    <a href="[% c.req.uri %]?debug=1"><i class="icon-toggle-on"></i>Toggle Debug Mode ON</a>
                [% END %]
