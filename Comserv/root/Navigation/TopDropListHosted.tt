[% PageVersion = 'Navigation/TopDropListHosted.tt,v 0.05 2026/06/12 Scoped sites: public DNS for users; .local for site admins only' %]
[% IF c.session.debug_mode == 1 %]
    [%# PageVersion %]
    [%# "Debugging HostName: " _ HostName %]
    [%# INCLUDE 'debug.tt' %]
[% END %]

<!-- Hosted menu -->
<li class="horizontal-dropdown">
    <a href="/hosted" class="dropbtn"><i class="icon-hosted"></i>Hosted</a>
    <div class="dropdown-content">
        <!-- Core Hosted Services -->
        <a href="/hosted" class="menu-item"><i class="icon-home"></i>My Hosting</a>
        <a href="/hosting_signup" class="menu-item"><i class="icon-apply"></i>Apply for Hosting</a>
        <a href="/marketplace?type=job&amp;q=hosting" class="menu-item"><i class="icon-marketplace"></i>Hosting on Marketplace</a>

        <!-- Quick shortcuts pinned to the top of the dropdown -->
        [% SET hosted_top_links = c.stash.hosted_top_links || [] %]
        [% FOREACH link IN hosted_top_links %]
        <a href="[% link.url %]" target="[% link.target || '_blank' %]" class="menu-item" title="[% link.name | nav_label %]">
            [% IF link.icon %]<i class="[% link.icon %]"></i>[% END %]
            [% link.name | nav_label %]
        </a>
        [% END %]

        [% IF c.session.username %]
        <div class="dropdown-divider"></div>
        <a href="/navigation/add_link?menu=Hosted&amp;category=Hosted_links&amp;submenu=hosted_links" class="menu-item"><i class="icon-add"></i>Add Hosting Bookmark</a>
        [% END %]

        <!-- Sites we host: active hosting accounts + extra SiteDomain rows (deduped) -->
        [% SET hosted_sites_merged = c.stash.hosted_sites_merged || [] %]
        [% IF hosted_sites_merged.size %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-production"></i>Sites We Host</span>
            <div class="submenu">
                [% FOREACH site IN hosted_sites_merged %]
                <a href="[% site.url %]" target="_blank" class="submenu-link[% IF site.internal %] nav-link-internal[% END %]" title="[% site.label | nav_label %]">
                    <i class="icon-site"></i>[% site.label | nav_label %][% IF site.internal %] <span class="nav-dev-badge">dev</span>[% END %]
                </a>
                [% END %]
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'Hosted_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'Hosted'
                    add_link_label = 'Add Shortcut' %]
            </div>
        </div>
        [% END %]

        <!-- Guides, docs, and bookmarks (merged hosted_links + hosted_pages + CMS pages) -->
        [% SET hosted_resource_links = c.stash.hosted_resource_links || [] %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-docs"></i>Guides &amp; Bookmarks</span>
            <div class="submenu">
                [% IF hosted_resource_links.size %]
                    [% INCLUDE 'Navigation/inc/menu_db_links.tt'
                        db_links = hosted_resource_links
                        add_link_menu = 'Hosted'
                        add_link_category = 'Hosted_links'
                        add_link_submenu = 'hosted_links'
                        skip_add_link = 1 %]
                [% END %]
                <!-- CMS pages assigned to the Hosted menu -->
                [% FOREACH link = c.stash.dbi.query("SELECT * FROM page WHERE (LOWER(menu) = 'hosted' AND status = 'active') AND (sitename = '$SiteName' OR sitename = 'All' OR share_with = 'all' OR share_with LIKE '%$SiteName%') ORDER BY link_order") %]
                    [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                        row_href = '/page/' _ link.page_code
                        row_label = link.title
                        row_icon = 'fas fa-file-alt'
                        row_edit_kind = 'cms_page'
                        row_edit_id = link.id %]
                [% END %]
                [% FOREACH legacy_link = c.stash.dbi.query("SELECT * FROM page_tb WHERE (LOWER(menu) = 'hosted' AND status = 2) AND (sitename = '$SiteName' OR sitename = 'All') ORDER BY link_order") %]
                    [% SET is_migrated = c.stash.dbi.query("SELECT COUNT(*) as cnt FROM page WHERE page_code = '" _ legacy_link.page_code _ "'").0.cnt %]
                    [% IF is_migrated == 0 %]
                        [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                            row_href = '/cgi-bin/index.cgi?site=' _ SiteName _ '&' _ session_string _ '&page=' _ legacy_link.page_code
                            row_label = legacy_link.view_name
                            row_target = legacy_link.target
                            row_icon = 'fas fa-file-alt'
                            row_edit_kind = 'legacy_page'
                            row_edit_id = legacy_link.id %]
                    [% END %]
                [% END %]
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'Hosted_links'
                    add_link_submenu = 'hosted_links'
                    add_link_menu = 'Hosted'
                    add_link_label = 'Add Bookmark' %]
            </div>
        </div>

        [% IF c.stash.is_admin || c.session.roles.grep('admin').size %]
        <div class="dropdown-divider"></div>
        <a href="/accounts" class="menu-item"><i class="icon-accounts"></i>All Hosting Accounts</a>
        <a href="/hosting/cost" class="menu-item"><i class="icon-settings"></i>Hosting Cost Config</a>
        <a href="/hosting" class="menu-item"><i class="icon-server"></i>NPM Proxy Manager</a>
        <a href="/admin/marketplace" class="menu-item"><i class="icon-admin"></i>Manage Marketplace</a>
        <a href="/navigation/manage_links?menu=Hosted" class="menu-item"><i class="icon-manage"></i>Manage Hosted Menu</a>
        [% END %]
    </div>
</li>