[% PageVersion = 'Navigation/TopDropListGlobal.tt,v 0.02 2025/09/03 shanta Exp shanta ' %]
[% IF c.session.debug_mode == 1 %]
    [%# PageVersion %]
    [% #"Debugging HostName: " _ HostName %]
    [%# INCLUDE 'debug.tt' %]
[% END %]

<li class="horizontal-dropdown">
    <a href="#" class="dropbtn"><i class="icon-global"></i>Global</a>
    <div class="dropdown-content">
        <!-- Core Global Services -->
        <a href="/mail"><i class="icon-mail"></i>Mail</a>
        <a href="/jobs"><i class="icon-briefcase"></i>Jobs</a>
        <a href="/join"><i class="icon-user-plus"></i>Join</a>
        
        [% IF c.session.username %]
        <div class="dropdown-divider"></div>
        <a href="/navigation/add_link?menu=Global" class="menu-item"><i class="icon-add"></i>Add Global Link</a>
        [% END %]
        
        <!-- Development Links (for authorized users) -->
        [% IF c.session.group == 'Dev_admin' OR c.session.group == 'CSC_Developer' OR c.session.username == 'Shanta' %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-dev"></i>Development</span>
            <div class="submenu">
                [% IF c.session.firstname %]
                <a href="http://dev.[% HostName %]/cgi-bin/index.cgi?site=[% SiteName %]" target="_blank" title="Development Site">
                    <i class="icon-dev"></i>What we are working on
                </a>
                [% END %]
                <a href="http://[% HostName %]/cgi-bin/index.cgi?site=[% SiteName %]" target="_blank" title="Production Site">
                    <i class="icon-prod"></i>Production Site
                </a>
            </div>
        </div>
        [% END %]
        
        <!-- Public Global Links added by admin -->
        [% FOREACH link = c.stash.dbi.query("SELECT * FROM internal_links_tb WHERE category = 'Global_links' AND (sitename = '$SiteName' OR sitename = 'All') ORDER BY link_order") %]
        <div class="dropdown-divider"></div>
            <a href="[% link.url %]" target="[% link.target || '_self' %]" title="[% link.name %]" class="menu-item">
                [% IF link.icon %]<i class="[% link.icon %]"></i>[% END %]
                [% link.name %]
            </a>
            [% IF c.session.roles.grep('admin').size %]
                <a href="/navigation/edit_link?link_id=[% link.id %]" class="edit-link">Edit</a>
            [% END %]
        [% END %]
        
        <!-- Private Global Links for logged in users -->
        [% IF c.session.username && c.stash.private_links %]
            [% SET has_private_global_links = 0 %]
            [% FOREACH link IN c.stash.private_links %]
                [% IF link.category == 'Global_links' || link.menu == 'Global' %]
                    [% SET has_private_global_links = 1 %]
                [% END %]
            [% END %]
            
            [% IF has_private_global_links %]
            <div class="dropdown-divider"></div>
            <div class="submenu-item">
                <span class="submenu-header"><i class="icon-user-global"></i>My Global Links</span>
                <div class="submenu">
                    [% FOREACH link IN c.stash.private_links %]
                        [% IF link.category == 'Global_links' || link.menu == 'Global' %]
                            <a href="[% link.url %]" target="[% link.target || '_self' %]" title="[% link.name %]" class="submenu-link">
                                [% IF link.icon %]<i class="[% link.icon %]"></i>[% END %]
                                [% link.name %]
                            </a>
                            <a href="/navigation/edit_link?link_id=[% link.id %]" class="edit-link">Edit</a>
                        [% END %]
                    [% END %]
                </div>
            </div>
            [% END %]
        [% END %]
        
        <!-- Services & Registration -->
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-services"></i>Services</span>
            <div class="submenu">
                [% IF data.affiliate_number %]
                <a href="http://www.computersystemconsulting.ca/whmcs/cart.php?a=add&domain=register&aff=[% data.affiliate_number %]" target="_blank" title="Domain registration services">
                    <i class="icon-domain"></i>Register Domains
                </a>
                [% END %]
                <!-- Additional service links can be added here -->
            </div>
        </div>
        
        [% IF c.session.roles.grep('admin').size %]
        <div class="dropdown-divider"></div>
        <a href="/navigation/manage_links?menu=Global" class="menu-item"><i class="icon-manage"></i>Manage Global Menu</a>
        [% END %]
    </div>
</li>

<style>
    /* Global Menu Specific Styles */
    .submenu-item {
        position: relative;
    }

    .submenu-header {
        display: block;
        padding: 8px 15px;
        background-color: #e9ecef;
        color: #495057;
        font-weight: bold;
        font-size: 0.9em;
        border-bottom: 1px solid #dee2e6;
    }

    .submenu {
        background-color: #f8f9fa;
    }

    .submenu-link {
        padding: 8px 25px;
        display: flex;
        align-items: center;
        text-decoration: none;
        color: #495057;
        font-size: 0.9em;
        transition: background-color 0.2s;
    }

    .submenu-link:hover {
        background-color: #e9ecef;
    }

    .submenu-link i {
        margin-right: 6px;
        width: 14px;
        text-align: center;
    }

    .menu-item {
        padding: 10px 15px;
        display: flex;
        align-items: center;
        text-decoration: none;
        color: #333;
        transition: background-color 0.2s;
    }

    .menu-item:hover {
        background-color: #f8f9fa;
    }

    .menu-item i {
        margin-right: 8px;
        width: 16px;
        text-align: center;
    }

    .dropdown-divider {
        height: 1px;
        margin: 5px 0;
        overflow: hidden;
        background-color: #e9ecef;
    }

    .edit-link {
        font-size: 0.8em;
        color: #6c757d;
        margin-left: 10px;
        text-decoration: none;
        padding: 2px 5px;
    }

    .edit-link:hover {
        color: #495057;
        text-decoration: underline;
    }

    /* Icons for Global menu */
    .icon-global:before { content: "🌍"; }
    .icon-mail:before { content: "✉️"; }
    .icon-briefcase:before { content: "💼"; }
    .icon-user-plus:before { content: "👤➕"; }
    .icon-add:before { content: "➕"; }
    .icon-dev:before { content: "🔧"; }
    .icon-prod:before { content: "🚀"; }
    .icon-user-global:before { content: "👤🌍"; }
    .icon-services:before { content: "⚙️"; }
    .icon-domain:before { content = "🌐"; }
    .icon-manage:before { content = "⚙️"; }
</style>