[% PageVersion = 'Navigation/TopDropListENCY.tt,v 0.03 2026/04/04 shanta Exp shanta ' %]
[% IF c.session.debug_mode == 1 %]
    [%# PageVersion %]
[% END %]

<!-- Start /Navigation/TopDropListENCY.tt-->
<li class="horizontal-dropdown">
    <a href="/ENCY" class="dropbtn"><i class="icon-ency"></i>ENCY</a>
    <div class="dropdown-content">
        <!-- Core — visible to everyone -->
        <a href="/ENCY" class="menu-item"><i class="icon-home"></i>ENCY Home</a>
        <a href="/ENCY/search" class="menu-item"><i class="icon-search"></i>Search Encyclopedia</a>

        <div class="dropdown-divider"></div>

        <!-- Biological Categories -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-biology"></i>Biological</span>
            <div class="submenu">
                <a href="/ENCY/BotanicalNameView" class="submenu-link"><i class="icon-plant"></i>Plants &amp; Herbs</a>
                <a href="/ENCY/Animal" class="submenu-link"><i class="icon-animal"></i>Animals</a>
                <a href="/ENCY/Insect" class="submenu-link"><i class="icon-insect"></i>Insects</a>
                <a href="/ENCY/bee_pasture_view" class="submenu-link"><i class="icon-pollinator"></i>Bee Pasture / Pollinators</a>
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'ENCY_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'ENCY' %]
            </div>
        </div>

        <!-- Therapeutic & Medicinal -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-medical"></i>Therapeutic</span>
            <div class="submenu">
                <a href="/ENCY/Constituent" class="submenu-link"><i class="icon-chemistry"></i>Constituents</a>
                <a href="/ENCY/Disease" class="submenu-link"><i class="icon-disease"></i>Diseases</a>
                <a href="/ENCY/Symptom" class="submenu-link"><i class="icon-symptom"></i>Symptoms</a>
                <a href="/ENCY/Drug" class="submenu-link"><i class="icon-medicine"></i>Drugs &amp; Pharmaceuticals</a>
                <a href="/ENCY/Formula" class="submenu-link"><i class="icon-recipe"></i>Herbal Formulas</a>
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'ENCY_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'ENCY' %]
            </div>
        </div>

        <!-- Reference -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-docs"></i>Reference</span>
            <div class="submenu">
                <a href="/ENCY/Glossary" class="submenu-link"><i class="icon-glossary"></i>Glossary</a>
                <a href="/ENCY/Reference" class="submenu-link"><i class="icon-book"></i>Reference Library</a>
                <a href="/ENCY/Author" class="submenu-link"><i class="icon-author"></i>Authors</a>
                <a href="/ENCY/search?q=cultivation" class="submenu-link"><i class="icon-grow"></i>Cultivation</a>
                <a href="/ENCY/search?q=conservation" class="submenu-link"><i class="icon-conservation"></i>Conservation</a>
                <a href="/ENCY/search?q=ecology" class="submenu-link"><i class="icon-ecology"></i>Ecology</a>
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'ENCY_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'ENCY' %]
            </div>
        </div>

        [%# Editor role: can add/edit entries %]
        [% IF c.session.roles && (c.session.roles.grep('editor').size || c.session.roles.grep('admin').size) %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-edit"></i>Add Entries</span>
            <div class="submenu">
                <a href="/ENCY/add_herb" class="submenu-link"><i class="icon-add"></i>Add Herb</a>
                <a href="/ENCY/Animal/add" class="submenu-link"><i class="icon-add"></i>Add Animal</a>
                <a href="/ENCY/Insect/add" class="submenu-link"><i class="icon-add"></i>Add Insect</a>
                <a href="/ENCY/Disease/add" class="submenu-link"><i class="icon-add"></i>Add Disease</a>
                <a href="/ENCY/Symptom/add" class="submenu-link"><i class="icon-add"></i>Add Symptom</a>
                <a href="/ENCY/Constituent/add" class="submenu-link"><i class="icon-add"></i>Add Constituent</a>
                <a href="/ENCY/Drug/add" class="submenu-link"><i class="icon-add"></i>Add Drug</a>
                <a href="/ENCY/Formula/add" class="submenu-link"><i class="icon-add"></i>Add Formula</a>
                <a href="/ENCY/Glossary/add" class="submenu-link"><i class="icon-add"></i>Add Glossary Term</a>
                <a href="/ENCY/Reference/add" class="submenu-link"><i class="icon-add"></i>Add Reference</a>
                <a href="/ENCY/Author/add" class="submenu-link"><i class="icon-add"></i>Add Author</a>
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'ENCY_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'ENCY' %]
            </div>
        </div>
        [% END %]

        [%# Admin/Developer: link to ENCY admin dashboard %]
        [% IF c.session.roles && (c.session.roles.grep('admin').size || c.session.roles.grep('developer').size) %]
        <div class="dropdown-divider"></div>
        <a href="/ENCY/admin"><i class="icon-admin"></i>ENCY Administration</a>
        [% END %]
    </div>
</li>
<!-- End /Navigation/TopDropListENCY.tt-->
