[% PageVersion = 'Navigation/TopDropListENCY.tt,v 0.03 2026/04/04 shanta Exp shanta ' %]
[% IF c.session.debug_mode == 1 %]
    [%# PageVersion %]
[% END %]

<!-- Start /Navigation/TopDropListENCY.tt-->
<li class="horizontal-dropdown">
    <a href="/ENCY" class="dropbtn"><i class="icon-ency"></i>ENCY</a>
    <div class="dropdown-content">
        <!-- Core — visible to everyone -->
        <a href="/ENCY"><i class="icon-home"></i>ENCY Home</a>
        <a href="/ENCY/search"><i class="icon-search"></i>Search Encyclopedia</a>

        <div class="dropdown-divider"></div>

        <!-- Biological Categories -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-biology"></i>Biological</span>
            <div class="submenu">
                <a href="/ENCY/BotanicalNameView"><i class="icon-plant"></i>Plants &amp; Herbs</a>
                <a href="/ENCY/Animal"><i class="icon-animal"></i>Animals</a>
                <a href="/ENCY/Insect"><i class="icon-insect"></i>Insects</a>
                <a href="/ENCY/bee_pasture_view"><i class="icon-pollinator"></i>Bee Pasture / Pollinators</a>
            </div>
        </div>

        <!-- Therapeutic & Medicinal -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-medical"></i>Therapeutic</span>
            <div class="submenu">
                <a href="/ENCY/Constituent"><i class="icon-chemistry"></i>Constituents</a>
                <a href="/ENCY/Disease"><i class="icon-disease"></i>Diseases</a>
                <a href="/ENCY/Symptom"><i class="icon-symptom"></i>Symptoms</a>
                <a href="/ENCY/Drug"><i class="icon-medicine"></i>Drugs &amp; Pharmaceuticals</a>
                <a href="/ENCY/Formula"><i class="icon-recipe"></i>Herbal Formulas</a>
            </div>
        </div>

        <!-- Reference -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-docs"></i>Reference</span>
            <div class="submenu">
                <a href="/ENCY/Glossary"><i class="icon-glossary"></i>Glossary</a>
                <a href="/ENCY/search?q=cultivation"><i class="icon-grow"></i>Cultivation</a>
                <a href="/ENCY/search?q=conservation"><i class="icon-conservation"></i>Conservation</a>
                <a href="/ENCY/search?q=ecology"><i class="icon-ecology"></i>Ecology</a>
            </div>
        </div>

        [%# Editor role: can add/edit entries %]
        [% IF c.session.roles && (c.session.roles.grep('editor').size || c.session.roles.grep('admin').size) %]
        <div class="dropdown-divider"></div>
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-edit"></i>Add Entries</span>
            <div class="submenu">
                <a href="/ENCY/add_herb"><i class="icon-add"></i>Add Herb</a>
                <a href="/ENCY/Animal/add"><i class="icon-add"></i>Add Animal</a>
                <a href="/ENCY/Insect/add"><i class="icon-add"></i>Add Insect</a>
                <a href="/ENCY/Disease/add"><i class="icon-add"></i>Add Disease</a>
                <a href="/ENCY/Symptom/add"><i class="icon-add"></i>Add Symptom</a>
                <a href="/ENCY/Constituent/add"><i class="icon-add"></i>Add Constituent</a>
                <a href="/ENCY/Drug/add"><i class="icon-add"></i>Add Drug</a>
                <a href="/ENCY/Formula/add"><i class="icon-add"></i>Add Formula</a>
                <a href="/ENCY/Glossary/add"><i class="icon-add"></i>Add Glossary Term</a>
            </div>
        </div>
        [% END %]

        [%# Admin: link to admin desktop ENCY section %]
        [% IF c.session.roles && c.session.roles.grep('admin').size %]
        <div class="dropdown-divider"></div>
        <a href="/admin/ency"><i class="icon-admin"></i>ENCY Administration</a>
        [% END %]
    </div>
</li>
<!-- End /Navigation/TopDropListENCY.tt-->
