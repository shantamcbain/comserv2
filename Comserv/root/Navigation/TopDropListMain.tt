[% PageVersion = 'Navigation/TopDropListMain.tt,v 0.02 2025/09/03 shanta Exp shanta ' %]
[% IF c.session.debug_mode == 1 %]
    [%# PageVersion %]
    [%# "Debugging HostName: " _ HostName %]
    [%# INCLUDE 'debug.tt' %]
[% END %]
    [%# /HTMLTemplates/Default/TopDropListMain.ttml %]
[%# $Id: TopDropListMain.ttml,v 0.01 2019/12/09 06:33:25 shanta Exp shanta $ %]

<!-- Start /HTMLTemplates/Default/TopDropListMain.tt-->
<li class="horizontal-dropdown">
    <a href="/" class="dropbtn"><i class="icon-main"></i>Main</a>
    <div class="dropdown-content">
        <!-- Core Navigation -->
        <a href="/" onclick="activateSite('Home')"><i class="icon-home"></i>Home</a>
        <a href="[% c.stash.nav_back_url || c.session.nav_back_url || '/' %]" class="nav-back-link" data-nav-back="1"><i class="icon-back"></i>Go Back</a>
        [% IF c.session.username && (c.session.roles.grep('admin').size || c.session.roles.grep('workshop_leader').size) %]
        <a href="/workshop" onclick="activateSite('Workshops')" target="_blank"><i class="icon-workshop"></i>Workshops</a>
        [% END %]

        <div class="dropdown-divider"></div>

        <!-- Community Services (previously in Global) -->
        <a href="/marketplace"><i class="icon-marketplace"></i>Marketplace</a>
        <a href="/mail"><i class="icon-mail"></i>Mail</a>
        <a href="/jobs"><i class="icon-briefcase"></i>Jobs</a>
        <a href="/join"><i class="icon-user-plus"></i>Join</a>
        <a href="/jobs"><i class="icon-briefcase"></i>Jobs &amp; Employment</a>

        [% IF c.session.username %]
        <div class="dropdown-divider"></div>
        <a href="/navigation/add_link"><i class="icon-add"></i>Add Link</a>
        [% END %]
        
        <div class="dropdown-divider"></div>
        
        <!-- Mail Services -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-mail"></i>Mail Services</span>
            <div class="submenu">
                <a href="/newsletters" class="submenu-link"><i class="icon-mail"></i>Newsletters</a>
                [% IF c.session.user_id %]
                <a href="/mail/my_subscriptions" class="submenu-link"><i class="icon-mail"></i>My Email Subscriptions</a>
                [% ELSE %]
                <a href="/mail/subscribe" class="submenu-link"><i class="icon-mail"></i>Join Mailing List</a>
                [% END %]
                [% IF c.session.roles.grep('(?i)admin').size || c.session.roles.grep('(?i)editor').size %]
                <a href="/mail/newsletters" class="submenu-link"><i class="icon-edit"></i>Manage Newsletters</a>
                [% END %]
                [% IF c.session.username == 'Shanta' %]
                <a href="http://mail.coop.ca/roundcube/" target="_blank" class="submenu-link"><i class="icon-webmail"></i>COOP Webmail</a>
                <a href="http://wbeck.zapto.org/roundcube/" target="_blank" class="submenu-link"><i class="icon-webmail"></i>WB Webmail</a>
                [% END %]
                
                [% SET main_db_links = c.stash.nav_merged_links.Main_links || c.stash.main_links || [] %]
                [% INCLUDE 'Navigation/inc/menu_db_links.tt'
                    db_links = main_db_links
                    add_link_menu = 'Main'
                    add_link_category = 'Main_links'
                    add_link_submenu = 'join_services' %]
            </div>
        </div>

        <!-- Shared Folders -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-folder"></i>Shared Folders</span>
            <div class="submenu">
                <a href="/Shares" class="submenu-link"><i class="icon-cloud"></i>File Shares</a>
                <a href="/media" class="submenu-link"><i class="icon-image"></i>Media Server</a>
                <a href="/" onclick="activateSite('BMaster')" class="submenu-link"><i class="icon-drive"></i>BMaster</a>
                <a href="/cloud" class="submenu-link"><i class="icon-sync"></i>Cloud Sync</a>
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'Main_links'
                    add_link_submenu = 'top'
                    add_link_menu = 'Main' %]
            </div>
        </div>

        <!-- Global/Public Links -->
        <div class="submenu-item">
            <span class="submenu-header"><i class="icon-globe"></i>Public Links</span>
            <div class="submenu">
                <!-- Dynamic Page-based links for Main menu from new page system -->
                [% FOREACH link = c.stash.dbi.query("SELECT * FROM page WHERE (LOWER(menu) = 'main' AND (status = 'active' OR status = '2' OR status = 2)) AND (sitename = '$SiteName' OR LOWER(sitename) = LOWER('$SiteName') OR sitename = 'All' OR share_with = 'all' OR share_with LIKE '%$SiteName%') ORDER BY link_order") %]
                    [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                        row_href = '/page/' _ link.page_code
                        row_label = link.title
                        row_edit_kind = 'cms_page'
                        row_edit_id = link.id %]
                [% END %]
                
                <!-- Legacy Page-based links for Main menu -->
                [% FOREACH legacy_link = c.stash.dbi.query("SELECT * FROM page_tb WHERE (LOWER(menu) = 'main' AND status = 2) AND (sitename = '$SiteName' OR sitename = 'All') ORDER BY link_order") %]
                    [%# Check if page is already in the new page system to avoid duplicates %]
                    [% SET is_migrated = c.stash.dbi.query("SELECT COUNT(*) as cnt FROM page WHERE page_code = '" _ legacy_link.page_code _ "'").0.cnt %]
                    [% IF is_migrated == 0 %]
                        [% INCLUDE 'Navigation/inc/submenu_link_row.tt'
                            row_href = '/cgi-bin/index.cgi?site=' _ SiteName _ '&' _ session_string _ '&page=' _ legacy_link.page_code
                            row_label = legacy_link.view_name
                            row_target = legacy_link.target
                            row_edit_kind = 'legacy_page'
                            row_edit_id = legacy_link.id %]
                    [% END %]
                [% END %]
                [% INCLUDE 'Navigation/inc/submenu_add_link.tt'
                    add_link_category = 'Main_links'
                    add_link_submenu = 'public_links'
                    add_link_menu = 'Main' %]
            </div>
        </div>
        
        [% IF c.session.roles.grep('admin').size %]
        <div class="dropdown-divider"></div>
        <a href="/navigation/manage_links?menu=Main" class="menu-item"><i class="icon-manage"></i>Manage Main Menu</a>
        [% END %]
    </div>
</li>
<!-- End /HTMLTemplates/Default/TopDropListMain.tt-->

