[% META
   title = "Coin Transaction History"
   description = "Full history of your coin transactions"
   roles = "user,admin"
   TemplateType = "Application"
   category = "Currency"
   page_version = "0.01"
   last_updated = "2026-04-03"
%]
[% IF error_msg %]<div class="error">[% error_msg | html %]</div>[% END %]
[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]

<div class="app-container">
  <div class="page-header">
    <h1>Coin Transaction History</h1>
    <div class="header-actions">
      <a href="[% c.uri_for('/currency/balance') %]" class="btn btn-secondary">Back to Balance</a>
    </div>
  </div>

  <div class="content-container">
    <div class="content-primary">

      <div class="content-section">
        <p>
          Current balance: <strong style="color:var(--success-color,#27ae60)">[% balance | format('%.4f') %] coins</strong>
          &bull; Showing [% ledger.size %] of [% total %] transactions
        </p>

        [% IF ledger.size %]
        <table class="data-table" style="width:100%">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Description</th>
              <th>Reference</th>
              <th style="text-align:right">Amount</th>
              <th style="text-align:right">Balance After</th>
            </tr>
          </thead>
          <tbody>
            [% FOREACH tx IN ledger %]
            [% SET is_credit = (tx.to_user_id == c.session.user_id) %]
            <tr>
              <td style="white-space:nowrap;font-size:0.85em">[% tx.created_at | html %]</td>
              <td style="font-size:0.85em">[% tx.transaction_type | ucfirst | html %]</td>
              <td style="font-size:0.85em">[% tx.description | html %]</td>
              <td style="font-size:0.85em;color:#888">
                [% IF tx.reference_type %][% tx.reference_type | html %][% IF tx.reference_id %] #[% tx.reference_id %][% END %][% END %]
              </td>
              <td style="text-align:right;font-weight:bold;
                         color:[% is_credit ? '#27ae60' : '#c0392b' %]">
                [% is_credit ? '+' : '-' %][% tx.amount | format('%.4f') %]
              </td>
              <td style="text-align:right;font-size:0.85em;color:#666">
                [% tx.balance_after | format('%.4f') %]
              </td>
            </tr>
            [% END %]
          </tbody>
        </table>

        [% IF total_pages > 1 %]
        <div style="margin-top:1rem;display:flex;gap:0.5rem;align-items:center">
          [% IF page > 1 %]
            <a href="[% c.uri_for('/currency/history', { page => page - 1 }) %]" class="btn btn-secondary" style="font-size:0.88em">&laquo; Prev</a>
          [% END %]
          <span style="font-size:0.88em;color:#666">Page [% page %] of [% total_pages %]</span>
          [% IF page < total_pages %]
            <a href="[% c.uri_for('/currency/history', { page => page + 1 }) %]" class="btn btn-secondary" style="font-size:0.88em">Next &raquo;</a>
          [% END %]
        </div>
        [% END %]

        [% ELSE %]
        <p class="empty-state">No transactions found.</p>
        [% END %]
      </div>

    </div>
  </div>
</div>
