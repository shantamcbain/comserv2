[%# root/ai2/editing_widget_popup.tt
   PyCharm-like AI Code Editor popup for AI2 system
   Layout: header + left sidebar + main editor + right chat
%]
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>[% page_title | html %]</title>
    <style>
        body { font-family: system-ui, sans-serif; margin:0; display:flex; flex-direction:column; height:100vh; }
        .header { background:#2b2b2b; color:#fff; padding:6px 12px; display:flex; align-items:center; gap:12px; }
        .header select, .header button { font-size:0.9em; }
        .main { display:flex; flex:1; overflow:hidden; }
        .sidebar { width:220px; background:#313335; color:#bbb; padding:8px; overflow:auto; border-right:1px solid #555; }
        .editor-area { flex:1; display:flex; flex-direction:column; }
        .editor-tabs { background:#2b2b2b; padding:4px 8px; color:#aaa; }
        .editor-content { flex:1; background:#1e1f22; color:#ddd; padding:12px; font-family:monospace; }
        .diff-pane { height:140px; background:#2b2b2b; color:#0f0; padding:8px; border-top:1px solid #555; font-size:0.85em; }
        .chat-sidebar { width:320px; background:#313335; color:#ddd; display:flex; flex-direction:column; border-left:1px solid #555; }
        .chat-header { padding:6px 10px; background:#2b2b2b; font-weight:bold; }
        .chat-messages { flex:1; padding:8px; overflow:auto; font-size:0.9em; }
        .chat-input { padding:6px; border-top:1px solid #555; }
    </style>
</head>
<body>
    <!-- Top Header (PyCharm style) -->
    <div class="header">
        <label>Branch:
            <select>
                [% FOREACH b IN branches %]
                    <option [% IF b == 'main' %]selected[% END %]>[% b | html %]</option>
                [% END %]
            </select>
        </label>
        <button onclick="alert('Merge functionality coming soon')">Merge</button>

        <label style="margin-left:auto">Model:
            <select>
                [% FOREACH m IN recommended_models %]
                    <option [% IF m == selected_model %]selected[% END %]>[% m | html %]</option>
                [% END %]
            </select>
        </label>
    </div>

    <div class="main">
        <!-- Left Sidebar: File tree / Commit / Terminal -->
        <div class="sidebar">
            <div><strong>Projects</strong></div>
            <ul style="list-style:none;padding-left:12px;margin:4px 0;">
                <li>📁 lib/Comserv</li>
                <li>📁 root/ai2</li>
            </ul>
            <div style="margin-top:12px"><strong>Commit</strong></div>
            <button style="width:100%">Commit Changes</button>
            <div style="margin-top:12px"><strong>Terminal</strong></div>
            <div style="background:#1e1f22;height:80px;font-size:0.8em;padding:4px;">$ git status</div>

            <!-- Editor Settings / Theme Complement -->
            <details style="margin-top:16px;background:#2b2b2b;border-radius:4px;padding:6px 8px;">
                <summary style="cursor:pointer;color:#fff;font-weight:bold;">⚙️ Editor Settings</summary>
                <div style="margin-top:8px;font-size:0.85em;color:#ccc;">
                    <label style="display:block;margin:4px 0;">Theme:
                        <select id="theme-select" onchange="applyEditorSettings()">
                            <option value="dark">Dark (PyCharm)</option>
                            <option value="light">Light</option>
                            <option value="custom">Custom</option>
                        </select>
                    </label>

                    <label style="display:block;margin:4px 0;">Font Size:
                        <select id="font-size" onchange="applyEditorSettings()">
                            <option value="12">12px</option>
                            <option value="14" selected>14px</option>
                            <option value="16">16px</option>
                            <option value="18">18px</option>
                        </select>
                    </label>

                    <label style="display:block;margin:4px 0;">
                        <input type="checkbox" id="line-numbers" checked onchange="applyEditorSettings()"> Line Numbers
                    </label>

                    <label style="display:block;margin:4px 0;">AI Diff Intensity:
                        <select id="diff-intensity" onchange="applyEditorSettings()">
                            <option value="low">Low</option>
                            <option value="medium" selected>Medium</option>
                            <option value="high">High</option>
                        </select>
                    </label>

                    <label style="display:block;margin:4px 0;">Suggestion Style:
                        <select id="suggestion-style" onchange="applyEditorSettings()">
                            <option value="buttons">Approve/Reject Buttons</option>
                            <option value="inline">Inline +/-</option>
                            <option value="minimal">Minimal</option>
                        </select>
                    </label>
                </div>
            </details>
        </div>

        <!-- Main Editor Area -->
        <div class="editor-area">
            <div class="editor-tabs">
                editing_widget_popup.tt &nbsp; | &nbsp; AI2.pm
            </div>
            <div class="editor-content">
                <!-- Placeholder for Ace/CodeMirror -->
                <textarea style="width:100%;height:100%;background:#1e1f22;color:#ddd;border:none;resize:none;font-family:monospace;" spellcheck="false"># TODO: load real file content here</textarea>
            </div>
            <!-- Live AI Diff Pane -->
            <div class="diff-pane">
                <strong>AI Suggestion (+/- diff)</strong><br>
                <span style="color:#0f0">+ new line added by AI</span><br>
                <span style="color:#f66">- old line removed</span>
                <div style="margin-top:8px">
                    <button>Approve</button>
                    <button>Reject</button>
                </div>
            </div>
        </div>

        <!-- Right Chat Sidebar -->
        <div class="chat-sidebar">
            <div class="chat-header">AI Chat (Router-selected)</div>
            <div class="chat-messages">
                <!-- Placeholder messages -->
                <div><strong>AI:</strong> How can I help with this file?</div>
            </div>
            <div class="chat-input">
                <input type="text" style="width:100%" placeholder="Ask AI...">
            </div>
        </div>
    </div>

    <script>
        // Apply editor settings from the collapsible settings panel
        function applyEditorSettings() {
            const theme = document.getElementById('theme-select').value;
            const fontSize = document.getElementById('font-size').value;
            const lineNumbers = document.getElementById('line-numbers').checked;
            const diffIntensity = document.getElementById('diff-intensity').value;
            const suggestionStyle = document.getElementById('suggestion-style').value;

            const editorContent = document.querySelector('.editor-content');
            const diffPane = document.querySelector('.diff-pane');

            // Theme
            if (theme === 'light') {
                editorContent.style.background = '#f5f5f5';
                editorContent.style.color = '#222';
            } else if (theme === 'custom') {
                editorContent.style.background = '#1a1a2e';
                editorContent.style.color = '#eaeaea';
            } else {
                editorContent.style.background = '#1e1f22';
                editorContent.style.color = '#ddd';
            }

            // Font size
            editorContent.style.fontSize = fontSize + 'px';

            // Line numbers (simple visual indicator)
            if (lineNumbers) {
                editorContent.style.borderLeft = '3px solid #555';
                editorContent.style.paddingLeft = '16px';
            } else {
                editorContent.style.borderLeft = 'none';
                editorContent.style.paddingLeft = '12px';
            }

            // Diff intensity
            if (diffPane) {
                if (diffIntensity === 'low') {
                    diffPane.style.opacity = '0.6';
                } else if (diffIntensity === 'high') {
                    diffPane.style.opacity = '1';
                    diffPane.style.fontWeight = 'bold';
                } else {
                    diffPane.style.opacity = '0.9';
                    diffPane.style.fontWeight = 'normal';
                }
            }

            // Suggestion style (placeholder for future UI)
            console.log('Suggestion style set to:', suggestionStyle);
        }

        // Future: load Ace editor, wire chat to /ai2/chat, etc.
        console.log('AI2 editing popup ready – model: [% selected_model | html %]');
    </script>
</body>
</html>