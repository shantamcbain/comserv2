[%# root/ai2/editing_widget_popup.tt
   PyCharm-like AI Code Editor popup for AI2 system
   Professional sidebar matching PyCharm dark theme
%]
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>[% page_title | html %]</title>
    <style>
        body { font-family: system-ui, sans-serif; margin:0; display:flex; flex-direction:column; height:100vh; background:#1e1f22; color:#ddd; }
        .header { background:#2b2b2b; color:#fff; padding:6px 12px; display:flex; align-items:center; gap:12px; border-bottom:1px solid #555; }
        .header select, .header button { font-size:0.9em; }

        select {
            background-color: #313335;
            color: #ddd;
            border: 1px solid #555;
            padding: 2px 6px;
            border-radius: 3px;
        }

        .main { display:flex; flex:1; overflow:hidden; }
        .sidebar {
            width: 64px;
            background: #313335;
            color: #bbb;
            padding: 12px 0;
            border-right: 1px solid #555;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }

        .sidebar-icon {
            width: 52px;
            padding: 8px 0 4px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            cursor: pointer;
            font-size: 11px;
            color: #aaa;
            transition: background 0.1s;
            position: relative;
        }
        .sidebar-icon:hover {
            background: #3c3f41;
        }
        .sidebar-icon.active {
            background: #0e639c;
            color: white;
        }
        .sidebar-icon .icon {
            font-size: 20px;
            margin-bottom: 2px;
        }
        .sidebar-icon .label {
            font-size: 9px;
            text-align: center;
            line-height: 1.1;
        }

        .file-tree { list-style:none; padding:0; margin:0; }
        .file-tree li { padding:2px 12px; cursor:pointer; display:flex; align-items:center; gap:6px; }
        .file-tree li:hover { background:#3c3f41; }
        .file-tree li.active { background:#0e639c; color:white; }

        .commit-btn { margin:0 12px; width:calc(100% - 24px); background:#0e639c; color:white; border:none; padding:6px; border-radius:3px; cursor:pointer; font-size:12px; }
        .commit-panel { background:#2b2b2b; margin:8px 12px; padding:8px; border-radius:4px; }
        .commit-panel textarea { width:100%; height:60px; background:#1e1f22; color:#ddd; border:1px solid #555; border-radius:3px; font-size:12px; resize:vertical; }
        .commit-panel button { margin-top:6px; width:100%; background:#0e639c; color:white; border:none; padding:4px 10px; border-radius:3px; cursor:pointer; font-size:12px; }
        .commit-panel button#cancel-commit-btn { background:#555; }

        .terminal { background:#1e1f22; font-family:monospace; font-size:11px; padding:6px 12px; margin:0 12px; border:1px solid #444; border-radius:3px; }
        .terminal-header { cursor:pointer; display:flex; justify-content:space-between; align-items:center; padding:0 12px; }

        .status-bar { background:#007acc; color:white; font-size:11px; padding:2px 8px; display:flex; justify-content:space-between; }
    </style>
</head>
<body>
    <!-- Top Header -->
    <div class="header">
        <label>Branch:
            <select id="branch-select">
                [% FOREACH b IN branches %]
                    <option [% IF b == 'main' %]selected[% END %]>[% b | html %]</option>
                [% END %]
            </select>
        </label>
        <button onclick="alert('Merge functionality coming soon')">Merge</button>

        <label style="margin-left:auto">Model:
            <select id="model-select">
                [% FOREACH m IN recommended_models %]
                    <option [% IF m == selected_model %]selected[% END %]>[% m | html %]</option>
                [% END %]
            </select>
        </label>

        <button id="refresh-btn" style="margin-left:12px;background:#0e639c;color:white;border:none;padding:4px 10px;border-radius:3px;cursor:pointer;">
            ↻ Refresh
        </button>
    </div>

    <div class="main">
        <!-- ==================== LEFT SIDEBAR ==================== -->
        <div class="sidebar" id="sidebar-icons">

    <!-- PROJECTS -->
    <div class="sidebar-icon" data-panel="projects" title="Projects">
        <div class="icon">📁</div>
        <div class="label">Project</div>
    </div>

    <!-- GIT / COMMIT -->
    <div class="sidebar-icon" data-panel="git" title="Git">
        <div class="icon">🔀</div>
        <div class="label">Commit</div>
    </div>

    <!-- TERMINAL -->
    <div class="sidebar-icon" data-panel="terminal" title="Terminal">
        <div class="icon">💻</div>
        <div class="label">Terminal</div>
    </div>

    <!-- EDITOR SETTINGS -->
    <div class="sidebar-icon" data-panel="settings" title="Settings">
        <div class="icon">⚙️</div>
        <div class="label">Settings</div>
    </div>

</div>

<!-- Sidebar Panels (shown to the right of icons) -->
<div id="sidebar-panels" style="position:absolute; left:56px; top:0; bottom:0; width:220px; background:#2b2b2b; border-right:1px solid #555; display:none; z-index:10; overflow:auto;">
    <div id="panel-projects" class="sidebar-panel" style="display:none; padding:12px;">
        <h4 style="margin:0 0 8px 0; font-size:12px; color:#aaa;">PROJECTS</h4>
        <ul class="file-tree">
            <li data-path="lib/Comserv/Controller/AI2.pm" class="file-item">📄 AI2.pm</li>
            <li data-path="root/ai2/editing_widget_popup.tt" class="file-item active">📄 editing_widget_popup.tt</li>
            <li style="padding-left:20px; color:#888;">📁 models/</li>
            <li style="padding-left:20px; color:#888;">📁 views/</li>
        </ul>
    </div>

    <!-- GIT Panel - Professional IDE-style Commit Dialog -->
<div id="panel-git" class="sidebar-panel" style="display:none; padding:0; width:100%; background:#2b2b2b; font-size:13px;">

    <!-- Top Tabs -->
    <div style="display:flex; background:#313335; border-bottom:1px solid #444;">
        <div style="padding:8px 16px; background:#1e1f22; color:#ddd; border-right:1px solid #444; font-weight:500;">Commit</div>
        <div style="padding:8px 16px; color:#888; cursor:pointer;">Shelf</div>
        <div style="padding:8px 16px; color:#888; cursor:pointer;">Stash</div>
        <div style="flex:1;"></div>
        <div style="padding:8px 12px; color:#888; cursor:pointer; font-size:16px;">&#8943;</div>
    </div>

    <!-- Toolbar -->
    <div style="display:flex; align-items:center; padding:6px 10px; background:#2b2b2b; border-bottom:1px solid #444; gap:8px;">
        <span style="cursor:pointer; color:#aaa;">&#8634;</span>
        <span style="cursor:pointer; color:#aaa;">&#8635;</span>
        <span style="cursor:pointer; color:#aaa;">&#8595;</span>
        <span style="cursor:pointer; color:#aaa;">&#8593;</span>
        <span style="cursor:pointer; color:#aaa;">&#128269;</span>
        <span style="cursor:pointer; color:#aaa;">&#128065;</span>
        <span style="flex:1;"></span>
        <span style="cursor:pointer; color:#aaa;">&#43;</span>
        <span style="cursor:pointer; color:#aaa;">&#8597;</span>
        <span style="cursor:pointer; color:#aaa;">&#10005;</span>
    </div>

    <!-- Changes Section -->
    <div style="padding:8px 12px; border-bottom:1px solid #444;">
        <div style="display:flex; align-items:center; margin-bottom:6px;">
            <input type="checkbox" checked style="margin-right:6px;">
            <span style="color:#ddd; font-weight:500;">Changes</span>
            <span style="margin-left:6px; color:#888; font-size:12px;">1 file</span>
        </div>
        <div style="padding-left:20px;">
            <label style="display:flex; align-items:center; margin-bottom:4px; cursor:pointer;">
                <input type="checkbox" checked style="margin-right:8px;">
                <span style="color:#4fc1ff; margin-right:6px;">T</span>
                <span style="color:#ddd;">editing_widget_popup.tt</span>
                <span style="margin-left:auto; color:#888; font-size:11px;">Comserv/root/ai2</span>
            </label>
        </div>
    </div>

    <!-- Unversioned Files Section -->
    <div style="padding:8px 12px;">
        <div style="display:flex; align-items:center; margin-bottom:6px;">
            <input type="checkbox" checked style="margin-right:6px;">
            <span style="color:#ddd; font-weight:500;">Unversioned Files</span>
            <span style="margin-left:6px; color:#888; font-size:12px;">1 file</span>
        </div>
        <div style="padding-left:20px;">
            <label style="display:flex; align-items:center; margin-bottom:4px; cursor:pointer;">
                <input type="checkbox" checked style="margin-right:8px;">
                <span style="color:#f0c674; margin-right:6px;">JS</span>
                <span style="color:#ddd;">commit-ui.js</span>
                <span style="margin-left:auto; color:#888; font-size:11px;">Comserv/root/static/js/ai2editor</span>
            </label>
        </div>
    </div>

    <!-- Commit Message -->
    <div style="padding:12px; border-top:1px solid #444;">
        <textarea id="commit-message"
                  placeholder="feat: improve AI2 editor commit UI"
                  style="width:100%; height:70px; background:#1e1f22; color:#ddd; border:1px solid #555; border-radius:4px; padding:8px; font-size:13px; resize:vertical; margin-bottom:10px;"></textarea>

        <div style="display:flex; gap:8px;">
            <button id="do-commit-btn"
                    style="flex:1; background:#0e639c; color:white; border:none; padding:8px 12px; border-radius:4px; cursor:pointer; font-size:13px;">
                Commit
            </button>
            <button id="cancel-commit-btn"
                    style="flex:1; background:#555; color:white; border:none; padding:8px 12px; border-radius:4px; cursor:pointer; font-size:13px;">
                Cancel
            </button>
        </div>
    </div>

</div>

    <div id="panel-terminal" class="sidebar-panel" style="display:none; padding:12px;">
        <h4 style="margin:0 0 8px 0; font-size:12px; color:#aaa;">TERMINAL</h4>
        <div class="terminal" style="height:120px; overflow:auto;">
            $ git status<br>
            On branch main<br>
            Your branch is up to date.<br>
            Changes not staged for commit:<br>
            &nbsp;&nbsp;modified: editing_widget_popup.tt
        </div>
    </div>

    <div id="panel-settings" class="sidebar-panel" style="display:none; padding:12px; font-size:12px;">
        <h4 style="margin:0 0 8px 0; font-size:12px; color:#aaa;">EDITOR SETTINGS</h4>
        <label style="display:block;margin:4px 0;">Theme:
            <select id="theme-select" onchange="applyEditorSettings()">
                <option value="dark">Dark (PyCharm)</option>
                <option value="light">Light</option>
                <option value="custom">Custom</option>
            </select>
        </label>
        <label style="display:block;margin:4px 0;">Font Size:
            <select id="font-size" onchange="applyEditorSettings()">
                <option value="12">12px</option>
                <option value="14" selected>14px</option>
                <option value="16">16px</option>
            </select>
        </label>
        <label style="display:block;margin:4px 0;">
            <input type="checkbox" id="line-numbers" checked onchange="applyEditorSettings()"> Line Numbers
        </label>
    </div>
</div>

        <!-- ==================== MAIN EDITOR ==================== -->
        <div class="editor-area" style="flex:1; display:flex; flex-direction:column;">
            <div class="editor-tabs" style="background:#2b2b2b; padding:4px 8px; color:#aaa; display:flex; align-items:center; justify-content:space-between;">
                <span>editing_widget_popup.tt &nbsp; | &nbsp; AI2.pm</span>
                <span id="file-status" style="font-size:11px;color:#888;"></span>
            </div>
            <div class="editor-content" style="flex:1; position:relative;">
                <div id="ace-editor" style="width:100%;height:100%;"></div>
            </div>
            <!-- AI Diff Pane -->
            <div class="diff-pane" style="height:140px; background:#2b2b2b; color:#0f0; padding:8px; border-top:1px solid #555; font-size:0.85em;">
                <strong>AI Suggestion (+/- diff)</strong><br>
                <span style="color:#0f0">+ new line added by AI</span><br>
                <span style="color:#f66">- old line removed</span>
                <div style="margin-top:8px">
                    <button>Approve</button>
                    <button>Reject</button>
                </div>
            </div>
        </div>

        <!-- Right Chat Sidebar -->
        <div class="chat-sidebar" style="width:320px; background:#313335; color:#ddd; display:flex; flex-direction:column; border-left:1px solid #555;">
            <div class="chat-header" style="padding:6px 10px; background:#2b2b2b; font-weight:bold;">AI Chat (Router-selected)</div>
            <div class="chat-messages" style="flex:1; padding:8px; overflow:auto; font-size:0.9em;">
                <div><strong>AI:</strong> How can I help with this file?</div>
            </div>
            <div class="chat-input" style="padding:6px; border-top:1px solid #555;">
                <input type="text" style="width:100%" placeholder="Ask AI...">
            </div>
        </div>
    </div>

    <!-- Status bar -->
    <div class="status-bar">
        <span id="auto-refresh-status">Auto-refresh: ON (4s)</span>
        <span id="last-modified" style="color:#a0d2ff;"></span>
    </div>

    <!-- Ace Editor -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.3/ace.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.3/ext-language_tools.js"></script>

    <script>
        // ===================================================================
        // Ace Editor + File loading + Auto-refresh
        // ===================================================================
        (function() {
            const editorEl = document.getElementById('ace-editor');
            const refreshBtn = document.getElementById('refresh-btn');
            const statusEl = document.getElementById('file-status');
            const mtimeEl = document.getElementById('last-modified');

            let currentFilePath = '[% file_path || "root/ai2/editing_widget_popup.tt" %]';
            let lastMtime = null;
            let autoRefreshTimer = null;

            const editor = ace.edit(editorEl);
            editor.setTheme("ace/theme/twilight");
            editor.session.setMode("ace/mode/perl");
            editor.setOptions({
                fontSize: "14px",
                showPrintMargin: false,
                wrap: true,
                enableBasicAutocompletion: true,
                enableLiveAutocompletion: true
            });

            async function loadFileContent(path) {
                try {
                    const res = await fetch(`/ai2/load_file?path=${encodeURIComponent(path)}`);
                    if (!res.ok) throw new Error('Failed to load file');
                    const data = await res.json();
                    editor.setValue(data.content || '', -1);
                    lastMtime = data.mtime;
                    mtimeEl.textContent = `Last modified: ${new Date(lastMtime * 1000).toLocaleTimeString()}`;
                    statusEl.textContent = `Loaded: ${path.split('/').pop()}`;
                    highlightActiveFile(path);
                } catch (err) {
                    console.error('loadFileContent error:', err);
                    statusEl.textContent = 'Error loading file';
                }
            }

            async function getFileMtime(path) {
                try {
                    const res = await fetch(`/ai2/file_checksum?path=${encodeURIComponent(path)}`);
                    if (!res.ok) return null;
                    const data = await res.json();
                    return data.mtime || null;
                } catch (err) {
                    return null;
                }
            }

            function highlightActiveFile(path) {
                document.querySelectorAll('.file-item').forEach(el => {
                    el.classList.remove('active');
                    if (el.dataset.path === path || el.textContent.includes(path.split('/').pop())) {
                        el.classList.add('active');
                    }
                });
            }

            refreshBtn.addEventListener('click', () => loadFileContent(currentFilePath));

            function startAutoRefresh() {
                if (autoRefreshTimer) clearInterval(autoRefreshTimer);
                autoRefreshTimer = setInterval(async () => {
                    const newMtime = await getFileMtime(currentFilePath);
                    if (newMtime && newMtime !== lastMtime) {
                        console.log('[AI2] External change detected, reloading...');
                        await loadFileContent(currentFilePath);
                    }
                }, 4000);
            }

            // Boot
            loadFileContent(currentFilePath).then(() => startAutoRefresh());

            window.AI2Editor = editor;
            window.loadFileFromTree = loadFileContent;
        })();

        // ==================== FILE TREE CLICK HANDLER ====================
        document.querySelectorAll('.file-item').forEach(item => {
            item.addEventListener('click', () => {
                const path = item.dataset.path;
                if (path && window.loadFileFromTree) {
                    window.loadFileFromTree(path);
                }
            });
        });

        // ==================== COMMIT UI ====================
        const commitBtn = document.getElementById('commit-btn');
        const commitPanel = document.getElementById('commit-panel');
        const doCommitBtn = document.getElementById('do-commit-btn');
        const cancelCommitBtn = document.getElementById('cancel-commit-btn');

        commitBtn.addEventListener('click', () => {
            commitPanel.style.display = commitPanel.style.display === 'none' ? 'block' : 'none';
        });

        doCommitBtn.addEventListener('click', () => {
            const msg = document.getElementById('commit-message').value.trim();
            if (!msg) {
                alert('Please enter a commit message');
                return;
            }
            alert('Commit created: ' + msg);
            commitPanel.style.display = 'none';
            document.getElementById('commit-message').value = '';
        });

        cancelCommitBtn.addEventListener('click', () => {
            commitPanel.style.display = 'none';
        });

        // ==================== TERMINAL TOGGLE ====================
        function toggleTerminal() {
            const content = document.getElementById('terminal-content');
            const toggle = document.getElementById('terminal-toggle');
            if (content.style.display === 'none') {
                content.style.display = 'block';
                toggle.textContent = '▼';
            } else {
                content.style.display = 'none';
                toggle.textContent = '▶';
            }
        }

        // ==================== EDITOR SETTINGS ====================
        function applyEditorSettings() {
            const theme = document.getElementById('theme-select').value;
            const fontSize = document.getElementById('font-size').value;
            const lineNumbers = document.getElementById('line-numbers').checked;

            const editorContent = document.querySelector('.editor-content');
            if (theme === 'light') {
                editorContent.style.background = '#f5f5f5';
                editorContent.style.color = '#222';
            } else if (theme === 'custom') {
                editorContent.style.background = '#1a1a2e';
                editorContent.style.color = '#eaeaea';
            } else {
                editorContent.style.background = '#1e1f22';
                editorContent.style.color = '#ddd';
            }
            editorContent.style.fontSize = fontSize + 'px';
            if (lineNumbers) {
                editorContent.style.borderLeft = '3px solid #555';
                editorContent.style.paddingLeft = '16px';
            } else {
                editorContent.style.borderLeft = 'none';
                editorContent.style.paddingLeft = '12px';
            }
        }

        console.log('AI2 editing popup ready – model: [% selected_model | html %]');

// Sidebar panel logic (JetBrains-style icon bar) using global toggleSection()
let currentPanel = null;

function showSidebarPanel(name) {
    const panelsContainer = document.getElementById('sidebar-panels');
    const allPanels = panelsContainer.querySelectorAll('.sidebar-panel');
    const target = document.getElementById('panel-' + name);

    // Deselect all icons
    document.querySelectorAll('.sidebar-icon').forEach(el => el.classList.remove('active'));

    if (currentPanel === name) {
        // Toggle off using global helper
        panelsContainer.style.display = 'none';
        currentPanel = null;
        return;
    }

    // Hide all, show target
    allPanels.forEach(p => p.style.display = 'none');
    if (typeof window.toggleSection === 'function') {
        // Use global helper for consistency (even though we show/hide manually here)
        window.toggleSection(target.id);
    } else {
        target.style.display = 'block';
    }
    panelsContainer.style.display = 'block';
    currentPanel = name;

    // Highlight active icon
    const icon = document.querySelector(`.sidebar-icon[data-panel="${name}"]`);
    if (icon) icon.classList.add('active');
}

// Attach click handlers to sidebar icons
document.querySelectorAll('.sidebar-icon').forEach(icon => {
    icon.addEventListener('click', () => {
        const panelName = icon.getAttribute('data-panel');
        if (panelName) {
            showSidebarPanel(panelName);
        }
    });
});

// Commit button logic for the new IDE-style dialog (only the actual Commit/Cancel buttons in the dialog)
document.addEventListener('DOMContentLoaded', function() {
    const doBtn = document.getElementById('do-commit-btn');
    const cancelBtn = document.getElementById('cancel-commit-btn');
    const gitPanel = document.getElementById('panel-git');

    if (doBtn) {
        doBtn.addEventListener('click', () => {
            alert('Committed!');
            if (gitPanel) gitPanel.style.display = 'none';
            document.querySelectorAll('.sidebar-icon').forEach(el => el.classList.remove('active'));
        });
    }

    if (cancelBtn) {
        cancelBtn.addEventListener('click', () => {
            if (gitPanel) gitPanel.style.display = 'none';
            document.querySelectorAll('.sidebar-icon').forEach(el => el.classList.remove('active'));
        });
    }
});
    </script>
</body>
</html>