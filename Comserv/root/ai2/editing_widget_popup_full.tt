[%# root/ai2/editing_widget_popup_full.tt
   Full standalone PyCharm-like AI Code Editor popup (opens in its own window)
   This is a complete HTML document so it can be dragged across monitors
%]
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>AI Code Editor (AI2) - [% selected_model | html %]</title>
    <style>
        body { margin:0; font-family:system-ui,sans-serif; display:flex; flex-direction:column; height:100vh; background:#1e1f22; color:#ddd; }
        .header { background:#2b2b2b; padding:8px 12px; display:flex; align-items:center; gap:12px; flex-shrink:0; }
        .header select, .header button { font-size:0.9em; }
        .main { display:flex; flex:1; overflow:hidden; }
        .sidebar { width:220px; background:#313335; padding:8px; border-right:1px solid #555; overflow:auto; flex-shrink:0; }
        .editor-area { flex:1; display:flex; flex-direction:column; min-width:0; }
        .editor-tabs { background:#2b2b2b; padding:6px 12px; color:#aaa; flex-shrink:0; }
        .editor-content { flex:1; background:#1e1f22; padding:12px; font-family:monospace; overflow:auto; }
        .diff-pane { height:130px; background:#2b2b2b; padding:8px; border-top:1px solid #555; flex-shrink:0; }
        .chat-sidebar { width:300px; background:#313335; border-left:1px solid #555; display:flex; flex-direction:column; flex-shrink:0; }
        .chat-header { padding:8px 12px; background:#2b2b2b; font-weight:bold; flex-shrink:0; }
        .chat-messages { flex:1; padding:10px; overflow:auto; font-size:0.9em; }
        .chat-input { padding:8px; border-top:1px solid #555; flex-shrink:0; }
        .settings { margin-top:16px; background:#2b2b2b; border-radius:4px; padding:6px 8px; }
        .settings summary { cursor:pointer; color:#fff; font-weight:bold; }
    </style>
</head>
<body>
    <!-- Top Header -->
    <div class="header">
        <label>Branch:
            <select><option>main</option><option>ai2-refactor</option></select>
        </label>
        <button>Merge</button>
        <label style="margin-left:auto">Model:
            <select>
                <option>[% selected_model | html %]</option>
                <option>grok-beta</option>
                <option>ollama/llama3</option>
            </select>
        </label>
    </div>

    <div class="main">
        <!-- Left Sidebar -->
        <div class="sidebar">
            <div><strong>Projects</strong></div>
            <ul style="list-style:none;padding-left:12px;margin:4px 0;">
                <li>📁 lib/Comserv</li>
                <li>📁 root/ai2</li>
            </ul>
            <div style="margin-top:12px"><strong>Commit</strong></div>
            <button style="width:100%">Commit Changes</button>
            <div style="margin-top:12px"><strong>Terminal</strong></div>
            <div style="background:#1e1f22;height:70px;font-size:0.8em;padding:4px;">$ git status</div>

            <!-- Editor Settings -->
            <details class="settings">
                <summary>⚙️ Editor Settings</summary>
                <div style="margin-top:8px;font-size:0.85em;color:#ccc;">
                    <label style="display:block;margin:4px 0;">Theme:
                        <select onchange="applyTheme(this.value)">
                            <option value="dark">Dark (PyCharm)</option>
                            <option value="light">Light</option>
                        </select>
                    </label>
                    <label style="display:block;margin:4px 0;">Font Size:
                        <select onchange="applyFontSize(this.value)">
                            <option value="12">12px</option>
                            <option value="14" selected>14px</option>
                            <option value="16">16px</option>
                        </select>
                    </label>
                </div>
            </details>
        </div>

        <!-- Main Editor Area -->
        <div class="editor-area">
            <div class="editor-tabs">editing_widget_popup_full.tt &nbsp;|&nbsp; AI2.pm</div>
            <div class="editor-content" id="editor-area">
                <textarea style="width:100%;height:100%;background:#1e1f22;color:#ddd;border:none;resize:none;font-family:monospace;" spellcheck="false"># TODO: load real file content here</textarea>
            </div>
            <div class="diff-pane">
                <strong>AI Suggestion (+/- diff)</strong><br>
                <span style="color:#0f0">+ new line added by AI</span><br>
                <span style="color:#f66">- old line removed</span>
                <div style="margin-top:8px;">
                    <button>Approve</button>
                    <button>Reject</button>
                </div>
            </div>
        </div>

        <!-- Right Chat Sidebar -->
        <div class="chat-sidebar">
            <div class="chat-header">AI Chat (Router-selected)</div>
            <div class="chat-messages">
                <div><strong>AI:</strong> How can I help with this file?</div>
            </div>
            <div class="chat-input">
                <input type="text" style="width:100%" placeholder="Ask AI...">
            </div>
        </div>
    </div>

    <script>
        function applyTheme(theme) {
            const editor = document.getElementById('editor-area');
            if (theme === 'light') {
                editor.style.background = '#f5f5f5';
                editor.style.color = '#222';
            } else {
                editor.style.background = '#1e1f22';
                editor.style.color = '#ddd';
            }
        }
        function applyFontSize(size) {
            const editor = document.getElementById('editor-area');
            editor.style.fontSize = size + 'px';
        }
        console.log('AI2 full popup loaded – model: [% selected_model | html %]');
    </script>
</body>
</html>