[%# AI Editor Left Toolbar Cards - Launches editor widget (separate from chat widget). This toolbar can grow. %]
[%# Floating 💻 Code button — unchanged %]


[%# Left PyCharm-style vertical toolbar (AI Editor + Project, Commit, Terminal, Settings) %]
<div id="ai2-left-toolbar"
     style="position:fixed;left:0;top:50%;transform:translateY(-50%);z-index:9998;display:flex;flex-direction:column;gap:4px;">



    <!-- Commit -->
    <button hx-get="/ai2/right_dock_commit"
            hx-target="#aew-right-dock"
            hx-swap="innerHTML"
            hx-on::after-swap="document.body.classList.add('aew-right-open')"
            style="background:#313335;color:#bbb;border:1px solid #555;padding:10px 8px;cursor:pointer;transition:all .15s ease;">
        🔀
    </button>

    <!-- Terminal -->
    <button hx-get="/ai2/right_dock_terminal"
            hx-target="#aew-right-dock"
            hx-swap="innerHTML"
            hx-on::after-swap="document.body.classList.add('aew-right-open')"
            style="background:#313335;color:#bbb;border:1px solid #555;padding:10px 8px;cursor:pointer;transition:all .15s ease;">
        💻
    </button>

    <!-- Settings -->
    <button hx-get="/ai2/right_dock_settings"
            hx-target="#aew-right-dock"
            hx-swap="innerHTML"
            hx-on::after-swap="document.body.classList.add('aew-right-open')"
            style="background:#313335;color:#bbb;border:1px solid #555;padding:10px 8px;cursor:pointer;transition:all .15s ease;">
        ⚙️
    </button>
</div>

<style>
    #aew-right-dock {
        position:fixed;right:-420px;top:0;bottom:0;width:420px;
        background:#2b2b2b;border-left:1px solid #555;
        transition:right .2s cubic-bezier(0.4,0,0.2,1);
        z-index:9997;overflow:auto;
    }
    body.aew-right-open #aew-right-dock { right:0; }
    body.aew-right-open .main-content-wrapper { margin-right:420px; transition:margin-right 0.3s; }
</style>

<div id="aew-right-dock"></div>
