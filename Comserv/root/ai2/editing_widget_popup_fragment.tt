[%# root/ai2/editing_widget_popup_fragment.tt
   Pure fragment for HTMX modal — no html/head/body tags
%]
<div style="display:flex;flex-direction:column;height:100%;background:#1e1f22;color:#ddd;font-family:system-ui;">
    <!-- Header -->
    <div style="background:#2b2b2b;padding:8px 12px;display:flex;gap:12px;align-items:center;">
        <label>Branch:
            <select><option>main</option><option>ai2-refactor</option></select>
        </label>
        <button>Merge</button>
        <label style="margin-left:auto">Model:
            <select>
                <option>[% selected_model | html %]</option>
                <option>grok-beta</option>
                <option>ollama/llama3</option>
            </select>
        </label>
    </div>

    <div style="display:flex;flex:1;overflow:hidden;">
        <!-- Left Sidebar -->
        <div style="width:220px;background:#313335;padding:8px;border-right:1px solid #555;overflow:auto;">
            <div><strong>Projects</strong></div>
            <ul style="list-style:none;padding-left:12px;margin:4px 0;">
                <li>📁 lib/Comserv</li>
                <li>📁 root/ai2</li>
            </ul>
            <div style="margin-top:12px"><strong>Commit</strong></div>
            <button style="width:100%">Commit Changes</button>

            <!-- Editor Settings -->
            <details style="margin-top:16px;background:#2b2b2b;border-radius:4px;padding:6px 8px;">
                <summary style="cursor:pointer;color:#fff;font-weight:bold;">⚙️ Editor Settings</summary>
                <div style="margin-top:8px;font-size:0.85em;color:#ccc;">
                    <label style="display:block;margin:4px 0;">Theme:
                        <select onchange="applyEditorSettings(this)">
                            <option value="dark">Dark (PyCharm)</option>
                            <option value="light">Light</option>
                        </select>
                    </label>
                    <label style="display:block;margin:4px 0;">Font Size:
                        <select onchange="applyEditorSettings(this)">
                            <option value="12">12px</option>
                            <option value="14" selected>14px</option>
                            <option value="16">16px</option>
                        </select>
                    </label>
                </div>
            </details>
        </div>

        <!-- Main Editor -->
        <div style="flex:1;display:flex;flex-direction:column;">
            <div style="background:#2b2b2b;padding:4px 8px;color:#aaa;">editing_widget_popup_fragment.tt | AI2.pm</div>
            <textarea style="flex:1;background:#1e1f22;color:#ddd;border:none;resize:none;font-family:monospace;padding:12px;" spellcheck="false"># TODO: load real file content here</textarea>
            <div style="height:120px;background:#2b2b2b;padding:8px;border-top:1px solid #555;">
                <strong>AI Suggestion (+/- diff)</strong><br>
                <span style="color:#0f0">+ new line</span><br>
                <span style="color:#f66">- old line</span>
                <div style="margin-top:6px;">
                    <button>Approve</button>
                    <button>Reject</button>
                </div>
            </div>
        </div>

        <!-- Right Chat -->
        <div style="width:300px;background:#313335;border-left:1px solid #555;display:flex;flex-direction:column;">
            <div style="padding:6px 10px;background:#2b2b2b;font-weight:bold;">AI Chat</div>
            <div style="flex:1;padding:8px;overflow:auto;font-size:0.9em;">
                <div><strong>AI:</strong> How can I help?</div>
            </div>
            <div style="padding:6px;border-top:1px solid #555;">
                <input type="text" style="width:100%" placeholder="Ask AI...">
            </div>
        </div>
    </div>
</div>

<script>
function applyEditorSettings(el) {
    const editor = document.querySelector('textarea');
    if (!editor) return;
    if (el.value === 'light') {
        editor.style.background = '#f5f5f5';
        editor.style.color = '#222';
    } else {
        editor.style.background = '#1e1f22';
        editor.style.color = '#ddd';
    }
    if (el.tagName === 'SELECT' && el.parentElement.textContent.includes('Font')) {
        editor.style.fontSize = el.value + 'px';
    }
}
</script>