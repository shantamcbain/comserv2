# Paste into ~/.ssh/config on your tablet or laptop (one block).
# Tablet /etc/hosts also needs:  127.0.0.1 workstation.local
# Then:  ssh -N comserv-aew
# Browser: http://workstation.local:3001/ai/editing_widget_popup
#
# ZeroTier (no SSH): http://172.30.131.126:3001/ai/editing_widget_popup
#   (tablet must be on the same ZeroTier network zthnhd6k65)

Host comserv-aew
    HostName 172.30.131.126
    User shanta
    Port 22
    LocalForward 3001 127.0.0.1:3001
    ServerAliveInterval 60
    ServerAliveCountMax 3
    IdentityFile ~/.ssh/id_ed25519