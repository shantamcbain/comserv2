[% META
   title = "Hosted Accounts — Admin"
   description = "Admin view: all CSC hosting accounts"
   TemplateType = "Application"
   roles = "admin"
   category = "Admin"
%]
<div class="content-container">

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1em;flex-wrap:wrap;gap:0.5em">
  <h1 style="font-family:var(--header-font);color:var(--text-color);margin:0">&#127760; Hosted Accounts</h1>
  <div style="display:flex;gap:0.5em;flex-wrap:wrap">
    <a href="/hosting/cost" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Cost Config</a>
    <a href="/hosted" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">My Hosting</a>
    <a href="/admin" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Admin</a>
  </div>
</div>

[% IF c.flash.error_msg %]
<div style="background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.error_msg | html %]</div>
[% END %]
[% IF c.flash.success_msg %]
<div style="background:#d4edda;color:#155724;border:1px solid #c3e6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.success_msg | html %]</div>
[% END %]

<div style="display:flex;gap:0.5em;margin-bottom:1.2em;flex-wrap:wrap;align-items:center">
  <span style="font-family:var(--body-font);font-size:0.9rem;color:var(--text-muted-color)">Filter:</span>
  [% FOREACH f IN [['all','All'],['pending','Pending'],['active','Active'],['suspended','Suspended'],['cancelled','Cancelled']] %]
  <a href="/accounts?status=[% f.0 %]"
     style="padding:5px 14px;border-radius:4px;font-family:var(--body-font);font-size:0.9rem;text-decoration:none;
            [% IF status_filter == f.0 %]background:var(--primary-color);color:#fff;border:1px solid var(--primary-color)
            [% ELSE %]background:var(--secondary-color);color:var(--text-color);border:1px solid var(--border-color)[% END %]">
    [% f.1 %]
  </a>
  [% END %]
</div>

[% IF accounts.size %]
<div style="overflow-x:auto;margin-bottom:2em">
<table style="width:100%;border-collapse:collapse;font-family:var(--body-font);font-size:0.9rem">
  <thead>
    <tr style="background:var(--secondary-color);border-bottom:2px solid var(--border-color)">
      <th style="padding:8px 10px;text-align:left">SiteName</th>
      <th style="padding:8px 10px;text-align:left">Plan</th>
      <th style="padding:8px 10px;text-align:left">Domain</th>
      <th style="padding:8px 10px;text-align:left">Contact</th>
      <th style="padding:8px 10px;text-align:right">Monthly</th>
      <th style="padding:8px 10px;text-align:center">Status</th>
      <th style="padding:8px 10px;text-align:center">Renewal</th>
      <th style="padding:8px 10px;text-align:center">Actions</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH acct IN accounts %]
  <tr style="border-bottom:1px solid var(--border-color)">
    <td style="padding:7px 10px"><strong>[% acct.sitename | html %]</strong>
      [% IF acct.referring_sitename %]<br><small style="color:var(--text-muted-color)">ref: [% acct.referring_sitename | html %]</small>[% END %]
    </td>
    <td style="padding:7px 10px">[% acct.plan_slug | html %]</td>
    <td style="padding:7px 10px">[% acct.domain | html %] [% IF acct.domain_type %]<small style="color:var(--text-muted-color)">([% acct.domain_type | html %])</small>[% END %]</td>
    <td style="padding:7px 10px">[% acct.contact_email | html %]</td>
    <td style="padding:7px 10px;text-align:right">CAD [% acct.monthly_cost || '0.00' %]</td>
    <td style="padding:7px 10px;text-align:center">
      <span style="padding:2px 8px;border-radius:3px;font-size:0.8rem;font-weight:600;
        [% IF acct.status == 'active' %]background:#e8f5e9;color:#2e7d32
        [% ELSIF acct.status == 'pending' %]background:#fff8e1;color:#e65100
        [% ELSIF acct.status == 'suspended' %]background:#fff3e0;color:#e65100
        [% ELSE %]background:#fce4ec;color:#b71c1c[% END %]">
        [% acct.status | html %]
      </span>
    </td>
    <td style="padding:7px 10px;text-align:center">[% acct.next_renewal_date || '—' %]</td>
    <td style="padding:7px 10px;text-align:center">
      [% IF acct.status == 'pending' %]
      <form method="POST" action="/hosting/activate" style="display:inline">
        <input type="hidden" name="account_id" value="[% acct.id %]">
        <input type="number" name="payment_amount" placeholder="CAD paid" step="0.01" min="0"
               style="width:80px;padding:3px 6px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color);font-size:0.8rem">
        <button type="submit" style="padding:3px 10px;background:#2e7d32;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:0.8rem"
                onclick="return confirm('Activate hosting for [% acct.sitename | html %]?')">Activate</button>
      </form>
      [% END %]
    </td>
  </tr>
  [% END %]
  </tbody>
</table>
</div>
[% ELSE %]
<div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:4px;padding:1.5em;text-align:center;color:var(--text-muted-color);font-family:var(--body-font)">
  No hosting accounts found.
</div>
[% END %]

[% IF cost_cfg %]
<h2 style="font-family:var(--header-font);color:var(--text-color);margin:1.5em 0 0.8em;font-size:1.1rem">Pricing Configuration</h2>
<div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:6px;padding:1em;font-family:var(--body-font);font-size:0.9rem;margin-bottom:1.5em">
  Server cost: <strong>CAD [% cost_cfg.server_cost_monthly %]/mo</strong> ÷
  <strong>[% cost_cfg.active_site_count %] sites</strong> +
  <strong>[% cost_cfg.overhead_percent %]%</strong> overhead =
  <strong>CAD [% cost_cfg.unit_price %]/site/mo</strong>
  | Commission: <strong>[% cost_cfg.commission_percent %]%</strong>
  | Member discount: <strong>[% cost_cfg.member_discount_percent %]%</strong>
  <a href="/hosting/cost" style="margin-left:1em;color:var(--link-color)">Edit</a>
</div>
[% END %]

[% IF site_accounts.size %]
<h2 style="font-family:var(--header-font);color:var(--text-color);margin:1.5em 0 0.8em;font-size:1.1rem">SiteName Commission Accounts</h2>
<div style="overflow-x:auto;margin-bottom:1.5em">
<table style="width:100%;border-collapse:collapse;font-family:var(--body-font);font-size:0.9rem">
  <thead>
    <tr style="background:var(--secondary-color);border-bottom:2px solid var(--border-color)">
      <th style="padding:8px 10px;text-align:left">SiteName</th>
      <th style="padding:8px 10px;text-align:right">Balance (pts)</th>
      <th style="padding:8px 10px;text-align:right">Lifetime Earned</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH sa IN site_accounts %]
  <tr style="border-bottom:1px solid var(--border-color)">
    <td style="padding:7px 10px">[% sa.sitename | html %]</td>
    <td style="padding:7px 10px;text-align:right">[% sa.balance %]</td>
    <td style="padding:7px 10px;text-align:right">[% sa.lifetime_earned %]</td>
  </tr>
  [% END %]
  </tbody>
</table>
</div>
[% END %]

[% IF founder_cfg %]
<div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:4px;padding:0.8em 1em;font-family:var(--body-font);font-size:0.85rem;color:var(--text-muted-color)">
  Founder royalty: <strong>[% founder_cfg.royalty_percent %]%</strong> to <strong>[% founder_cfg.founder_username | html %]</strong> on every hosting payment.
</div>
[% END %]

</div>
