[%
   title = "Hosting Setup"
   description = "Create hosting tables and seed initial config data"
   TemplateType = "Application"
   roles = "admin"
   category = "Admin"
%]
<div class="content-container">

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1em;flex-wrap:wrap;gap:0.5em">
  <h1 style="font-family:var(--header-font);color:var(--text-color);margin:0">&#9881; Hosting Setup</h1>
  <div style="display:flex;gap:0.5em">
    <a href="/hosting/cost" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Cost Config</a>
    <a href="/accounts" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">All Accounts</a>
    <a href="/admin" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Admin</a>
  </div>
</div>

<p style="font-family:var(--body-font);color:var(--text-muted-color);font-size:0.9rem;margin-bottom:1.2em">
  This page creates the three hosting support tables in the database (if they do not already exist)
  and seeds the initial configuration rows (hosting cost config, founder royalty config, and inventory items
  HOST-APP and HOST-CPANEL). It is safe to run multiple times — existing rows are never overwritten.
</p>

[% IF errors.size %]
<div style="background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;border-radius:6px;padding:1em;margin-bottom:1.2em">
  <strong>Errors:</strong>
  <ul style="margin:0.5em 0 0 1.2em;font-family:var(--body-font);font-size:0.9rem">
  [% FOREACH e IN errors %]
    <li>[% e | html %]</li>
  [% END %]
  </ul>
</div>
[% END %]

[% IF log.size %]
<div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:6px;padding:1em;margin-bottom:1.2em">
  <strong style="font-family:var(--header-font);color:var(--text-color)">Setup Log:</strong>
  <ul style="margin:0.5em 0 0 1.2em;font-family:var(--body-font);font-size:0.9rem;color:var(--text-color)">
  [% FOREACH entry IN log %]
    <li>[% entry | html %]</li>
  [% END %]
  </ul>
</div>
[% END %]

[% IF !errors.size && log.size %]
<div style="background:#d4edda;color:#155724;border:1px solid #c3e6cb;border-radius:4px;padding:0.8em 1em;margin-bottom:1.2em;font-family:var(--body-font)">
  &#10003; Setup complete. You can now configure hosting cost at
  <a href="/hosting/cost" style="color:#155724"><strong>/hosting/cost</strong></a>
  and manage accounts at <a href="/accounts" style="color:#155724"><strong>/accounts</strong></a>.
</div>
[% END %]

<form method="GET" action="/hosting/setup" style="margin-top:1em">
  <button type="submit"
    style="padding:8px 22px;background:var(--primary-color);color:#fff;border:none;border-radius:4px;cursor:pointer;font-family:var(--body-font);font-size:1rem">
    Run Setup Again
  </button>
</form>

</div>
