[% META
   title = "Hosted Services"
   description = "CSC Hosting — your site's hosting status and plans"
   TemplateType = "Application"
   category = "Hosting"
%]
<div class="content-container">

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.2em;flex-wrap:wrap;gap:0.5em">
  <h1 style="font-family:var(--header-font);color:var(--text-color);margin:0">&#127760; CSC Hosting</h1>
  <div style="display:flex;gap:0.5em;flex-wrap:wrap">
    [% IF is_admin %]
    <a href="/accounts" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">All Accounts</a>
    <a href="/hosting/cost" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Cost Config</a>
    [% END %]
    <a href="/hosting_signup" style="padding:6px 14px;background:var(--primary-color);color:#fff;border:none;border-radius:4px;text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Apply for Hosting</a>
  </div>
</div>

[% IF c.flash.error_msg %]
<div style="background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.error_msg | html %]</div>
[% END %]
[% IF c.flash.success_msg %]
<div style="background:#d4edda;color:#155724;border:1px solid #c3e6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.success_msg | html %]</div>
[% END %]

[% IF acct %]
<div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:6px;padding:1.2em;margin-bottom:1.5em">
  <h2 style="font-family:var(--header-font);color:var(--text-color);margin:0 0 0.8em 0;font-size:1.2rem">
    [% IF acct.status == 'active' %]&#x2705;[% ELSIF acct.status == 'pending' %]&#x23F3;[% ELSE %]&#x26A0;[% END %]
    [% sitename | html %] Hosting — <span style="color:[% IF acct.status == 'active' %]#2e7d32[% ELSIF acct.status == 'pending' %]#e65100[% ELSE %]#b71c1c[% END %]">[% acct.status | html %]</span>
  </h2>
  <table style="width:100%;border-collapse:collapse;font-family:var(--body-font);font-size:0.9rem">
    <tr><td style="padding:5px 10px;color:var(--text-muted-color)">Plan</td><td style="padding:5px 10px"><strong>[% acct.plan_slug | html %]</strong></td></tr>
    <tr><td style="padding:5px 10px;color:var(--text-muted-color)">Domain</td><td style="padding:5px 10px">[% acct.domain | html %] [% IF acct.domain_type %]<small style="color:var(--text-muted-color)">([% acct.domain_type | html %])</small>[% END %]</td></tr>
    <tr><td style="padding:5px 10px;color:var(--text-muted-color)">Monthly Cost</td><td style="padding:5px 10px">CAD [% acct.monthly_cost || '0.00' %]</td></tr>
    [% IF acct.next_renewal_date %]
    <tr><td style="padding:5px 10px;color:var(--text-muted-color)">Next Renewal</td><td style="padding:5px 10px">[% acct.next_renewal_date %]</td></tr>
    [% END %]
    [% IF acct.contact_email %]
    <tr><td style="padding:5px 10px;color:var(--text-muted-color)">Contact</td><td style="padding:5px 10px">[% acct.contact_email | html %]</td></tr>
    [% END %]
    [% IF acct.auto_pay %]
    <tr><td style="padding:5px 10px;color:var(--text-muted-color)">Auto-pay</td><td style="padding:5px 10px">&#x2705; Enabled (points)</td></tr>
    [% END %]
  </table>
  [% IF acct.is_active %]
  <div style="margin-top:1em">
    <a href="/hosting/renew" style="padding:7px 18px;background:var(--primary-color);color:#fff;border-radius:4px;text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Renew Now</a>
  </div>
  [% END %]
</div>
[% ELSE %]
<div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:6px;padding:1.5em;margin-bottom:1.5em;text-align:center">
  <p style="font-family:var(--body-font);color:var(--text-muted-color);margin:0 0 1em 0">
    <strong>[% sitename | html %]</strong> is not yet registered with CSC Hosting.
  </p>
  <a href="/hosting_signup" style="padding:8px 22px;background:var(--primary-color);color:#fff;border:none;border-radius:4px;text-decoration:none;font-family:var(--body-font)">Apply for Hosting</a>
</div>
[% END %]

<h2 style="font-family:var(--header-font);color:var(--text-color);margin:0 0 0.8em 0;font-size:1.1rem">Available Plans</h2>
<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1em;margin-bottom:1.5em">
[% FOREACH plan IN all_plans %]
<div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:6px;padding:1.2em">
  <h3 style="font-family:var(--header-font);margin:0 0 0.5em 0;font-size:1rem">[% plan.name | html %]</h3>
  <div style="font-size:1.4rem;font-weight:bold;color:var(--primary-color);margin-bottom:0.5em">CAD [% plan.monthly %]/mo</div>
  <div style="font-size:0.8rem;color:var(--text-muted-color);margin-bottom:0.8em">SKU: [% plan.sku | html %]</div>
  <a href="/hosting_signup?plan=[% plan.slug | uri %]"
     style="display:inline-block;padding:6px 16px;background:var(--primary-color);color:#fff;border-radius:4px;text-decoration:none;font-family:var(--body-font);font-size:0.9rem">Apply</a>
</div>
[% END %]
</div>

[% IF cost_cfg %]
<div style="font-family:var(--body-font);font-size:0.8rem;color:var(--text-muted-color);border-top:1px solid var(--border-color);padding-top:0.8em">
  Pricing is cost-of-server based: CAD [% cost_cfg.server_cost_monthly %]/mo ÷ [% cost_cfg.active_site_count %] sites + [% cost_cfg.overhead_percent %]% overhead.
  Refer a new member and earn [% cost_cfg.commission_percent %]% commission on their first payment.
  Members of the referring SiteName receive [% cost_cfg.member_discount_percent %]% off.
</div>
[% END %]

</div>
