[% META
   title = "Hosting Cost Configuration"
   description = "Admin: set server cost, overhead, commission rates"
   TemplateType = "Application"
   roles = "admin"
   category = "Admin"
%]
<div class="content-container">

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1em;flex-wrap:wrap;gap:0.5em">
  <h1 style="font-family:var(--header-font);color:var(--text-color);margin:0">Hosting Cost Config</h1>
  <div style="display:flex;gap:0.5em">
    <a href="/accounts" style="padding:6px 14px;border:1px solid var(--border-color);border-radius:4px;color:var(--text-color);text-decoration:none;font-family:var(--body-font);font-size:0.9rem">← Accounts</a>
  </div>
</div>

[% IF c.flash.error_msg %]
<div style="background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.error_msg | html %]</div>
[% END %]
[% IF c.flash.success_msg %]
<div style="background:#d4edda;color:#155724;border:1px solid #c3e6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.success_msg | html %]</div>
[% END %]

<form method="POST" action="/hosting/cost" style="max-width:520px">
  <div style="display:grid;gap:1em;font-family:var(--body-font)">

    <div>
      <label style="display:block;font-size:0.85rem;color:var(--text-muted-color);margin-bottom:0.3em">Server Cost / Month (CAD)</label>
      <input type="number" name="server_cost_monthly" step="0.01" min="0"
             value="[% cfg.server_cost_monthly || '0.00' %]"
             style="width:100%;padding:7px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
    </div>

    <div>
      <label style="display:block;font-size:0.85rem;color:var(--text-muted-color);margin-bottom:0.3em">Active Site Count</label>
      <input type="number" name="active_site_count" step="1" min="1"
             value="[% cfg.active_site_count || '1' %]"
             style="width:100%;padding:7px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
    </div>

    <div>
      <label style="display:block;font-size:0.85rem;color:var(--text-muted-color);margin-bottom:0.3em">Overhead % (markup on cost-per-site)</label>
      <input type="number" name="overhead_percent" step="0.1" min="0" max="100"
             value="[% cfg.overhead_percent || '20.00' %]"
             style="width:100%;padding:7px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
    </div>

    <div>
      <label style="display:block;font-size:0.85rem;color:var(--text-muted-color);margin-bottom:0.3em">Referral Commission % (one-time on first payment)</label>
      <input type="number" name="commission_percent" step="0.1" min="0" max="100"
             value="[% cfg.commission_percent || '10.00' %]"
             style="width:100%;padding:7px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
    </div>

    <div>
      <label style="display:block;font-size:0.85rem;color:var(--text-muted-color);margin-bottom:0.3em">Member Discount % (buyer is member of referring site)</label>
      <input type="number" name="member_discount_percent" step="0.1" min="0" max="100"
             value="[% cfg.member_discount_percent || '10.00' %]"
             style="width:100%;padding:7px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
    </div>

    <div>
      <label style="display:block;font-size:0.85rem;color:var(--text-muted-color);margin-bottom:0.3em">Notes</label>
      <textarea name="notes" rows="3"
                style="width:100%;padding:7px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color);font-family:var(--body-font)">[% cfg.notes | html %]</textarea>
    </div>

    [% IF cfg %]
    <div style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:4px;padding:0.8em 1em;font-size:0.85rem">
      Current unit price: <strong>CAD [% cfg.unit_price %]/site/mo</strong>
      (server [% cfg.server_cost_monthly %] ÷ [% cfg.active_site_count %] sites + [% cfg.overhead_percent %]% overhead)
    </div>
    [% END %]

    <div>
      <button type="submit" style="padding:8px 22px;background:var(--primary-color);color:#fff;border:none;border-radius:4px;cursor:pointer;font-family:var(--body-font)">Save</button>
    </div>
  </div>
</form>

</div>
