 [% META title = 'Hosting Signup' %]
[% PageVersion = 'hosting/signup_form.tt,v 0.02 2026/06/17 shanta Exp shanta ' %]

[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
    [% # Use the standard debug message system %]
    [% IF debug_msg.defined && debug_msg.size > 0 %]
        <div class="debug-messages">
            [% FOREACH msg IN debug_msg %]
                <p class="debug">Debug: [% msg %]</p>
            [% END %]
        </div>
    [% END %]
[% END %]

<!-- Application-compliant container structure -->
<div class="app-container">
    <div class="page-header">
        <h1>[% title || 'Hosting Signup' %]</h1>
        [% IF subtitle %]<h2 class="page-subtitle">[% subtitle %]</h2>[% END %]
    </div>

    <div class="content-container">
        <div class="content-primary">
            <div class="form-container">
<style>
.plan-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1rem;
}
.plan-card {
  border: 1px solid var(--border-color, #ccc);
  border-radius: 6px;
  padding: 1rem;
  background: var(--card-bg, #fff);
  display: flex;
  flex-direction: column;
  min-height: 280px;
}
.plan-card h3 { margin: 0 0 .5rem; }
.plan-card-price { font-size: 1.1rem; font-weight: bold; }
.plan-card ul { font-size: .9rem; padding-left: 1.1em; flex: 1; }
</style>
                    [% IF errors && errors.size %]
                    <div class="alert alert-danger">
                        <h4 class="alert-heading">Please fix the following errors:</h4>
                        <ul>
                            [% FOREACH error IN errors %]
                            <li>[% error %]</li>
                            [% END %]
                        </ul>
                    </div>
                    [% END %]
                    

                    <p class="lead">Select a hosting plan below. Domain and site details will be collected after plan selection.</p>

                                        <!-- Plan chooser only — no form submission here. Domain details collected after plan selection. -->
                    <div class="content-section">
                        <h3>Available Hosting Plans</h3>
                        <p class="text-muted">Choose a plan. You will be taken to the plan details page where you can review features and continue the signup flow.</p>
                        [% IF c.session.username %]
                        <div class="alert alert-success" style="margin:1rem 0">
                            <strong>Limited-time offer:</strong> Activate any hosting plan now and receive <strong>100 SiteCoins</strong> bonus credit.
                        </div>
                        [% END %]

                        [% IF user_plans.size || user_hosting.size %]
                        <h4 style="margin-top:1rem;">Your Current Hosting / Memberships</h4>
                        <div class="plan-cards-grid">
                            [% FOREACH m IN user_plans %]
                            [% SET p = m.plan %]
                            [% SET display_price = p.inventory_item ? p.inventory_item.unit_price : p.price_monthly %]
                            <div class="plan-card">
                                <h3 class="plan-card-name">[% p.name | html %] <small style="font-weight:normal;color:#666">([% m.site.name || 'CSC' %])</small></h3>
                                <div class="plan-card-price">
                                    [% IF display_price == 0 %]Free
                                    [% ELSE %][% p.price_currency | html %]&nbsp;[% display_price %]/mo[% END %]
                                </div>
                                <div class="plan-card-desc"><small>Status: [% m.status %] • Expires: [% m.expires_at || 'Never' %]</small></div>
                                <ul class="plan-card-features">
                                    [% IF p.has_subdomain %]<li>Subdomain included</li>[% END %]
                                    [% IF p.has_custom_domain %]<li>Custom domain support</li>[% END %]
                                    [% IF p.has_email %]<li>[% p.email_addresses || 1 %] email address[% IF (p.email_addresses||1) != 1 %]es[% END %]</li>[% END %]
                                    [% IF p.has_hosting %]<li>Hosting tier: [% p.hosting_tier || 'included' %]</li>[% END %]
                                    [% IF p.ai_requests_per_day > 0 %]<li>[% p.ai_requests_per_day %] AI requests/day</li>[% END %]
                                </ul>
                                <div class="plan-card-actions" style="margin-top:auto;">
                                    <a href="[% c.uri_for('/membership/account') %]" class="btn btn-secondary">Manage</a>
                                    <a href="[% c.uri_for('/membership/plan_details/' _ p.id) %]" class="btn btn-primary" style="margin-left:4px;">Features &amp; Upgrades</a>
                                </div>
                            </div>
                            [% END %]

                            [% FOREACH ha IN user_hosting %]
                            <div class="plan-card">
                                <h3 class="plan-card-name">Hosting Account <small style="font-weight:normal;color:#666">([% ha.sitename %])</small></h3>
                                <div class="plan-card-desc"><small>Domain: [% ha.domain || '—' %] • Status: [% ha.status %]</small></div>
                                <ul class="plan-card-features">
                                    <li>Plan: [% ha.plan_slug || '—' %]</li>
                                    [% IF ha.contact_email %]<li>Contact: [% ha.contact_email %]</li>[% END %]
                                </ul>
                                <div class="plan-card-actions" style="margin-top:auto;">
                                    <a href="[% c.uri_for('/membership/account') %]" class="btn btn-secondary">Manage</a>
                                </div>
                            </div>
                            [% END %]
                        </div>
                        [% END %]

                        [% IF public_plans.size %]
                        <h4 style="margin-top:1rem;">Site Plans</h4>
                        <div class="plan-cards-grid">
                            [% FOREACH plan IN public_plans %]
                            [% SET display_price = plan.inventory_item ? plan.inventory_item.unit_price : plan.price_monthly %]
                            <div class="plan-card">
                                <h3 class="plan-card-name">[% plan.name | html %]</h3>
                                <div class="plan-card-price">
                                    [% IF display_price == 0 %]Free
                                    [% ELSE %][% plan.price_currency | html %]&nbsp;[% display_price %]/mo[% END %]
                                </div>
                                [% IF plan.price_annual > 0 AND display_price > 0 %]
                                <div class="plan-card-annual">or [% plan.price_currency | html %]&nbsp;[% plan.price_annual %]/yr</div>
                                [% END %]
                                [% IF plan.description %]<p class="plan-card-desc">[% plan.description | html %]</p>[% END %]
                                <ul class="plan-card-features">
                                    [% IF plan.has_subdomain %]<li>Subdomain included</li>[% END %]
                                    [% IF plan.has_custom_domain %]<li>Custom domain support</li>[% END %]
                                </ul>
                                <div class="plan-card-actions">
                                    <a href="[% c.uri_for('/membership/hosting_signup', { plan => plan.slug, new => 1 }) %]" class="btn btn-primary">Learn More &amp; Join →</a>
                                </div>
                            </div>
                            [% END %]
                        </div>
                        [% END %]

                        [% IF csc_plans.size %]
                        <h4 style="margin-top:1rem;">CSC Hosting Plans</h4>
                        <div class="plan-cards-grid">
                            [% FOREACH plan IN csc_plans %]
                            [% SET display_price = plan.inventory_item ? plan.inventory_item.unit_price : plan.price_monthly %]
                            <div class="plan-card">
                                <h3 class="plan-card-name">[% plan.name | html %]</h3>
                                <div class="plan-card-price">
                                    [% IF display_price == 0 %]Free
                                    [% ELSE %][% plan.price_currency | html %]&nbsp;[% display_price %]/mo[% END %]
                                </div>
                                [% IF plan.price_annual > 0 AND display_price > 0 %]
                                <div class="plan-card-annual">or [% plan.price_currency | html %]&nbsp;[% plan.price_annual %]/yr</div>
                                [% END %]
                                [% IF plan.description %]<p class="plan-card-desc">[% plan.description | html %]</p>[% END %]
                                <ul class="plan-card-features">
                                    [% IF plan.has_subdomain %]<li>Subdomain included</li>[% END %]
                                    [% IF plan.has_custom_domain %]<li>Custom domain support</li>[% END %]
                                </ul>
                                <div class="plan-card-actions">
                                    <a href="[% c.uri_for('/membership/hosting_signup', { plan => plan.slug, new => 1 }) %]" class="btn btn-primary">Learn More &amp; Join →</a>
                                </div>
                            </div>
                            [% END %]
                        </div>
                        [% END %]
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Plan selection helper
function selectPlan(slug) {
    document.getElementById('plan_slug').value = slug;
    // Optionally highlight selected card or scroll to submit
    alert('Plan selected: ' + slug + '. Click Sign Up Now to continue.');
}

// Form validation script
(function() {
    'use strict';
    window.addEventListener('load', function() {
        // Get the password fields
        var password = document.getElementById('password');
        var confirmPassword = document.getElementById('confirm_password');
        
        // Function to validate password match
        function validatePasswordMatch() {
            if (password.value !== confirmPassword.value) {
                confirmPassword.setCustomValidity("Passwords do not match");
            } else {
                confirmPassword.setCustomValidity("");
            }
        }
        
        // Add event listeners to password fields
        if (password && confirmPassword) {
            password.addEventListener('change', validatePasswordMatch);
            confirmPassword.addEventListener('keyup', validatePasswordMatch);
        }
        
        // Standard form validation
        var forms = document.getElementsByClassName('needs-validation');
        var validation = Array.prototype.filter.call(forms, function(form) {
            form.addEventListener('submit', function(event) {
                // Check password match again on submit
                if (password && confirmPassword) {
                    validatePasswordMatch();
                }
                
                if (form.checkValidity() === false) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
    }, false);
})();
</script>