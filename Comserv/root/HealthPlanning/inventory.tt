<h2>Health Inventory — [% sitename | html %]</h2>

[% IF flash.success_msg %]
<div class="alert alert-success">[% flash.success_msg %]</div>
[% END %]
[% IF flash.error_msg %]
<div class="alert alert-danger">[% flash.error_msg %]</div>
[% END %]

<p><a href="/HealthPlanning">&larr; Dashboard</a></p>

<h3>Add / Update Item</h3>
<form method="post" action="/HealthPlanning/inventory_update" style="margin-bottom:20px;">
    <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:flex-end;">
        <div>
            <label>Item Name</label>
            <input type="text" name="item_name" class="form-control" required placeholder="e.g. Turmeric root">
        </div>
        <div>
            <label>Type</label>
            <select name="item_type" class="form-control">
                <option value="herb">Herb</option>
                <option value="food">Food</option>
                <option value="supplement">Supplement</option>
            </select>
        </div>
        <div>
            <label>Quantity</label>
            <input type="number" name="quantity" class="form-control" step="0.01" value="0">
        </div>
        <div>
            <label>Unit</label>
            <input type="text" name="unit" class="form-control" placeholder="g / oz / ml / each">
        </div>
        <div>
            <label>Low Stock Alert At</label>
            <input type="number" name="low_stock_threshold" class="form-control" step="0.01" value="0">
        </div>
        <div>
            <button type="submit" class="btn btn-primary">Add Item</button>
        </div>
    </div>
</form>

[% IF inventory && inventory.size %]
<h3>Current Inventory</h3>
<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Item</th>
            <th>Type</th>
            <th>Quantity</th>
            <th>Unit</th>
            <th>Status</th>
            <th>Update</th>
        </tr>
    </thead>
    <tbody>
    [% FOREACH item IN inventory %]
        <tr [% IF item.quantity <= item.low_stock_threshold %]style="background:#fff3cd;"[% END %]>
            <td>[% item.item_name | html %]
                [% IF item.herb_record_id %]
                    (<a href="/ENCY/herb_detail/[% item.herb_record_id %]">ENCY</a>)
                [% END %]
            </td>
            <td>[% item.item_type | html %]</td>
            <td>[% item.quantity %]</td>
            <td>[% item.unit | html %]</td>
            <td>
                [% IF item.quantity <= 0 %]<span style="color:red; font-weight:bold;">Out of Stock</span>
                [% ELSIF item.quantity <= item.low_stock_threshold %]<span style="color:orange;">Low — Order [% item.reorder_quantity %] [% item.unit | html %]</span>
                [% ELSE %]<span style="color:green;">OK</span>
                [% END %]
            </td>
            <td>
                <form method="post" action="/HealthPlanning/inventory_update" style="display:inline-flex; gap:4px;">
                    <input type="hidden" name="item_id" value="[% item.id %]">
                    <input type="number" name="quantity" class="form-control form-control-sm"
                           value="[% item.quantity %]" step="0.01" style="width:80px;">
                    <button type="submit" class="btn btn-sm btn-secondary">Save</button>
                </form>
            </td>
        </tr>
    [% END %]
    </tbody>
</table>
[% ELSE %]
<p>No inventory items found for this site. Add items above to track food and herb stock.</p>
[% END %]
