<h2>Diet &amp; Meal Plan</h2>
<p><a href="/HealthPlanning/plan/[% plan.id %]">&larr; Back to Plan</a></p>

[% IF plan %]

[% FOREACH diet IN plan.diet_plans %]
<div class="card" style="padding:16px; border:1px solid #ccc; margin-bottom:16px;">
    <h3>[% diet.dietary_protocol | html %]</h3>
    <p>[% diet.description | html %]</p>
    [% IF diet.foods_to_emphasise %]
    <p><strong>Foods to Emphasise:</strong><br>[% diet.foods_to_emphasise | html %]</p>
    [% END %]
    [% IF diet.foods_to_avoid %]
    <p><strong>Foods to Avoid:</strong><br>[% diet.foods_to_avoid | html %]</p>
    [% END %]

    [% IF diet.meal_plans && diet.meal_plans.size %]
    <h4>Meal Schedule</h4>
    <table class="table table-striped table-sm">
        <thead>
            <tr><th>Day</th><th>Meal</th><th>Recipe</th><th>Inventory</th></tr>
        </thead>
        <tbody>
        [% FOREACH meal IN diet.meal_plans %]
            <tr>
                <td>[% meal.day_of_week | html %]</td>
                <td>[% meal.meal_slot | html %]</td>
                <td>[% meal.recipe_name | html %]</td>
                <td>
                    [% IF meal.inventory_check %]
                        <span style="color:green;">&#10003; In Stock</span>
                    [% ELSE %]
                        <span style="color:orange;">&#9888; Check Stock</span>
                    [% END %]
                </td>
            </tr>
        [% END %]
        </tbody>
    </table>
    [% END %]
</div>
[% END %]

[% IF inventory && inventory.size %]
<h3>Available Inventory</h3>
<table class="table table-sm">
    <thead><tr><th>Item</th><th>Type</th><th>Quantity</th><th>Unit</th><th>Status</th></tr></thead>
    <tbody>
    [% FOREACH item IN inventory %]
        <tr [% IF item.quantity <= item.low_stock_threshold %]style="background:#fff3cd;"[% END %]>
            <td>[% item.item_name | html %]</td>
            <td>[% item.item_type | html %]</td>
            <td>[% item.quantity %]</td>
            <td>[% item.unit | html %]</td>
            <td>
                [% IF item.quantity <= 0 %]<span style="color:red;">Out of Stock</span>
                [% ELSIF item.quantity <= item.low_stock_threshold %]<span style="color:orange;">Low Stock</span>
                [% ELSE %]<span style="color:green;">OK</span>
                [% END %]
            </td>
        </tr>
    [% END %]
    </tbody>
</table>
[% END %]

[% END %]
