<h2>Exercise Plan</h2>
<p><a href="/HealthPlanning/plan/[% plan.id %]">&larr; Back to Plan</a></p>

[% IF plan %]
<p>Movement and exercise are key components of your natural health journey. Choose activities that suit your current ability and gradually increase intensity.</p>

[% IF plan.exercise_plans && plan.exercise_plans.size %]
<table class="table table-striped">
    <thead>
        <tr>
            <th>Exercise</th>
            <th>Frequency / Week</th>
            <th>Duration</th>
            <th>Intensity</th>
            <th>Description</th>
        </tr>
    </thead>
    <tbody>
    [% FOREACH e IN plan.exercise_plans %]
        <tr>
            <td>[% e.exercise_type | html %]</td>
            <td>[% e.frequency_per_week %]x</td>
            <td>[% e.duration_minutes %] min</td>
            <td>[% e.intensity | html %]</td>
            <td>[% e.description | html %]</td>
        </tr>
    [% END %]
    </tbody>
</table>
[% ELSE %]
<p>No exercise entries have been added to this plan yet.</p>
[% END %]

[% ELSE %]
<p>Plan not found.</p>
[% END %]
