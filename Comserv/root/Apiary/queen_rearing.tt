[% META title = "Queen Rearing System" %]
[% PageVersion = 'Apiary/queen_rearing.tt,v 0.02 2026/03/17 shanta Exp shanta' %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="app-container">

    <div class="page-header">
        <h1>Queen Rearing System</h1>
        <p class="page-subtitle">Plan and manage your queen rearing program.</p>
    </div>

    <div class="content-container">
        <div class="content-primary">

            <div class="app-section">
                <p>Welcome to the Queen Rearing System. This system helps beekeepers manage their queen rearing operations from graft to mating nuc.</p>
            </div>

            <div class="app-section">
                <h2>Queen Rearing Calendar</h2>
                <div class="content-section">
                    <p>The queen rearing process follows a strict timeline. Use this calendar to plan your grafting and emergence dates.</p>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Day</th>
                                    <th>Event</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td>Day 0</td><td>Grafting</td><td>Transfer larvae to queen cups</td></tr>
                                <tr><td>Day 4</td><td>Cell Capping</td><td>Queen cells are capped by workers</td></tr>
                                <tr><td>Day 10</td><td>Cell Transfer</td><td>Transfer cells to mating nucs</td></tr>
                                <tr><td>Day 16</td><td>Virgin Emergence</td><td>Virgin queens emerge from cells</td></tr>
                                <tr><td>Day 21–28</td><td>Mating Flights</td><td>Queens take mating flights</td></tr>
                                <tr><td>Day 30+</td><td>Laying</td><td>Mated queens begin laying eggs</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="app-section">
                <h2>Queen Rearing Methods</h2>
                <div class="content-section">
                    <ul>
                        <li>Grafting Method</li>
                        <li>Jenter / Nicot System</li>
                        <li>Miller Method</li>
                        <li>Alley Method</li>
                        <li>Hopkins Method</li>
                        <li>Cloake Board Method</li>
                    </ul>
                </div>
            </div>

            <div class="app-section">
                <h2>Queen Management</h2>
                <div class="content-section">
                    <p>Track queens by tag number to view their associated frames and performance history.</p>
                    <div class="form-container">
                        <form action="/Apiary/frames_for_queen" method="get" class="app-form">
                            <div class="form-row">
                                <div class="form-field">
                                    <label for="queen_tag_number">Queen Tag Number:</label>
                                    <input type="text" name="queen_tag_number" id="queen_tag_number" class="form-input" placeholder="e.g. Q2024-001">
                                </div>
                            </div>
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary">View Frames</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="app-section">
                <h2>Resources</h2>
                <div class="content-section">
                    <ul>
                        <li><a href="/BMaster/Queens">Queen Rearing Graft Calendar</a></li>
                        <li><a href="/BMaster/education">Education and Collaboration</a></li>
                        <li><a href="/workshop">Workshops — Queen Rearing Sessions</a></li>
                    </ul>
                </div>
            </div>

            <div class="page-footer">
                <div class="footer-actions">
                    <a href="/Apiary" class="btn btn-secondary">Back to Apiary Management</a>
                    <a href="/BMaster" class="btn btn-secondary">Back to BMaster Home</a>
                </div>
            </div>

        </div>
    </div>

</div>
