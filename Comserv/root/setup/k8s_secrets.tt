[% META title = 'Kubernetes Secrets Configuration' %]

<div class="setup-container">
    <h1>Kubernetes Secrets Configuration (Phase 0)</h1>
    
    <div class="info-banner">
        <p><strong>Purpose</strong>: Configure database credentials as Kubernetes Secrets (K8s primary source) or environment variables (Docker fallback).</p>
        <p><strong>Development Only</strong>: This setup tool is only available in development mode.</p>
    </div>
    
    [% IF error_msg %]
    <div class="error-banner">
        <strong>❌ Error:</strong> [% error_msg %]
    </div>
    [% END %]
    
    [% IF success_msg %]
    <div class="success-banner">
        <strong>✓ Success:</strong> [% success_msg %]
    </div>
    
    [% IF test_results && test_results.size > 0 %]
    <div class="test-results">
        <h3>Database Connection Test Results:</h3>
        <table class="results-table">
            <thead>
                <tr>
                    <th>Connection Name</th>
                    <th>Host</th>
                    <th>Port</th>
                    <th>Database</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                [% FOREACH result IN test_results %]
                <tr class="[% result.status == 'CONNECTED' ? 'status-success' : 'status-failed' %]">
                    <td><strong>[% result.connection %]</strong></td>
                    <td><code>[% result.host %]</code></td>
                    <td>[% result.port %]</td>
                    <td><code>[% result.database %]</code></td>
                    <td class="status-cell">
                        [% IF result.status == 'CONNECTED' %]
                            <span class="badge-success">✓ CONNECTED</span>
                        [% ELSE %]
                            <span class="badge-failed">✗ FAILED</span>
                        [% END %]
                    </td>
                </tr>
                [% END %]
            </tbody>
        </table>
        <p style="margin-top: 15px; color: var(--text-muted-color, #666); font-size: 0.9em;">
            <strong>Note:</strong> Check <code>root/log/application.log</code> for detailed connection diagnostics.
        </p>
    </div>
    [% END %]
    
    [% IF creation_details && creation_details.size > 0 %]
    <div class="creation-details">
        <h3>K8s Secrets Creation Details:</h3>
        <ul>
            [% FOREACH detail IN creation_details %]
            <li>
                [% IF detail.status == 'SUCCESS' %]
                    <strong style="color: #4caf50;">✓</strong> 
                    <code>[% detail.file %]</code> created successfully
                [% ELSE %]
                    <strong style="color: #d32f2f;">✗</strong> 
                    <code>[% detail.location %]</code> - [% detail.reason || detail.status %]
                [% END %]
            </li>
            [% END %]
        </ul>
    </div>
    [% END %]
    [% END %]
    
    <!-- Option 1: Create K8s Secrets from existing db_config.json -->
    [% IF db_config_exists %]
    <div class="setup-section">
        <h2>Option 1: Create K8s Secrets from Existing db_config.json</h2>
        
        [% IF databases_parsed && databases_parsed.size > 0 %]
        <div class="databases-table">
            <h3>Databases in db_config.json:</h3>
            <table class="config-table">
                <thead>
                    <tr>
                        <th>Connection Name</th>
                        <th>Host</th>
                        <th>Port</th>
                        <th>Database</th>
                        <th>Type</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    [% FOREACH db IN databases_parsed %]
                    <tr>
                        <td><strong>[% db.name | html %]</strong></td>
                        <td><code>[% db.config.host | html %]</code></td>
                        <td>[% db.config.port || 3306 %]</td>
                        <td><code>[% db.config.database | html %]</code></td>
                        <td>[% db.config.db_type || 'mariadb' %]</td>
                        <td>[% (db.config.description || 'N/A') | html %]</td>
                    </tr>
                    [% END %]
                </tbody>
            </table>
        </div>
        [% END %]
        
        <div class="db-config-preview">
            <h3>Full db_config.json Content (for verification):</h3>
            <pre><code>[% db_config_content | html %]</code></pre>
        </div>
        
        <p><strong>Action:</strong> Click the button below to create Kubernetes Secrets from all [% databases_parsed.size %] database connection(s) in db_config.json. The system will:</p>
        <ul>
            <li>Create secret files at <code>/opt/secrets/comserv/dbi/</code> (primary location)</li>
            <li>Create secret files at <code>/var/run/secrets/comserv/dbi/</code> (fallback location)</li>
            <li>Automatically test each database connection</li>
            <li>Log all actions to application.log</li>
        </ul>
        
        <form method="POST" action="[% c.uri_for('/setup/k8s-secrets') %]">
            <input type="hidden" name="action" value="create_from_json">
            <div class="form-actions">
                <button type="submit" class="btn-primary">Create K8s Secrets from db_config.json</button>
            </div>
        </form>
    </div>
    [% ELSE %]
    <div class="setup-section warning">
        <h2>Note: db_config.json Not Found</h2>
        <p><strong>⚠️ No existing db_config.json file was found.</strong> Please use Option 2 below to provide database credentials and create K8s Secrets from form input.</p>
    </div>
    [% END %]
    
    <!-- Option 2: Create K8s Secrets from Form Input -->
    <div class="setup-section">
        <h2>Option 2: Create K8s Secrets from Form Input</h2>
        
        <p>Enter your database credentials below to create Kubernetes Secrets. These will be stored securely.</p>
        
        <form method="POST" action="[% c.uri_for('/setup/k8s-secrets') %]">
            <input type="hidden" name="action" value="create_from_form">
            
            <div class="form-group">
                <label for="db_type">Database Type:</label>
                <select name="db_type" id="db_type">
                    <option value="mariadb">MariaDB</option>
                    <option value="mysql">MySQL</option>
                    <option value="sqlite">SQLite</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="host">Database Host:</label>
                <input type="text" name="host" id="host" placeholder="e.g., 192.168.1.198" required>
            </div>
            
            <div class="form-group">
                <label for="port">Port:</label>
                <input type="number" name="port" id="port" value="3306">
            </div>
            
            <div class="form-group">
                <label for="database">Database Name:</label>
                <input type="text" name="database" id="database" placeholder="e.g., ency" required>
            </div>
            
            <div class="form-group">
                <label for="username">Username:</label>
                <input type="text" name="username" id="username" required>
            </div>
            
            <div class="form-group">
                <label for="password">Password:</label>
                <input type="password" name="password" id="password" required>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn-primary">Create K8s Secrets</button>
            </div>
        </form>
    </div>
    
    <!-- Option 3: Create .env File for Docker -->
    <div class="setup-section">
        <h2>Option 3: Create .env File for Docker</h2>
        
        <p>For Docker environments, create an .env file with COMSERV_DB_* environment variables.</p>
        
        <form method="POST" action="[% c.uri_for('/setup/k8s-secrets') %]">
            <input type="hidden" name="action" value="create_env_file">
            
            <div class="form-group">
                <label for="docker_db_type">Database Type:</label>
                <select name="db_type" id="docker_db_type">
                    <option value="mariadb">MariaDB</option>
                    <option value="mysql">MySQL</option>
                    <option value="sqlite">SQLite</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="docker_host">Database Host:</label>
                <input type="text" name="host" id="docker_host" placeholder="e.g., database (Docker service name)" required>
            </div>
            
            <div class="form-group">
                <label for="docker_port">Port:</label>
                <input type="number" name="port" id="docker_port" value="3306">
            </div>
            
            <div class="form-group">
                <label for="docker_database">Database Name:</label>
                <input type="text" name="database" id="docker_database" placeholder="e.g., ency" required>
            </div>
            
            <div class="form-group">
                <label for="docker_username">Username:</label>
                <input type="text" name="username" id="docker_username" required>
            </div>
            
            <div class="form-group">
                <label for="docker_password">Password:</label>
                <input type="password" name="password" id="docker_password" required>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn-primary">Create .env File</button>
            </div>
        </form>
    </div>
    
    <!-- Configuration Summary -->
    <div class="setup-section info">
        <h2>Configuration Sources (Priority Order)</h2>
        
        <ol>
            <li><strong>Kubernetes Secrets</strong> (Primary - K8s Readiness)
                <ul>
                    <li>Location: <code>/opt/secrets/comserv/dbi/</code></li>
                    <li>Format: JSON files per connection</li>
                    <li>Security: File permissions restricted (0600)</li>
                </ul>
            </li>
            <li><strong>Environment Variables</strong> (Docker/Manual)
                <ul>
                    <li>Pattern: <code>COMSERV_DB_{CONNECTION}_{FIELD}=value</code></li>
                    <li>Example: <code>COMSERV_DB_PRODUCTION_SERVER_HOST=192.168.1.198</code></li>
                </ul>
            </li>
            <li><strong>db_config.json</strong> (Fallback - Development/Temporary)
                <ul>
                    <li>Location: <code>Comserv/db_config.json</code></li>
                    <li>Status: DEPRECATED - migrate to K8s or env vars</li>
                </ul>
            </li>
        </ol>
    </div>
    
    <div class="setup-actions">
        <a href="[% c.uri_for('/setup') %]" class="btn-secondary">Back to Main Setup</a>
        <a href="[% c.uri_for('/') %]" class="btn-secondary">Go to Home</a>
    </div>
</div>

<style>
.setup-container {
    max-width: 900px;
    margin: 20px auto;
    padding: 20px;
    font-family: Arial, sans-serif;
}

.info-banner, .error-banner, .success-banner {
    padding: 15px;
    margin-bottom: 20px;
    border-radius: 4px;
    border-left: 4px solid;
}

.info-banner {
    background-color: #e3f2fd;
    border-left-color: #2196f3;
    color: #1565c0;
}

.error-banner {
    background-color: #ffebee;
    border-left-color: #f44336;
    color: #c62828;
}

.success-banner {
    background-color: #e8f5e9;
    border-left-color: #4caf50;
    color: #2e7d32;
}

.setup-section {
    margin-bottom: 30px;
    padding: 20px;
    background-color: #f9f9f9;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
}

.setup-section.warning {
    background-color: var(--caution-bg, #fff3cd);
    border-color: #ff9800;
}

.setup-section.info {
    background-color: #e8f5e9;
    border-color: #4caf50;
}

.setup-section h2 {
    margin-top: 0;
    color: var(--text-color, #333);
}

.form-group {
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: bold;
    color: var(--text-color, #333);
}

.form-group input,
.form-group select {
    width: 100%;
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 14px;
    box-sizing: border-box;
}

.form-group input:focus,
.form-group select:focus {
    outline: none;
    border-color: #2196f3;
    box-shadow: 0 0 5px rgba(33, 150, 243, 0.3);
}

.form-actions {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #e0e0e0;
}

.btn-primary, .btn-secondary {
    padding: 10px 20px;
    margin-right: 10px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    text-decoration: none;
    display: inline-block;
}

.btn-primary {
    background-color: #2196f3;
    color: white;
}

.btn-primary:hover {
    background-color: #1976d2;
}

.btn-secondary {
    background-color: #757575;
    color: white;
}

.btn-secondary:hover {
    background-color: #616161;
}

.db-config-preview {
    margin: 15px 0;
    padding: 15px;
    background-color: var(--bg-secondary, #f5f5f5);
    border: 1px solid var(--border-color, #ddd);
    border-radius: 4px;
}

.db-config-preview pre {
    margin: 0;
    overflow-x: auto;
    max-height: 300px;
}

.setup-actions {
    margin-top: 30px;
    padding-top: 20px;
    border-top: 2px solid var(--border-color, #ddd);
    text-align: center;
}

ol li {
    margin-bottom: 10px;
}

ol ul {
    margin-top: 5px;
    margin-bottom: 10px;
}

code {
    background-color: #f0f0f0;
    padding: 2px 6px;
    border-radius: 3px;
    font-family: monospace;
}

.config-table, .results-table {
    width: 100%;
    border-collapse: collapse;
    margin: 15px 0;
    background-color: rgba(255,255,255,0.88);
    border: 1px solid var(--border-color, #ddd);
    border-radius: 4px;
}

.config-table thead, .results-table thead {
    background-color: var(--bg-secondary, #f5f5f5);
    border-bottom: 2px solid var(--border-color, #ddd);
}

.config-table th, .results-table th {
    text-align: left;
    padding: 12px;
    font-weight: bold;
    color: var(--text-color, #333);
    border-right: 1px solid var(--border-color, #ddd);
}

.config-table td, .results-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #eee;
    border-right: 1px solid #eee;
    color: var(--text-muted-color, #555);
}

.config-table tbody tr:hover, .results-table tbody tr:hover {
    background-color: #f9f9f9;
}

.results-table .status-success {
    background-color: #f1f8f6;
}

.results-table .status-failed {
    background-color: #fdf5f5;
}

.results-table .status-cell {
    text-align: center;
    font-weight: bold;
}

.badge-success {
    background-color: #4caf50;
    color: white;
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 0.85em;
}

.badge-failed {
    background-color: #d32f2f;
    color: white;
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 0.85em;
}

.test-results, .creation-details {
    margin: 20px 0;
    padding: 15px;
    background-color: #f9f9f9;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
}

.creation-details ul {
    list-style-type: none;
    padding-left: 0;
}

.creation-details li {
    padding: 8px 0;
    border-bottom: 1px solid #eee;
}

.creation-details li:last-child {
    border-bottom: none;
}

.databases-table {
    margin: 15px 0;
    padding: 15px;
    background-color: #f0f7ff;
    border: 1px solid #90caf9;
    border-radius: 4px;
}

.databases-table h3 {
    margin-top: 0;
    color: #1976d2;
}
</style>
