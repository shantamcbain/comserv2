
[% PageVersion  = 'todo/details.tt,v 0.06 2026/04/07 Shanta Exp Shanta'; %]
[% IF debug_mode == 1 %][% PageVersion %][% END %]

[% SET _grp      = c.session.group || '' %]
[% SET is_editor = is_admin || _grp == 'editor' || _grp == 'developer' %]
[% SET edit_mode = c.request.params.edit && is_editor %]

<h1>Todo: [% record.get_column('subject') | html %]</h1>

<div class="return-nav">
    <a href="/todo" class="return-button">Return to List View</a>
    <a href="/todo/day" class="return-button">Return to Day View</a>
    <a href="/todo/week" class="return-button">Return to Week View</a>
    <a href="/todo/month" class="return-button">Return to Month View</a>
    <button type="button" class="return-button" onclick="window.history.back();">Return to Previous Page</button>
    [% IF is_editor %]
    <a href="/todo/edit/[% record.get_column('record_id') %]"
       class="return-button">Edit</a>
    [% END %]
</div>

[% IF edit_mode %]

<form action="/todo/modify/[% record.get_column('record_id') %]" method="post">
    <input type="hidden" name="return_to" value="[% c.uri_for('/todo/details', { record_id => record.get_column('record_id') }) %]">

    <table border="0" cellpadding="4">
        <tr><td><label>Site:</label></td>
            <td><input type="text" name="sitename" value="[% record.get_column('sitename') | html %]"></td></tr>
        <tr><td><label>Subject:</label></td>
            <td><input type="text" name="subject" style="width:400px" value="[% record.get_column('subject') | html %]"></td></tr>
        <tr><td><label>Description:</label></td>
            <td><textarea name="description" rows="6" cols="60">[% record.get_column('description') | html %]</textarea></td></tr>
        <tr><td><label>Start Date:</label></td>
            <td><input type="date" name="start_date" value="[% record.get_column('start_date') %]"></td></tr>
        <tr><td><label>Due Date:</label></td>
            <td><input type="date" name="due_date" value="[% record.get_column('due_date') %]"></td></tr>
        <tr><td><label>Time of Day:</label></td>
            <td>
                <select name="time_of_day">
                    <option value="">-- Select Time --</option>
                    [%
                        USE date;
                        SET current_time = record.get_column('time_of_day');
                        IF current_time;
                            SET current_time_short = current_time.substr(0, 5);
                        ELSE;
                            SET current_time_short = '';
                        END;
                        FOREACH hour IN [0..23];
                            SET hour_24 = hour < 10 ? '0' _ hour : hour;
                            IF hour == 0;
                                SET hour_12 = 12; SET period = 'AM';
                            ELSIF hour < 12;
                                SET hour_12 = hour; SET period = 'AM';
                            ELSIF hour == 12;
                                SET hour_12 = 12; SET period = 'PM';
                            ELSE;
                                SET hour_12 = hour - 12; SET period = 'PM';
                            END;
                            FOREACH minute IN ['00', '30'];
                                SET time_value_24 = hour_24 _ ':' _ minute;
                                SET time_display  = hour_12 _ ':' _ minute _ ' ' _ period;
                    %]
                    <option value="[% time_value_24 %]:00" [% IF current_time_short == time_value_24 %]selected[% END %]>[% time_display %]</option>
                    [%
                            END;
                        END;
                    %]
                </select>
            </td></tr>
        <tr><td><label>Status:</label></td>
            <td>
                <select name="status">
                    <option value="1" [% IF current_status == 1 %]selected[% END %]>New</option>
                    <option value="2" [% IF current_status == 2 %]selected[% END %]>In Progress</option>
                    <option value="3" [% IF current_status == 3 %]selected[% END %]>Done</option>
                    <option value="4" [% IF current_status == 4 %]selected[% END %]>Cancelled</option>
                </select>
            </td></tr>
        <tr><td><label>Priority:</label></td>
            <td>
                <select name="priority">
                    [% INCLUDE "todo/priority_select.tt" %]
                </select>
            </td></tr>
        <tr><td><label>Est. Hours:</label></td>
            <td><input type="number" name="estimated_man_hours" value="[% record.get_column('estimated_man_hours') %]" size="6"></td></tr>
        <tr><td><label>Accumulated Time:</label></td>
            <td><input type="text" name="accumulative_time" value="[% accumulative_time | html %]" size="10" placeholder="HH:MM">
                <small style="color:#888;">(auto-calculated from logs; override if needed)</small></td></tr>
        <tr><td><label>Group:</label></td>
            <td><input type="text" name="group_of_poster" value="[% record.get_column('group_of_poster') | html %]"></td></tr>
        <tr><td><label>Project:</label></td>
            <td>
                [% INCLUDE "todo/project_list.tt" projects=projects selected_project_id=record.get_column('project_id') field_name='project_id' %]
            </td></tr>
    </table>

    <br>
    <input type="submit" value="Save Changes" class="btn btn-primary">
    <a href="[% c.uri_for('/todo/details', { record_id => record.get_column('record_id') }) %]" class="btn btn-default">Cancel</a>
</form>

[% ELSE %]

[% IF error_source && (error_source.server || error_source.branch || error_source.file) %]
<div style="background:#fff3cd;border:2px solid #ffc107;border-radius:6px;padding:12px 16px;margin-bottom:16px">
  <strong style="font-size:1.1em;color:#856404">⚠ Error Source</strong>
  <table style="margin-top:8px;border-collapse:collapse;font-size:0.9em">
    [% IF error_source.server %]
    <tr><td style="padding:2px 12px 2px 0;font-weight:bold;white-space:nowrap">🖥 Server:</td>
        <td style="font-family:monospace">[% error_source.server | html %]</td></tr>
    [% END %]
    [% IF error_source.branch %]
    <tr><td style="padding:2px 12px 2px 0;font-weight:bold;white-space:nowrap">🌿 Branch:</td>
        <td style="font-family:monospace">[% error_source.branch | html %]</td></tr>
    [% END %]
    [% IF error_source.file %]
    <tr><td style="padding:2px 12px 2px 0;font-weight:bold;white-space:nowrap">📄 File:</td>
        <td style="font-family:monospace">[% error_source.file | html %]</td></tr>
    [% END %]
    [% IF error_source.function %]
    <tr><td style="padding:2px 12px 2px 0;font-weight:bold;white-space:nowrap">⚙ Function:</td>
        <td style="font-family:monospace">[% error_source.function | html %]</td></tr>
    [% END %]
  </table>
</div>
[% END %]

<table border="0" cellpadding="6" style="width:100%;max-width:800px">
    <tr><th align="left" width="180">Record ID</th>
        <td>[% record.get_column('record_id') %]</td></tr>
    <tr><th align="left">Site</th>
        <td>[% record.get_column('sitename') | html %]</td></tr>
    <tr><th align="left">Subject</th>
        <td><strong>[% record.get_column('subject') | html %]</strong></td></tr>
    <tr><th align="left">Description</th>
        <td style="white-space:pre-wrap">[% record.get_column('description') | html %]</td></tr>
    <tr><th align="left">Status</th>
        <td>[% record.get_column('status') | html %]</td></tr>
    <tr><th align="left">Priority</th>
        <td>[% record.get_column('priority') %]</td></tr>
    <tr><th align="left">Start Date</th>
        <td>[% record.get_column('start_date') %]</td></tr>
    <tr><th align="left">Due Date</th>
        <td>[% record.get_column('due_date') %]</td></tr>
    <tr><th align="left">Time of Day</th>
        <td>[% record.get_column('time_of_day') %]</td></tr>
    <tr><th align="left">Est. Minutes</th>
        <td>[% record.get_column('estimated_man_hours') %]</td></tr>
    <tr><th align="left">Accumulated Time</th>
        <td>[% accumulative_time %]</td></tr>
    <tr><th align="left">Type</th>
        <td>[% SET _dt = record.get_column('todo_type') || 'task' %]
            [% IF _dt == 'appointment' %]📌 Appointment
            [% ELSIF _dt == 'meeting' %]🤝 Meeting
            [% ELSIF _dt == 'event' %]🎂 Event
            [% ELSIF _dt == 'reminder' %]🔔 Reminder
            [% ELSE %]Task[% END %]</td></tr>
    <tr><th align="left">Recurring</th>
        <td>[% IF record.get_column('is_recurring') %]🔁 Yes
            [% SET _rr = record.get_column('recurrence_rule') || '' %]
            [% IF _rr == 'daily' %]— Every Day
            [% ELSIF _rr == 'weekdays' %]— Weekdays (Mon–Fri)
            [% ELSIF _rr == 'weekly' %]— Every Week
            [% ELSIF _rr == 'biweekly' %]— Every Two Weeks
            [% ELSIF _rr == 'monthly' %]— Every Month
            [% ELSIF _rr == 'yearly' %]— Every Year
            [% ELSIF _rr %]— [% _rr %]
            [% END %]
            [% ELSE %]No[% END %]</td></tr>
    [% IF record.get_column('creator_timezone') %]
    <tr><th align="left">Creator Timezone</th>
        <td>[% record.get_column('creator_timezone') %]</td></tr>
    [% END %]
    [% IF record.get_column('scheduled_start') %]
    <tr><th align="left">Scheduled Start</th>
        <td>[% record.get_column('scheduled_start') %]</td></tr>
    [% END %]
    [% IF record.get_column('scheduled_end') %]
    <tr><th align="left">Scheduled End</th>
        <td>[% record.get_column('scheduled_end') %]</td></tr>
    [% END %]
    <tr><th align="left">Project ID</th>
        <td>[% record.get_column('project_id') || '—' %]</td></tr>
    <tr><th align="left">Group</th>
        <td>[% record.get_column('group_of_poster') | html %]</td></tr>
    <tr><th align="left">Posted By</th>
        <td>[% record.get_column('username_of_poster') | html %]</td></tr>
    <tr><th align="left">Last Modified By</th>
        <td>[% record.get_column('last_mod_by') | html %]</td></tr>
    <tr><th align="left">Last Modified Date</th>
        <td>[% record.get_column('last_mod_date') %]</td></tr>
    <tr><th align="left">Date Posted</th>
        <td>[% record.get_column('date_time_posted') %]</td></tr>
    [% IF record.get_column('comments') %]
    <tr><th align="left">Comments</th>
        <td style="white-space:pre-wrap">[% record.get_column('comments') | html %]</td></tr>
    [% END %]
</table>

[% END %]

[% SET det_rid    = record.get_column('record_id') %]
[% SET det_status = record.get_column('status') %]
[% SET det_is_done   = (det_status == 3 OR det_status == 4) %]
[% SET det_is_active = (det_status == 5 OR active_todos.$det_rid) %]

<div class="action-buttons" style="margin-top:16px;display:flex;flex-wrap:wrap;align-items:center;gap:8px;">
    <form action="/log/log_form" method="POST" target="_blank" style="display:inline;margin:0">
        <input type="hidden" name="todo_record_id" value="[% det_rid %]">
        <input type="hidden" name="site_name"      value="[% record.get_column('sitename') %]">
        <input type="hidden" name="start_date"     value="[% record.get_column('start_date') %]">
        <input type="hidden" name="due_date"       value="[% record.get_column('due_date') %]">
        <input type="hidden" name="abstract"       value="[% record.get_column('subject') %]">
        <input type="hidden" name="details"        value="[% record.get_column('description') %]">
        <input type="hidden" name="priority"       value="[% record.get_column('priority') %]">
        <input type="hidden" name="status"         value="[% det_status %]">
        <input type="hidden" name="comments"       value="[% record.get_column('comments') %]">
        <button type="submit" class="btn btn-secondary" title="Open manual log entry form">📝 Log</button>
    </form>

    [% IF is_admin && !det_is_done %]
      [% IF det_is_active %]
      <button id="det-active-btn" onclick="detCloseLog([% det_rid %])"
          style="padding:5px 14px;border:1px solid #fd7e14;border-radius:4px;background:#fd7e14;color:#fff;cursor:pointer;font-size:0.9em;"
          title="Session active — click to close log with notes (todo stays in-progress for next session)">⏸ Active</button>
      [% ELSE %]
      <button id="det-start-btn" onclick="detStartWork([% det_rid %])"
          style="padding:5px 14px;border:1px solid #0d6efd;border-radius:4px;background:transparent;color:#0d6efd;cursor:pointer;font-size:0.9em;"
          title="Start working — creates a log entry, marks todo active on all servers">▶ Start</button>
      [% END %]
      <button id="det-done-btn" onclick="detDoneWithLog([% det_rid %],[% det_is_active ? 1 : 0 %])"
          style="padding:5px 14px;border:1px solid #28a745;border-radius:4px;background:transparent;color:#28a745;cursor:pointer;font-size:0.9em;"
          title="[% det_is_active ? 'Close log and mark todo done' : 'Mark done — will ask for duration if no active session' %]">✓ Done</button>
    [% END %]
</div>

<script>
function detStartWork(recordId) {
    var btn = document.getElementById('det-start-btn');
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    fetch('/todo/open_log', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ record_id: recordId })
    }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok || (d.error && d.error.indexOf('already open') !== -1)) {
            if (btn) {
                btn.id = 'det-active-btn';
                btn.textContent = '⏸ Active';
                btn.style.background = '#fd7e14';
                btn.style.color = '#fff';
                btn.style.borderColor = '#fd7e14';
                btn.title = 'Session active — click to close log with notes (todo stays in-progress for next session)';
                btn.onclick = function() { detCloseLog(recordId); };
                btn.disabled = false;
            }
            var doneBtn = document.getElementById('det-done-btn');
            if (doneBtn) { doneBtn.title = 'Close log and mark todo done'; doneBtn.onclick = function() { detDoneWithLog(recordId, 1); }; }
        } else {
            if (btn) { btn.disabled = false; btn.textContent = '▶ Start'; }
            alert('Could not start: ' + (d.error || 'unknown error'));
        }
    }).catch(function(e) {
        if (btn) { btn.disabled = false; btn.textContent = '▶ Start'; }
        alert('Error: ' + e);
    });
}

function detCloseLog(recordId) {
    var btn = document.getElementById('det-active-btn');
    var notes = prompt('Close session — brief notes on what was done (optional):\n(todo stays in-progress; click Start again for next session)');
    if (notes === null) return;
    if (btn) { btn.disabled = true; btn.textContent = '…'; }
    fetch('/todo/close_log', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ record_id: recordId, notes: notes || '' })
    }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok) {
            if (btn) {
                btn.id = 'det-start-btn';
                btn.textContent = '▶ Start';
                btn.style.background = 'transparent';
                btn.style.color = '#0d6efd';
                btn.style.borderColor = '#0d6efd';
                btn.title = 'Start working — creates a log entry, marks todo active on all servers';
                btn.onclick = function() { detStartWork(recordId); };
                btn.disabled = false;
            }
            var doneBtn = document.getElementById('det-done-btn');
            if (doneBtn) { doneBtn.title = 'Mark done — will ask for duration if no active session'; doneBtn.onclick = function() { detDoneWithLog(recordId, 0); }; }
        } else {
            if (btn) { btn.disabled = false; btn.textContent = '⏸ Active'; }
            alert('Could not close log: ' + (d.error || 'unknown'));
        }
    }).catch(function(e) {
        if (btn) { btn.disabled = false; btn.textContent = '⏸ Active'; }
        alert('Error: ' + e);
    });
}

function detDoneWithLog(recordId, isActive) {
    var notes = prompt('Mark todo DONE — what was done / resolution notes (optional):');
    if (notes === null) return;
    var payload = { record_id: recordId, notes: notes || '' };
    if (!isActive) {
        var durStr = prompt('No active log session.\nHow many minutes did this take? (leave blank to skip log)');
        if (durStr === null) return;
        var durMins = parseInt(durStr, 10);
        if (!isNaN(durMins) && durMins > 0) { payload.duration_mins = durMins; }
    }
    var doneBtn = document.getElementById('det-done-btn');
    if (doneBtn) { doneBtn.disabled = true; doneBtn.textContent = '…'; }
    fetch('/todo/done_with_log', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok) {
            if (doneBtn) { doneBtn.textContent = '✓ Done'; doneBtn.disabled = true; doneBtn.style.background = '#28a745'; doneBtn.style.color = '#fff'; }
            var startBtn = document.getElementById('det-start-btn') || document.getElementById('det-active-btn');
            if (startBtn) { startBtn.style.display = 'none'; }
            var statusCell = document.querySelector('tr th[align="left"] + td');
            document.querySelectorAll('table tr').forEach(function(tr) {
                if (tr.querySelector('th') && tr.querySelector('th').textContent.trim() === 'Status') {
                    tr.querySelector('td').textContent = '3';
                }
            });
        } else {
            if (doneBtn) { doneBtn.disabled = false; doneBtn.textContent = '✓ Done'; }
            alert('Could not mark done: ' + (d.error || 'unknown'));
        }
    }).catch(function(e) {
        if (doneBtn) { doneBtn.disabled = false; doneBtn.textContent = '✓ Done'; }
        alert('Error: ' + e);
    });
}
</script>

[% IF todo_intervals && todo_intervals.size %]
<div class="reschedule-log" style="margin-top:20px">
    <h3>Rescheduling History</h3>
    <table border="1" cellpadding="4">
        <thead>
            <tr><th>#</th><th>Type</th><th>Change</th><th>Held From</th><th>Moved On</th><th>By</th></tr>
        </thead>
        <tbody>
        [% FOREACH interval IN todo_intervals %]
            <tr>
                <td>[% interval.record_id %]</td>
                <td>[% interval.interval_type %]</td>
                <td>[% interval.status %]</td>
                <td>[% interval.start_date || '—' %]</td>
                <td>[% interval.end_date   || '—' %]</td>
                <td>[% interval.last_mod_by %]</td>
            </tr>
        [% END %]
        </tbody>
    </table>
</div>
[% END %]

[% SET task_id = record.get_column('record_id') %]
[% SET task_subject     = record.get_column('subject')     | html %]
[% SET task_description = record.get_column('description') | html %]
[% SET task_status      = record.get_column('status')          %]
[% SET task_due_date    = record.get_column('due_date')         %]
[% SET task_project     = record.get_column('project_code') | html %]
<div class="ai-chat-activity-panel" style="margin-top:20px; border:1px solid var(--border-color, #ddd); border-radius:4px; padding:16px; background: var(--bg-secondary, #fafafa);">
    <h3 style="margin-top:0;">AI Chat Activity</h3>
    <div id="ai-task-conversations" data-task-id="[% task_id %]">
        <p style="color:#888; font-size:0.9em;">Loading conversations&hellip;</p>
    </div>
    <div style="margin-top:10px;">
        <button type="button" class="button button-primary" style="font-size:0.9em;"
            onclick="openAIChatWithTask({record_id:[% task_id %],subject:'[% task_subject | js %]',description:'[% task_description | js %]',status:[% task_status %],due_date:'[% task_due_date %]',project:'[% task_project | js %]'})">
            💬 Chat about this task
        </button>
        <a href="/todo/edit/[% task_id %]" class="button button-secondary" style="font-size:0.9em; margin-left:8px;">✏️ Edit this task</a>
        <a href="/ai/conversations?task_id=[% task_id %]" class="button button-secondary" style="font-size:0.9em; margin-left:8px;">View all conversations</a>
    </div>
</div>

<script>
(function() {
    var el = document.getElementById('ai-task-conversations');
    var taskId = el ? el.getAttribute('data-task-id') : null;
    if (!taskId) return;
    fetch('/ai/project_conversations?task_id=' + encodeURIComponent(taskId))
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (!d.success || !d.conversations || !d.conversations.length) {
                el.innerHTML = '<p style="color:#888;font-size:0.9em;">No AI conversations for this task yet.</p>';
                return;
            }
            var html = '<ul style="margin:0;padding-left:18px;">';
            d.conversations.forEach(function(c) {
                html += '<li><a href="/ai/conversation/' + c.id + '">' + (c.title || 'Untitled') + '</a>'
                      + ' <span style="color:#888;font-size:0.85em;">(' + (c.model || 'unknown') + ' &mdash; ' + c.updated_at + ')</span></li>';
            });
            html += '</ul>';
            el.innerHTML = html;
        })
        .catch(function() {
            el.innerHTML = '<p style="color:#888;font-size:0.9em;">Could not load conversations.</p>';
        });
})();
</script>

<div class="return-nav" style="margin-top:16px">
    <a href="/todo" class="return-button">Return to List View</a>
    <a href="/todo/day" class="return-button">Return to Day View</a>
    <button type="button" class="return-button" onclick="window.history.back();">Return to Previous Page</button>
</div>
