   <label for="sitename">[% label_text || 'Site Name' %]:</label><br>
    <select id="sitename" name="sitename" required>
        [% FOREACH site IN sites %]
            <option value="[% site.name %]" [% IF site.name == form_data.sitename OR site.name == project.sitename OR site.name == session.SiteName %]selected[% END %]>[% site.name %]</option>
        [% END %]
    </select>