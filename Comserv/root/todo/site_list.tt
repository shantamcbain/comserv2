<label for="sitename">[% label_text || 'Site Name' %]:</label>
    <select id="sitename" name="sitename" required>
        [% SET sn_sel = selected_sitename || todo_sitename || form_data.sitename || project.sitename || SiteName %]
        [% FOREACH site IN sites %]
            <option value="[% site.name %]" [% IF site.name == sn_sel %]selected[% END %]>[% site.name %]</option>
        [% END %]
    </select>