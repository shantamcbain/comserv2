[% META title = 'Error' %]

<div class="container mt-4">
    <div class="alert alert-danger">
        <h4>Error</h4>
        <p>[% error_msg | html %]</p>
    </div>
    <a href="javascript:history.back()" class="btn btn-secondary">Go Back</a>
    <a href="/" class="btn btn-primary ml-2">Home</a>
</div>
