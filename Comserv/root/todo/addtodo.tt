[% PageVersion = 'addtodo.tt,v 0.08 2026/02/08 Shanta - Added current time default and fixed selection logic' %]
[% IF debug_mode == 1 %]
    Version: [% PageVersion %]
[% END %]

<style>
    /* Form styling */
    form div {
        margin-bottom: 15px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
    }

    input[type="text"],
    input[type="number"],
    select {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
    }

    input[type="date"] {
        width: 200px;
        max-width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
    }

    input[type="submit"] {
        background-color: #4CAF50;
        color: white;
        padding: 10px 15px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: bold;
    }

    input[type="submit"]:hover {
        background-color: #45a049;
    }

    /* Textarea styling */
    textarea {
        width: 100%;
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 4px;
        box-sizing: border-box;
        min-height: 60px;
        resize: vertical;
    }

    /* Form container */
    form {
        max-width: 600px;
        margin: 0 auto;
    }

    /* Responsive design for smaller screens */
    @media (max-width: 768px) {
        input[type="date"] {
            width: 100%;
        }
        
        form {
            max-width: 100%;
            margin: 0;
            padding: 0 10px;
        }
    }
</style>

<h1>Add a New To-do Item</h1>

<form action="/todo/create" method="post">
    <input type="hidden" name="return_to" value="[% return_to %]">
    <!-- record_id is auto-increment, no need for manual input -->
    <div>
        <label for="sitename">Site Name:</label>
        <input type="text" id="sitename" name="sitename" value="[% SiteName OR 'Site Name' %]" readonly>
    </div>
    <div>
        <label for="start_date">Start Date:</label>
        <input type="date" id="start_date" name="start_date" value="[% start_date OR '' %]">
    </div>
    <div>
        <label for="project_id">Select Project:</label>
          [% INCLUDE "todo/project_list.tt" projects=projects selected_project_id=current_project.id field_name='project_id' %]<br>
    </div>

    <div>
        <label for="manual_project_id">Manual Project ID:</label>
        <input type="text" id="manual_project_id" name="manual_project_id" value="[% project_id OR '' %]" placeholder="Enter numeric project ID if you know it, otherwise leave blank">
        <small style="color: #666; font-size: 0.9em; display: block; margin-top: 2px;">
            Only use this field if you know the exact numeric project ID. Otherwise, use the dropdown above.
        </small>
    </div>
    <div>
        <label for="due_date">Due Date:</label>
        <input type="date" id="due_date" name="due_date" value="[% todo.due_date OR '' %]">
    </div>
    <div>
        <label for="time_of_day">Time of Day:</label>
        <select id="time_of_day" name="time_of_day">
            <option value="">-- Select Time --</option>
            [% 
                USE date;
                IF time_of_day;
                    SET default_time = time_of_day;
                ELSE;
                    # Default to current system time
                    SET default_time = date.format(date.now, '%H:%M');
                END;
                
                FOREACH hour IN [0..23];
                    SET hour_24 = hour < 10 ? '0' _ hour : hour;
                    
                    # Convert to 12-hour format
                    IF hour == 0;
                        SET hour_12 = 12;
                        SET period = 'AM';
                    ELSIF hour < 12;
                        SET hour_12 = hour;
                        SET period = 'AM';
                    ELSIF hour == 12;
                        SET hour_12 = 12;
                        SET period = 'PM';
                    ELSE;
                        SET hour_12 = hour - 12;
                        SET period = 'PM';
                    END;
                    
                    FOREACH minute IN ['00', '30'];
                        SET time_value_24 = hour_24 _ ':' _ minute;
                        SET time_display = hour_12 _ ':' _ minute _ ' ' _ period;
            %]
            <option value="[% time_value_24 %]:00" [% IF default_time == time_value_24 %]selected[% END %]>[% time_display %]</option>
            [%
                    END;
                END;
            %]
        </select>
    </div>
    <div>
        <label for="subject">Subject:</label>
        <input type="text" id="subject" name="subject" value="[% todo.subject OR '' %]">
    </div>
    <div>
        <label for="description">Description:</label>
        <textarea id="description" name="description">[% todo.description OR '' %]</textarea>
    </div>
    <div>
        <label for="estimated_man_hours">Estimated Man Hours:</label>
        <select id="estimated_man_hours" name="estimated_man_hours">
        [% FOREACH hour IN [1..24] %]
        <option value="[% hour %]" [% IF hour == todo.estimated_man_hours %]selected[% END %]>[% hour %]</option>
        [% END %]
        </select>
    </div>
    <div>
        <label for="accumulative_time">Accumulative Time:</label>
        <input type="number" id="accumulative_time" name="accumulative_time" value="[% todo.accumulative_time OR '' %]">
    </div>
    <div>
        <label for="status">Status:</label>
        [% SET sel_status = todo.status || default_status || 1 %]
        <select id="status" name="status" class="form-select">
            <option value="1" [% IF sel_status == 'NEW' || sel_status == 1 %]selected[% END %]>NEW</option>
            <option value="2" [% IF sel_status == 'IN PROGRESS' || sel_status == 2 %]selected[% END %]>IN PROGRESS</option>
            <option value="3" [% IF sel_status == 'DONE' || sel_status == 3 %]selected[% END %]>DONE</option>
        </select>
    </div>
    <div>
        <label for="priority">Priority:</label>
        <select id="priority" name="priority" class="form-select">
        [% FOREACH key IN build_priority.keys.sort %]
        <option value="[% key %]" [% IF key == todo.priority %]selected[% END %]>[% build_priority.$key %]</option>
        [% END %]
        </select>
    </div>
    <div>
        <label for="share">Share:</label>
        <select id="share" name="share" class="form-select">
            <option value="0" [% IF todo.share == 'public' %]selected[% END %]>Public</option>
            <option value="1" [% IF todo.share == 'private' %]selected[% END %]>Private</option>
        </select>
    </div>
    <div>
        <label for="last_mod_by">Last Modified By:</label>
        <input type="text" id="last_mod_by" name="last_mod_by" value="[% todo.last_mod_by OR '' %]">
    </div>
    <div>
        <label for="last_mod_date">Last Modified Date:</label>
        <input type="date" id="last_mod_date" name="last_mod_date" value="[% todo.last_mod_date OR '' %]">
    </div>
    <div>
        <label for="user_id">User ID:</label>
        <select id="user_id" name="user_id" class="form-select">
        [% FOREACH user IN users %]
        <option value="[% user.id %]" [% IF user.id == user_id %]selected[% END %]>[% user.username %]</option>
        [% END %]
        </select>
    </div>
    <div>
        <input type="submit" value="Add Todo" class="btn btn-primary">
    </div>
</form>
