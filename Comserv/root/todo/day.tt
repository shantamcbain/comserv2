
[% PageVersion = 'todo/day.tt, v  0.12 2026/02/09 shanta Exp shanta - Made overdue todos draggable with drag handles for week/month view rescheduling. Added data attributes and todo-item-shared class.' %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]

[% # Context-aware detection: Adjust behavior if included in DailyPlan or Planning documentation
   # OR when included from week.tt/month.tt (include_mode parameter)
   IF template.name.match('DailyPlan.tt') OR template.name.match('Planning.tt') OR (c.req.path AND c.req.path.match('DailyPlan')) OR (c.req.path AND c.req.path.match('planning/daily'));
      is_daily_plan = 1;
      IF c.req.path AND c.req.path.match('planning/daily');
         base_url = '/planning/daily';
      ELSE;
         base_url = '/Documentation/DailyPlan';
      END;
      day_hash     = '#daily-schedule';
      planning_hash = '#planning';
      week_hash = '#weekly-view';
      month_hash = '#month-view';
   ELSE;
      base_url = '/todo/day';
      planning_hash = '';
      week_hash = '';
      month_hash = '';
   END;
   
   # When included as a component (from week.tt or month.tt), hide navigation
   IF !include_mode.defined;
      include_mode = 0;
   END;
   
   # Normalize variables from different controllers (Todo.pm vs Documentation.pm)
   IF !date AND selected_date;
      date = selected_date;
   ELSIF !date;
      date = c.request.params.date || today || '2026-02-01'; # Fallback to today
   END;
   
   # When todos_for_today is pre-computed (Planning.pm standalone path), use it directly.
   # ONLY when NOT included from week.tt/month.tt (include_mode==0), to prevent stash leak.
   IF !include_mode AND todos_for_today.size > 0;
      todos = todos_for_today;
   ELSIF !include_mode AND !todos AND todos_for_today;
      todos = todos_for_today;
   END;

   # Ensure overdue_todos is defined as an array
   IF !overdue_todos;
      overdue_todos = [];
   END;

   # If todos_for_today was NOT pre-computed (old Documentation.pm path), do TT2 filtering.
   IF is_daily_plan AND !include_mode AND !(todos_for_today.size > 0);
       SET temp_today_todos = [];
       SET temp_overdue_todos = [];
       
       SET fdn = date.replace('-', '');
       FOREACH todo IN todos;
           NEXT IF todo.status == 3;
           SET fsd = todo.start_date _ '';
           SET fdd = todo.due_date   _ '';
           SET fst = fsd ? fsd.substr(0, 10).replace('-', '') : 0;
           SET fdu = fdd ? fdd.substr(0, 10).replace('-', '') : 0;
           IF fst AND fst < fdn;
               temp_overdue_todos.push(todo);
           ELSIF (fst AND fst == fdn) OR (!fst AND fdu AND fdu == fdn);
               temp_today_todos.push(todo);
           END;
       END;

       todos = temp_today_todos;
       
       IF temp_overdue_todos.size > 0;
           overdue_todos = temp_overdue_todos;
       END;
   END;

   IF !previous_date AND prev_date;
      previous_date = prev_date;
   END;
   IF !next_date AND next_day;
      next_date = next_day;
   END;
%]

[% UNLESS include_mode %]
<link rel="stylesheet" type="text/css" href="/static/css/week_view.css">
<link rel="stylesheet" type="text/css" href="/static/css/components/tables.css">
