[% META
   title = "Customer List"
   description = "All customers derived from orders and invoices"
   roles = "admin"
   TemplateType = "Application"
   category = "CustomerOrder"
   page_version = "0.02"
   last_updated = "2026-04-22"
%]
[% PageVersion = 'CustomerOrder/customers.tt,v 0.02 2026/04/22 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<div class="app-container">
  <div class="page-header">
    <h1><i class="fas fa-users"></i> Customers &mdash; [% sitename | html %]</h1>
  </div>

  <div class="content-container">
    <div class="content-primary">

      <div class="form-actions">
        <a href="/CustomerOrder" class="btn btn-secondary"><i class="fas fa-list"></i> Orders</a>
        <a href="/Cart/orders" class="btn btn-secondary"><i class="fas fa-receipt"></i> Invoices</a>
        <a href="/admin" class="btn btn-secondary"><i class="fas fa-tachometer-alt"></i> Admin</a>
      </div>

      [% IF customers.size %]
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Orders</th>
              <th>Invoices</th>
              <th>Total Spend</th>
              <th>Last Activity</th>
              <th class="action-cell"></th>
            </tr>
          </thead>
          <tbody>
          [% FOREACH cust IN customers %]
          <tr>
            <td><strong>[% cust.name | html %]</strong></td>
            <td>
              [% IF cust.email %]<a href="mailto:[% cust.email | html %]">[% cust.email | html %]</a>[% ELSE %]&mdash;[% END %]
            </td>
            <td>[% cust.phone || '&mdash;' | html %]</td>
            <td>
              [% IF cust.order_count > 0 %]
                <span class="badge badge-info">[% cust.order_count %]</span>
              [% ELSE %]&mdash;[% END %]
            </td>
            <td>
              [% IF cust.invoice_count > 0 %]
                <span class="badge badge-success">[% cust.invoice_count %]</span>
              [% ELSE %]&mdash;[% END %]
            </td>
            <td>
              [% IF cust.total_spend > 0 %]$[% cust.total_spend | format('%.2f') %][% ELSE %]&mdash;[% END %]
            </td>
            <td class="text-muted">[% cust.last_seen %]</td>
            <td class="action-cell">
              [% SET q = cust.email ? ('?email=' _ cust.email) : ('?name=' _ cust.name) %]
              <a href="/CustomerOrder/customer[% q | html %]" class="btn btn-sm btn-primary">View</a>
            </td>
          </tr>
          [% END %]
          </tbody>
        </table>
      </div>
      [% ELSE %]
      <div class="empty-state">
        <p>No customers found yet. Orders and invoices will appear here as they come in.</p>
      </div>
      [% END %]

    </div>
  </div>
</div>
