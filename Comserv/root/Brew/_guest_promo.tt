[%# Guest / member promo — what this Brew feature offers. %]
<div class="content-section brew-guest-promo">
    <h3><i class="fas fa-beer"></i> What [% brew_feature.title | html %] does for you</h3>
    <p class="text-muted">[% brew_feature.subtitle | html %]</p>
    <ul class="sidebar-list">
        [% FOREACH line IN brew_feature.guest_bullets %]
        <li>[% line | html %]</li>
        [% END %]
    </ul>
    [% UNLESS c.session.username %]
    <p><a href="[% c.uri_for('/login') %]" class="btn btn-primary">Sign in</a> to manage your brewhouse when this feature launches.</p>
    [% END %]
    [% IF brew_feature.plan_links && c.stash.can_plan %]
    <div class="form-actions">
        <a href="[% c.uri_for('/planning/daily') %]#month-view" class="btn btn-primary">Open Planning calendar</a>
    </div>
    [% END %]
</div>