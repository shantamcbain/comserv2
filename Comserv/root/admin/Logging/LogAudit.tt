[%
   title = "Log Audit & Health Dashboard"
   description = "Audit system_log table, view health alerts, and prune old records"
   roles = "admin"
   TemplateType = "Application"
   category = "Admin"
   page_version = "0.02"
   last_updated = "2026-03-13"
%]
[% PageVersion = 'admin/Logging/LogAudit.tt,v 0.02 2026/03/13 Zencoder Exp Zencoder' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<style>
.page-header-actions  { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; }
.stats-row            { display:flex; gap:30px; flex-wrap:wrap; }
.alert-warning-box    { padding:10px; background:#fff3cd; border:1px solid #ffc107; border-radius:4px; margin-bottom:15px; }
.prune-form-row       { display:flex; flex-wrap:wrap; gap:15px; margin-bottom:15px; }
.prune-input          { width:100px; }
.prune-note           { margin-left:10px; color: var(--text-muted-color, #666); }
.stat-large           { font-size:2em; font-weight:bold; }
.lookback-form        { margin-bottom:10px; }
.prune-eligible       { color:orange; }
.prune-total-val      { color:red; }
.table-foot-bold      { font-weight:bold; }
.form-inline          { display:inline; }
.nowrap               { white-space:nowrap; }
.urgency-critical     { color:red; }
.urgency-high         { color:orange; }
.urgency-medium       { color:goldenrod; }
.urgency-low          { color:inherit; }
tr.level-debug        { color: var(--text-muted-color, #888); }
tr.level-info         { color:#000; }
tr.level-warn         { background:#fff8e1; }
tr.level-error        { background:#fdecea; }
tr.level-critical     { background:#f8d7da; font-weight:bold; }
.btn-sm               { padding:2px 8px; font-size:0.85em; }
.btn-danger           { background: var(--danger-color, #dc3545); color:#fff; border-color:#dc3545; }
.docker-grid          { display:flex; flex-wrap:wrap; gap:12px; margin-bottom:10px; }
.docker-card          { border:1px solid #ccc; border-radius:6px; padding:12px 16px; min-width:200px; flex:1; }
.docker-healthy       { border-color:#28a745; background:#f0fff4; }
.docker-unhealthy     { border-color:#dc3545; background:#fff5f5; }
.docker-none          { border-color:#6c757d; background: var(--bg-secondary, #f8f9fa); }
.docker-name          { font-weight:bold; font-size:1.05em; }
.docker-badge         { display:inline-block; padding:2px 8px; border-radius:10px; font-size:0.8em; font-weight:bold; }
.badge-healthy        { background: var(--success-color, #28a745); color:#fff; }
.badge-unhealthy      { background: var(--danger-color, #dc3545); color:#fff; }
.badge-none           { background: var(--secondary-color, #6c757d); color:#fff; }
.docker-detail        { font-size:0.85em; color: var(--text-color, #555); margin-top:4px; }
.docker-lastcheck     { font-size:0.78em; color: var(--text-muted-color, #888); margin-top:4px; font-style:italic; word-break:break-all; }
.stats-loading        { color: var(--text-muted-color, #888); font-style:italic; padding:20px 0; }
</style>

<div class="app-container">
    <div class="page-header page-header-actions">
        <h1>Log Audit &amp; Health Dashboard</h1>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
            <a href="[% c.uri_for('/admin') %]" class="btn btn-secondary" style="font-size:0.85em;">&larr; Admin</a>
            <a href="[% c.uri_for('/admin/logging') %]" class="btn btn-secondary" style="font-size:0.85em;">&larr; Logging</a>
            <a href="[% c.uri_for('/admin/logging/audit') %]" class="btn btn-secondary" style="font-size:0.85em;">&#x21BA; Clear Filter</a>
            <a href="[% c.uri_for('/planning/daily') %]" class="btn btn-secondary" style="font-size:0.85em;">&#x1F4C5; Daily Plan</a>
        </div>
    </div>

    <nav style="background:#f0f4f8;border:1px solid #c8d8e8;border-radius:4px;padding:6px 12px;margin-bottom:12px;display:flex;flex-wrap:wrap;gap:6px;align-items:center;font-size:0.88em;">
        <strong style="color:#333;margin-right:4px;">Jump to:</strong>
        <a href="#section-docker"   style="padding:3px 10px;background:#fff;border:1px solid #aac;border-radius:3px;text-decoration:none;color:#004085;white-space:nowrap;">&#x1F40B; Docker Health</a>
        [% IF recent_alerts && recent_alerts.size %]
        <a href="#alert-section"    style="padding:3px 10px;background:#f8d7da;border:1px solid #dc3545;border-radius:3px;text-decoration:none;color:#721c24;white-space:nowrap;font-weight:bold;">&#x1F6A8; Alerts ([% recent_alerts.size %])</a>
        [% ELSE %]
        <a href="#alert-section"    style="padding:3px 10px;background:#fff;border:1px solid #aac;border-radius:3px;text-decoration:none;color:#004085;white-space:nowrap;">&#x1F6A8; Alerts</a>
        [% END %]
        <a href="#section-servers"  style="padding:3px 10px;background:#fff;border:1px solid #aac;border-radius:3px;text-decoration:none;color:#004085;white-space:nowrap;">&#x1F5A5; Active Servers</a>
        <a href="#section-stats"    style="padding:3px 10px;background:#fff;border:1px solid #aac;border-radius:3px;text-decoration:none;color:#004085;white-space:nowrap;">&#x1F4CA; Audit Stats</a>
        <a href="#section-prune"    style="padding:3px 10px;background:#fff;border:1px solid #aac;border-radius:3px;text-decoration:none;color:#004085;white-space:nowrap;">&#x1F5D1; Prune Logs</a>
        <span style="color:#999;margin:0 4px;">|</span>
        [% IF filter_system || filter_level %]
        <a href="[% c.uri_for('/admin/logging/audit') %]" style="padding:3px 10px;background:#fff3cd;border:1px solid #ffc107;border-radius:3px;text-decoration:none;color:#856404;white-space:nowrap;">&#x21BA; Clear Filter</a>
        [% ELSE %]
        <a href="[% c.uri_for('/admin/logging/audit') %]" style="padding:3px 10px;background:#fff;border:1px solid #aac;border-radius:3px;text-decoration:none;color:#004085;white-space:nowrap;">&#x21BA; Reset</a>
        [% END %]
    </nav>

    [% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
    [% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]
    [% IF c.flash.info_msg %]<div class="info" style="padding:8px;background:#d1ecf1;border:1px solid #bee5eb;border-radius:4px;margin-bottom:10px">[% c.flash.info_msg | html %]</div>[% END %]
    [% IF page_error %]
    <div class="error"><strong>Notice:</strong> [% page_error | html %]
        Some sections below may be incomplete. The system administrator has been notified.</div>
    [% END %]

    <!-- ================================================================
         ALERT ENTRIES — shown when arriving via a health-alert link
         ================================================================ -->
    [% IF recent_alerts && recent_alerts.size %]
    <div id="alert-section" class="content-section" style="background:#f8d7da;border:2px solid #dc3545;border-radius:6px;padding:14px 18px;margin-bottom:16px;">
        <h2 style="color:#721c24;margin-top:0;">&#x1F6A8; Recent Alert Entries
            [% IF filter_system %]&nbsp;&mdash; <code>[% filter_system | html %]</code>[% END %]
            [% IF filter_level %]&nbsp;&mdash; Level: <code>[% filter_level | html %]</code>[% END %]
            <small style="font-size:0.7em;font-weight:normal;color:#856404;">(last 10 min, newest first — ERROR + CRITICAL)</small>
        </h2>
        <p style="color:#721c24;margin-top:0;font-size:0.9em;">
            These are the log entries that triggered the health alert notification.
            [% IF recent_alerts.size %]<strong>[% recent_alerts.size %] item(s)</strong> shown.[% END %]
        </p>
        <table style="width:100%;border-collapse:collapse;font-size:0.88em;">
            <thead>
                <tr style="background: var(--danger-color, #dc3545);color:#fff;">
                    <th style="padding:4px 8px;white-space:nowrap;">Time</th>
                    <th style="padding:4px 8px;white-space:nowrap;">Level</th>
                    <th style="padding:4px 8px;white-space:nowrap;">System</th>
                    <th style="padding:4px 8px;white-space:nowrap;">Subroutine</th>
                    <th style="padding:4px 8px;">Message</th>
                </tr>
            </thead>
            <tbody>
                [% FOR row IN recent_alerts %]
                [% lvl = row.level.upper %]
                <tr style="border-bottom:1px solid #f5c6cb;[% IF lvl == 'CRITICAL' %]background:#f5c6cb;font-weight:bold;[% ELSE %]background:#fff5f5;[% END %]">
                    <td style="padding:4px 8px;white-space:nowrap;">[% row.timestamp | html %]</td>
                    <td style="padding:4px 8px;white-space:nowrap;color:[% lvl == 'CRITICAL' ? '#721c24' : '#856404' %];font-weight:bold;">[% lvl | html %]</td>
                    <td style="padding:4px 8px;white-space:nowrap;font-size:0.85em;">[% row.system_identifier | html %]</td>
                    <td style="padding:4px 8px;white-space:nowrap;font-size:0.85em;font-family:monospace;">[% row.subroutine | html %]</td>
                    <td style="padding:4px 8px;word-break:break-word;">[% row.message | html %]</td>
                </tr>
                [% END %]
            </tbody>
        </table>
        [% IF recent_alerts.size >= 100 %]
        <p style="margin-top:8px;font-size:0.85em;color:#721c24;">Showing 100 most recent. Use the audit stats below for a broader view.</p>
        [% END %]
    </div>
    [% END %]

    <!-- ================================================================
         DOCKER CONTAINER HEALTH  (rendered first — no DB dependency)
         ================================================================ -->
    <div id="section-docker" class="content-section">
        <h2>Docker Container Health</h2>

        [%# Macro to render a single container card %]
        [% MACRO container_card(ct) BLOCK %]
            [% SET hclass = (ct.health == 'healthy') ? 'docker-healthy'
                          : (ct.health == 'unhealthy') ? 'docker-unhealthy'
                          : 'docker-none' %]
            [% SET bclass = (ct.health == 'healthy') ? 'badge-healthy'
                          : (ct.health == 'unhealthy') ? 'badge-unhealthy'
                          : 'badge-none' %]
            <div class="docker-card [% hclass %]">
                <div class="docker-name">[% ct.name | html %]
                    <span class="docker-badge [% bclass %]">[% ct.health | html %]</span>
                </div>
                [% IF ct.image %]
                <div class="docker-detail"><strong>Image:</strong> <code style="font-size:0.88em;">[% ct.image | html %]</code></div>
                [% END %]
                [% IF ct.build_info %]
                <div class="docker-detail" style="color:#28a745;font-size:0.82em;font-weight:bold;">&#x2714; Running LATEST image</div>
                [% END %]
                <div class="docker-detail">
                    [% IF ct.short_id %]<span style="color:#888;font-size:0.82em;font-family:monospace;">[% ct.short_id | html %]</span> | [% END %]
                    <strong>Status:</strong> [% ct.status_str | html %]
                </div>
                [% IF ct.ports %]
                <div class="docker-detail" style="font-size:0.82em;"><strong>Ports:</strong> [% ct.ports | html %]</div>
                [% END %]
                [% IF ct.build_info %]
                <div class="docker-detail" style="font-size:0.82em;color:#555;">
                    <strong>Build:</strong> [% ct.build_info.build_date | html %]
                    [% IF ct.build_info.commit %] | <strong>Commit:</strong> <code>[% ct.build_info.commit | html %]</code>[% END %]
                    [% IF ct.build_info.branch %] | <strong>Branch:</strong> [% ct.build_info.branch | html %][% END %]
                    [% IF ct.build_info.build_host %] | <strong>Built On:</strong> [% ct.build_info.build_host | html %][% END %]
                </div>
                [% END %]
                [% IF ct.last_output %]
                <div class="docker-lastcheck">Last check: [% ct.last_output | html %]</div>
                [% END %]
                [% IF ct.timestamp %]
                <div class="docker-lastcheck">Reported: [% ct.timestamp | html %]</div>
                [% END %]
            </div>
        [% END %]

        <!-- Local (this server) -->
        [% IF docker_health && docker_health.size %]
        <h3>This server ([% system_identifier || 'local' %])</h3>
        <div class="docker-grid">
            [% FOR ct IN docker_health %][% container_card(ct) %][% END %]
        </div>
        [% ELSE %]
        <p class="docker-detail">No comserv containers running locally on this server.</p>
        [% END %]

        <!-- Cross-server Docker health from shared system_log -->
        [% IF docker_sync_report && docker_sync_report.size %]
        <div style="margin:10px 0;padding:8px 12px;background:#f8f9fa;border:1px solid #dee2e6;border-radius:4px;font-size:0.88em;">
            <strong>Server-room sync (this page load):</strong>
            [% FOR r IN docker_sync_report %]
            <span style="margin-right:12px;">
                [% r.target | html %]:
                [% IF r.ok %][% r.containers %] container(s) recorded[% ELSE %]failed — [% r.error | html %][% END %]
            </span>
            [% END %]
            <span style="color:#666;">Requires SSH credentials in <code>~/.comserv/secrets/ssh_credentials.json</code> (same as Docker admin).</span>
        </div>
        [% END %]

        [% IF docker_health_db && docker_health_db.size %]
        <h3>All Servers — from system_log (last 2 hours)</h3>
        [% FOR srv IN docker_health_db %]
        <h4 style="margin:10px 0 4px">[% srv.system_identifier | html %]</h4>
        <div class="docker-grid">
            [% FOR ct IN srv.containers %][% container_card(ct) %][% END %]
        </div>
        [% END %]
        [% ELSE %]
        <p class="docker-detail"><em>No cross-server Docker data in system_log yet.
            Reload this page to sync from this host and production servers (192.168.1.126 / .127).
            Long-running dev servers also write every 5 min via <code>comserv_server.pl</code> health evaluator.</em></p>
        [% END %]

        <div style="margin-top:16px;padding:12px;background:#eef6ff;border:1px solid #b8daff;border-radius:4px;font-size:0.9em;">
            <strong>Admin code &amp; AI tools</strong> (CSC / developer):
            <a href="/ai/template_editor">Template / code editor</a> ·
            <a href="/admin/docker-containers">Docker containers</a> ·
            <a href="/ai">AI chat</a> (add Grok API key at <a href="/ai/manage_api_keys">manage API keys</a>).
            In-app AI and external agents (e.g. AI Code Editor) can edit the repo when run on the workstation with git access.
        </div>

    </div>

    <!-- ================================================================
         ACTIVE SERVERS — derived from system_log activity, no daemon needed
         ================================================================ -->
    [% IF active_servers && active_servers.size %]
    <div id="section-servers" class="content-section">
        <h2>Active Servers <small style="font-size:0.6em;font-weight:normal;color:#666;">(last 2 hours of system_log activity)</small></h2>
        <table style="width:100%;border-collapse:collapse;font-size:0.9em;">
            <thead>
                <tr style="background:#f5f5f5;text-align:left;">
                    <th style="padding:6px 10px;border:1px solid #ddd;">Server</th>
                    <th style="padding:6px 10px;border:1px solid #ddd;">Status</th>
                    <th style="padding:6px 10px;border:1px solid #ddd;">Last Seen</th>
                    <th style="padding:6px 10px;border:1px solid #ddd;">Log Entries</th>
                    <th style="padding:6px 10px;border:1px solid #ddd;">Errors</th>
                    <th style="padding:6px 10px;border:1px solid #ddd;">Warnings</th>
                    <th style="padding:6px 10px;border:1px solid #ddd;">Filter</th>
                </tr>
            </thead>
            <tbody>
            [% FOR srv IN active_servers %]
                [% SET st = srv.status %]
                [% SET row_bg = (st == 'active') ? '#f0fff4'
                              : (st == 'recent') ? '#fff8e1'
                              : (st == 'idle')   ? '#f8f9fa'
                              :                    '#fff5f5' %]
                [% SET badge_col = (st == 'active') ? '#28a745'
                                 : (st == 'recent') ? '#fd7e14'
                                 : (st == 'idle')   ? '#6c757d'
                                 :                    '#dc3545' %]
                <tr style="background:[% row_bg %];border-bottom:1px solid #eee;">
                    <td style="padding:6px 10px;border:1px solid #ddd;font-family:monospace;font-size:0.88em;">[% srv.system_identifier | html %]</td>
                    <td style="padding:6px 10px;border:1px solid #ddd;">
                        <span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:0.8em;font-weight:bold;background:[% badge_col %];color:#fff;">[% st | html %]</span>
                    </td>
                    <td style="padding:6px 10px;border:1px solid #ddd;white-space:nowrap;font-size:0.88em;">
                        [% srv.last_seen | html %]
                        [% IF srv.tz_offset %]<br><small style="color:#6c757d;" title="Timestamp is [% srv.tz_offset %] min ahead — server timezone differs from DB (likely UTC vs local)">⏱ UTC offset ~[% (srv.tz_offset / 60).int %]h</small>
                        [% ELSIF srv.minutes_ago == 0 %]<br><small style="color:#28a745;">just now</small>
                        [% ELSIF srv.minutes_ago < 60 %]<br><small style="color:#666;">[% srv.minutes_ago %] min ago</small>
                        [% ELSE %]<br><small style="color:#888;">[% srv.minutes_ago %] min ago</small>
                        [% END %]
                    </td>
                    <td style="padding:6px 10px;border:1px solid #ddd;text-align:right;">[% srv.total | html %]</td>
                    <td style="padding:6px 10px;border:1px solid #ddd;text-align:right;[% IF srv.errors > 0 %]color:#dc3545;font-weight:bold;[% END %]">[% srv.errors | html %]</td>
                    <td style="padding:6px 10px;border:1px solid #ddd;text-align:right;[% IF srv.warns > 0 %]color:#856404;[% END %]">[% srv.warns | html %]</td>
                    <td style="padding:6px 10px;border:1px solid #ddd;">
                        [% IF srv.errors > 0 %]
                        <a href="[% c.uri_for('/admin/logging/audit') %]?system=[% srv.system_identifier | uri %]&amp;level=ERROR" style="font-size:0.82em;color:#dc3545;">View errors</a>
                        [% ELSE %]
                        <a href="[% c.uri_for('/admin/logging/audit') %]?system=[% srv.system_identifier | uri %]" style="font-size:0.82em;color:#0d6efd;">View logs</a>
                        [% END %]
                    </td>
                </tr>
            [% END %]
            </tbody>
        </table>
    </div>
    [% END %]

    <!-- Active filter notice -->
    [% IF filter_system || filter_level %]
    <div class="content-section" style="background:#fff3cd;border:1px solid #ffc107;border-radius:4px;padding:10px 16px;">
        <strong>&#x1F50D; Filtered view</strong>
        [% IF filter_system %]&nbsp;&mdash; System: <code>[% filter_system | html %]</code>[% END %]
        [% IF filter_level %]&nbsp;&mdash; Level: <code>[% filter_level | html %]</code>[% END %]
        &nbsp;<a href="[% c.uri_for('/admin/logging/audit') %]" style="font-size:0.85em">&times; Clear filter</a>
    </div>
    [% END %]

    <!-- Look-back window selector -->
    <div class="content-section">
        <form method="get" action="[% c.uri_for('/admin/logging/audit') %]" class="lookback-form">
            [% IF filter_system %]<input type="hidden" name="system" value="[% filter_system | html %]">[% END %]
            [% IF filter_level  %]<input type="hidden" name="level"  value="[% filter_level  | html %]">[% END %]
            <label><strong>Look-back window:</strong></label>
            <select name="hours" onchange="this.form.submit()">
                [% FOR h IN [1, 6, 12, 24, 48, 168] %]
                    <option value="[% h %]" [% IF h == hours %]selected[% END %]>
                        [% IF h < 24 %][% h %] hour[% IF h > 1 %]s[% END %]
                        [% ELSIF h == 24 %]24 h (1 day)
                        [% ELSIF h == 48 %]48 h (2 days)
                        [% ELSE %]7 days
                        [% END %]
                    </option>
                [% END %]
            </select>
        </form>
    </div>

    <!-- Async-loaded audit statistics and health alerts -->
    <div id="section-stats"></div>
    <div id="audit-stats-container">
        <p class="stats-loading">&#8987; Loading audit statistics&hellip;</p>
    </div>

</div>

<script>
(function() {
    var hours = [% hours | html %];
    var url   = '[% c.uri_for('/admin/logging/audit/stats') %]?hours=' + hours
        [% IF filter_system %] + '&system=' + encodeURIComponent('[% filter_system | html %]')[% END %]
        [% IF filter_level  %] + '&level='  + encodeURIComponent('[% filter_level  | html %]')[% END %];

    // Auto-scroll to alert section when arriving via health-alert link
    [% IF recent_alerts && recent_alerts.size %]
    var alertSection = document.getElementById('alert-section');
    if (alertSection) { setTimeout(function() { alertSection.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 200); }
    [% END %]
    fetch(url, { credentials: 'same-origin', redirect: 'manual' })
        .then(function(r) {
            if (r.type === 'opaqueredirect' || r.status === 0 || (r.status >= 300 && r.status < 400)) {
                document.getElementById('audit-stats-container').innerHTML =
                    '<div class="error">Session expired — please <a href="/user/login?destination=[% c.req.uri | uri | html %]">log in again</a> to view audit statistics.</div>';
                return;
            }
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.text();
        })
        .then(function(html) {
            if (html !== undefined) {
                document.getElementById('audit-stats-container').innerHTML = html;
            }
        })
        .catch(function(err) {
            document.getElementById('audit-stats-container').innerHTML =
                '<div class="error">Could not load audit statistics: ' + err + '</div>';
        });
})();
</script>


