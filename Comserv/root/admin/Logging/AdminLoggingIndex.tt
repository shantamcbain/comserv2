[% META
   title = "Logging Administration"
   description = "Manage application logs and alerts"
   roles = "admin"
   TemplateType = "Application"
   category = "Admin"
   page_version = "0.01"
   last_updated = "2026-03-08"
%]
[% PageVersion = 'admin/Logging/AdminLoggingIndex.tt,v 0.01 2026/03/08 Zencoder Exp Zencoder' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">
    <div class="page-header">
        <h1>Logging Administration</h1>
    </div>

    [% IF error_msg %]<div class="error">[% error_msg | html %]</div>[% END %]
    [% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
    [% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

    <div class="content-container">
        <div class="content-primary">
            
            <div class="content-section">
                <h3>Current Configuration</h3>
                <div class="data-container">
                    <p><strong>NFS Log Directory:</strong> [% nfs_dir | html %]</p>
                    <p><strong>Alert Level (Email Notification):</strong> <span class="badge">[% email_threshold | html %]</span></p>
                    <div class="form-actions">
                        <a href="[% c.uri_for('/admin/logging/settings') %]" class="btn btn-secondary">Change Settings</a>
                        <form method="post" action="[% c.uri_for('/admin/logging/rotate') %]" style="display: inline;">
                            <button type="submit" class="btn btn-warning" onclick="return confirm('Are you sure you want to rotate the log file manually?')">Rotate Log Now</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="content-section">
                <h3>Database Logs (Recent 100)</h3>
                
                <div class="filter-container" style="margin-bottom: 20px; padding: 15px; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 4px;">
                    <form method="get" action="[% c.uri_for('/admin/logging') %]" class="form-inline">
                        <div style="display: flex; flex-wrap: wrap; gap: 15px; align-items: flex-end;">
                            <div class="form-group">
                                <label for="filter_level">Level:</label><br>
                                <select name="filter_level" id="filter_level" class="form-control">
                                    <option value="">-- All --</option>
                                    [% FOR level IN levels %]
                                        <option value="[% level %]" [% IF level == filter_level %]selected[% END %]>[% level %]</option>
                                    [% END %]
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="filter_sitename">Site:</label><br>
                                <input type="text" name="filter_sitename" id="filter_sitename" value="[% filter_sitename | html %]" class="form-control" placeholder="CSC">
                            </div>
                            <div class="form-group">
                                <label for="filter_username">User:</label><br>
                                <input type="text" name="filter_username" id="filter_username" value="[% filter_username | html %]" class="form-control" placeholder="username">
                            </div>
                            <div class="form-group">
                                <label for="search_text">Message Search:</label><br>
                                <input type="text" name="search_text" id="search_text" value="[% search_text | html %]" class="form-control" placeholder="Search message text...">
                            </div>
                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary">Filter</button>
                                <a href="[% c.uri_for('/admin/logging') %]" class="btn btn-secondary">Reset</a>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="table-container" style="max-height: 400px; overflow-y: auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Timestamp</th>
                                <th>Site</th>
                                <th>Level</th>
                                <th>User</th>
                                <th>Message</th>
                                <th>Location</th>
                            </tr>
                        </thead>
                        <tbody>
                            [% IF db_logs.size > 0 %]
                                [% FOR log IN db_logs %]
                                    <tr class="level-[% log.level | lower %]">
                                        <td style="white-space: nowrap;">[% log.timestamp | html %]</td>
                                        <td>[% log.sitename | html %]</td>
                                        <td><strong>[% log.level | html %]</strong></td>
                                        <td>[% log.username | html %]</td>
                                        <td>[% log.message | html %]</td>
                                        <td><small>[% log.file | html %]:[% log.line | html %]</small></td>
                                    </tr>
                                [% END %]
                            [% ELSE %]
                                <tr>
                                    <td colspan="6" class="empty-state">No logs found matching criteria.</td>
                                </tr>
                            [% END %]
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="content-section">
                <h3>Current Log File</h3>
                [% IF current_log.exists %]
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Path</th>
                                    <th>Size</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>[% current_log.path | html %]</td>
                                    <td>[% current_log.size | html %]</td>
                                    <td class="action-cell">
                                        <a href="[% c.uri_for('/admin/logging/view', { path => current_log.path }) %]" class="btn btn-sm btn-primary">View Content</a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                [% ELSE %]
                    <p class="empty-state">Current log file not found at [% current_log.path | html %].</p>
                [% END %]
            </div>

            <div class="content-section">
                <h3>Archived Logs</h3>
                [% IF archived_logs.size %]
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Filename</th>
                                    <th>Size</th>
                                    <th>Date Modified</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH log IN archived_logs %]
                                    <tr>
                                        <td>[% log.name | html %]</td>
                                        <td>[% log.size | html %]</td>
                                        <td>[% c.format_datetime(log.mtime) || log.mtime %]</td>
                                        <td class="action-cell">
                                            <a href="[% c.uri_for('/admin/logging/view', { path => log.path }) %]" class="btn btn-sm btn-secondary">View Content</a>
                                        </td>
                                    </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                [% ELSE %]
                    <p class="empty-state">No archived log files found.</p>
                [% END %]
            </div>

        </div>
    </div>
</div>
