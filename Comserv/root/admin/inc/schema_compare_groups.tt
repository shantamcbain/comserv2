[%# Shared partial: always show all three schema compare groups.
    Args: database_key, table_comparisons, results_without_tables, read_only (optional)
    NOTE: JS for this template's data-action attributes is expected in schema-compare.js.
          Add event delegation handlers for: toggle-group, toggle-comparison, sync-table,
          recreate-table-from-result, create-table-from-result, create-result-from-table
    JS convention: event delegation on document click, checking element.closest('[data-action=...]')
%]
[% SET read_only = read_only ? 1 : 0 %]
[% tables_with_results = [] %]
[% tables_without_results = [] %]
[% FOREACH table_comparison IN table_comparisons %]
    [% IF table_comparison.has_result_file %]
        [% tables_with_results.push(table_comparison) %]
    [% ELSE %]
        [% tables_without_results.push(table_comparison) %]
    [% END %]
[% END %]
[% results_without_tables = results_without_tables || [] %]

<!-- Group 1: Tables with Result files (always visible) -->
<div class="group-comparison-section">
    <div class="group-header" data-action="toggle-group">
        <span>
            <i class="fas fa-check-circle"></i> Tables with Result Files
            <span class="group-count">[% tables_with_results.size %]</span>
        </span>
        <i class="fas fa-chevron-right toggle-icon" data-action="toggle-group"></i>
    </div>
    <div class="group-content">
    [% IF tables_with_results.size > 0 %]
        [% FOREACH table_comparison IN tables_with_results %]
            <div class="table-comparison-card" data-table="[% table_comparison.table_name | html %]" data-database="[% database_key | html %]">
                <div class="comparison-header" data-action="toggle-comparison" data-table="[% table_comparison.table_name | html %]">
                    <div class="comparison-title">
                        <i class="fas fa-table"></i>
                        <h4>[% table_comparison.table_name | html %]</h4>
                        [% IF table_comparison.sync_status == 'synchronized' %]
                            <span class="difference-indicator same" title="Synchronized"></span>
                        [% ELSE %]
                            <span class="difference-indicator different" title="Needs sync"></span>
                        [% END %]
                    </div>
                    <div class="comparison-actions">
                        [% UNLESS read_only %]
                            [% IF table_comparison.sync_status == 'needs_sync' %]
                                <button class="sync-btn" data-action="sync-table"
                                        data-table="[% table_comparison.table_name | html %]"
                                        data-database="[% database_key | html %]">
                                    <i class="fas fa-sync"></i> Sync Fields
                                </button>
                                <button class="btn btn-sm btn-warning" data-action="recreate-table-from-result"
                                        data-result="[% table_comparison.result_name || table_comparison.table_name | html %]"
                                        data-database="[% database_key | html %]"
                                        title="Drop and recreate table from Result file (empty tables only)">
                                    <i class="fas fa-redo"></i> Recreate
                                </button>
                            [% END %]
                        [% END %]
                        <i class="fas fa-chevron-right expand-icon"></i>
                    </div>
                </div>
                <div class="comparison-detail">
                    <div class="loading-indicator">
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Loading field comparison...</span>
                    </div>
                </div>
            </div>
        [% END %]
    [% ELSE %]
        <p class="group-no-data"><i class="fas fa-info-circle"></i> No tables with matching Result files.</p>
    [% END %]
    </div>
</div>

<!-- Group 2: Result files without Tables (always visible) -->
<div class="group-comparison-section">
    <div class="group-header" data-action="toggle-group">
        <span>
            <i class="fas fa-file-alt"></i> Result Files without Tables
            <span class="group-count">[% results_without_tables.size %]</span>
        </span>
        <i class="fas fa-chevron-right toggle-icon"></i>
    </div>
    <div class="group-content">
    [% IF results_without_tables.size > 0 %]
        [% FOREACH result_file IN results_without_tables %]
            <div class="table-comparison-card" data-table="[% result_file.actual_table_name | html %]" data-database="[% database_key | html %]">
                <div class="comparison-header" data-action="toggle-comparison" data-table="[% result_file.actual_table_name | html %]">
                    <div class="comparison-title">
                        <i class="fas fa-file-alt"></i>
                        <h4>[% result_file.result_name | html %] (Result only)</h4>
                        <span class="difference-indicator missing" title="No corresponding table"></span>
                    </div>
                    <div class="comparison-actions">
                        [% UNLESS read_only %]
                            <button class="create-btn" data-action="create-table-from-result"
                                    data-result="[% result_file.result_name | html %]"
                                    data-database="[% database_key | html %]">
                                <i class="fas fa-plus"></i> Create Table
                            </button>
                        [% ELSE %]
                            <span class="read-only-badge" title="Migration target is read-only">Read-only</span>
                        [% END %]
                        <i class="fas fa-chevron-right expand-icon"></i>
                    </div>
                </div>
                <div class="comparison-detail">
                    <div class="loading-indicator">
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Loading result schema...</span>
                    </div>
                </div>
            </div>
        [% END %]
    [% ELSE %]
        <p class="group-no-data"><i class="fas fa-check"></i> Every Result file has a matching table.</p>
    [% END %]
    </div>
</div>

<!-- Group 3: Tables without Result files (always visible) -->
<div class="group-comparison-section">
    <div class="group-header" data-action="toggle-group">
        <span>
            <i class="fas fa-plus-square"></i> Tables without Result Files
            <span class="group-count">[% tables_without_results.size %]</span>
        </span>
        <i class="fas fa-chevron-right toggle-icon"></i>
    </div>
    <div class="group-content">
    [% IF tables_without_results.size > 0 %]
        [% FOREACH table_comparison IN tables_without_results %]
            <div class="table-comparison-card" data-table="[% table_comparison.table_name | html %]" data-database="[% database_key | html %]">
                <div class="comparison-header" data-action="toggle-comparison" data-table="[% table_comparison.table_name | html %]">
                    <div class="comparison-title">
                        <i class="fas fa-table"></i>
                        <h4>[% table_comparison.table_name | html %] (Table only)</h4>
                        <span class="difference-indicator missing" title="No result file"></span>
                    </div>
                    <div class="comparison-actions">
                        [% UNLESS read_only %]
                            <button class="create-btn" data-action="create-result-from-table"
                                    data-table="[% table_comparison.table_name | html %]"
                                    data-database="[% database_key | html %]">
                                <i class="fas fa-plus"></i> Create Result
                            </button>
                        [% ELSE %]
                            <span class="read-only-badge" title="Migration target is read-only">Read-only</span>
                        [% END %]
                        <i class="fas fa-chevron-right expand-icon"></i>
                    </div>
                </div>
                <div class="comparison-detail">
                    <div class="loading-indicator">
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Loading table schema...</span>
                    </div>
                </div>
            </div>
        [% END %]
    [% ELSE %]
        <p class="group-no-data"><i class="fas fa-check"></i> Every table has a matching Result file.</p>
    [% END %]
    </div>
</div>