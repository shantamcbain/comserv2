// Sync metadata to result file
function syncMetadataToResult(tableName, database, attribute, value, constraintName) {
    if (!confirm('Are you sure you want to update ' + attribute + (constraintName ? ' (' + constraintName + ')' : '') + ' in the Result file to match the Table?')) {
        return;
    }
    
    let url = '';
    const body = { 
        table_name: tableName, 
        database: database 
    };
    
    if (attribute === 'table') {
        url = '[% c.uri_for("/schema-comparison/sync_table_name_to_result") %]';
    } else if (attribute === 'primary_key') {
        url = '[% c.uri_for("/schema-comparison/sync_primary_key_to_result") %]';
    } else if (attribute === 'unique_constraint') {
        url = '[% c.uri_for("/schema-comparison/sync_unique_constraint_to_result") %]';
        body.constraint_name = constraintName;
    }
    
    if (!url) {
        alert('Unknown attribute: ' + attribute);
        return;
    }
    
    fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(body)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Metadata updated in Result file successfully!');
            refreshFieldComparison(tableName, database);
        } else {
            alert('Error updating Result file: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(error => {
        alert('Failed to update Result file. Please try again.');
    });
}

// Sync metadata to table
function syncMetadataToTable(tableName, database, attribute, value, constraintName) {
    if (!confirm('Are you sure you want to update ' + attribute + (constraintName ? ' (' + constraintName + ')' : '') + ' in the Table to match the Result file?')) {
        return;
    }
    
    let url = '';
    const body = { 
        table_name: tableName, 
        database: database 
    };
    
    if (attribute === 'primary_key') {
        url = '[% c.uri_for("/schema-comparison/sync_primary_key_to_table") %]';
    } else if (attribute === 'unique_constraint') {
        url = '[% c.uri_for("/schema-comparison/sync_unique_constraint_to_table") %]';
        body.constraint_name = constraintName;
    }
    
    if (!url) {
        alert('Sync to table not supported for attribute: ' + attribute);
        return;
    }
    
    fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(body)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Table schema updated successfully!');
            refreshFieldComparison(tableName, database);
        } else {
            alert('Error updating Table: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(error => {
        alert('Failed to update Table. Please try again.');
    });
}

// Create result from table
function createResultFromTable(tableName, database) {
    console.log('createResultFromTable called with:', { tableName, database });
    
