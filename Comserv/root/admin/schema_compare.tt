// Sync primary key from result to table
function syncPrimaryKeyToTable(tableName, database) {
    if (!confirm('Sync primary key from Result file to database table? This will execute an ALTER TABLE command.')) return;
    
    fetch('[% c.uri_for("/schema-comparison/sync_primary_key_to_table") %]', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            table_name: tableName,
            database: database
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Primary key synced successfully from result to table!');
            refreshFieldComparison(tableName, database);
        } else {
            alert('Error syncing primary key: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(error => alert('Failed to sync primary key.'));
}

// Sync unique constraint from result to table
function syncUniqueConstraintToTable(tableName, database, constraintName) {
    if (!confirm('Sync unique constraint "' + constraintName + '" from Result file to database table? This will execute an ALTER TABLE command.')) return;
    
    fetch('[% c.uri_for("/schema-comparison/sync_unique_constraint_to_table") %]', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            table_name: tableName,
            database: database,
            constraint_name: constraintName
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Unique constraint synced successfully from result to table!');
            refreshFieldComparison(tableName, database);
        } else {
            alert('Error syncing unique constraint: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(error => alert('Failed to sync unique constraint.'));
}

// Sync unique constraint to result
function syncUniqueConstraintToResult(tableName, database, constraintName) {
    if (!confirm('Are you sure you want to sync unique constraint "' + constraintName + '" to result file?')) {
        return;
    }
    
    fetch('[% c.uri_for("/schema-comparison/sync_unique_constraint_to_result") %]', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            table_name: tableName,
            database: database,
            constraint_name: constraintName
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Unique constraint synchronized successfully!');
            refreshFieldComparison(tableName, database);
        } else {
            alert('Error syncing unique constraint: ' + data.error);
        }
    })
    .catch(error => alert('Failed to sync unique constraint: ' + error));
}

// Format size for display, combining explicit size with parsed size
function formatSize(dataType, explicitSize) {
    const parsed = parseDataType(dataType);
    
    // If we have a size from parsing the data type, use that
    if (parsed.size) {
        return parsed.size.toString();
    }
    
    // Otherwise use the explicit size if available
    if (explicitSize && explicitSize !== null && explicitSize !== undefined) {
        return explicitSize.toString();
    }
    
    return '<em>N/A</em>';
}

// Switch database environment
function switchEnvironment(environment) {
    if (environment === 'production') {
        const confirmed = confirm(
            'WARNING: You are switching to PRODUCTION database!\n\n' +
            'Changes made in this environment will affect live data.\n\n' +
            'Are you sure you want to proceed?'
        );
        if (!confirmed) {
            document.getElementById('dbEnvironmentSelect').value = '[% active_environment %]';
            return;
        }
    }
    
    // Store environment preference in session and reload
    window.location.href = '[% c.uri_for("/admin/schema_compare") %]?environment=' + environment;
}

// Toggle add environment form visibility
function toggleAddForm() {
    const form = document.getElementById('addEnvForm');
    if (form.style.display === 'none' || form.style.display === '') {
        form.style.display = 'block';
    } else {
        form.style.display = 'none';
    }
}

// Submit new environment form
function submitNewEnvironment(event) {
    event.preventDefault();
    
    const formData = {
        env_name: document.getElementById('newEnvName').value,
        display_name: document.getElementById('newEnvDisplayName').value,
        db_host: document.getElementById('newEnvHost').value,
        db_name: document.getElementById('newEnvDbName').value,
        port: document.getElementById('newEnvPort').value,
        warning_level: document.getElementById('newEnvWarning').value
    };
    
    // TODO: Submit to backend endpoint
    fetch('[% c.uri_for("/admin/database-env/add") %]', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(formData)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            alert('Environment added successfully!');
            toggleAddForm();
            document.getElementById('newEnvForm').reset();
            // Reload page to show new environment
            window.location.reload();
        } else {
            alert('Error adding environment: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(error => {
        alert('Failed to add environment: ' + error);
        console.error('Error:', error);
    });
}

// Handle Full Dev Mode checkbox
document.getElementById('fullDevMode').addEventListener('change', function() {
    const currentEnv = document.getElementById('dbEnvironmentSelect').value;
    if (this.checked) {
        // Enable full dev mode
        location.href = '[% c.uri_for("/admin/schema_compare") %]?full_dev=1&environment=' + currentEnv;
    } else {
        // Disable full dev mode
        location.href = '[% c.uri_for("/admin/schema_compare") %]?full_dev=0&environment=' + currentEnv;
    }
});

// Initialize page
document.addEventListener('DOMContentLoaded', function() {
    // Add event listeners for radio button changes
    document.addEventListener('change', function(e) {
        if (e.target.type === 'radio' && e.target.classList.contains('field-checkbox')) {
            // Update visual state when radio buttons change
            const container = e.target.closest('.field-value-container');
            const fieldValue = container.querySelector('.field-value');
            
            // Remove checked state from all values in this row
            const row = e.target.closest('tr');
            row.querySelectorAll('.field-value').forEach(val => {
                val.classList.remove('selected');
            });
            
            // Add checked state to selected value
            if (e.target.checked) {
                fieldValue.classList.add('selected');
            }
        }
    });
});
</script>
