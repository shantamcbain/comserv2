    <!-- Host System Statistics Footer Status Bar -->
    <div class="compact-card" style="margin-top: 20px; border-top: 3px solid #0066cc; background-color: #f8f9fa;">
        <div class="compact-card-body" style="padding: 10px 15px; display: flex; align-items: center; justify-content: space-between; gap: 15px; flex-wrap: wrap; font-size: 12px; color: #333;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <i class="fas fa-server" style="color: #0066cc; font-size: 14px;"></i>
                <strong>Host System Stats:</strong>
                <span id="footer-host-badge" class="badge-pill" style="background-color: #0066cc; color: white; padding: 1px 6px; border-radius: 3px; font-weight: bold; font-size: 10px;">WORKSTATION</span>
