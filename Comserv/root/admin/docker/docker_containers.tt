            <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
                <div>
                    <i class="fas fa-clock" style="color: #28a745;"></i> 
                    <strong>Uptime:</strong> <span id="footer-uptime" style="font-family: monospace; background: #e9ecef; padding: 2px 6px; border-radius: 3px;">Loading...</span>
                </div>
                <div>
                    <i class="fas fa-hdd" style="color: #17a2b8;"></i> 
                    <strong>Disk Usage:</strong> <span id="footer-disk" style="font-family: monospace; background: #e9ecef; padding: 2px 6px; border-radius: 3px;">Loading...</span>
                </div>
                <div>
                    <i class="fas fa-memory" style="color: #ffc107;"></i> 
                    <strong>Memory:</strong> <span id="footer-mem" style="font-family: monospace; background: #e9ecef; padding: 2px 6px; border-radius: 3px;">Loading...</span>
                </div>
            </div>
            <div style="font-size: 11px; color: #666; font-style: italic;">
                Last Refreshed: <span id="footer-last-refresh">N/A</span>
            </div>
        </div>
    </div>

    <!-- Custom Results Modal Popup -->
    <div id="result-modal" style="display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
        <div style="background-color: #fff; margin: auto; padding: 20px; border: 1px solid #888; width: 80%; max-width: 650px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); display: flex; flex-direction: column; gap: 15px; max-height: 85vh;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                <h3 id="modal-title" style="margin: 0; font-size: 16px; font-weight: bold; color: #333; display: flex; align-items: center; gap: 6px;">Action Status</h3>
                <span onclick="closeResultModal()" style="color: #aaa; font-size: 24px; font-weight: bold; cursor: pointer; line-height: 1;" onmouseover="this.style.color='#000'" onmouseout="this.style.color='#aaa'">&times;</span>
            </div>
            <div id="modal-body" style="font-size: 12px; line-height: 1.4; overflow-y: auto; max-height: 50vh; white-space: pre-wrap; font-family: monospace; background-color: #1e1e1e; color: #f8f8f2; padding: 12px; border-radius: 4px; border: 1px solid #333; word-break: break-all;">
            </div>
            <div style="display: flex; justify-content: flex-end; padding-top: 10px; border-top: 1px solid #eee;">
                <button onclick="closeResultModal()" style="padding: 6px 15px; font-size: 12px; font-weight: bold; border-radius: 4px; cursor: pointer; background-color: #0066cc; color: white; border: none;">Dismiss</button>
            </div>
        </div>
    </div>

    [% END %]
</div>

