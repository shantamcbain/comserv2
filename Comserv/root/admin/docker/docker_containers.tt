[% META
   title = 'Docker Container Management'
   version = '1.3'
   author = 'System'
   date = '2026-07-06'
   last_modified = '2026-07-06'
   category = 'admin'
   tags = 'docker, containers, volumes, infrastructure'
%]

[% PageVersion = 'root/admin/docker/docker_containers.tt,v 1.3 2026/07/06 system Exp system ' %]

<div class="app-container" style="margin: 20px auto; max-width: 1200px;">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ccc; padding-bottom: 10px; margin-bottom: 20px;">
        <h1 style="margin: 0;"><i class="icon-docker"></i> Docker Servers</h1>
        <div style="display: flex; gap: 8px; align-items: center;">
            <span id="docker-status-badge" style="display:inline-flex;align-items:center;gap:5px;font-size:0.82em;padding:3px 10px;border-radius:12px;background:#21262d;color:#8b949e;">
                <span id="docker-status-dot" style="width:8px;height:8px;border-radius:50%;background:#8b949e;display:inline-block;"></span>
                <span id="docker-status-text">Loading...</span>
            </span>
            <button class="btn btn-secondary btn-sm" data-action="refresh-all" style="padding:4px 10px;font-size:0.85em;">
                <i class="icon-refresh"></i> Refresh
            </button>
            <button class="btn btn-secondary btn-sm" data-action="docker-prune" style="padding:4px 10px;font-size:0.85em;background:#28a745;color:#fff;border-color:#28a745;">
                <i class="fas fa-broom"></i> Clean Up Disk
            </button>
            <button class="btn btn-primary btn-sm" data-action="show-deploy-form" style="padding:4px 10px;font-size:0.85em;background:#0366d6;color:#fff;border-color:#0366d6;">
                <i class="fas fa-ship"></i> Pull & Deploy
            </button>
            <a href="/admin/docker-containers-working" class="btn btn-secondary btn-sm" style="padding:4px 10px;font-size:0.85em;">
                <i class="fas fa-history"></i> Working View
            </a>
        </div>
    </div>

    <!-- Target selector -->
    <div class="card mb-3" style="border-left:4px solid #0066cc;">
        <div class="card-body" style="padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
            <div style="display:flex;align-items:center;gap:8px;">
                <label for="docker-target-select" style="font-weight:bold;font-size:0.88em;margin:0;display:inline-flex;align-items:center;gap:5px;">
                    <i class="fas fa-server" style="color:#0066cc;"></i> Target Host:
                </label>
                <select id="docker-target-select" style="width:auto;display:inline-block;font-size:0.82em;padding:3px 8px;border-radius:4px;border:1px solid #ccc;">
                    <option value="workstation" selected>Workstation (Local)</option>
                    <option value="production1">Production 1 (192.168.1.126)</option>
                    <option value="production2">Production 2 (192.168.1.127)</option>
                </select>
            </div>
            <div id="target-info-display" style="font-size:0.82em;color:#666;font-style:italic;">
                <span id="target-name-display">Workstation</span>
            </div>
        </div>
    </div>

    <!-- Containers Section -->
    <div class="card mb-3">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:#f8f9fa;">
            <strong style="font-size:0.9em;">
                <i class="icon-list"></i> Containers
                <span id="container-count" style="font-weight:normal;color:#666;font-size:0.85em;"></span>
            </strong>
            <label style="display:inline-flex;align-items:center;gap:4px;font-size:0.82em;margin:0;cursor:pointer;">
                <input type="checkbox" id="show-all-containers" style="width:14px;height:14px;margin:0;cursor:pointer;">
                Show stopped
            </label>
            <label style="display:inline-flex;align-items:center;gap:4px;font-size:0.82em;margin:0;cursor:pointer;margin-left:auto;">
                <input type="checkbox" id="no-cache-rebuild" style="width:14px;height:14px;margin:0;cursor:pointer;">
                <span style="color:#ffc107;">No Cache</span> <span style="color:#888;font-size:0.9em;">(clean rebuild)</span>
            </label>
        </div>
        <div id="containers-list" style="padding:10px 14px;display:flex;flex-direction:column;gap:8px;">
            <p style="color:#666;text-align:center;padding:10px;font-size:0.85em;">Select a target and click <strong>Refresh</strong>.</p>
        </div>
    </div>

    <!-- Volumes Section -->
    <div class="card mb-3">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:#f8f9fa;">
            <strong style="font-size:0.9em;">
                <i class="fas fa-database"></i> Volumes
                <span id="volume-count" style="font-weight:normal;color:#666;font-size:0.85em;"></span>
            </strong>
        </div>
        <div id="volumes-list" style="padding:10px 14px;display:flex;flex-direction:column;gap:6px;">
            <p style="color:#666;text-align:center;padding:10px;font-size:0.85em;">Load containers to see volumes.</p>
        </div>
    </div>

    <!-- Output Console -->
    <div class="card">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:#f8f9fa;">
            <strong style="font-size:0.9em;"><i class="icon-log"></i> Output</strong>
            <button class="btn btn-sm" data-action="clear-output" style="background:#6c757d;color:#fff;padding:2px 8px;font-size:0.8em;">Clear</button>
        </div>
        <div class="card-body" style="padding:8px 14px;">
            <pre id="output-box" style="background:#1e1e1e;color:#d4d4d4;padding:10px;border-radius:4px;font-family:'Courier New',monospace;font-size:0.82em;max-height:250px;overflow-y:auto;margin:0;white-space:pre-wrap;word-break:break-all;">Ready.</pre>
        </div>
    </div>
</div>

<style>
#output-box .ok   { color: #3fb950; }
#output-box .err  { color: #f85149; }
#output-box .info { color: #79c0ff; }
#output-box .dim  { color: #8b949e; }
</style>