<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>🐳 Docker Deploy</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: monospace; background: #0d1117; color: #c9d1d9; min-height: 100vh; display: flex; flex-direction: column; }
  #header { background: #161b22; border-bottom: 1px solid #30363d; padding: 12px 16px; display: flex; align-items: center; gap: 12px; }
  #header h1 { font-size: 1em; font-weight: bold; color: #58a6ff; flex: 1; }
  #status-badge { font-size: 0.8em; padding: 3px 10px; border-radius: 12px; background: #21262d; color: #8b949e; }
  #status-badge.running { background: #1f3d2a; color: #3fb950; }
  #status-badge.success { background: #1f3d2a; color: #3fb950; }
  #status-badge.error   { background: #3d1f1f; color: #f85149; }
  #console { flex: 1; overflow-y: auto; padding: 14px 16px; font-size: 0.82em; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }
  #console .ok   { color: #3fb950; }
  #console .err  { color: #f85149; }
  #console .info { color: #79c0ff; }
  #console .dim  { color: #8b949e; }
  #footer { background: #161b22; border-top: 1px solid #30363d; padding: 10px 16px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  #notes { flex: 1; min-width: 180px; background: #21262d; border: 1px solid #30363d; border-radius: 4px; color: #c9d1d9; padding: 6px 10px; font-size: 0.85em; }
  .btn { padding: 6px 16px; border: none; border-radius: 4px; font-size: 0.85em; cursor: pointer; font-family: monospace; }
  .btn-close { background: #238636; color: #fff; }
  .btn-close:disabled { background: #21262d; color: #8b949e; cursor: not-allowed; }
  .btn-view  { background: #1f6feb; color: #fff; text-decoration: none; display: inline-block; line-height: 1.8; }
  .btn-view:not([href]) { display: none; }
  #spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid #30363d; border-top-color: #58a6ff; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<div id="header">
  <h1>🐳 Docker Deploy</h1>
  <span id="status-badge" class="running"><span id="spinner"></span> Running…</span>
</div>

<pre id="console"><span class="info">Connecting to deploy endpoint…</span>
</pre>

<div id="footer">
  <input id="notes" type="text" placeholder="Notes for this deploy log (optional)…">
  <button id="btn-close" class="btn btn-close" disabled onclick="closeLog()">📋 Close &amp; Save Log</button>
  <a id="btn-view" class="btn btn-view" target="_blank">👁 View Log</a>
</div>

<script>
var logId    = null;
var logOutput = '';
var baseUrl  = window.location.origin;

function appendLine(text, cls) {
    var con = document.getElementById('console');
    if (cls) {
        var span = document.createElement('span');
        span.className = cls;
        span.textContent = text + '\n';
        con.appendChild(span);
    } else {
        con.appendChild(document.createTextNode(text + '\n'));
    }
    con.scrollTop = con.scrollHeight;
}

function setStatus(state, text) {
    var badge = document.getElementById('status-badge');
    var spinner = document.getElementById('spinner');
    badge.className = 'status-badge ' + state;
    badge.innerHTML = (state === 'running' ? '<span id="spinner"></span> ' : '') + text;
    badge.id = 'status-badge';
}

window.addEventListener('load', function() {
    appendLine('[' + new Date().toLocaleTimeString() + '] Starting deploy…', 'info');

    fetch(baseUrl + '/admin/docker/deploy', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: ''
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        logId     = d.log_id;
        logOutput = d.output || '';

        if (d.output) {
            var lines = d.output.split('\n');
            for (var i = 0; i < lines.length; i++) {
                var l = lines[i];
                var cls = l.match(/error|fail|ERRORS/i) ? 'err'
                        : l.match(/^\[.*\] ===/) ? 'info'
                        : l.match(/SUCCESS|Already up|up-to-date/i) ? 'ok'
                        : null;
                appendLine(l, cls);
            }
        }

        if (d.success) {
            setStatus('success', '✅ Success');
            appendLine('', null);
            appendLine('Deploy completed successfully. Add notes if needed, then close the log.', 'ok');
        } else {
            setStatus('error', '❌ Errors detected');
            appendLine('', null);
            appendLine('Deploy finished with errors. Review output above.', 'err');
        }

        var closeBtn = document.getElementById('btn-close');
        if (closeBtn) closeBtn.disabled = false;

        if (logId) {
            var viewBtn = document.getElementById('btn-view');
            if (viewBtn) viewBtn.href = baseUrl + '/log/' + logId;
        }

        if (window.opener && window.opener.postMessage) {
            window.opener.postMessage({ type: 'deploy_done', success: d.success ? 1 : 0 }, '*');
        }
    })
    .catch(function(e) {
        setStatus('error', '❌ Request failed');
        appendLine('Error: ' + e.message, 'err');
        var closeBtn = document.getElementById('btn-close');
        if (closeBtn) closeBtn.disabled = false;
    });
});

function closeLog() {
    var notes   = (document.getElementById('notes') || {}).value || '';
    var closeBtn = document.getElementById('btn-close');
    if (closeBtn) { closeBtn.disabled = true; closeBtn.textContent = 'Saving…'; }

    var body = 'log_id=' + encodeURIComponent(logId || '')
             + '&output=' + encodeURIComponent(logOutput)
             + '&notes='  + encodeURIComponent(notes);

    fetch(baseUrl + '/admin/docker/close_deploy_log', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        appendLine('', null);
        appendLine(d.success ? '📋 Log saved and closed.' : '⚠ Log save error: ' + d.message,
                   d.success ? 'ok' : 'err');
        setTimeout(function() { window.close(); }, 1200);
    })
    .catch(function() {
        appendLine('⚠ Could not save log — closing anyway.', 'err');
        setTimeout(function() { window.close(); }, 1200);
    });
}

window.addEventListener('beforeunload', function() {
    if (logId) {
        var notes = (document.getElementById('notes') || {}).value || '';
        navigator.sendBeacon(
            baseUrl + '/admin/docker/close_deploy_log',
            new URLSearchParams({ log_id: logId, output: logOutput, notes: notes })
        );
    }
});
</script>
</body>
</html>
