<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>🐳 Docker Hub Deploy</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: monospace; background: #0d1117; color: #c9d1d9; min-height: 100vh; display: flex; flex-direction: column; }
  #header { background: #161b22; border-bottom: 1px solid #30363d; padding: 12px 16px; display: flex; align-items: center; gap: 12px; }
  #header h1 { font-size: 1em; font-weight: bold; color: #58a6ff; flex: 1; }
  #status-badge { font-size: 0.8em; padding: 3px 10px; border-radius: 12px; background: #21262d; color: #8b949e; }
  #status-badge.running { background: #1f3d2a; color: #3fb950; }
  #status-badge.success { background: #1f3d2a; color: #3fb950; }
  #status-badge.error   { background: #3d1f1f; color: #f85149; }
  #console { flex: 1; overflow-y: auto; padding: 14px 16px; font-size: 0.82em; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }
  #console .ok   { color: #3fb950; }
  #console .err  { color: #f85149; }
  #console .info { color: #79c0ff; }
  #console .dim  { color: #8b949e; }
  #footer { background: #161b22; border-top: 1px solid #30363d; padding: 10px 16px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  #notes { flex: 1; min-width: 180px; background: #21262d; border: 1px solid #30363d; border-radius: 4px; color: #c9d1d9; padding: 6px 10px; font-size: 0.85em; }
  .btn { padding: 6px 16px; border: none; border-radius: 4px; font-size: 0.85em; cursor: pointer; font-family: monospace; }
  .btn-close { background: #238636; color: #fff; }
  .btn-close:disabled { background: #21262d; color: #8b949e; cursor: not-allowed; }
  .btn-view  { background: #1f6feb; color: #fff; text-decoration: none; display: inline-block; line-height: 1.8; }
  .btn-view:not([href]) { display: none; }
  #spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid #30363d; border-top-color: #58a6ff; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<div id="header">
  <h1>🐳 Docker Hub Deploy</h1>
  <span id="status-badge" class="running"><span id="spinner"></span> Starting…</span>
</div>

<pre id="console"><span class="info">Initialising deploy log…</span>
</pre>

<div id="footer">
  <input id="notes" type="text" placeholder="Notes for this deploy log (optional)…">
  <button id="btn-close" class="btn btn-close" disabled onclick="closeLog()">📋 Close &amp; Save Log</button>
  <a id="btn-view" class="btn btn-view" target="_blank">👁 View Log</a>
</div>

<script>
var logId         = null;
var logOutput     = '';
var todoRecordId  = (new URLSearchParams(window.location.search)).get('todo_record_id') || '';
var quickDeploy   = (new URLSearchParams(window.location.search)).get('quick_deploy') || '0';
var pollingTimer  = null;
var lastContent   = '';

var con = document.getElementById('console');

function appendLine(text, cls) {
    if (cls) {
        var span = document.createElement('span');
        span.className = cls;
        span.textContent = text + '\n';
        con.appendChild(span);
    } else {
        con.appendChild(document.createTextNode(text + '\n'));
    }
    con.scrollTop = con.scrollHeight;
    logOutput += text + '\n';
}

function setStatus(state, text) {
    var badge = document.getElementById('status-badge');
    badge.className = 'status-badge ' + state;
    badge.id = 'status-badge';
    badge.innerHTML = (state === 'running' ? '<span id="spinner"></span> ' : '') + text;
}

function safeFetch(url, options) {
    var opts = Object.assign({ credentials: 'same-origin', redirect: 'manual' }, options || {});
    return fetch(url, opts).then(function(response) {
        if (response.type === 'opaqueredirect' || response.status === 0 ||
            (response.status >= 300 && response.status < 400)) {
            appendLine('✗ Session expired — reload and log in again.', 'err');
            return Promise.reject(new Error('session-expired'));
        }
        if (!response.ok) {
            appendLine('✗ Server error (HTTP ' + response.status + ')', 'err');
            return Promise.reject(new Error('HTTP ' + response.status));
        }
        return response;
    });
}

function startPolling() {
    if (pollingTimer) clearInterval(pollingTimer);
    lastContent = '';
    pollingTimer = setInterval(function() {
        safeFetch('/admin/docker-deploy-status')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    if (data.output && data.output !== lastContent) {
                        var newContent = data.output.substring(lastContent.length);
                        if (newContent) {
                            con.appendChild(document.createTextNode(newContent));
                            con.scrollTop = con.scrollHeight;
                            logOutput += newContent;
                            lastContent = data.output;
                        }
                    }
                    if (!data.is_running) {
                        clearInterval(pollingTimer);
                        pollingTimer = null;
                        appendLine('', null);
                        appendLine('='.repeat(60), 'ok');
                        appendLine('✅ DEPLOYMENT FINISHED', 'ok');
                        appendLine('='.repeat(60), 'ok');
                        setStatus('success', '✅ Done');
                        document.getElementById('btn-close').disabled = false;
                        if (logId) {
                            document.getElementById('btn-view').href = '/log/' + logId;
                        }
                        if (window.opener && window.opener.postMessage) {
                            window.opener.postMessage({ type: 'deploy_done', success: 1 }, '*');
                        }
                        alert('✅ Docker Hub deploy complete — review log and close the window to save.');
                    }
                }
            })
            .catch(function(e) {
                if (e.message !== 'session-expired') {
                    appendLine('Polling error: ' + e.message, 'err');
                }
            });
    }, 1000);
}

window.addEventListener('load', function() {
    safeFetch('/admin/docker/init_log', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: todoRecordId ? 'todo_record_id=' + encodeURIComponent(todoRecordId) : ''
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (!d.success) {
            appendLine('⚠ Log creation failed: ' + (d.message || 'unknown'), 'err');
        } else {
            logId = d.log_id;
            if (logId) {
                document.getElementById('btn-view').href = '/log/' + logId;
            }
        }
        appendLine('[' + new Date().toLocaleTimeString() + '] Log created — starting Hub deploy…', 'info');
        setStatus('running', 'Deploying…');

        var bodyParams = [];
        if (quickDeploy)  { bodyParams.push('quick_deploy=' + encodeURIComponent(quickDeploy)); }
        if (todoRecordId) { bodyParams.push('todo_record_id=' + encodeURIComponent(todoRecordId)); }

        return safeFetch('/admin/docker-deploy-to-production', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: bodyParams.join('&')
        });
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            appendLine('Background deploy process started.', 'ok');
            appendLine('Streaming output…', 'info');
            startPolling();
        } else {
            appendLine('❌ Failed to start deploy: ' + (data.error || 'unknown error'), 'err');
            setStatus('error', '❌ Failed');
            document.getElementById('btn-close').disabled = false;
            if (window.opener && window.opener.postMessage) {
                window.opener.postMessage({ type: 'deploy_done', success: 0 }, '*');
            }
            alert('⚠️ Docker Hub deploy failed to start — review output for details.');
        }
    })
    .catch(function(e) {
        if (e.message !== 'session-expired') {
            setStatus('error', '❌ Error');
            document.getElementById('btn-close').disabled = false;
        }
    });
});

function closeLog() {
    var notes    = (document.getElementById('notes') || {}).value || '';
    var closeBtn = document.getElementById('btn-close');
    if (closeBtn) { closeBtn.disabled = true; closeBtn.textContent = 'Saving…'; }

    var body = 'log_id='  + encodeURIComponent(logId || '')
             + '&output=' + encodeURIComponent(logOutput)
             + '&notes='  + encodeURIComponent(notes);

    fetch('/admin/docker/close_deploy_log', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
        appendLine('', null);
        appendLine(d.success ? '📋 Log saved and closed.' : '⚠ Log save error: ' + d.message,
                   d.success ? 'ok' : 'err');
        setTimeout(function() { window.close(); }, 1200);
    })
    .catch(function() {
        appendLine('⚠ Could not save log — closing anyway.', 'err');
        setTimeout(function() { window.close(); }, 1200);
    });
}

window.addEventListener('beforeunload', function() {
    if (logId) {
        var notes = (document.getElementById('notes') || {}).value || '';
        navigator.sendBeacon(
            '/admin/docker/close_deploy_log',
            new URLSearchParams({ log_id: logId, output: logOutput, notes: notes })
        );
    }
});
</script>
</body>
</html>
