<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>🐳 Docker Deploy</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: monospace; background: #0d1117; color: #c9d1d9; min-height: 100vh; display: flex; flex-direction: column; }
  #header { background: #161b22; border-bottom: 1px solid #30363d; padding: 12px 16px; display: flex; align-items: center; gap: 12px; }
  #header h1 { font-size: 1em; font-weight: bold; color: #58a6ff; flex: 1; }
  #status-badge { font-size: 0.8em; padding: 3px 10px; border-radius: 12px; background: #21262d; color: #8b949e; }
  #status-badge.running { background: #1f3d2a; color: #3fb950; }
  #status-badge.success { background: #1f3d2a; color: #3fb950; }
  #status-badge.error   { background: #3d1f1f; color: #f85149; }
  #console { flex: 1; overflow-y: auto; padding: 14px 16px; font-size: 0.82em; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }
  #console .ok   { color: #3fb950; }
  #console .err  { color: #f85149; }
  #console .info { color: #79c0ff; }
  #console .dim  { color: #8b949e; }
  #footer { background: #161b22; border-top: 1px solid #30363d; padding: 10px 16px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  #notes { flex: 1; min-width: 180px; background: #21262d; border: 1px solid #30363d; border-radius: 4px; color: #c9d1d9; padding: 6px 10px; font-size: 0.85em; }
  .btn { padding: 6px 16px; border: none; border-radius: 4px; font-size: 0.85em; cursor: pointer; font-family: monospace; }
  .btn-close { background: #238636; color: #fff; }
  .btn-close:disabled { background: #21262d; color: #8b949e; cursor: not-allowed; }
  .btn-view  { background: #1f6feb; color: #fff; text-decoration: none; display: inline-block; line-height: 1.8; }
  .btn-view:not([href]) { display: none; }
  #spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid #30363d; border-top-color: #58a6ff; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Choice screen styles */
  .choice-container { padding: 20px; }
  .choice-title { color: #58a6ff; margin-bottom: 16px; font-size: 1.1em; }
  .choice-option { 
    background: #21262d; 
    border: 1px solid #30363d; 
    padding: 12px 16px; 
    margin: 8px 0; 
    border-radius: 6px; 
    cursor: pointer; 
    transition: all 0.2s;
  }
  .choice-option:hover { background: #30363d; border-color: #58a6ff; }
  .choice-option .label { font-weight: bold; color: #c9d1d9; }
  .choice-option .desc { color: #8b949e; font-size: 0.85em; margin-top: 4px; }
  .choice-cancel { color: #f85149; margin-top: 20px; }
</style>
</head>
<body>

<div id="header">
  <h1>🐳 Docker Deploy</h1>
  <span id="status-badge" class="running"><span id="spinner"></span> Ready</span>
</div>

<!-- Choice Screen -->
<div id="choice-screen" class="choice-container">
  <div class="choice-title">Choose Deployment Method</div>

  <div class="choice-option" data-action="start-deploy" data-target="production1">
    <div class="label">[1] FULL DEPLOY → production1</div>
    <div class="desc">Rebuilds and pushes a new image to Docker Hub, then restarts the production1 server container.</div>
  </div>

  <div class="choice-option" data-action="start-deploy" data-target="production2">
    <div class="label">[2] FULL DEPLOY → production2</div>
    <div class="desc">Rebuilds and pushes a new image to Docker Hub, then restarts the production2 server container.</div>
  </div>

  <div class="choice-option" data-action="start-deploy" data-target="workstation">
    <div class="label">[3] FULL DEPLOY → workstation</div>
    <div class="desc">Deploys to the local workstation (useful for testing).</div>
  </div>

  <div class="choice-option" data-action="start-deploy" data-target="staging-4000" style="border-color: #58a6ff;">
    <div class="label" style="color: #58a6ff;">[S] DEPLOY TO LOCAL 4000 → staging</div>
    <div class="desc">Builds and starts the web-staging service on port 4000 (local workstation). All volumes ensured first.</div>
  </div>

  <div class="choice-option" data-action="start-deploy" data-target="web-dev" style="border-color: #28a745;">
    <div class="label" style="color: #28a745;">[D] DEPLOY TO LOCAL 3000 → web-dev</div>
    <div class="desc">Builds and starts the web-dev service on port 3000 for active development work.</div>
  </div>

  <div class="choice-option" data-action="start-deploy" data-target="local-test">
    <div class="label">[B] Build &amp; test locally only (no deploy)</div>
    <div class="desc">Builds and tests the production image locally but does not push or deploy.</div>
  </div>

  <div class="choice-option choice-cancel" data-action="cancel-deploy">
    <div class="label">[C] Cancel / Abort</div>
  </div>
</div>

<!-- No Cache Option -->
<div style="padding:0 20px 12px;">
  <label style="display:inline-flex;align-items:center;gap:6px;font-size:0.85em;cursor:pointer;color:#c9d1d9;">
    <input type="checkbox" id="no-cache-deploy" style="width:14px;height:14px;cursor:pointer;">
    <span style="color:#ffc107;">No Cache</span> <span style="color:#8b949e;">(clean rebuild — skips Docker layer cache)</span>
  </label>
</div>

<!-- Live Log Screen (hidden until choice is made) -->
<pre id="console" style="display:none;"></pre>

<div id="footer" style="display:none;">
  <input id="notes" type="text" placeholder="Notes for this deploy log (optional)…">
  <button id="btn-cancel" class="btn" style="background: #dc3545; color: white;" data-action="abort-save">🛑 Abort &amp; Save</button>
  <button id="btn-close" class="btn btn-close" disabled data-action="close-save">📋 Close &amp; Save Log</button>
  <a id="btn-view" class="btn btn-view" target="_blank">👁 View Log</a>
</div>

<script src="/static/js/planning/daily-plan-deploy-form.js" defer></script>
</body>
</html>