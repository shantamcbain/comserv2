    [% PageVersion %]
[% END %]

<style>
    .priority-container {
        background: var(--background-color);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        margin: 15px 0;
        padding: 0;
        scroll-margin-top: 170px !important;
    }
    
    [id^="priority-"], #dynamic-daily, #cleanup-todos, #completed {
        scroll-margin-top: 170px !important;
    }
    
    .priority-container.priority-high {
        border-left: 5px solid var(--warning-color);
        background: var(--schema-alert-warning-bg);
    }
    
    .priority-container.priority-medium {
        border-left: 5px solid var(--accent-color);
        background: var(--light-color);
    }
    
    .priority-container.priority-low {
        border-left: 5px solid var(--success-color);
        background: var(--secondary-color);
    }
    
    .priority-container summary {
        padding: 15px 20px;
        cursor: pointer;
        font-weight: bold;
        font-size: 1.1em;
        list-style: none;
        user-select: none;
    }
    
    .priority-container summary::-webkit-details-marker {
        display: none;
    }
    
    .priority-container summary:before {
        content: "▶ ";
        display: inline-block;
        margin-right: 8px;
        transition: transform 0.2s;
    }
    
    .priority-container[open] summary:before {
        transform: rotate(90deg);
    }
    
    .priority-content {
        padding: 0 20px 20px 20px;
        border-top: 1px solid var(--border-color);
    }
    
    .priority-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin: 15px 0;
        padding: 15px;
        background: rgba(255,255,255,0.5);
        border-radius: 4px;
    }
    
    .priority-meta-item {
        display: flex;
        flex-direction: column;
    }
    
    .priority-meta-label {
        font-size: 0.85em;
        color: var(--text-muted-color);
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .priority-meta-value {
        font-weight: 500;
    }
    
    .status-pending {
        color: var(--warning-color);
        font-weight: bold;
    }
    
    .status-in-progress {
        color: var(--accent-color);
        font-weight: bold;
    }
    
    .status-completed {
        color: var(--success-color);
        font-weight: bold;
    }
    
    .priority-section {
        margin: 15px 0;
    }
    
    .priority-section h4 {
        margin: 0 0 10px 0;
        color: var(--text-color);
        font-size: 0.95em;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .priority-tasks {
        background: var(--background-color);
        padding: 15px;
        border-radius: 4px;
        border: 1px solid var(--border-color);
    }
    
    .priority-tasks ul {
        margin: 0;
        padding-left: 20px;
    }
    
    .priority-tasks li {
        margin: 8px 0;
        line-height: 1.6;
    }
    
    .blocker-tag {
        display: inline-block;
        padding: 4px 10px;
        background: var(--schema-alert-danger-bg);
        border: 1px solid var(--warning-color);
        border-radius: 3px;
        font-size: 0.9em;
        margin: 3px;
    }
    
    .unblocks-tag {
        display: inline-block;
        padding: 4px 10px;
        background: var(--schema-alert-success-bg);
        border: 1px solid var(--success-color);
        border-radius: 3px;
        font-size: 0.9em;
        margin: 3px;
    }
    
    .nav-jump {
        background: var(--secondary-color);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        padding: 0;
        margin: 20px 0;
    }
    
    .nav-jump summary {
        padding: 15px 20px;
        cursor: pointer;
        font-weight: bold;
        background: var(--info-color);
        color: white;
        border-radius: 6px;
    }
    
    .jump-links-container {
        padding: 20px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }
    
    .jump-group h6 {
        margin: 0 0 10px 0;
        color: var(--info-color);
        font-size: 0.9em;
    }
    
    .jump-links {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }
    
    .jump-link {
        padding: 8px 12px;
        background: var(--background-color);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        text-decoration: none;
        color: var(--info-color);
        transition: all 0.2s;
    }
    
    .jump-link:hover {
        background: var(--light-color);
        border-color: var(--info-color);
        transform: translateX(5px);
    }
    
    .completed-section {
        background: var(--secondary-color);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        padding: 20px;
        margin-top: 30px;
    }
    
    .completed-item {
        padding: 12px;
        background: var(--background-color);
        border-left: 4px solid var(--success-color);
        margin: 10px 0;
        border-radius: 4px;
    }
</style>

