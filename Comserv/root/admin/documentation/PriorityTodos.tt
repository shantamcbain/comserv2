<script>
    // Automatically open the targeted <details> container when navigating via anchor
    function openTargetDetails() {
        const hash = window.location.hash;
        if (hash) {
            const target = document.querySelector(hash);
            if (target && target.tagName === 'DETAILS') {
                target.open = true;
                // If it's nested inside another details (like nav-jump), we don't necessarily want to open the parent
            }
        }
    }

    // Run on load and on hash change
    window.addEventListener('load', openTargetDetails);
    window.addEventListener('hashchange', openTargetDetails);
</script>
