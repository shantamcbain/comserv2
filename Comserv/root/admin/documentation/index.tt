[%# Admin Documentation Index Template %]
[% META title = 'Admin Documentation Index' %]
[% META description = 'Complete list of all documentation files for administrators' %]
[% PageVersion = 'admin/documentation/index.tt,v 1.09 2025/10/19 08:04:27 shanta Exp shanta - Added search functionality with role-based filtering' %]

[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<head>
    <link rel="stylesheet" href="[% c.uri_for('/static/css/components/documentation.css') %]?v=20260324b">
</head>

<div class="documentation-container">
    <header class="doc-header">
        <h1>Admin Documentation</h1>
        <div class="user-context">
            <span class="context-item"><strong>Site:</strong> [% site_name || 'Comserv' %]</span>
            <span class="context-item"><strong>Role:</strong> [% user_role || 'Unknown' %]</span>
            <span class="context-item"><strong>Admin:</strong> [% is_admin ? 'Yes' : 'No' %]</span>
            <span class="context-item"><strong>Files Available:</strong> [% page_count || 0 %]</span>
        </div>
    </header>

    <!-- Search Form -->
    <div class="search-container">
        <form method="GET" action="[% c.uri_for('/documentation/search') %]" class="search-form">
            <div class="search-input-group">
                <input type="text"
                       name="q"
                       value="[% c.req.param('q') | html %]"
                       placeholder="Search documentation..."
                       class="search-input"
                       minlength="2"
                       required>
                <select name="category" class="search-category">
                    <option value="">All Categories</option>
                    [% FOREACH category_key IN sorted_categories %]
                        [% category = categories.$category_key %]
                        <option value="[% category_key %]"
                                [% IF c.req.param('category') == category_key %]selected[% END %]>
                            [% category.title || category_key.ucfirst %]
                        </option>
                    [% END %]
                </select>
                <button type="submit" class="search-button">Search</button>
            </div>
        </form>

        [% IF is_admin %]
        <div style="margin-top: 15px; text-align: center;">
            <button onclick="rescanDocumentation()" class="search-button" style="background: #28a745;" title="Scan for new or modified documentation files">
                🔄 Rescan Files
            </button>
            <span id="rescan-status" style="margin-left: 10px; color: #666; font-size: 14px;"></span>
        </div>
        [% END %]
    </div>

    <!-- Search Results (if search was performed) -->
    [% IF c.req.param('q') %]
        <div class="search-results">
            [% IF search_results && search_results.size > 0 %]
                <div class="search-results-header">
                    <h3>Search Results</h3>
                    <p>Found [% search_results.size %] result[% IF search_results.size != 1 %]s[% END %] 
                       for "[% c.req.param('q') | html %]"
                       [% IF c.req.param('category') %] in [% categories.${c.req.param('category')}.title %][% END %]</p>
                </div>
                
                <div class="files-grid search-results-grid">
                    [% FOREACH result IN search_results %]
                        <div class="file-card search-result-card">
                            <div class="file-title">
                                <a href="[% result.url %]">[% result.title || result.page_name %]</a>
                                <span class="match-score">Score: [% result.score %]</span>
                            </div>
                            <div class="file-meta">
                                <strong>Path:</strong> [% result.path %]<br>
                                <strong>Category:</strong> [% result.category || 'General' %]<br>
                                <strong>Site:</strong> [% result.site || 'all' %]
                            </div>
                            [% IF result.excerpt %]
                                <div class="search-excerpt">
                                    [% result.excerpt %]
                                </div>
                            [% END %]
                            <div class="file-roles">
                                [% IF result.roles %]
                                    [% FOREACH role IN result.roles %]
                                        <span class="role-badge [% role %]">[% role | ucfirst %]</span>
                                    [% END %]
                                [% ELSE %]
                                    <span class="role-badge">All Users</span>
                                [% END %]
                            </div>
                        </div>
                    [% END %]
                </div>
            [% ELSIF c.req.param('q').length >= 2 %]
                <div class="search-results-header">
                    <h3>No Results Found</h3>
                    <p>No documentation found matching "[% c.req.param('q') | html %]"
                       [% IF c.req.param('category') %] in [% categories.${c.req.param('category')}.title %][% END %]</p>
                    <p>Try a different search term or check a different category.</p>
                </div>
            [% ELSE %]
                <div class="search-results-header">
                    <h3>Search Query Too Short</h3>
                    <p>Please enter at least 2 characters to search.</p>
                </div>
            [% END %]
        </div>
    [% END %]

    <!-- All Files Container (Global Theme Compatible) -->
    <div class="theme-container">
        <div class="container-header" onclick="toggleContainer(this)" data-container-id="all-files">
            <h2>All Files</h2>
            <span class="toggle-icon"></span>
        </div>
        <div class="container-content">
            <div class="summary-info">
                Complete documentation library with [% page_count || 0 %] available files
                <span class="role-filter-count" id="all-files-count"></span>
            </div>

            <div class="role-filter-bar" id="all-files-filter-bar">
                <label>Filter by role:</label>
                <button class="role-filter-btn active" data-role="all" onclick="filterAllFiles('all', this)">All</button>
                <button class="role-filter-btn role-guest" data-role="guest" onclick="filterAllFiles('guest', this)">Guest</button>
                <button class="role-filter-btn role-normal" data-role="normal" onclick="filterAllFiles('normal', this)">Normal</button>
                <button class="role-filter-btn role-editor" data-role="editor" onclick="filterAllFiles('editor', this)">Editor</button>
                <button class="role-filter-btn role-developer" data-role="developer" onclick="filterAllFiles('developer', this)">Developer</button>
                <button class="role-filter-btn role-admin" data-role="admin" onclick="filterAllFiles('admin', this)">Admin</button>
                <button class="role-filter-btn role-csc_admin" data-role="csc_admin" onclick="filterAllFiles('csc_admin', this)">CSC Admin</button>
            </div>
            
            <div class="files-grid" id="all-files-grid">
                [% FOREACH page_name IN sorted_pages %]
                    [% page = pages.$page_name %]
                    [% # Show all pages if admin, or pages without roles, or pages with matching user role %]
                    [% show_page = 0 %]
                    [% IF page %]
                        [% IF is_admin %]
                            [% show_page = 1 %]
                        [% ELSIF !page.roles || page.roles.size == 0 %]
                            [% show_page = 1 %]
                        [% ELSIF user_role && page.roles.grep("^${user_role}\$").size > 0 %]
                            [% show_page = 1 %]
                        [% END %]
                    [% END %]
                    [% IF show_page %]
                        [% roles_str = page.roles ? page.roles.join(',') : '' %]
                        <div class="file-card" data-roles="[% roles_str %]">
                            <div class="file-title">
                                <a href="[% page.url %]">[% page.title || page_name %]</a>
                            </div>
                            <div class="file-meta">
                                <strong>Path:</strong> [% page.path %]<br>
                                <strong>Site:</strong> [% page.site || 'all' %]
                            </div>
                            <div class="file-roles">
                                [% IF page.roles %]
                                    [% FOREACH role IN page.roles %]
                                        <span class="role-badge [% role %] [% IF is_admin %]clickable[% END %]" 
                                              [% IF is_admin %]onclick="editRoles('[% page_name %]')"[% END %]
                                              title="[% IF is_admin %]Click to edit roles for this page[% ELSE %]Role: [% role | ucfirst %][% END %]">
                                            [% role | ucfirst %]
                                        </span>
                                    [% END %]
                                [% ELSE %]
                                    <span class="role-badge [% IF is_admin %]clickable[% END %]" 
                                          [% IF is_admin %]onclick="editRoles('[% page_name %]')"[% END %]
                                          title="[% IF is_admin %]Click to edit roles for this page[% ELSE %]Accessible to all users[% END %]">
                                        All Users
                                    </span>
                                [% END %]
                            </div>
                            
                            [% IF is_admin %]
                                <div class="file-card-actions">
                                    <div class="roles-edit-hint">
                                        Click roles above to edit access permissions
                                    </div>
                                    <div>
                                        <a href="/Documentation/manage_config/[% page_name | uri %]" class="edit-roles-btn" style="background: #48bb78; margin-right: 8px;">
                                            Manage File Config
                                        </a>
                                        <a href="/Documentation/edit_roles/[% page_name %]" class="edit-roles-btn">
                                            Edit Roles
                                        </a>
                                    </div>
                                </div>
                            [% END %]
                        </div>
                    [% END %]
                [% END %]
                
                [% IF !sorted_pages.size %]
                    <div class="file-card" style="grid-column: 1 / -1; text-align: center;">
                        <div class="file-title">No Documentation Files Found</div>
                        <div class="file-meta">
                            The documentation system could not find any files to display.<br>
                            Please check the file permissions and documentation configuration.
                        </div>
                    </div>
                [% END %]
            </div>
        </div>
    </div>

    <!-- Category-based containers (Dynamic from JSON config) -->
    [% FOREACH category_key IN sorted_categories %]
        [% category = categories.$category_key %]
        [% category_pages = categorized_pages.$category_key %]
        [% # Filter category pages by user roles %]
        [% accessible_pages = [] %]
        [% FOREACH page IN category_pages %]
            [% allow_page = 0 %]
            [% IF is_admin %]
                [% allow_page = 1 %]
            [% ELSIF !page.roles || page.roles.size == 0 %]
                [% allow_page = 1 %]
            [% ELSIF user_role && page.roles.grep("^${user_role}\$").size > 0 %]
                [% allow_page = 1 %]
            [% END %]
            [% IF allow_page %]
                [% accessible_pages.push(page) %]
            [% END %]
        [% END %]
        [% IF accessible_pages.size > 0 %]
            <!-- Each category gets its own collapsible container -->
            <div class="theme-container">
                <div class="container-header" onclick="toggleContainer(this)" data-container-id="cat-[% category_key %]">
                    <h2>
                        [% IF category.icon %]<i class="[% category.icon %]"></i> [% END %]
                        [% category.title || category_key.ucfirst %]
                        <span class="badge">[% accessible_pages.size %]</span>
                    </h2>
                    <span class="toggle-icon"></span>
                </div>
                <div class="container-content">
                    [% IF category.description %]
                        <div class="category-description">
                            [% category.description %]
                        </div>
                    [% END %]
                    
                    <div class="summary-info">
                        [% accessible_pages.size %] file[% IF accessible_pages.size != 1 %]s[% END %] in this category
                    </div>
                    
                    <div class="files-grid">
                        [% FOREACH page IN accessible_pages %]
                            <div class="file-card">
                                <div class="file-title">
                                    <a href="[% page.url %]">[% page.title %]</a>
                                </div>
                                <div class="file-meta">
                                    <strong>Path:</strong> [% page.path %]<br>
                                    <strong>Site:</strong> [% page.site || 'all' %]
                                </div>
                                <div class="file-roles">
                                    [% IF page.roles %]
                                        [% FOREACH role IN page.roles %]
                                            <span class="role-badge [% role %] [% IF is_admin %]clickable[% END %]" 
                                                  [% IF is_admin %]onclick="editRoles('[% page.title %]')"[% END %]
                                                  title="[% IF is_admin %]Click to edit roles for this page[% ELSE %]Role: [% role | ucfirst %][% END %]">
                                                [% role | ucfirst %]
                                            </span>
                                        [% END %]
                                    [% ELSE %]
                                        <span class="role-badge [% IF is_admin %]clickable[% END %]" 
                                              [% IF is_admin %]onclick="editRoles('[% page.title %]')"[% END %]
                                              title="[% IF is_admin %]Click to edit roles for this page[% ELSE %]Accessible to all users[% END %]">
                                            All Users
                                        </span>
                                    [% END %]
                                </div>
                                
                                [% IF is_admin %]
                                    <div class="file-card-actions">
                                        <div class="roles-edit-hint">
                                            Click roles above to edit access permissions
                                        </div>
                                        <div>
                                            <a href="/Documentation/manage_config/[% page.title | uri %]" class="edit-roles-btn" style="background: #48bb78; margin-right: 8px;">
                                                Manage File Config
                                            </a>
                                            <a href="/Documentation/edit_roles/[% page.title %]" class="edit-roles-btn">
                                                Edit Roles
                                            </a>
                                        </div>
                                    </div>
                                [% END %]
                            </div>
                        [% END %]
                    </div>
                </div>
            </div>
        [% END %]
    [% END %]
</div>

<script>
const DOC_STORAGE_KEY = 'doc_container_states';
const DOC_FILTER_KEY  = 'doc_all_files_filter';

function getContainerStates() {
    try { return JSON.parse(localStorage.getItem(DOC_STORAGE_KEY) || '{}'); }
    catch(e) { return {}; }
}

function saveContainerState(id, open) {
    const states = getContainerStates();
    states[id] = open;
    localStorage.setItem(DOC_STORAGE_KEY, JSON.stringify(states));
}

function expandContainer(header, content) {
    content.classList.add('expanded');
    header.classList.add('expanded');
    const actualHeight = content.scrollHeight;
    const maxAllowedHeight = Math.min(actualHeight, window.innerHeight - 300);
    content.style.maxHeight = maxAllowedHeight + 'px';
    if (actualHeight > maxAllowedHeight) {
        content.style.overflowY = 'auto';
        content.style.overflowX = 'hidden';
    }
}

function collapseContainer(header, content) {
    content.style.maxHeight = '0px';
    content.classList.remove('expanded');
    header.classList.remove('expanded');
}

function toggleContainer(header) {
    const content = header.nextElementSibling;
    const id = header.getAttribute('data-container-id') || header.textContent.trim().substring(0, 30);
    const isExpanded = content.classList.contains('expanded');
    if (isExpanded) {
        collapseContainer(header, content);
        saveContainerState(id, false);
    } else {
        expandContainer(header, content);
        saveContainerState(id, true);
    }
}

// Function to handle role editing
function editRoles(pageName) {
    window.location.href = '/Documentation/edit_roles/' + encodeURIComponent(pageName);
}

// Role filter for "All Files" grid
function filterAllFiles(role, btn) {
    const grid = document.getElementById('all-files-grid');
    const countEl = document.getElementById('all-files-count');
    if (!grid) return;

    const bar = document.getElementById('all-files-filter-bar');
    if (bar) {
        bar.querySelectorAll('.role-filter-btn').forEach(b => b.classList.remove('active'));
    }
    if (btn) btn.classList.add('active');

    const cards = grid.querySelectorAll('.file-card');
    let visible = 0;

    cards.forEach(card => {
        if (role === 'all') {
            card.classList.remove('role-hidden');
            visible++;
        } else {
            const rolesAttr = card.getAttribute('data-roles') || '';
            const roles = rolesAttr ? rolesAttr.split(',').map(r => r.trim()) : [];
            if (roles.includes(role)) {
                card.classList.remove('role-hidden');
                visible++;
            } else {
                card.classList.add('role-hidden');
            }
        }
    });

    if (countEl) {
        countEl.textContent = role === 'all'
            ? ''
            : '— showing ' + visible + ' file' + (visible !== 1 ? 's' : '') + ' with role: ' + role;
    }

    localStorage.setItem(DOC_FILTER_KEY, role);

    const container = grid.closest('.container-content');
    if (container && container.classList.contains('expanded')) {
        const newHeight = container.scrollHeight;
        container.style.maxHeight = Math.min(newHeight, window.innerHeight - 150) + 'px';
    }
}

// Function to trigger manual rescan
function rescanDocumentation() {
    const statusEl = document.getElementById('rescan-status');
    if (statusEl) {
        statusEl.textContent = 'Scanning...';
        statusEl.style.color = '#667eea';
    }

    fetch('[% c.uri_for('/Documentation/rescan') %]')
        .then(response => {
            if (response.redirected) {
                // Show success message before redirect
                if (statusEl) {
                    statusEl.textContent = '✓ Scan complete! Reloading...';
                    statusEl.style.color = '#28a745';
                }
                // Redirect to the page (which will show updated content)
                setTimeout(() => {
                    window.location.href = response.url;
                }, 1000);
            } else {
                throw new Error('Rescan failed');
            }
        })
        .catch(error => {
            console.error('Rescan error:', error);
            if (statusEl) {
                statusEl.textContent = '✗ Error scanning files';
                statusEl.style.color = '#dc3545';
            }
        });
}

document.addEventListener('DOMContentLoaded', function() {
    const states = getContainerStates();

    document.querySelectorAll('.container-header[data-container-id]').forEach(header => {
        const id = header.getAttribute('data-container-id');
        const content = header.nextElementSibling;
        if (states[id] === true) {
            expandContainer(header, content);
        } else {
            content.style.maxHeight = '0px';
        }
    });

    // Restore sticky filter
    const savedFilter = localStorage.getItem(DOC_FILTER_KEY) || 'all';
    const filterBtn = document.querySelector('.role-filter-btn[data-role="' + savedFilter + '"]');
    if (filterBtn) {
        filterAllFiles(savedFilter, filterBtn);
    }
});
</script>