            [% INCLUDE admin/documentation/_workshops_phases.tt %]

            <h4>📁 Documentation & Resources</h4>
            <ul>
                <li>Zenflow Task: <code>workshops-7d21</code></li>
                <li>Requirements: <code>.zenflow/tasks/workshops-7d21/requirements.md</code></li>
