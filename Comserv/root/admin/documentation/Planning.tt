<script>
    // Automatically open the targeted <details> container when navigating via anchor
    function openTargetDetails() {
        const hash = window.location.hash;
        if (hash) {
            const target = document.querySelector(hash);
            if (target) {
                // If the target is an anchor, look for the next details element
                let details = target.tagName === 'DETAILS' ? target : target.nextElementSibling;
                // Skip other anchors or hidden elements if necessary
                while (details && details.tagName !== 'DETAILS' && (details.classList.contains('nav-anchor') || details.nodeType === 3)) {
                    details = details.nextElementSibling;
                }
                
                if (details && details.tagName === 'DETAILS') {
                    details.open = true;
                }
            }
        }
    }

    // Run on load and on hash change
    window.addEventListener('load', openTargetDetails);
    window.addEventListener('hashchange', openTargetDetails);
</script>
