[% META
   title = "Project Planning - Docker Health Monitoring"
   description = "Plan and progress for the Docker Health Monitoring feature"
   roles = "admin"
   TemplateType = "Application"
   category = "System"
   page_version = "0.03"
   last_updated = "2026-03-11"
%]
[% PageVersion = 'admin/documentation/Planning.tt,v 0.03 2026/03/11 Zencoder Exp Zencoder ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">
    <div class="page-header">
        <h1>Project Planning: Docker Health Monitoring</h1>
        <p class="page-subtitle">Tracking the implementation of system-wide health alerts and identification.</p>
    </div>

    <div class="content-container">
        <div class="content-primary">
            [% IF error_msg %]<div class="error">[% error_msg | html %]</div>[% END %]
            [% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
            [% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

            <div class="content-section">
                <h2>Phase 1: Internal Health Monitoring (Server-Side)</h2>
                <ul class="task-list">
                    <li class="completed"><strong>Task 1.1: Support System Identification in Logging</strong> - Updated <code>SystemLog.pm</code> and <code>Logging.pm</code>.</li>
                    <li class="completed"><strong>Task 1.2: Implement ContainerHealthMonitor.pl</strong> - Background service for MySQL and resource monitoring.</li>
                    <li class="completed"><strong>Task 1.3: Update /health endpoint in Root.pm</strong> - Active database and resource checks.</li>
                    <li class="completed"><strong>Task 1.4: Update Supervisor configuration</strong> - Service management via Supervisord.</li>
                </ul>
            </div>

            <div class="content-section">
                <h2>Phase 2: Health API and UI Warning (Client-Side)</h2>
                <ul class="task-list">
                    <li class="completed"><strong>Task 2.1: Implement Admin::Health controller</strong> - API for UI polling.</li>
                    <li class="completed"><strong>Task 2.2: Implement HealthMonitor.js</strong> - Banner alerts and web notifications.</li>
                    <li class="completed"><strong>Task 2.3: Integrate into global template</strong> - Integrated into admin views.</li>
                </ul>
            </div>

            <div class="content-section">
                <h2>Phase 3: Documentation & Verification</h2>
                <ul class="task-list">
                    <li class="completed"><strong>Task 3.1: Create User Guide and How-to</strong> - Located at <a href="/Documentation/HealthMonitoringGuide.tt">Health Monitoring Guide</a>.</li>
                    <li class="completed"><strong>Task 3.2: Playwright E2E Tests</strong> - Automated verification of UI banner (created <code>tests/HealthMonitoring.spec.js</code>).</li>
                    <li class="in-progress"><strong>Task 3.3: Manual Verification</strong> - Inducing failures to confirm email/UI alerts.</li>
                    <li><strong>Task 3.4: Final Report</strong> - Documenting final implementation details.</li>
                    <li class="in-progress"><strong>Task 3.5: Fix Random Logout Issue</strong> - Investigating session stability in <code>File.pm</code> and <code>WorkShop.pm</code>.</li>
                </ul>
            </div>
            
            <div class="content-section">
                <h2>Notes & Requirements</h2>
                <ul>
                    <li><strong>Database</strong>: All operations must use MySQL (SQLite is not in use).</li>
                    <li><strong>Schema Management</strong>: Table changes via <code>schema_compare</code> or Application API.</li>
                    <li><strong>System Identification</strong>: Alerts must identify the specific system (e.g., Production, Workstation2).</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
.task-list { list-style: none; padding-left: 0; }
.task-list li { margin-bottom: 10px; padding: 5px; border-left: 4px solid #ccc; }
.task-list li.completed { border-left-color: #28a745; background-color: #f8fff8; }
.task-list li.in-progress { border-left-color: #ffc107; background-color: #fffbef; font-weight: bold; }
.task-list li.completed::before { content: "✓ "; color: #28a745; }
</style>
