            <details id="aichat-system" class="priority-container">
                <summary class="priority-summary">🤖 AI Chat System Enhancement & Agent Architecture [Project #114]</summary>
                <div class="priority-content">
                    [%# Fetch project data from database %]
                    [% TRY %]
                        [% SET schema = c.model('DBEncy').schema %]
                        [% SET project = schema.resultset('Project').find(114) %]
                        
                        [% IF project %]
                            <div class="project-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; padding: 10px; background: #f8f9fa; border-radius: 5px;">
                                <div>
