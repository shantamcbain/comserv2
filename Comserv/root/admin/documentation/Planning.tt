[%# Define all version, date, and path variables in one place here %]
[% version = '0.75' %]
[% date_iso = '2026/03/20' %]
[% formatted_date = 'March 20, 2026' %]
[% time = '16:30:00' %]
[% change_log = 'Planning System Migration: DB-driven model now live for all sites via DailyPlan.tt. Non-CSC sites see DB plans only. CSC sees DB plans + this legacy text section. SiteName-based access controls implemented. Plan creation form live at /admin/plan/create. Normal/user/editor roles now have planning access. NEXT: migrate remaining text groups below into DB records, then remove text section entirely.' %]
[%# Determine file path for metadata %]
[% file_path = 'admin/documentation/Planning.tt' %]


[% META title = 'Application Planning System'
description = 'Planning System (Database-Driven Migration): Complete 15-phase workflow (P0-P14). Phase 0 COMPLETE. First container: Planning System project details from database. Second container: All existing projects with hierarchy (top → sub → sub-sub). Third: All workflow phases as sub-projects with tasks and todos. Includes database env management, schema design, RBAC, controllers, templates, testing, deployment. Integrated with Project.pm for real-time data. DailyPlan UI, Todo System, Architecture, AI Systems, Sync & Standards sections included.'
roles = 'admin,developer'
TemplateType = 'PriorityList'
category = 'todo,priority,blocking,planning-system,workflow,project-integration,database-driven'
page_version = '0.52'
last_updated = '2026/02/08'
%]

[% PageVersion = file_path _ ' ,v ' _ version _ ' ' _ date_iso _ ' ' _ time _ ' ' _ change_log %]

[% IF c.session.debug_mode == 1 %]
[% PageVersion %]
[% END %]

<style>
    /* Force visibility of content when details is open */
    details[open] > .priority-content,
    details[open] > .section-content,
    details[open] > .jump-links-container {
        max-height: none !important;
        overflow: visible !important;
        display: block !important;
        padding: 10px !important;
        visibility: visible !important;
        opacity: 1 !important;
    }

    /* Sticky/Floating Quick Jump Navigation */
    .nav-jump {
        position: sticky;
        top: 50px; /* Position below the sticky nav menu */
        z-index: 1500; /* Below nav menu (2000) but still high */
        background: var(--background-color, white);
        border: 2px solid var(--border-color, #dee2e6);
        border-radius: 4px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }
    
    .nav-jump summary {
        padding: 10px 15px;
        font-weight: bold;
        cursor: pointer;
        background: var(--secondary-color, #e9ecef);
        border-radius: 4px;
        user-select: none;
    }
    
    .nav-jump summary:hover {
        background: var(--nav-hover-bg, #dee2e6);
    }

    /* Ultra-compact horizontal jump links */
    .jump-links-container {
        padding: 8px;
        background: var(--table-header-bg, #f8f9fa);
        border: 1px solid var(--border-color, #dee2e6);
        border-radius: 4px;
        font-size: 0.9em;
        line-height: 1.6;
    }

    /* Status styling classes */
    .status-pending { color: #dc3545; font-weight: bold; background: #f8d7da; padding: 2px 6px; border-radius: 3px; }
    .status-in-progress { color: #856404; font-weight: bold; background: #fff3cd; padding: 2px 6px; border-radius: 3px; }
    .status-completed { color: #155724; font-weight: bold; background: #d4edda; padding: 2px 6px; border-radius: 3px; }
    .jump-line {
        margin-bottom: 4px;
    }
    .jump-line:last-child {
        margin-bottom: 0;
    }
    .jump-link {
        color: #0056b3;
        text-decoration: none;
        padding: 0 4px;
        white-space: nowrap;
    }
    .jump-link:hover {
        text-decoration: underline;
        background: #e9ecef;
    }

    /* Navigation Anchors - strictly for positioning jump targets */
    .nav-anchor {
        display: block;
        position: relative;
        visibility: hidden;
        scroll-margin-top: 180px; /* Account for sticky nav menu (~50px) + Quick Jump menu (~100px) + margin */
    }

    /* Target highlight for containers when jump link is used */
    .priority-container:target, .doc-section:target, .priority-group-container:target {
        border: 2px solid #007bff;
        box-shadow: 0 0 10px rgba(0,123,255,0.2);
    }

    /* Group container styling */
    .priority-group-container {
        margin-bottom: 20px;
        border: 2px solid #dee2e6;
        border-radius: 6px;
        background-color: #f8f9fa;
    }

    .group-header {
        font-size: 1.3em;
        font-weight: bold;
        padding: 12px 15px;
        cursor: pointer;
        background-color: #e9ecef;
        border-radius: 4px 4px 0 0;
        color: #495057;
    }

    .group-header:hover {
        background-color: #dee2e6;
    }

    .priority-group-container > .priority-content {
        padding: 15px;
    }

    /* Sub-container styling - nested priority containers */
    .priority-group-container .priority-container {
        margin-bottom: 10px;
        border: 1px solid #dee2e6;
    }
</style>

<div class="container">
    <h1>Planning (CSC — Legacy Text View)</h1>

    <!-- YOU ARE HERE banner -->
    <div style="background:#cce5ff;border:1px solid #004085;border-radius:6px;padding:10px 16px;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:0.9em;">
            <strong>📍 YOU ARE HERE:</strong>
            Step 3 of 7 — <em>Refactor MasterPlanCoordination to coordinator-only role</em> &nbsp;·&nbsp;
            <a href="#anchor-planning-system-project" style="color:#004085;font-weight:bold;">View full plan status ↓</a>
        </span>
        <span style="font-size:0.82em;color:#004085;">
            Branch: <code>planningsystem-59ae</code> &nbsp;·&nbsp;
            <a href="/Documentation/DailyPlan#planning" style="color:#004085;">Back to DB view</a>
        </span>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         MIGRATION STATUS — March 2026
         This section is ONLY visible to CSC users. All other sites now
         see the DB-driven plan list at the top of the PLANNING tab.
         Goal: migrate all groups below into DB records, then delete this file.
    ═══════════════════════════════════════════════════════════════ -->
    <div style="background:#fff3cd;border:2px solid #ffc107;border-radius:6px;padding:14px 18px;margin-bottom:18px;">
        <strong>⚠️ LEGACY TEXT PLANNING — BEING MIGRATED</strong>
        <p style="margin:6px 0 0;">This text-based planning view is <strong>CSC-admin-only</strong> and is being replaced by the DB-driven plan list above.
        Non-CSC sites (BMaster, Shanta, etc.) no longer see this section — they use the database model only.
        The goal is to enter each project/plan below into the database, then remove this entire section.</p>
        <p style="margin:6px 0 0;">
            <strong>Current migration progress:</strong>
            <span style="background:#28a745;color:#fff;padding:1px 7px;border-radius:3px;font-size:0.85em;">DB Model LIVE ✓</span>
            <span style="background:#ffc107;color:#333;padding:1px 7px;border-radius:3px;font-size:0.85em;">Migrating projects ⏳</span>
            <span style="background:#6c757d;color:#fff;padding:1px 7px;border-radius:3px;font-size:0.85em;">Remove text view 🔜</span>
        </p>
        <p style="margin:8px 0 0;font-size:0.9em;">
            <strong>What "Start Next Step" means:</strong>
            The Zenflow task listed for each group has phases. "Start Next Step" = the next unchecked phase box in that group's task plan.
            Before starting, verify: (1) all previous phase boxes are ✅, (2) no blocking dependencies are open,
            (3) the feature branch for that task is active (check port assignments in Active Zenflow Workflows below).
        </p>
    </div>

    <!-- HOW TO ADD A PLAN (Plan vs Project) -->
    <details style="background:var(--secondary-color);border:1px solid var(--border-color);border-radius:6px;padding:0;margin-bottom:18px;">
        <summary style="padding:12px 16px;cursor:pointer;font-weight:bold;">📖 How to Add a Plan — Plan vs Project (click to expand)</summary>
        <div style="padding:14px 16px;font-size:0.93em;line-height:1.6;">
            <h4 style="margin-top:0;">Plan vs Project — what's the difference?</h4>
            <table style="border-collapse:collapse;width:100%;font-size:0.92em;">
                <thead>
                    <tr style="background:var(--primary-color);color:#fff;">
                        <th style="padding:8px 12px;text-align:left;">Concept</th>
                        <th style="padding:8px 12px;text-align:left;">Plan</th>
                        <th style="padding:8px 12px;text-align:left;">Project</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">What it is</td>
                        <td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">A time-boxed focus sprint or theme (e.g. "Q2 Hive Expansion")</td>
                        <td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">A deliverable system or feature (e.g. "Planning System", "AI Chat")</td></tr>
                    <tr><td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">Answers</td>
                        <td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">"What are we focusing on right now?"</td>
                        <td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">"What are we building?"</td></tr>
                    <tr><td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">Scoped to</td>
                        <td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">SiteName, has priority + status + dates</td>
                        <td style="padding:6px 12px;border-bottom:1px solid var(--border-color);">Has project code, developer, todos</td></tr>
                    <tr><td style="padding:6px 12px;">Linked via</td>
                        <td style="padding:6px 12px;" colspan="2">Many-to-many <code>daily_plan_projects</code> join table — one plan can span multiple projects</td></tr>
                </tbody>
            </table>
            <h4 style="margin-top:14px;">Steps to add a Plan (DB-driven):</h4>
            <ol style="margin:0;padding-left:20px;">
                <li>Click <strong>+ New Plan</strong> at the top of the PLANNING tab (or go to <a href="/admin/plan/create">/admin/plan/create</a>).</li>
                <li>Fill in: <strong>Plan Name</strong> (required), Description, Status (active/paused/completed), Priority (1=highest), Start Date, Due Date.</li>
                <li>The plan is automatically scoped to your <strong>SiteName</strong> — CSC admins can see all sites; other admins see only their own.</li>
                <li>After saving, add <strong>Todos</strong> to the plan via the Todo System (<a href="/todo/addtodo">/todo/addtodo</a>) — link the todo to the plan.</li>
                <li>To add a <strong>Project</strong> to the plan, use the project DB (<a href="/project">/project</a>) and associate via <code>daily_plan_projects</code>.</li>
            </ol>
            <p style="margin:10px 0 0;font-size:0.88em;color:var(--text-muted-color);">
                <strong>Routes:</strong> Admin access via <code>/admin</code> | User profile &amp; role info at <code>/user/profile</code> |
                Roles with planning access: admin, developer, devops, editor, user, normal (all above member).
            </p>
        </div>
    </details>

    <div class="row">
        <div class="col-12">
            <!-- Priority Todos Quick Navigation Menu -->
            <details class="nav-jump" open>
                <summary>🎯 Quick Jump to Priority (Click to Toggle)</summary>
                <div class="jump-links-container">
                    <div class="jump-line" style="background:#d4edda;padding:4px 8px;border-radius:3px;margin-bottom:6px;">
                        <strong>📅 <a href="/Documentation/DailyPlan#planning" class="jump-link">DB-Driven Plans (live)</a></strong>:
                        <a href="/admin/plan/create" class="jump-link">+ New Plan</a> |
                        <a href="/Documentation/DailyPlan#planning" class="jump-link">View All Plans</a> |
                        <a href="/todo" class="jump-link">Todo System</a> |
                        <a href="/todo/addtodo" class="jump-link">+ Add Todo</a>
                    </div>
                    <div class="jump-line">
                        <strong><a href="#group-docker-k8s" class="jump-link">🐳 Docker and K8s Management</a></strong>:
                        <a href="#anchor-project-config-test" class="jump-link">ProjectConfig</a>
                    </div>
                    <div class="jump-line">
                        <strong><a href="#group-docker-k8s" class="jump-link">✅ Docker Bug (COMPLETED)</a></strong>:
                        <a href="#anchor-dockerbug-completed" class="jump-link">DockerBugFix</a> |
                        <a href="#anchor-env-vars-admin" class="jump-link">EnvVarsAdmin</a>
                    </div>
                    <div class="jump-line">
                        <strong><a href="#group-arch" class="jump-link">🏗️ Architecture & Infrastructure</a></strong>:
                        <a href="#anchor-api-bc05" class="jump-link">ApiSystemBC05</a> |
                        <a href="#anchor-priority-11" class="jump-link">ArchMigrationPhase2</a> |
                        <a href="#anchor-priority-4" class="jump-link">MasterPlanRefactor</a> |
                        <a href="#anchor-priority-schema" class="jump-link">SchemaManagement</a> |
                        <a href="#anchor-priority-ha" class="jump-link">InfrastructureHA</a> |
                        <a href="#anchor-priority-19" class="jump-link">UpdatepromptFix</a> |
