[% META title = 'Priority Todos - Blocking Dependencies'
   description = 'Critical priority tasks blocking development progress, ordered by dependency chain. Includes Architecture Migration Phase 2, DailyPlan System, Project IDs, Theme Sync, and Fix updateprompt.pl API Logging. All sections collapsible for improved readability.'
