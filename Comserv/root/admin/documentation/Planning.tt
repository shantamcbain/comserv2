<script>
    function openTargetDetails() {
        const hash = window.location.hash;
        if (!hash) return;
        
        try {
            const target = document.querySelector(hash);
            if (!target) return;
            
            // If we are inside a tabbed interface (like DailyPlan.tt), ensure our tab is active
            let tabContent = target.closest('.tab-content');
            if (tabContent && !tabContent.classList.contains('active')) {
                if (typeof switchTab === 'function') {
                    switchTab(null, tabContent.id);
                } else {
                    tabContent.classList.add('active');
                }
            }

            // If target is a nav-anchor, we want to open the container immediately following it
            let container = target;
            if (target.classList.contains('nav-anchor')) {
                container = target.nextElementSibling;
            }
            
            if (!container) return;

            // If the container is a details element or inside one
            let details = container.tagName.toUpperCase() === 'DETAILS' ? container : container.closest('details');
            
            // If still not found, check if it's a div containing a details
            if (!details && container.tagName.toUpperCase() === 'DIV') {
                details = container.querySelector('details');
            }
            
            if (details) {
                details.open = true;
                // Recursive open if nested
                let parent = details.parentElement.closest('details');
                while (parent) {
                    parent.open = true;
                    parent = parent.parentElement.closest('details');
                }
            }
            
            // Smooth scroll to the container (not the hidden anchor)
            // The scroll-margin-top handles the offset
            setTimeout(() => {
                container.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);

        } catch (e) {
            console.error("Error navigating to hash:", e);
        }
    }

    // Handle all hash links (including absolute paths with hashes)
    document.addEventListener('click', function(e) {
        const link = e.target.closest('a[href*="#"]');
        if (link) {
            const url = new URL(link.href, window.location.origin);
            if (url.pathname === window.location.pathname) {
                // Give time for browser to update hash
                setTimeout(openTargetDetails, 50);
            }
        }
    });

    window.addEventListener('load', openTargetDetails);
    window.addEventListener('hashchange', openTargetDetails);
</script>
