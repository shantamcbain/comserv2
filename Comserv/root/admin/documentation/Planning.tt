[%# Define all version, date, and path variables in one place here %]
[% version = '0.47' %]
[% date_iso = '2026/02/07' %]
[% formatted_date = 'February 07, 2026' %]
[% time = '16:35:00' %]
[% change_log = 'Updated Infrastructure HA section with recent progress: Dell 710 sub-project added, K8s control plane installed on VM 101, Plan Management System completed. Added Project Table Integration placeholder. Renamed DailyPlan UI/UX group to Planning System. Added ALL 15 phases (0-14) as visible sub-projects with complete todo lists and dependencies. Phase 0 COMPLETE (6 steps, 74K docs). Phases 1-14 PENDING (database env, schema, RBAC, controllers, templates, testing, deployment). Updated jump links to show all phases (P0-P14). Improved navigation structure with phase shortcuts. All workflow steps now visible in browser for easy tracking.' %]
[%# Determine file path for metadata %]
[% file_path = 'admin/documentation/Planning.tt' %]


[% META title = 'Application Planning System'
description = 'Planning System migration from text-based to database-driven. Complete 15-phase workflow (P0-P14) with all tasks and dependencies visible. Phase 0 COMPLETE (6 steps, 74K docs). Phases 1-14 PENDING (database env, schema, RBAC, controllers, templates, testing, deployment). Each phase shows objectives, tasks, dependencies, verification. Includes DailyPlan UI, Todo System, Architecture, AI Systems, Sync & Standards. All sections collapsible with full progress tracking.'
roles = 'admin,developer'
TemplateType = 'PriorityList'
category = 'todo,priority,blocking,planning-system,workflow'
page_version = '0.47'
last_updated = '2026/02/07'
%]

[% PageVersion = file_path _ ' ,v ' _ version _ ' ' _ date_iso _ ' ' _ time _ ' ' _ change_log %]

[% IF c.session.debug_mode == 1 %]
[% PageVersion %]
[% END %]

<style>
    /* Force visibility of content when details is open */
    details[open] > .priority-content,
    details[open] > .section-content,
    details[open] > .jump-links-container {
        max-height: none !important;
        overflow: visible !important;
        display: block !important;
        padding: 10px !important;
        visibility: visible !important;
        opacity: 1 !important;
    }

    /* Ultra-compact horizontal jump links */
    .jump-links-container {
        padding: 8px;
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        font-size: 0.9em;
        line-height: 1.6;
    }

    /* Status styling classes */
    .status-pending { color: #dc3545; font-weight: bold; background: #f8d7da; padding: 2px 6px; border-radius: 3px; }
    .status-in-progress { color: #856404; font-weight: bold; background: #fff3cd; padding: 2px 6px; border-radius: 3px; }
    .status-completed { color: #155724; font-weight: bold; background: #d4edda; padding: 2px 6px; border-radius: 3px; }
    .jump-line {
        margin-bottom: 4px;
    }
    .jump-line:last-child {
        margin-bottom: 0;
    }
    .jump-link {
        color: #0056b3;
        text-decoration: none;
        padding: 0 4px;
        white-space: nowrap;
    }
    .jump-link:hover {
        text-decoration: underline;
        background: #e9ecef;
    }

    /* Navigation Anchors - strictly for positioning jump targets */
    .nav-anchor {
        display: block;
        position: relative;
        visibility: hidden;
        scroll-margin-top: 140px; /* Leave container header exposed */
    }

    /* Target highlight for containers when jump link is used */
    .priority-container:target, .doc-section:target, .priority-group-container:target {
        border: 2px solid #007bff;
        box-shadow: 0 0 10px rgba(0,123,255,0.2);
    }

    /* Group container styling */
    .priority-group-container {
        margin-bottom: 20px;
        border: 2px solid #dee2e6;
        border-radius: 6px;
        background-color: #f8f9fa;
    }

    .group-header {
        font-size: 1.3em;
        font-weight: bold;
        padding: 12px 15px;
        cursor: pointer;
        background-color: #e9ecef;
        border-radius: 4px 4px 0 0;
        color: #495057;
    }

    .group-header:hover {
        background-color: #dee2e6;
    }

    .priority-group-container > .priority-content {
        padding: 15px;
    }

    /* Sub-container styling - nested priority containers */
    .priority-group-container .priority-container {
        margin-bottom: 10px;
        border: 1px solid #dee2e6;
    }
</style>

