[%# Define all version, date, and path variables in one place here %]
[% version = '0.41' %]
[% date_iso = '2026/02/05' %]
[% formatted_date = 'February 05, 2026' %]
[% time = '17:25:00' %]
[% change_log = 'Added Infrastructure Resilience & High Availability Architecture workflow to Architecture & Infrastructure section.' %]
[%# Determine file path for metadata %]
[% file_path = 'admin/documentation/Planning.tt' %]


[% META title = 'Application planning - '
description = 'Critical priority tasks blocking development progress, ordered by dependency chain. Includes Architecture Migration Phase 2, DailyPlan System, Project IDs, Theme Sync, Fix updateprompt.pl API Logging, and ToDo System Update Plan. All sections collapsible for improved readability.'
roles = 'admin,developer'
TemplateType = 'PriorityList'
category = 'todo,priority,blocking'
page_version = '0.34'
last_updated = '2026/02/01'
%]

[% PageVersion = file_path _ ' ,v ' _ version _ ' ' _ date_iso _ ' ' _ time _ ' ' _ change_log %]

[% IF c.session.debug_mode == 1 %]
[% PageVersion %]
[% END %]

<style>
    /* Force visibility of content when details is open */
    details[open] > .priority-content,
    details[open] > .section-content,
    details[open] > .jump-links-container {
        max-height: none !important;
        overflow: visible !important;
        display: block !important;
        padding: 10px !important;
        visibility: visible !important;
        opacity: 1 !important;
    }

    /* Ultra-compact horizontal jump links */
    .jump-links-container {
        padding: 8px;
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        font-size: 0.9em;
        line-height: 1.6;
    }

    /* Status styling classes */
    .status-pending { color: #dc3545; font-weight: bold; background: #f8d7da; padding: 2px 6px; border-radius: 3px; }
    .status-in-progress { color: #856404; font-weight: bold; background: #fff3cd; padding: 2px 6px; border-radius: 3px; }
    .status-completed { color: #155724; font-weight: bold; background: #d4edda; padding: 2px 6px; border-radius: 3px; }
    .jump-line {
        margin-bottom: 4px;
    }
    .jump-line:last-child {
        margin-bottom: 0;
    }
    .jump-link {
        color: #0056b3;
        text-decoration: none;
        padding: 0 4px;
        white-space: nowrap;
    }
    .jump-link:hover {
        text-decoration: underline;
        background: #e9ecef;
    }

    /* Navigation Anchors - strictly for positioning jump targets */
    .nav-anchor {
        display: block;
        position: relative;
        visibility: hidden;
        scroll-margin-top: 140px; /* Leave container header exposed */
    }

    /* Target highlight for containers when jump link is used */
    .priority-container:target, .doc-section:target, .priority-group-container:target {
        border: 2px solid #007bff;
        box-shadow: 0 0 10px rgba(0,123,255,0.2);
    }
</style>

