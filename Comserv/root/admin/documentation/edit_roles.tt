[%# Edit Roles Template for Documentation %]
[% META title = 'Edit Documentation Roles' %]
[% META description = 'Edit roles for a documentation page' %]
[% PageVersion = 'admin/documentation/edit_roles.tt,v 1.03 2026/04/22 theme-audit-P4' %]

[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<head>
    <style>
        .er-wrap {
            max-width: 900px;
            margin: 10px auto;
            font-family: Arial, sans-serif;
        }

        .er-topbar {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
            gap: 10px;
            flex-wrap: wrap;
        }

        .er-title-block h2 { margin: 0 0 2px; font-size: 1.2em; color: var(--text-color, #333); }
        .er-title-block h3 { margin: 0 0 2px; font-size: 1em; color: var(--text-color, #444); }
        .er-title-block .er-path { font-size: 12px; color: var(--text-muted-color, #666); }

        .er-topbar-actions { display: flex; gap: 8px; flex-shrink: 0; }

        .er-main {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            align-items: start;
        }

        .er-card {
            background: var(--card-bg, rgba(255,255,255,0.88));
            border: 1px solid var(--border-color, #dee2e6);
            border-radius: 6px;
            padding: 14px 16px;
        }

        .er-card h4 {
            margin: 0 0 10px;
            font-size: 0.9em;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-color, #495057);
            border-bottom: 1px solid var(--border-color, #dee2e6);
            padding-bottom: 6px;
        }

        .er-current-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 12px;
        }

        .er-badge {
            background: #343a40;
            color: #fff;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 12px;
        }

        .er-help-list {
            font-size: 12px;
            color: var(--text-color, #555);
            line-height: 1.7;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .er-help-list li strong { color: var(--text-color, #333); }

        /* Role checkboxes grid */
        .er-roles-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 14px;
        }

        .er-role-option {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border: 2px solid var(--border-color, #dee2e6);
            border-radius: 5px;
            background: var(--bg-secondary, #f8f9fa);
            cursor: pointer;
            transition: all 0.15s ease;
        }

        .er-role-option:hover { border-color: #2c7be5; background: #e8f0fe; }
        .er-role-option.selected { border-color: #2c7be5; background: #dceeff; }

        .er-role-option input[type="checkbox"] { margin: 0; cursor: pointer; }

        .er-role-label { font-size: 13px; font-weight: 500; color: var(--text-color, #333); text-transform: capitalize; cursor: pointer; line-height: 1.2; }
        .er-role-desc  { font-size: 11px; color: var(--text-muted-color, #888); }

        .er-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 4px;
        }

        .btn {
            padding: 7px 16px;
            border: none;
            border-radius: 5px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: all 0.2s ease;
        }
        .btn-primary  { background: #2c7be5; color: #fff; }
        .btn-primary:hover { background: #1a68c7; color: #fff; }
        .btn-success  { background: var(--success-color, #28a745); color: #fff; }
        .btn-success:hover { background: #1e7e34; color: #fff; }
        .btn-secondary { background: #e2e8f0; color: #4a5568; }
        .btn-secondary:hover { background: #cbd5e0; }

        .er-alert {
            padding: 10px 14px;
            border-radius: 5px;
            margin-bottom: 12px;
            font-size: 13px;
        }
        .er-alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .er-alert-error   { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

        @media (max-width: 640px) {
            .er-main { grid-template-columns: 1fr; }
            .er-roles-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>

<div class="er-wrap">

    [% IF success_message %]
        <div class="er-alert er-alert-success">[% success_message %]</div>
    [% END %]
    [% IF error_message %]
        <div class="er-alert er-alert-error">[% error_message %]</div>
    [% END %]

    <div class="er-topbar">
        <div class="er-title-block">
            <h2>Edit Documentation Roles</h2>
            <h3>[% page_title %]</h3>
            <div class="er-path"><strong>Path:</strong> [% page_metadata.path %]</div>
        </div>
        <div class="er-topbar-actions">
            <a href="[% c.uri_for('/Documentation/manage_config') %]" class="btn btn-primary">Full Config Manager</a>
        </div>
    </div>

    <div class="er-main">

        <!-- Left: current roles + help -->
        <div class="er-card">
            <h4>Current Access</h4>
            <div class="er-current-badges">
                [% IF current_roles.size > 0 %]
                    [% FOREACH role IN current_roles %]
                        <span class="er-badge">[% role | ucfirst %]</span>
                    [% END %]
                [% ELSE %]
                    <span class="er-badge" style="background: var(--secondary-color, #6c757d);">No Roles Set</span>
                [% END %]
            </div>
            <h4>Role Reference</h4>
            <ul class="er-help-list">
                <li><strong>Normal / User</strong> — basic authenticated users</li>
                <li><strong>Editor</strong> — content managers</li>
                <li><strong>Developer</strong> — technical staff</li>
                <li><strong>Admin</strong> — system administrators</li>
                <li><strong>CSC Admin</strong> — full system access</li>
            </ul>
        </div>

        <!-- Right: form -->
        <div class="er-card">
            <h4>Select Roles</h4>
            <form method="POST" action="/Documentation/update_roles/[% page_name | uri %]">
                <div class="er-roles-grid">
                    [% FOREACH role IN available_roles %]
                        [% is_checked = 0 %]
                        [% FOREACH current_role IN current_roles %]
                            [% IF current_role == role %][% is_checked = 1 %][% LAST %]
                            [% END %]
                        [% END %]
                        <div class="er-role-option [% IF is_checked %]selected[% END %]" onclick="toggleRole(this)">
                            <input type="checkbox"
                                   name="roles"
                                   value="[% role %]"
                                   id="role_[% role %]"
                                   [% IF is_checked %]checked[% END %]>
                            <label for="role_[% role %]">
                                <div class="er-role-label">[% role | ucfirst %]</div>
                                [% IF role == 'normal' || role == 'user' %]
                                    <div class="er-role-desc">Basic users</div>
                                [% ELSIF role == 'editor' %]
                                    <div class="er-role-desc">Content managers</div>
                                [% ELSIF role == 'admin' %]
                                    <div class="er-role-desc">Administrators</div>
                                [% ELSIF role == 'developer' %]
                                    <div class="er-role-desc">Technical staff</div>
                                [% ELSIF role == 'csc_admin' %]
                                    <div class="er-role-desc">Full access</div>
                                [% END %]
                            </label>
                        </div>
                    [% END %]
                </div>

                <div class="er-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/Documentation/manage_config?file=[% page_name | uri %]" class="btn btn-success">Manage File Config</a>
                    <a href="/Documentation" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>

    </div>
</div>

<script>
function toggleRole(element) {
    const checkbox = element.querySelector('input[type="checkbox"]');
    checkbox.checked = !checkbox.checked;
    element.classList.toggle('selected', checkbox.checked);
}
</script>
