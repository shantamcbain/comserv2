[% META 
   title = "Daily Plan - Weekly Priority View"
   description = "Weekly priority tasks organized by day with collapsible daily sections. Current day open, others collapsed."
   roles = "admin,developer,devops"
   TemplateType = "Application"
   category = "planning,priorities,daily-tasks"
   page_version = "1.10"
   last_updated = "Tue Jan 28 16:43:00 UTC 2026"
   site_specific = "false"
%]
[% PageVersion = 'admin/documentation/DailyPlan.tt, v 2.0 2026/03/20 SiteName-aware: CSC-only tabs conditionally shown; DB plan list in PLANNING tab for all sites.' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]
[% SET is_csc = is_csc || (c.stash.SiteName == 'CSC') || (c.session.SiteName == 'CSC') %]
[% SET plan_sitename = plan_sitename || c.stash.SiteName || c.session.SiteName || 'CSC' %]

<style>
    /* Sticky Header Styles */
    .daily-plan-header {
        position: sticky;
        top: 0;
        background-color: var(--background-color);
        border-bottom: 3px solid var(--primary-color);
        padding: 10px 15px;
        margin: -20px -20px 20px -20px;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .daily-plan-header h1 {
        margin: 0 0 5px 0;
        font-size: 1.4em;
        color: var(--text-color);
    }
    
    .header-nav {
        display: flex;
        gap: 20px;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85em;
    }
    
    .header-nav-links {
        display: flex;
        gap: 15px;
        }
    
    .header-nav-links a {
        color: var(--primary-color);
        text-decoration: none;
        padding: 5px 10px;
        border-radius: 3px;
    }
    
    .header-nav-links a:hover {
        background-color: var(--bg-secondary);
    }
    
    /* Tab Styles */
    .tab-navigation {
        display: flex;
        border-bottom: 2px solid var(--border-color);
        margin: 20px 0 0 0;
        gap: 5px;
    }
    
    .tab-button {
        padding: 12px 24px;
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 1em;
        font-weight: 500;
        color: var(--text-muted-color);
        border-bottom: 3px solid transparent;
        transition: all 0.2s ease;
    }
    
    .tab-button:hover {
        color: var(--text-color);
        background-color: var(--secondary-color);
    }
    
    .tab-button.active {
        color: var(--text-color) !important;
        background-color: var(--bg-secondary) !important;
        border-bottom-color: var(--primary-color) !important;
        border-bottom-width: 4px !important;
        font-weight: bold;
    }
    
    .tab-content {
        display: none;
    }
    
    .tab-content.active {
        display: block;
    }
</style>

[% 
    display_date_str = selected_date;
    
    days = [
        { date = '2026-01-21', display = 'Wednesday, January 21, 2026' },
        { date = '2026-01-22', display = 'Thursday, January 22, 2026' },
        { date = '2026-01-23', display = 'Friday, January 23, 2026' },
        { date = '2026-01-24', display = 'Saturday, January 24, 2026' },
        { date = '2026-01-25', display = 'Sunday, January 25, 2026' },
        { date = '2026-01-26', display = 'Monday, January 26, 2026' },
        { date = '2026-01-27', display = 'Tuesday, January 27, 2026' },
    ];
%]

<div class="container">
    <!-- Sticky Header with Navigation -->
    <div class="daily-plan-header">
        <h1>[DAILY PLAN] [% display_date %]</h1>
        <div class="header-nav">
            <div class="header-nav-links">
                <span><strong>Today:</strong> [% current_display %]</span>
                <span>|</span>
                <a href="/Documentation/DailyPlan/[% current_date_str %]">[Jump to Today]</a>
                <a href="/Documentation/MasterPlanCoordination" target="_blank">Master Plans</a>
                <a href="/Documentation">All Docs</a>
                <a href="/todo">Todo System</a>
            </div>
            <div style="text-align: right; color: var(--text-muted-color); font-size: 0.85em;">
                <a href="/Documentation/DailyPlan/[% prev_date %]" class="prev-day-link">← Prev Day</a>
                | Viewing [% display_date %] |
                <a href="/Documentation/DailyPlan/[% next_date %]" class="next-day-link">Next Day →</a>
            </div>
        </div>
    </div>

    <!-- Tab Navigation -->
    <div class="tab-navigation">
        <button class="tab-button active" onclick="switchTab(event, 'today-work')">
            DAILY PRIORITIES
        </button>
        <button class="tab-button" onclick="switchTab(event, 'daily-schedule')">
            🕐 DAILY SCHEDULE
        </button>
        <button class="tab-button" onclick="switchTab(event, 'weekly-view')">
            📅 THIS WEEK
        </button>
        <button class="tab-button" onclick="switchTab(event, 'month-view')">
            MONTH VIEW
        </button>
        <button class="tab-button" onclick="switchTab(event, 'planning')">
            PLANNING
        </button>
        <button class="tab-button" onclick="switchTab(event, 'gantt-view')">
            📊 GANTT
        </button>
        <button class="tab-button" onclick="switchTab(event, 'resources-view')">
            RESOURCES & CONTEXT
        </button>
        [% IF is_csc %]
        <button class="tab-button" onclick="switchTab(event, 'daily-plan-guide')">
            DAILY PLAN GUIDE
        </button>
        <button class="tab-button" onclick="switchTab(event, 'zencoder-prompt')">
            ZENCODER PROMPT
        </button>
        <button class="tab-button" onclick="switchTab(event, 'master-plan-coordination')">
            MASTER PLAN COORDINATION
        </button>
        [% END %]
    </div>

<!-- TAB 1: TODAY'S WORK (Default) -->
    <div id="today-work" class="tab-content active">
        <div id="today-work-content">

            [%# ── CURRENT ACTIVE PRIORITIES (DB-driven, role/site/user scoped) ── %]
            <div style="margin-bottom:24px;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;padding-bottom:8px;border-bottom:2px solid var(--primary-color);">
                    <h3 style="margin:0;font-size:1.1em;">🎯 Current Active Priorities</h3>
                    <div style="display:flex;gap:8px;flex-wrap:wrap;">
                        <a href="/todo/addtodo" style="background:var(--primary-color);color:#fff;padding:4px 12px;border-radius:4px;text-decoration:none;font-size:0.82em;">+ Add Todo</a>
                        <a href="/todo" style="padding:4px 12px;border:1px solid var(--border-color);border-radius:4px;text-decoration:none;font-size:0.82em;color:var(--text-color);">All Todos</a>
                        <a href="/log" style="padding:4px 12px;border:1px solid var(--border-color);border-radius:4px;text-decoration:none;font-size:0.82em;color:var(--text-color);">Logs</a>
                        [% IF is_admin %]
                        <a href="/log/log_form?todo_record_id=221&abstract=Good+Morning+%E2%98%80+Work+Session&details=Daily+work+session+log+started+by+[% c.session.username %]&status=2" style="padding:4px 12px;border:1px solid #20c997;border-radius:4px;text-decoration:none;font-size:0.82em;color:#20c997;" title="Start a new time-tracking log entry for this session">☀ Good Morning</a>
                        <button onclick="triageStale()" style="padding:4px 12px;border:1px solid #fd7e14;border-radius:4px;background:transparent;font-size:0.82em;color:#fd7e14;cursor:pointer;" title="Reduce priority of todos inactive for 180+ days">⚠ Triage Stale</button>
                        <button onclick="rescheduleTodos(this)" style="padding:4px 12px;border:1px solid #6f42c1;border-radius:4px;background:transparent;font-size:0.82em;color:#6f42c1;cursor:pointer;" title="Re-score all todos: staleness, due dates, blocking status — then reload">♻ Reschedule</button>
                        [% END %]
                    </div>
                </div>

                [% IF active_priorities && active_priorities.size %]
                [% SET rank = 0 %]
                [% FOREACH ap IN active_priorities %]
                [% SET rank = rank + 1 %]
                [%# Determine if this todo is blocked by an incomplete blocker %]
                [% SET is_blocked = ap.blocked_by_todo_id && !ap.blocker_done %]
                <div id="ap-row-[% ap.record_id %]" style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;margin-bottom:6px;
                    border-radius:6px;border:1px solid [% IF ap.is_stale %]#fd7e14[% ELSE %]var(--border-color)[% END %];
                    background:[% IF is_blocked %]var(--bg-secondary)[% ELSIF ap.status == 2 %]color-mix(in srgb,var(--primary-color) 8%,var(--bg-color))[% ELSE %]var(--bg-color)[% END %];
                    opacity:[% IF is_blocked %]0.65[% ELSE %]1[% END %];">

                    [%# Rank badge %]
                    <span style="min-width:26px;height:26px;border-radius:50%;background:var(--primary-color);color:#fff;
                        display:flex;align-items:center;justify-content:center;font-size:0.75em;font-weight:bold;flex-shrink:0;">
                        [% rank %]
                    </span>

                    [%# Main content %]
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:3px;">
                            [%# Priority badge %]
                            [% IF ap.priority %]
                            <span style="font-size:0.7em;font-weight:bold;padding:1px 5px;border-radius:3px;
                                [% IF ap.priority <= 2 %]background:#dc3545;color:#fff
                                [% ELSIF ap.priority <= 4 %]background:#fd7e14;color:#fff
                                [% ELSIF ap.priority <= 6 %]background:#ffc107;color:#333
                                [% ELSE %]background:#6c757d;color:#fff[% END %]">
                                P[% ap.priority %]
                            </span>
                            [% END %]

                            [%# Status badge %]
                            <span style="font-size:0.7em;padding:1px 5px;border-radius:3px;
                                [% IF ap.status == 2 %]background:#17a2b8;color:#fff
                                [% ELSE %]background:#6c757d;color:#fff[% END %]">
                                [% IF ap.status == 2 %]IN PROGRESS[% ELSE %]NEW[% END %]
                            </span>

                            [%# Stale badge %]
                            [% IF ap.is_stale %]
                            <span style="font-size:0.7em;padding:1px 5px;border-radius:3px;background:#fd7e14;color:#fff;" title="No activity for [% ap.stale_days %] days — may be outdated or already done">⏳ STALE [% ap.stale_days %]d</span>
                            [% END %]

                            [%# Blocking badge %]
                            [% IF ap.is_blocking %]
                            <span style="font-size:0.7em;padding:1px 5px;border-radius:3px;background:#dc3545;color:#fff;" title="Other tasks depend on this">🔒 BLOCKING</span>
                            [% END %]

                            [%# Blocked badge %]
                            [% IF is_blocked %]
                            <span style="font-size:0.7em;padding:1px 5px;border-radius:3px;background:#adb5bd;color:#333;" title="Waiting on: [% ap.blocker_subject %]">⏸ BLOCKED</span>
                            [% END %]

                            [%# Site label (CSC all-sites view) %]
                            [% IF is_csc && ap.sitename && ap.sitename != 'CSC' %]
                            <span style="font-size:0.7em;padding:1px 5px;border-radius:3px;background:var(--primary-color);color:#fff;">[% ap.sitename %]</span>
                            [% END %]
                        </div>

                        [%# Subject link %]
                        <a href="/todo/details?record_id=[% ap.record_id %]"
                           style="font-weight:bold;color:var(--text-color);text-decoration:none;font-size:0.95em;[% IF is_blocked %]color:var(--text-muted-color)[% END %]">
                            [% ap.subject || '(No subject)' %]
                        </a>

                        [%# Meta line: project, due date, blocked-by %]
                        <div style="font-size:0.78em;color:var(--text-muted-color);margin-top:3px;display:flex;gap:10px;flex-wrap:wrap;">
                            [% IF ap.project_name %]<span>📁 [% ap.project_name %]</span>[% END %]
                            [% IF ap.due_date %]<span>📅 Due: [% ap.due_date %]</span>[% END %]
                            [% IF is_blocked %]<span>⏸ Waiting on: <em>[% ap.blocker_subject %]</em></span>[% END %]
                            [% IF ap.sitename && !(is_csc && ap.sitename != 'CSC') %]<span>[% ap.sitename %]</span>[% END %]
                        </div>
                    </div>

                    [%# Quick actions %]
                    <div style="display:flex;flex-direction:column;gap:4px;flex-shrink:0;padding-top:2px;">
                        <a href="/todo/details?record_id=[% ap.record_id %]"
                           style="font-size:0.75em;color:var(--primary-color);text-decoration:none;">View →</a>
                        <a href="/log/log_form?todo_record_id=[% ap.record_id %]"
                           style="font-size:0.7em;padding:2px 6px;border:1px solid #17a2b8;border-radius:3px;text-decoration:none;color:#17a2b8;text-align:center;" title="Add a time log for this todo">📋 Log</a>
                        [% IF is_admin %]
                        <button onclick="quickClose([% ap.record_id %])"
                            style="font-size:0.7em;padding:2px 6px;border:1px solid #28a745;border-radius:3px;background:transparent;color:#28a745;cursor:pointer;" title="Mark done and create log">✓ Done</button>
                        [% END %]
                    </div>
                </div>
                [% END %]

                [% ELSE %]
                <div style="text-align:center;padding:30px;color:var(--text-muted-color);background:var(--bg-secondary);border-radius:6px;">
                    <p style="margin:0 0 10px;">No active todos found for your role and site.</p>
                    <a href="/todo/addtodo" style="color:var(--primary-color);">+ Create your first todo</a>
                </div>
                [% END %]
            </div>

            <script>
            function quickClose(recordId) {
                if (!confirm('Mark todo #' + recordId + ' as Done and create a log entry?')) return;
                fetch('/todo/quick_close', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                    body: JSON.stringify({record_id: recordId})
                }).then(function(r){ return r.json(); }).then(function(d){
                    if (d.ok) {
                        var row = document.getElementById('ap-row-' + recordId);
                        if (row) { row.style.opacity = '0.4'; row.style.textDecoration = 'line-through'; }
                        setTimeout(function(){ if (row) row.remove(); }, 1200);
                    } else {
                        alert('Could not close: ' + (d.error || 'unknown error'));
                    }
                }).catch(function(e){ alert('Error: ' + e); });
            }
            function rescheduleTodos(btn) {
                btn.disabled = true;
                btn.textContent = '⏳ Rescheduling…';
                fetch('/todo/reschedule', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                    body: JSON.stringify({})
                }).then(function(r){ return r.json(); }).then(function(d){
                    if (d.ok) {
                        alert('Rescheduled: ' + d.count + ' todo' + (d.count !== 1 ? 's' : '') + ' updated. Reloading…');
                        location.reload();
                    } else {
                        btn.disabled = false;
                        btn.textContent = '♻ Reschedule';
                        alert('Error: ' + (d.error || 'unknown'));
                    }
                }).catch(function(e){
                    btn.disabled = false;
                    btn.textContent = '♻ Reschedule';
                    alert('Error: ' + e);
                });
            }
            function triageStale() {
                if (!confirm('Reduce priority of all todos inactive for 180+ days by 2 levels?')) return;
                fetch('/todo/triage_stale', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
                    body: JSON.stringify({})
                }).then(function(r){ return r.json(); }).then(function(d){
                    if (d.ok) { alert('Triaged ' + d.count + ' stale todos. Reloading…'); location.reload(); }
                    else { alert('Error: ' + (d.error || 'unknown')); }
                }).catch(function(e){ alert('Error: ' + e); });
            }
            </script>

            [%# ── CSC LEGACY: Master Plan Priority List (being migrated to DB above) ── %]
            [% IF is_csc %]
            <details style="background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:4px;margin-bottom:16px;">
                <summary style="padding:10px 14px;cursor:pointer;font-size:0.85em;color:var(--text-muted-color);">
                    📋 Legacy: Master Plan Priority List (text-based — being migrated to DB above)
                </summary>
                <div style="padding:14px;">
                    [% INCLUDE "admin/documentation/PriorityTodos.tt" %]
                </div>
            </details>
            [% END %]

        </div>
    </div>

    <!-- TAB: DAILY SCHEDULE (hourly time-slot view) -->
    <div id="daily-schedule" class="tab-content">
        <div id="anchor-dynamic-daily" class="nav-anchor"></div>
        <h2>Daily Schedule</h2>
        <div class="dynamic-container">
            [% TRY %]
                [% INCLUDE 'todo/day.tt' %]
            [% CATCH %]
                <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; padding: 15px; margin: 15px 0;">
                    <h4 style="margin-top: 0; color: #856404;">⚠️ Daily Schedule Not Available</h4>
                    <p>The daily time-slot view is not currently available.</p>
                </div>
            [% END %]
        </div>
    </div>

    <!-- TAB 2: WEEKLY VIEW -->
    <div id="weekly-view" class="tab-content">
        [% TRY %]
            [% INCLUDE 'todo/week.tt' %]
        [% CATCH %]
            <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; padding: 15px; margin: 15px 0;">
                <h4 style="margin-top: 0; color: #856404;">⚠️ Todo Week View Not Available</h4>
                <p>The live todo week view component is not currently available.</p>
            </div>
        [% END %]
    </div>

    <!-- TAB 4: DAILY PLAN GUIDE -->
    <div id="daily-plan-guide" class="tab-content">
        <h2>Instructions for Admin Working on The Daily Plan</h2>
        [%  INCLUDE 'admin/documentation/DailyAuditGuide.tt' %]
        <div style="background: var(--light-color); border: 1px solid var(--info-color); border-radius: 4px; padding: 20px; margin: 20px 0;">
            <h3>How to Update This Daily Plan</h3>
            <ol style="line-height: 1.8;">
                <li><strong>Read First:</strong> Always read the entire DailyPlan.tt file before making changes. Understand the tab structure and container relationships.</li>
                <li><strong>Preserve Floating Header:</strong> The sticky header with navigation must remain at the top. Do not remove or modify the floating position.</li>
                <li><strong>Preserve Tab Structure:</strong> Never remove existing tabs without explicit user permission. You may add new tabs, but do not delete TODAY'S WORK, RESOURCES & CONTEXT, or COMPLETED tabs.</li>
                <li><strong>Update Within Containers:</strong> Edit task content within task-list containers, not the containers themselves. Preserve checkbox structure and task items.</li>
                <li><strong>Link to Master Docs:</strong> Reference PriorityTodos.tt at /admin/documentation/PriorityTodos - never duplicate the full table into daily plans.</li>
                <li><strong>Track Progress:</strong> Update checkbox status as tasks complete. Move items to COMPLETED tab when done.</li>
                <li><strong>Conditional Planning:</strong> If a critical blocker succeeds, update the next day's plan to show unblocked work.</li>
                <li><strong>Log Changes:</strong> After edits, execute updateprompt.pl --phase after with files modified and changes made.</li>
            </ol>
        </div>
    </div>

    <!-- TAB 3: RESOURCES & CONTEXT -->
    <div id="resources-view" class="tab-content">
        <h3>[RESOURCES & SUPPORTING CONTEXT] — [% plan_sitename %]</h3>

        [% IF is_csc %]
        <!-- Planning Quick Links (CSC only) — DB-driven state -->
        <div style="background:var(--bg-secondary);border-left:4px solid var(--primary-color);padding:14px 18px;margin-bottom:20px;border-radius:4px;">
            <h3 style="margin-top:0;font-size:1em;">📋 Planning System — Current State</h3>
            <p style="margin:4px 0;font-size:0.88em;">All planning is now DB-driven. Tasks tracked in the <strong>Planning System</strong> project (todos 502–516). Text-based planning content below is CSC-only and being phased out.</p>
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;">
                <a href="/project/details?project_id=138" style="font-size:0.83em;padding:3px 10px;border:1px solid var(--border-color);border-radius:3px;text-decoration:none;color:var(--primary-color);">Planning System Project</a>
                <a href="/todo?project_id=186" style="font-size:0.83em;padding:3px 10px;border:1px solid var(--border-color);border-radius:3px;text-decoration:none;color:var(--primary-color);">Phase 1 Todos</a>
                <a href="/todo?project_id=187" style="font-size:0.83em;padding:3px 10px;border:1px solid var(--border-color);border-radius:3px;text-decoration:none;color:var(--primary-color);">Phase 2 Todos</a>
                <a href="/Documentation/MasterPlanCoordination" style="font-size:0.83em;padding:3px 10px;border:1px solid var(--border-color);border-radius:3px;text-decoration:none;color:var(--primary-color);">Master Plan</a>
                <a href="/todo" style="font-size:0.83em;padding:3px 10px;border:1px solid var(--border-color);border-radius:3px;text-decoration:none;color:var(--primary-color);">All Todos</a>
            </div>
        </div>
        [% END %]<!-- end is_csc resources -->

        <h4 style="margin-top: 30px;">Quick Todo Actions</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <div style="background: #f5f5f5; padding: 15px; border-radius: 4px;">
                <a href="/todo" style="display: block; color: var(--link-color); text-decoration: none; font-weight: bold; padding: 10px; border: 1px solid var(--primary-color); border-radius: 3px; text-align: center;">📋 Open Todo System</a>
            </div>
            <div style="background: #f5f5f5; padding: 15px; border-radius: 4px;">
                <a href="/todo/addtodo" onclick="window.open('/todo/addtodo', '_blank'); return false;" style="display: block; color: var(--link-color); text-decoration: none; font-weight: bold; padding: 10px; border: 1px solid var(--success-color); border-radius: 3px; text-align: center;">➕ Add New Todo</a>
            </div>
        </div>

        <h4>Daily Notes for [% display_date %]:</h4>
        <div style="background: #f9f9f9; border: 1px solid #ddd; border-radius: 4px; padding: 15px; min-height: 150px;">
            <p><em>Add notes about this day's work here...</em></p>
        </div>
    </div>

    <!-- TAB: MONTH VIEW -->
    <div id="month-view" class="tab-content">
        <h4 style="margin-top: 30px;">Todo Month View</h4>
        <p style="background: #e3f2fd; border-left: 4px solid #2196f3; padding: 15px; border-radius: 4px; margin: 15px 0;">
            <strong>Live Todo System Integration:</strong> Below is the current month's todo items.
        </p>
        [% TRY %]
            [% INCLUDE 'todo/month.tt' %]
        [% CATCH %]
            <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; padding: 15px; margin: 15px 0;">
                <h4 style="margin-top: 0; color: #856404;">⚠️ Todo Month View Not Available</h4>
                <p>The live todo month view component is not currently available.</p>
            </div>
        [% END %]
    </div>

    <!-- TAB: PLANNING — Project→Plan hierarchy; DB-driven for all sites; CSC also sees legacy Planning.tt -->
    <div id="planning" class="tab-content">

        [%# ── Data from controller stash (fetched in Documentation.pm::daily_plan) ── %]
        [% SET view_sitename = filter_site || plan_sitename %]

        [%# ── Branch server launcher (admin only) ── %]
        [% IF is_admin %]
        [% SET cur_branch = c.stash.app_workflow || 'main' %]
        [% SET host       = c.req.uri.host %]
        [% SET scheme     = c.req.uri.scheme %]

        [%# Static branch → port map (matches Planning.tt overview) %]
        [% SET bp = {
            'planningsystem-59ae'                      => 4001,
            'aichatsystem-ef4e'                        => 4010,
            'schema-managment-system-7eb3'             => 4002,
            'new-task-9cf1'                            => 4003,
            'workshops-7d21'                           => 4004,
            'users-e5b8'                               => 4005,
            'set-up-project-config-d327'               => 3000,
            'new-task-bb05'                            => 4006,
            'unified-mail-system-site-managed-2c53'    => 4007,
            'membership-1304'                          => 4008,
            'pointsystem-3230'                         => 4009,
            'cssthemes-9195'                           => 4011,
            'ency-53b0'                                => 4012,
            'helpdesk-7217'                            => 4013,
            'healthplanning-9db9'                      => 4014,
            'productionserverhealth-82fb'              => 4015,
            'security-764f'                            => 4016,
            'documentation-9122'                       => 4017,
            'api-bc05'                                 => 4018,
            'bmaster-f0fd'                             => 4019,
            'aichatsystem-planning-system-int-f187'    => 4020,
        } %]

        [%# All known branch servers for the overview panel %]
        [% SET all_branches = [
            { name => 'planningsystem-59ae',                   port => 4001, label => 'PlanningSystem',       url => '/Documentation/DailyPlan' },
            { name => 'aichatsystem-ef4e',                     port => 4010, label => 'AIChatSystem',         url => '/Documentation/DailyPlan' },
            { name => 'schema-managment-system-7eb3',          port => 4002, label => 'SchemaManagement',     url => '/Documentation/DailyPlan' },
            { name => 'new-task-9cf1',                         port => 4003, label => 'InfrastructureHA',     url => '/Documentation/DailyPlan' },
            { name => 'workshops-7d21',                        port => 4004, label => 'WorkShops',            url => '/workshop' },
            { name => 'users-e5b8',                            port => 4005, label => 'Users',                url => '/user/dashboard' },
            { name => 'set-up-project-config-d327',            port => 3000, label => 'ProjectConfig',        url => '/Documentation/DailyPlan' },
            { name => 'new-task-bb05',                         port => 4006, label => 'FileManagement',       url => '/admin/planning' },
            { name => 'unified-mail-system-site-managed-2c53', port => 4007, label => 'UnifiedMail',          url => '/Documentation/DailyPlan' },
            { name => 'membership-1304',                       port => 4008, label => 'Membership',           url => '/membership' },
            { name => 'pointsystem-3230',                      port => 4009, label => 'PointSystem',          url => '/Documentation/DailyPlan' },
            { name => 'cssthemes-9195',                        port => 4011, label => 'CssThemes',            url => '/Documentation/DailyPlan' },
            { name => 'ency-53b0',                             port => 4012, label => 'ENCY',                 url => '/ENCY' },
            { name => 'helpdesk-7217',                         port => 4013, label => 'HelpDesk',             url => '/HelpDesk' },
            { name => 'healthplanning-9db9',                   port => 4014, label => 'HealthPlanning',       url => '/Documentation/DailyPlan' },
            { name => 'productionserverhealth-82fb',           port => 4015, label => 'ProdServerHealth',     url => '/Documentation/DailyPlan' },
            { name => 'security-764f',                         port => 4016, label => 'Security',             url => '/Documentation/DailyPlan' },
            { name => 'documentation-9122',                    port => 4017, label => 'Documentation',        url => '/Documentation' },
            { name => 'api-bc05',                              port => 4018, label => 'APISystem',            url => '/Documentation/DailyPlan' },
            { name => 'bmaster-f0fd',                          port => 4019, label => 'BMaster',              url => '/Documentation/DailyPlan' },
            { name => 'aichatsystem-planning-system-int-f187', port => 4020, label => 'AIChatPlanInt',        url => '/Documentation/DailyPlan' },
        ] %]

        <details style="margin-bottom:14px;border:1px solid #fd7e14;border-radius:6px;font-size:0.85em;">
            <summary style="padding:8px 14px;cursor:pointer;background:color-mix(in srgb,#fd7e14 10%,var(--bg-color));border-radius:6px;display:flex;justify-content:space-between;align-items:center;">
                <span style="font-weight:bold;color:#fd7e14;">🌿 Branch Servers
                    [% IF cur_branch && cur_branch != 'main' %]
                    — currently on <code style="font-size:1em;">[% cur_branch %]</code>
                    [% END %]
                </span>
                <span style="color:var(--text-muted-color);font-size:0.9em;">▾</span>
            </summary>
            <div style="padding:10px 14px;">

                [%# Current branch start command %]
                [% IF cur_branch && cur_branch != 'main' %]
                [% SET cur_port     = bp.$cur_branch || '????' %]
                [% SET worktree_dir = '/home/shanta/.zenflow/worktrees/' _ cur_branch _ '/Comserv' %]
                [% SET start_cmd    = 'cd ' _ worktree_dir _ ' && CATALYST_DEBUG=1 perl script/comserv_server.pl -p ' _ cur_port _ ' -r' %]
                <div style="margin-bottom:10px;padding:8px 10px;background:color-mix(in srgb,#fd7e14 8%,var(--bg-color));border-radius:4px;">
                    <div style="margin-bottom:6px;font-weight:bold;color:#fd7e14;">▶ Start current branch server (port [% cur_port %]):</div>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <code id="branch-start-cmd" style="flex:1;padding:4px 8px;background:var(--bg-color);border:1px solid var(--border-color);border-radius:3px;font-size:0.88em;word-break:break-all;">[% start_cmd %]</code>
                        <button onclick="navigator.clipboard.writeText(document.getElementById('branch-start-cmd').textContent);this.textContent='✓';setTimeout(()=>this.textContent='📋 Copy',1500);"
                            style="padding:3px 10px;border:1px solid #fd7e14;border-radius:3px;background:transparent;color:#fd7e14;cursor:pointer;white-space:nowrap;">📋 Copy</button>
                        <a href="[% scheme %]://[% host %]:[% cur_port %]/Documentation/DailyPlan" target="_blank"
                           style="padding:3px 10px;background:#fd7e14;color:#fff;border-radius:3px;text-decoration:none;white-space:nowrap;">Open →</a>
                    </div>
                </div>
                [% END %]

                [%# All branch servers table %]
                <table style="width:100%;border-collapse:collapse;font-size:0.88em;">
                    <tr style="border-bottom:1px solid var(--border-color);">
                        <th style="text-align:left;padding:4px 8px;color:var(--text-muted-color);">Branch</th>
                        <th style="text-align:left;padding:4px 8px;color:var(--text-muted-color);">Port</th>
                        <th style="text-align:left;padding:4px 8px;color:var(--text-muted-color);">Start Command</th>
                        <th style="padding:4px 8px;"></th>
                    </tr>
                    [% FOREACH b IN all_branches %]
                    [% SET b_cmd = 'cd /home/shanta/.zenflow/worktrees/' _ b.name _ '/Comserv && CATALYST_DEBUG=1 perl script/comserv_server.pl -p ' _ b.port _ ' -r' %]
                    <tr style="border-bottom:1px solid var(--border-color);[% IF b.name == cur_branch %]background:color-mix(in srgb,#fd7e14 8%,var(--bg-color));[% END %]">
                        <td style="padding:5px 8px;"><code>[% b.label %]</code>
                            [% IF b.name == cur_branch %]<span style="color:#fd7e14;font-size:0.8em;"> ← current</span>[% END %]
                        </td>
                        <td style="padding:5px 8px;"><code>:[% b.port %]</code></td>
                        <td style="padding:5px 8px;max-width:320px;">
                            <code id="cmd-[% b.port %]" style="font-size:0.82em;word-break:break-all;">[% b_cmd %]</code></td>
                        <td style="padding:5px 8px;white-space:nowrap;">
                            <button onclick="navigator.clipboard.writeText(document.getElementById('cmd-[% b.port %]').textContent);this.textContent='✓';setTimeout(()=>this.textContent='📋',1500);"
                                style="padding:2px 6px;border:1px solid var(--border-color);border-radius:3px;background:transparent;color:var(--text-muted-color);cursor:pointer;margin-right:4px;">📋</button>
                            <a href="[% scheme %]://[% host %]:[% b.port %][% b.url %]" target="_blank"
                               style="padding:2px 8px;background:var(--primary-color);color:#fff;border-radius:3px;text-decoration:none;font-size:0.85em;">Open</a>
                        </td>
                    </tr>
                    [% END %]
                </table>
            </div>
        </details>
        [% END %]

        [%# ── Header row ── %]
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;padding-bottom:10px;border-bottom:2px solid var(--primary-color);">
            <h2 style="margin:0;font-size:1.2em;">
                📁 Projects &amp; Plans:
                [% IF is_csc && !filter_site %]All Sites[% ELSE %][% view_sitename %][% END %]
            </h2>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                [% IF is_csc %]
                <a href="#planning" onclick="switchTab(event,'planning');return false;"
                   style="font-size:0.8em;color:var(--text-muted-color);text-decoration:none;">[text view ↓]</a>
                [% END %]
                [% IF is_admin %]
                <a href="/admin/plan/create" style="background:var(--primary-color);color:#fff;padding:5px 12px;border-radius:4px;text-decoration:none;font-size:0.85em;">+ New Plan</a>
                [% END %]
                <a href="/todo" style="padding:5px 12px;border:1px solid var(--border-color);border-radius:4px;text-decoration:none;font-size:0.85em;color:var(--text-color);">Todos</a>
            </div>
        </div>

        [%# ── CSC admin: SiteName filter toggle (from stash plan_sitenames) ── %]
        [% IF is_csc && plan_sitenames && plan_sitenames.size %]
        <div style="margin-bottom:14px;display:flex;gap:6px;flex-wrap:wrap;align-items:center;font-size:0.85em;">
            <span style="color:var(--text-muted-color);font-weight:bold;">Filter:</span>
            <a href="/Documentation/DailyPlan#planning"
               style="padding:2px 10px;border-radius:3px;text-decoration:none;border:1px solid var(--border-color);
               [% IF !filter_site %]background:var(--primary-color);color:#fff[% ELSE %]color:var(--text-color)[% END %]">All</a>
            [% FOREACH sname IN plan_sitenames %]
            <a href="/Documentation/DailyPlan?filter_site=[% sname %]#planning"
               style="padding:2px 10px;border-radius:3px;text-decoration:none;border:1px solid var(--border-color);
               [% IF filter_site == sname %]background:var(--primary-color);color:#fff[% ELSE %]color:var(--text-color)[% END %]">
                [% sname %]
            </a>
            [% END %]
        </div>
        [% END %]

        [%# ── Project search filter ── %]
        <div style="margin-bottom:12px;display:flex;gap:8px;align-items:center;">
            <input type="text" id="project-search" placeholder="🔍 Search projects by name, site, or status…"
                oninput="filterProjects(this.value)"
                style="flex:1;padding:6px 10px;border:1px solid var(--border-color);border-radius:4px;font-size:0.88em;background:var(--bg-color);color:var(--text-color);">
            <button onclick="document.getElementById('project-search').value='';filterProjects('');"
                style="padding:5px 10px;border:1px solid var(--border-color);border-radius:4px;background:transparent;color:var(--text-muted-color);cursor:pointer;font-size:0.85em;">✕</button>
        </div>
        <script>
        function filterProjects(q) {
            q = q.toLowerCase().trim();
            var cards = document.querySelectorAll('.project-card');
            var headers = document.querySelectorAll('.site-group-header');
            cards.forEach(function(card) {
                var text = card.textContent.toLowerCase();
                card.style.display = (!q || text.indexOf(q) !== -1) ? '' : 'none';
            });
            headers.forEach(function(h) {
                var next = h.nextElementSibling;
                var visible = false;
                while (next && !next.classList.contains('site-group-header')) {
                    if (next.classList.contains('project-card') && next.style.display !== 'none') visible = true;
                    next = next.nextElementSibling;
                }
                h.style.display = (!q || visible) ? '' : 'none';
            });
        }
        </script>

        [%# ── Project → Plan hierarchy (from stash planning_projects) ── %]
        [% IF planning_projects && planning_projects.size %]
        [% IF is_admin %]
        <div id="project-reorder-bar" style="display:none;padding:8px 12px;background:color-mix(in srgb,var(--primary-color) 12%,var(--bg-color));border:1px solid var(--primary-color);border-radius:4px;margin-bottom:10px;font-size:0.85em;align-items:center;gap:12px;">
            <span>⇅ Drag rows to reorder projects</span>
            <button id="save-order-btn" onclick="saveProjectOrder()" style="padding:3px 12px;background:var(--primary-color);color:#fff;border:none;border-radius:3px;cursor:pointer;font-size:0.85em;">Save Order</button>
            <span id="save-order-msg" style="color:green;display:none;">✓ Saved</span>
        </div>
        [% END %]
        <div id="project-sortable-list">
        [% SET current_site_label = '' %]
        [% FOREACH proj IN planning_projects %]
            [%# Site group header for CSC all-sites view %]
            [% IF is_csc && !filter_site && proj.sitename != current_site_label %]
            [% SET current_site_label = proj.sitename %]
            <div class="site-group-header" style="margin:18px 0 6px;padding:4px 10px;background:var(--primary-color);color:#fff;border-radius:4px;font-size:0.85em;font-weight:bold;">
                🌐 [% proj.sitename %]
            </div>
            [% END %]

            [%# Project card %]
            <details data-project-id="[% proj.id %]" draggable="[% is_admin ? 'true' : 'false' %]"
                style="background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:6px;margin-bottom:10px;"
                class="project-card" open>
                <summary style="padding:12px 14px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none;">
                    <span style="display:flex;align-items:center;gap:8px;">
                        [% IF is_admin %]<span class="drag-handle" title="Drag to reorder" style="cursor:grab;color:var(--text-muted-color);font-size:1.1em;user-select:none;" onclick="event.stopPropagation()">⠿</span>[% END %]
                        <strong>[% proj.name %]</strong>
                        [% IF proj.project_code %]<span style="font-size:0.8em;color:var(--text-muted-color);margin-left:6px;">[% proj.project_code %]</span>[% END %]
                        [% IF proj.developer_name %]<span style="font-size:0.78em;color:var(--text-muted-color);margin-left:6px;">· [% proj.developer_name %]</span>[% END %]
                    </span>
                    <span style="display:flex;gap:6px;align-items:center;">
                        [% IF proj.status %]
                        <span style="padding:1px 7px;border-radius:3px;font-size:0.75em;font-weight:bold;
                            [% IF proj.status == 'In-Process' || proj.status == 'active' %]background:#17a2b8;color:#fff
                            [% ELSIF proj.status == 'Completed' || proj.status == 'completed' %]background:#28a745;color:#fff
                            [% ELSE %]background:#6c757d;color:#fff[% END %]">
                            [% proj.status %]
                        </span>
                        [% END %]
                        <a href="/project/details?project_id=[% proj.id %]" style="font-size:0.78em;color:var(--primary-color);text-decoration:none;" onclick="event.stopPropagation()">Details</a>
                    </span>
                </summary>
                <div style="padding:0 14px 12px;">
                    [% IF proj.description %]
                    <div style="font-size:0.85em;color:var(--text-color);margin:6px 0 10px;">[% proj.description %]</div>
                    [% END %]

                    [%# Sub-projects (from proj.sub_projects set by controller) %]
                    [% IF proj.sub_projects && proj.sub_projects.size %]
                    <details style="margin-bottom:8px;">
                        <summary style="cursor:pointer;font-size:0.82em;color:var(--text-muted-color);padding:3px 0;">
                            📂 [% proj.sub_projects.size %] sub-project[% proj.sub_projects.size > 1 ? 's' : '' %]
                        </summary>
                        <div style="margin:4px 0 8px 10px;border-left:2px solid var(--border-color);padding-left:10px;">
                            [% FOREACH sub IN proj.sub_projects %]
                            <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0;">
                                <span style="font-size:0.82em;">
                                    <a href="/project/details?project_id=[% sub.id %]" style="color:var(--text-color);text-decoration:none;">[% sub.name %]</a>
                                    [% IF sub.project_code %]<span style="color:var(--text-muted-color);font-size:0.9em;"> [% sub.project_code %]</span>[% END %]
                                </span>
                                [% IF sub.status %]
                                <span style="font-size:0.7em;padding:1px 5px;border-radius:3px;
                                    [% IF sub.status == 'In-Process' || sub.status == 'active' %]background:#17a2b8;color:#fff
                                    [% ELSIF sub.status == 'Completed' || sub.status == 'completed' %]background:#28a745;color:#fff
                                    [% ELSE %]background:#6c757d;color:#fff[% END %]">
                                    [% sub.status %]
                                </span>
                                [% END %]
                            </div>
                            [% END %]
                        </div>
                    </details>
                    [% END %]

                    [%# Plans linked to this project (from proj.linked_plans set by controller) %]
                    [% IF proj.linked_plans && proj.linked_plans.size %]
                    <div style="margin-left:8px;border-left:2px solid var(--primary-color);padding-left:10px;">
                        [% FOREACH pln IN proj.linked_plans %]
                        <div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border-color);">
                            <div>
                                <a href="/admin/plan/[% pln.id %]" style="font-weight:bold;font-size:0.9em;color:var(--primary-color);text-decoration:none;">[% pln.plan_name %]</a>
                                [% IF pln.due_date %]<span style="font-size:0.78em;color:var(--text-muted-color);margin-left:6px;">due [% pln.due_date %]</span>[% END %]
                            </div>
                            <div style="display:flex;gap:6px;align-items:center;">
                                [% IF pln.priority %]<span style="font-size:0.78em;color:var(--text-muted-color);">P[% pln.priority %]</span>[% END %]
                                <span style="padding:1px 6px;border-radius:3px;font-size:0.72em;font-weight:bold;
                                    [% IF pln.status == 'active' %]background:#28a745;color:#fff[% ELSIF pln.status == 'paused' %]background:#ffc107;color:#333[% ELSE %]background:#6c757d;color:#fff[% END %]">
                                    [% pln.status || 'active' %]
                                </span>
                                <a href="/admin/plan/[% pln.id %]" style="font-size:0.78em;color:var(--primary-color);">View</a>
                            </div>
                        </div>
                        [% END %]
                    </div>
                    [% ELSE %]
                    <div style="font-size:0.82em;color:var(--text-muted-color);margin:4px 0 6px;">
                        No plans linked.
                        [% IF is_admin %]
                        <a href="/admin/plan/create?project_id=[% proj.id %]" style="color:var(--primary-color);margin-left:6px;">+ New Plan</a>
                        [% IF all_plans && all_plans.size %]
                        &nbsp;·&nbsp;
                        <span style="color:var(--text-muted-color);">Link existing plan:
                            <span title="A Plan is a time-boxed sprint or theme (e.g. 'Q2 2026 Planning Migration'). A Project is the long-running system or feature. Linking a plan to this project associates that sprint's goals with this project. You can link multiple plans to one project." style="cursor:help;color:var(--primary-color);">ⓘ</span>
                        </span>
                        <select id="link-plan-[% proj.id %]" style="font-size:0.8em;padding:2px 4px;border:1px solid var(--border-color);border-radius:3px;margin:0 4px;">
                            <option value="">— select plan —</option>
                            [% FOREACH ap IN all_plans %]
                            <option value="[% ap.id %]">[% ap.plan_name %] [% IF ap.sitename %]([% ap.sitename %])[% END %]</option>
                            [% END %]
                        </select>
                        <button onclick="linkPlanToProject(this, [% proj.id %])"
                            style="font-size:0.78em;padding:2px 8px;border:1px solid var(--primary-color);border-radius:3px;background:transparent;color:var(--primary-color);cursor:pointer;">
                            Link
                        </button>
                        [% END %]
                        [% END %]
                    </div>
                    [% END %]
                </div>
            </details>
        [% END %]
        </div>[%# end #project-sortable-list %]

        [%# ── Standalone plans (not linked to any project) ── %]
        [% IF orphan_plans && orphan_plans.size %]
        <div style="margin-top:20px;">
            <h3 style="font-size:0.95em;color:var(--text-muted-color);margin-bottom:8px;">📋 Standalone Plans (not yet linked to a project)</h3>
            [% FOREACH pln IN orphan_plans %]
            <div style="background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:6px;padding:12px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <a href="/admin/plan/[% pln.id %]" style="font-weight:bold;color:var(--primary-color);text-decoration:none;">[% pln.plan_name %]</a>
                    <span style="font-size:0.8em;color:var(--text-muted-color);margin-left:8px;">[% pln.sitename %]</span>
                    [% IF pln.plan_description %]<div style="font-size:0.82em;color:var(--text-color);margin-top:3px;">[% pln.plan_description | truncate(100) %]</div>[% END %]
                </div>
                <div style="display:flex;gap:6px;align-items:center;flex-shrink:0;">
                    <span style="padding:1px 6px;border-radius:3px;font-size:0.75em;font-weight:bold;
                        [% IF pln.status == 'active' %]background:#28a745;color:#fff[% ELSIF pln.status == 'paused' %]background:#ffc107;color:#333[% ELSE %]background:#6c757d;color:#fff[% END %]">
                        [% pln.status || 'active' %]
                    </span>
                    <a href="/admin/plan/[% pln.id %]" style="font-size:0.82em;color:var(--primary-color);">View</a>
                    [% IF is_admin %]<a href="/admin/plan/[% pln.id %]/edit" style="font-size:0.82em;color:var(--primary-color);">Edit</a>[% END %]
                </div>
            </div>
            [% END %]
        </div>
        [% END %]

        [% ELSE %]
        <div style="text-align:center;padding:40px;color:var(--text-muted-color);">
            <p>No projects found for <strong>[% IF is_csc && !filter_site %]All Sites[% ELSE %][% view_sitename %][% END %]</strong>.</p>
            [% IF is_admin %]
            <p>Add a project at <a href="/project/addproject" style="color:var(--primary-color);">/project/addproject</a>, then it will appear here.</p>
            <a href="/admin/plan/create" style="background:var(--primary-color);color:#fff;padding:8px 18px;border-radius:4px;text-decoration:none;">Create the first plan</a>
            [% END %]
        </div>
        [% END %]

        [% IF is_csc %]
        <hr style="margin:30px 0;border-color:var(--border-color);">
        <h3 style="color:var(--text-muted-color);font-size:0.95em;">CSC Text-Based Planning (being migrated to DB above)</h3>
        [% INCLUDE "admin/documentation/Planning.tt" %]
        [% END %]
    </div>

    <!-- TAB: GANTT VIEW (all sites — DB-driven project timeline) -->
    <div id="gantt-view" class="tab-content">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;padding-bottom:10px;border-bottom:2px solid var(--primary-color);">
            <h2 style="margin:0;font-size:1.2em;">📊 Project Timeline — [% IF is_csc && !filter_site %]All Sites[% ELSE %][% plan_sitename %][% END %]</h2>
            <div style="display:flex;gap:8px;align-items:center;font-size:0.8em;">
                <span style="display:inline-block;width:12px;height:12px;background:#17a2b8;border-radius:2px;"></span>In-Process
                <span style="display:inline-block;width:12px;height:12px;background:#28a745;border-radius:2px;margin-left:6px;"></span>Completed
                <span style="display:inline-block;width:12px;height:12px;background:#6c757d;border-radius:2px;margin-left:6px;"></span>Pending
                <span style="display:inline-block;width:12px;height:12px;background:#dc3545;border-radius:2px;margin-left:6px;"></span>On Hold
            </div>
        </div>

        [% IF planning_projects && planning_projects.size %]
        <div id="gantt-container" style="overflow-x:auto;">
            <div id="gantt-chart" style="min-width:700px;"></div>
        </div>

        <script>
        (function() {
            var projects = [
                [% FOREACH p IN planning_projects %]
                {
                    id: [% p.id %],
                    name: "[% p.name %]",
                    sitename: "[% p.sitename %]",
                    status: "[% p.status %]",
                    start_date: [% p.start_date ? ('"' _ p.start_date _ '"') : 'null' %],
                    end_date:   [% p.end_date   ? ('"' _ p.end_date   _ '"') : 'null' %]
                }[% UNLESS loop.last %],[% END %]
                [% END %]
            ];

            var now = new Date();
            var windowStart = new Date(now);
            windowStart.setMonth(windowStart.getMonth() - 3);
            var windowEnd = new Date(now);
            windowEnd.setMonth(windowEnd.getMonth() + 9);
            var totalMs = windowEnd - windowStart;

            var statusColor = {
                'In-Process': '#17a2b8',
                'active':     '#17a2b8',
                'Completed':  '#28a745',
                'completed':  '#28a745',
                'On Hold':    '#dc3545',
                'paused':     '#dc3545'
            };

            function toDate(s) { return s ? new Date(s) : null; }
            function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
            function pct(d) { return clamp(((d - windowStart) / totalMs) * 100, 0, 100); }

            // Build month-label header
            var header = '<div style="display:flex;font-size:0.7em;color:var(--text-muted-color);margin-bottom:4px;padding-left:200px;">';
            var m = new Date(windowStart);
            m.setDate(1);
            while (m <= windowEnd) {
                var leftPct = pct(m);
                header += '<div style="position:absolute;left:calc(200px + ' + leftPct + '%);transform:translateX(-50%);white-space:nowrap;">'
                         + m.toLocaleString('default',{month:'short'}) + ' ' + m.getFullYear() + '</div>';
                m.setMonth(m.getMonth() + 1);
            }
            header += '</div>';

            var todayPct = pct(now);

            var rows = '';
            var grouped = {};
            projects.forEach(function(p) { var s = p.sitename||'Other'; (grouped[s]=grouped[s]||[]).push(p); });

            Object.keys(grouped).sort().forEach(function(site) {
                if (projects.length > 1 && Object.keys(grouped).length > 1) {
                    rows += '<div style="font-size:0.78em;font-weight:bold;padding:6px 0 2px;color:var(--text-muted-color);">🌐 ' + site + '</div>';
                }
                grouped[site].forEach(function(p) {
                    var sd = toDate(p.start_date);
                    var ed = toDate(p.end_date);
                    var barColor = statusColor[p.status] || '#6c757d';

                    var barLeft = sd ? pct(sd) : pct(now) - 1;
                    var barRight = ed ? pct(ed) : pct(now) + 2;
                    if (!sd && !ed) { barLeft = todayPct - 0.5; barRight = todayPct + 2; }
                    if (barRight <= barLeft) barRight = barLeft + 2;
                    var barWidth = barRight - barLeft;

                    var dateLabel = (p.start_date||'?') + ' → ' + (p.end_date||'ongoing');

                    rows += '<div style="display:flex;align-items:center;margin-bottom:5px;height:24px;">'
                          + '<div style="width:200px;flex-shrink:0;font-size:0.8em;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;padding-right:8px;">'
                          + '<a href="/project/details?project_id=' + p.id + '" style="color:var(--text-color);text-decoration:none;" title="' + p.name + '">' + p.name + '</a>'
                          + '</div>'
                          + '<div style="flex:1;position:relative;height:18px;background:var(--bg-secondary);border-radius:3px;">'
                          + '<div style="position:absolute;left:' + todayPct + '%;top:0;bottom:0;width:2px;background:var(--primary-color);opacity:0.5;"></div>'
                          + '<div style="position:absolute;left:' + barLeft + '%;width:' + barWidth + '%;height:100%;background:' + barColor + ';border-radius:3px;opacity:0.85;" title="' + p.name + ': ' + dateLabel + '"></div>'
                          + '</div>'
                          + '</div>';
                });
            });

            var container = document.getElementById('gantt-chart');
            container.style.position = 'relative';
            container.innerHTML = header + rows;
        })();
        </script>

        <p style="font-size:0.78em;color:var(--text-muted-color);margin-top:12px;">
            Blue line = today. Projects without dates are placed at current position. 
            Window: 3 months back → 9 months forward.
            <a href="/project/addproject" style="color:var(--primary-color);">Add dates to a project</a> to improve accuracy.
        </p>

        [% ELSE %]
        <div style="text-align:center;padding:40px;color:var(--text-muted-color);">
            <p>No projects found. Add projects at <a href="/project/addproject" style="color:var(--primary-color);">/project/addproject</a>.</p>
        </div>
        [% END %]
    </div>

