            <button onclick="window.open('/todo/addtodo', '_blank')" style="padding: 10px 20px; background: var(--success-color); color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
                ➕ Create Todo in DB
            </button>
        </div>

        <details open style="background: #f9f9f9; border: 1px solid #ddd; border-radius: 4px; margin: 20px 0;">
            <summary style="padding: 15px; cursor: pointer; font-weight: bold; background: #f5f5f5; border-bottom: 1px solid #ddd;">
                📊 Phase 1: Database Schema & Models
            </summary>
            <div style="padding: 15px;">
                <p><strong>Status:</strong> <span style="background: #ffc107; color: #000; padding: 3px 8px; border-radius: 3px;">Pending</span></p>
