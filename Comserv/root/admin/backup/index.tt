[% META title = 'Backup Management' %]
[% PageVersion = 'admin/backup/index.tt,v 1.4 2025/10/16 comserv Exp comserv' %]

[% debug %]
[% IF c.session.debug_mode == 1 %]
<!-- Debug info block -->
<div class="debug-info">
  <p>Template: admin/backup/index.tt</p>
  <p>Last Modified: [% PageVersion %]</p>
</div>
[% END %]

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h1>Backup Management</h1>
            <p class="lead">Comprehensive backup and restore functionality for Comserv application files and databases.</p>
        </div>
    </div>

    <!-- Status Messages -->
    [% IF success_msg OR c.flash.success_msg %]
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>Success:</strong> [% success_msg || c.flash.success_msg %]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    [% END %]

    [% IF error_msg OR c.flash.error_msg %]
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error:</strong> [% error_msg || c.flash.error_msg %]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    [% END %]

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>Quick Actions</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-2">
                            <a href="[% c.uri_for('/admin/backup/create_backup') %]" 
                               class="btn btn-primary btn-lg w-100 mb-2"
                               title="Create a new backup of protected files or manual backup">
                                <i class="fas fa-file-archive"></i> Files Backup
                            </a>
                        </div>
                        <div class="col-md-2">
                            <a href="[% c.uri_for('/admin/backup/create_database_backup') %]" 
                               class="btn btn-success btn-lg w-100 mb-2"
                               title="Create a database backup (all databases, ENCY only, or Forager only)">
                                <i class="fas fa-database"></i> Database Backup
                            </a>
                        </div>
                        <div class="col-md-2">
                            <a href="[% c.uri_for('/admin/backup/test_database_connections') %]" 
                               class="btn btn-info btn-lg w-100 mb-2"
                               title="Test database connections for backup readiness">
                                <i class="fas fa-heartbeat"></i> Test DB Connections
                            </a>
                        </div>
                        <div class="col-md-2">
                            <a href="[% c.uri_for('/admin/emergency-restore') %]" 
                               class="btn btn-warning btn-lg w-100 mb-2"
                               title="Emergency restore interface for critical files">
                                <i class="fas fa-exclamation-triangle"></i> Emergency Restore
                            </a>
                        </div>
                        <div class="col-md-2">
                            <a href="[% c.uri_for('/admin/backup/restore_backup') %]" 
                               class="btn btn-secondary btn-lg w-100 mb-2"
                               title="Restore files from existing backups">
                                <i class="fas fa-undo"></i> Restore Backup
                            </a>
                        </div>
                        <div class="col-md-2">
                            [% IF !psgi_exists %]
                            <form method="post" action="[% c.uri_for('/admin/emergency-restore') %]" style="display: inline;">
                                <input type="hidden" name="action" value="restore_psgi">
                                <button type="submit" 
                                        class="btn btn-danger btn-lg w-100 mb-2"
                                        title="PSGI file is missing - click to restore from backup">
                                    <i class="fas fa-first-aid"></i> Restore PSGI
                                </button>
                            </form>
                            [% ELSE %]
                            <button type="button" 
                                    class="btn btn-outline-success btn-lg w-100 mb-2" 
                                    disabled
                                    title="PSGI file exists and is accessible - no action needed">
                                <i class="fas fa-check"></i> PSGI OK
                            </button>
                            [% END %]
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Available Backups -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>Available Backups</h3>
                </div>
                <div class="card-body">
                    [% IF available_backups.size > 0 %]
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Filename</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Created By</th>
                                    <th>Created</th>
                                    <th>Size</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH backup IN available_backups %]
                                <tr>
                                    <td><code>[% backup.filename %]</code></td>
                                    <td>
                                        [% IF backup.metadata %]
                                            [% IF backup.metadata.type == 'database' %]
                                                <span class="badge bg-success">
                                                    <i class="fas fa-database"></i> 
                                                    [% backup.metadata.subtype || 'DB' %]
                                                </span>
                                            [% ELSIF backup.metadata.type == 'protected_files' %]
                                                <span class="badge bg-warning">
                                                    <i class="fas fa-shield-alt"></i> Protected
                                                </span>
                                            [% ELSIF backup.metadata.type == 'manual' %]
                                                <span class="badge bg-info">
                                                    <i class="fas fa-user"></i> Manual
                                                </span>
                                            [% ELSE %]
                                                <span class="badge bg-secondary">[% backup.metadata.type %]</span>
                                            [% END %]
                                        [% ELSE %]
                                            <span class="badge bg-secondary">unknown</span>
                                        [% END %]
                                    </td>
                                    <td>
                                        [% IF backup.metadata %]
                                            [% backup.metadata.description %]
                                        [% ELSE %]
                                            No description available
                                        [% END %]
                                    </td>
                                    <td>
                                        [% IF backup.metadata %]
                                            [% backup.metadata.created_by %]
                                        [% ELSE %]
                                            Unknown
                                        [% END %]
                                    </td>
                                    <td>[% backup.modified %]</td>
                                    <td>[% backup.size %] bytes</td>
                                    <td>
                                        <div class="btn-group" role="group" aria-label="Backup actions">
                                            <a href="[% c.uri_for('/admin/backup/view_backup', backup.filename) %]" 
                                               class="btn btn-sm btn-outline-info">
                                                View
                                            </a>
                                            <a href="[% c.uri_for('/admin/backup/download_backup', backup.filename) %]" 
                                               class="btn btn-sm btn-outline-success">
                                                Download
                                            </a>
                                            <a href="[% c.uri_for('/admin/backup/delete_backup', backup.filename) %]" 
                                               class="btn btn-sm btn-outline-danger"
                                               onclick="return confirm('Are you sure you want to permanently delete this backup? This action cannot be undone.')">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                    [% ELSE %]
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> No backups found. Create your first backup using the buttons above.
                    </div>
                    [% END %]
                </div>
            </div>
        </div>
    </div>

    <!-- Protected Files Status -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>Protected Files Status</h3>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>File Path</th>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th>Last Modified</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH file IN protected_files %]
                                <tr>
                                    <td><code>[% file.path %]</code></td>
                                    <td>[% file.description %]</td>
                                    <td>
                                        [% SET full_path = c.config.home _ '/' _ file.path %]
                                        [% IF File.exists(full_path) %]
                                            <span class="badge bg-success">Exists</span>
                                        [% ELSE %]
                                            <span class="badge bg-danger">Missing</span>
                                        [% END %]
                                    </td>
                                    <td>
                                        [% SET full_path = c.config.home _ '/' _ file.path %]
                                        [% IF File.exists(full_path) %]
                                            [% USE date %]
                                            [% date.format(File.stat(full_path).mtime, '%Y-%m-%d %H:%M:%S') %]
                                        [% ELSE %]
                                            N/A
                                        [% END %]
                                    </td>
                                </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Backup Directory Contents -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>Backup Directory Contents</h3>
                </div>
                <div class="card-body">
                    [% IF backup_contents.error %]
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> [% backup_contents.error %]
                    </div>
                    [% ELSE %]
                    <div class="accordion" id="backupDirectoryAccordion">
                        <!-- Backup (Singular) Directory -->
                        [% IF backup_contents.backup_singular.size > 0 %]
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingSingular">
                                <button class="accordion-button collapsed" type="button" 
                                        data-bs-toggle="collapse" data-bs-target="#collapseSingular">
                                    Legacy Backup Directory ([% backup_contents.backup_singular.size %] items)
                                </button>
                            </h2>
                            <div id="collapseSingular" class="accordion-collapse collapse" 
                                 data-bs-parent="#backupDirectoryAccordion">
                                <div class="accordion-body">
                                    <div class="table-responsive">
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>Type</th>
                                                    <th>Size</th>
                                                    <th>Modified</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                [% FOREACH file IN backup_contents.backup_singular %]
                                                <tr>
                                                    <td>
                                                        [% IF file.is_directory %]
                                                            <i class="fas fa-folder"></i> [% file.name %]/
                                                        [% ELSE %]
                                                            <i class="fas fa-file"></i> [% file.name %]
                                                        [% END %]
                                                    </td>
                                                    <td>[% file.is_directory ? 'Directory' : 'File' %]</td>
                                                    <td>[% file.is_directory ? '-' : file.size %]</td>
                                                    <td>[% file.modified %]</td>
                                                </tr>
                                                [% END %]
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        [% END %]

                        <!-- Backups (Plural) Directory -->
                        [% IF backup_contents.backup_plural.size > 0 %]
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingPlural">
                                <button class="accordion-button" type="button" 
                                        data-bs-toggle="collapse" data-bs-target="#collapsePlural">
                                    Current Backup Directory ([% backup_contents.backup_plural.size %] items)
                                </button>
                            </h2>
                            <div id="collapsePlural" class="accordion-collapse collapse show" 
                                 data-bs-parent="#backupDirectoryAccordion">
                                <div class="accordion-body">
                                    <div class="table-responsive">
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>Type</th>
                                                    <th>Size</th>
                                                    <th>Modified</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                [% FOREACH file IN backup_contents.backup_plural %]
                                                <tr>
                                                    <td>
                                                        [% IF file.is_directory %]
                                                            <i class="fas fa-folder"></i> [% file.name %]/
                                                        [% ELSE %]
                                                            <i class="fas fa-file"></i> [% file.name %]
                                                        [% END %]
                                                    </td>
                                                    <td>[% file.is_directory ? 'Directory' : 'File' %]</td>
                                                    <td>[% file.is_directory ? '-' : file.size %]</td>
                                                    <td>[% file.modified %]</td>
                                                </tr>
                                                [% END %]
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        [% END %]
                    </div>
                    [% END %]
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-group .btn {
        margin-right: 2px;
    }
    
    .badge {
        font-size: 0.8em;
    }
    
    .badge i {
        margin-right: 3px;
    }
    
    /* Ensure FontAwesome icons display properly */
    .fas {
        font-family: "Font Awesome 5 Free", "Font Awesome 5 Pro", "FontAwesome";
        font-weight: 900;
        font-style: normal;
        font-variant: normal;
        text-rendering: auto;
        -webkit-font-smoothing: antialiased;
    }
    
    /* Screen reader only text */
    .sr-only {
        position: absolute !important;
        width: 1px !important;
        height: 1px !important;
        padding: 0 !important;
        margin: -1px !important;
        overflow: hidden !important;
        clip: rect(0,0,0,0) !important;
        white-space: nowrap !important;
        border: 0 !important;
    }
</style>

<script>
// Initialize Bootstrap tooltips
document.addEventListener('DOMContentLoaded', function() {
    // Check if Bootstrap tooltip is available
    if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
        // Initialize tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    } else {
        // Fallback: Use title attribute for basic tooltip functionality
        console.log('Bootstrap tooltips not available, using title attribute fallback');
    }
    
    // Add confirmation dialog for delete buttons
    var deleteButtons = document.querySelectorAll('a[href*="delete_backup"]');
    deleteButtons.forEach(function(button) {
        button.addEventListener('click', function(e) {
            if (!confirm('Are you sure you want to permanently delete this backup? This action cannot be undone.')) {
                e.preventDefault();
                return false;
            }
        });
    });
});
</script>