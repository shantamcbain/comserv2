[% META title = 'View Backup Details' %]
[% PageVersion = 'admin/backup/view.tt,v 1.2 2025/10/16 comserv Exp comserv' %]

[% debug %]
[% IF c.session.debug_mode == 1 %]
<div class="debug-info">
  <p>Template: admin/backup/view.tt</p>
  <p>Last Modified: [% PageVersion %]</p>
</div>
[% END %]

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h1>Backup Details</h1>
            [% IF backup_info %]
            <p class="lead">Details for backup: <code>[% backup_info.filename %]</code></p>
            [% ELSE %]
            <p class="lead">Backup information</p>
            [% END %]
        </div>
    </div>

    <!-- Status Messages -->
    [% IF success_msg %]
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>Success:</strong> [% success_msg %]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    [% END %]

    [% IF error_msg %]
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error:</strong> [% error_msg %]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    [% END %]

    <!-- Navigation -->
    <div class="row mb-3">
        <div class="col-md-12">
            <a href="[% c.uri_for('/admin/backup') %]" class="btn btn-secondary">
                Back to Backup Management
            </a>
        </div>
    </div>

    [% IF backup_info %]
    <!-- Backup Information -->
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>Backup Information</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <th>Filename:</th>
                                    <td><code>[% backup_info.filename %]</code></td>
                                </tr>
                                <tr>
                                    <th>File Size:</th>
                                    <td>[% backup_info.size %] bytes</td>
                                </tr>
                                <tr>
                                    <th>Created:</th>
                                    <td>[% backup_info.modified %]</td>
                                </tr>
                                <tr>
                                    <th>Full Path:</th>
                                    <td><code>[% backup_info.full_path %]</code></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            [% IF backup_info.metadata %]
                            <table class="table table-borderless">
                                <tr>
                                    <th>Type:</th>
                                    <td><span class="badge bg-info">[% backup_info.metadata.type %]</span></td>
                                </tr>
                                <tr>
                                    <th>Description:</th>
                                    <td>[% backup_info.metadata.description %]</td>
                                </tr>
                                <tr>
                                    <th>Created By:</th>
                                    <td>[% backup_info.metadata.created_by %]</td>
                                </tr>
                                <tr>
                                    <th>Timestamp:</th>
                                    <td>[% backup_info.metadata.timestamp %]</td>
                                </tr>
                            </table>
                            [% ELSE %]
                            <div class="alert alert-info">
                                No metadata available for this backup.
                            </div>
                            [% END %]
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h4>Actions</h4>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="[% c.uri_for('/admin/backup_restore') %]" class="btn btn-info">
                            Restore from this Backup
                        </a>
                        <a href="[% c.uri_for('/admin/backup/download_backup', backup_info.filename) %]" 
                           class="btn btn-success">
                            Download this Backup
                        </a>
                        <a href="[% c.uri_for('/admin/backup/delete_backup', backup_info.filename) %]" 
                           class="btn btn-outline-danger"
                           onclick="return confirm('Are you sure you want to permanently delete this backup? This action cannot be undone.')">
                            Delete this Backup
                        </a>
                    </div>
                </div>
            </div>

            [% IF backup_info.metadata %]
            <div class="card mt-3">
                <div class="card-header">
                    <h4>Metadata</h4>
                </div>
                <div class="card-body">
                    <pre class="bg-light p-3 rounded"><code>[% backup_info.metadata_raw %]</code></pre>
                </div>
            </div>
            [% END %]
        </div>
    </div>

    <!-- Backup Contents (if available) -->
    [% IF backup_info.contents %]
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>Backup Contents</h3>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>File Path</th>
                                    <th>Size</th>
                                    <th>Modified</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH file IN backup_info.contents %]
                                <tr>
                                    <td><code>[% file.path %]</code></td>
                                    <td>[% file.size %] bytes</td>
                                    <td>[% file.modified %]</td>
                                </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    [% END %]

    [% ELSE %]
    <!-- No backup found -->
    <div class="row">
        <div class="col-md-12">
            <div class="alert alert-warning">
                <strong>Backup not found.</strong> The requested backup file could not be located.
            </div>
        </div>
    </div>
    [% END %]
</div>

<style>
.debug-info {
    background-color: var(--bg-secondary, #f8f9fa);
    border: 1px solid var(--border-color, #dee2e6);
    border-radius: 0.375rem;
    padding: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: var(--text-muted-color, #6c757d);
}

pre code {
    font-size: 0.875rem;
    white-space: pre-wrap;
    word-wrap: break-word;
}
</style>