[% META title = 'Migrate Legacy Pages' %]

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                <div>
                    <h2 style="margin:0;">Migrate Legacy Pages</h2>
                    <p class="lead" style="margin-bottom:0;">Import pages from Forager. Select one or more to import.</p>
                </div>
                <a href="[% c.uri_for('/admin/pages') %]" class="btn btn-default">
                    <i class="fa fa-arrow-left"></i> Back to Pages
                </a>
            </div>
            
            [% IF error_msg %]
                <div class="alert alert-danger">
                    <strong>Error:</strong> [% error_msg %]
                </div>
            [% END %]
            
            [% IF show_result %]
                <div class="alert alert-info">
                    <h4>Migration Results</h4>
                    <ul>
                        <li><strong>Migrated:</strong> [% migration_result.migrated_count %] pages</li>
                        <li><strong>Skipped:</strong> [% migration_result.skipped_count %] pages</li>
                        <li><strong>Errors:</strong> [% migration_result.error_count %] pages</li>
                    </ul>
                    
                    [% IF migration_result.migration_log.size > 0 %]
                        <h5>Migration Log:</h5>
                        <ul>
                            [% FOREACH log_entry IN migration_result.migration_log %]
                                <li>[% log_entry %]</li>
                            [% END %]
                        </ul>
                    [% END %]
                    
                    [% IF migration_result.errors.size > 0 %]
                        <h5>Errors:</h5>
                        <ul class="text-danger">
                            [% FOREACH error IN migration_result.errors %]
                                <li>[% error %]</li>
                            [% END %]
                        </ul>
                    [% END %]
                    <a href="[% c.uri_for('/admin/migrate_pages') %]" class="btn btn-primary">
                        <i class="fa fa-refresh"></i> Import More Pages
                    </a>
                    <a href="[% c.uri_for('/admin/pages') %]" class="btn btn-default">
                        <i class="fa fa-list"></i> View Imported Pages
                    </a>
                </div>
            [% END %]
            
            [% IF show_preview %]

                [%# Summary bar %]
                <div style="display:flex; gap:20px; margin-bottom:15px; flex-wrap:wrap;">
                    <span class="label label-primary" style="font-size:13px; padding:6px 12px;">
                        [% preview_data.available.size %] available to import
                    </span>
                    [% IF preview_data.already_imported.size %]
                        <span class="label label-success" style="font-size:13px; padding:6px 12px;">
                            [% preview_data.already_imported.size %] already imported (hidden)
                        </span>
                    [% END %]
                    [% IF preview_data.missing_data.size %]
                        <span class="label label-warning" style="font-size:13px; padding:6px 12px;">
                            [% preview_data.missing_data.size %] skipped (missing page code, site, or menu)
                        </span>
                    [% END %]
                </div>

                [% IF preview_data.available.size > 0 %]
                    <form method="post" action="[% c.uri_for('/admin/migrate_pages') %]">
                        <input type="hidden" name="action" value="migrate">

                        <div class="table-responsive">
                            <table class="table table-striped table-hover" style="font-size:13px;">
                                <thead>
                                    <tr>
                                        <th><input type="checkbox" id="select_all" title="Select all"> All</th>
                                        <th>Site</th>
                                        <th>Menu</th>
                                        <th>Page Code</th>
                                        <th>Title</th>
                                        <th>Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    [% FOREACH page IN preview_data.available %]
                                        <tr>
                                            <td><input type="checkbox" name="selected_pages" value="[% page.record_id %]" class="page-checkbox"></td>
                                            <td>[% page.sitename %]</td>
                                            <td>[% page.menu %]</td>
                                            <td style="font-family:monospace;">[% page.page_code %]</td>
                                            <td>[% page.app_title || page.page_code %]</td>
                                            <td>[% page.status == '1' ? 'active' : 'inactive' %]</td>
                                            <td style="white-space:nowrap;">
                                                <button type="button" class="btn btn-xs btn-info view-page-btn"
                                                    data-id="[% page.record_id %]"
                                                    data-title="[% page.app_title | html %]"
                                                    data-site="[% page.sitename | html %]"
                                                    data-code="[% page.page_code | html %]"
                                                    data-menu="[% page.menu | html %]"
                                                    data-body="[% page.body | html %]"
                                                    data-desc="[% page.description | html %]"
                                                    data-status="[% page.status | html %]"
                                                    data-order="[% page.link_order | html %]">View</button>
                                                [% IF is_csc %]
                                                    <a href="[% c.uri_for('/admin/hide_forager_page', { record_id => page.record_id }) %]"
                                                       class="btn btn-xs btn-default"
                                                       onclick="return confirm('Hide this page from the migration list?')"
                                                       title="Hide from list">Hide</a>
                                                [% END %]
                                            </td>
                                        </tr>
                                    [% END %]
                                </tbody>
                            </table>
                        </div>
                                
                        <div class="form-group" style="margin-top:10px;">
                            <button type="submit" class="btn btn-primary" id="migrate-btn" disabled>
                                <i class="fa fa-database"></i> Import Selected
                            </button>
                            <a href="[% c.uri_for('/admin/migrate_pages') %]" class="btn btn-default">
                                <i class="fa fa-refresh"></i> Refresh
                            </a>
                        </div>
                    </form>
                [% ELSE %]
                    <div class="alert alert-info">No pages available to import.</div>
                [% END %]
            [% ELSE %]
                <div class="alert alert-warning">No pages found in the Forager database.</div>
            [% END %]
        </div>
    </div>
</div>

<!-- Page preview / edit modal -->
<div id="page-preview-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; overflow-y:auto;">
    <div style="background:#fff; max-width:860px; margin:40px auto; border-radius:4px; box-shadow:0 4px 20px rgba(0,0,0,0.3);">

        <!-- Header -->
        <div style="background:#337ab7; color:#fff; padding:15px 20px; border-radius:4px 4px 0 0; display:flex; justify-content:space-between; align-items:center;">
            <h4 id="modal-title" style="margin:0;"></h4>
            <button type="button" id="modal-close" style="background:none; border:none; color:#fff; font-size:22px; cursor:pointer; line-height:1;">&times;</button>
        </div>

        <!-- Tabs -->
        <div style="border-bottom:1px solid #ddd; padding:0 20px; background:#f5f5f5;">
            <button type="button" id="tab-view-btn" class="modal-tab active-tab" onclick="switchTab('view')">Preview</button>
            <button type="button" id="tab-edit-btn" class="modal-tab" onclick="switchTab('edit')">Edit &amp; Import</button>
        </div>

        <!-- Preview tab -->
        <div id="tab-view" style="padding:20px;">
            <table style="width:100%; margin-bottom:15px; font-size:13px;">
                <tr><td style="width:110px; color:#888; padding:3px 0;"><strong>Site</strong></td><td id="modal-site"></td></tr>
                <tr><td style="color:#888; padding:3px 0;"><strong>Page Code</strong></td><td id="modal-code" style="font-family:monospace;"></td></tr>
                <tr><td style="color:#888; padding:3px 0;"><strong>Menu</strong></td><td id="modal-menu"></td></tr>
                <tr><td style="color:#888; padding:3px 0; vertical-align:top;"><strong>Description</strong></td><td id="modal-desc" style="color:#555;"></td></tr>
            </table>
            <hr style="margin:10px 0;">
            <h5 style="margin-top:0; margin-bottom:10px; color:#555;">Page Body</h5>
            <div id="modal-body" style="border:1px solid #ddd; padding:15px; border-radius:3px; max-height:400px; overflow-y:auto; background:#fafafa;"></div>
        </div>

        <!-- Edit & Import tab -->
        <div id="tab-edit" style="display:none; padding:20px;">
            <form method="post" action="[% c.uri_for('/admin/import_single') %]">
                <input type="hidden" name="record_id" id="edit-record-id">

                <div class="form-group">
                    <label>Title</label>
                    <input type="text" name="title" id="edit-title" class="form-control" required>
                </div>
                <div style="display:flex; gap:15px;">
                    <div class="form-group" style="flex:1;">
                        <label>Site</label>
                        <select name="sitename" id="edit-sitename" class="form-control">
                            [% FOREACH s IN site_names %]
                                <option value="[% s %]">[% s %]</option>
                            [% END %]
                        </select>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>Menu</label>
                        <select name="menu" id="edit-menu" class="form-control">
                            [% FOREACH m IN menu_options %]
                                <option value="[% m %]">[% m %]</option>
                            [% END %]
                        </select>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>Page Code</label>
                        <input type="text" name="page_code" id="edit-page-code" class="form-control" required>
                    </div>
                </div>
                <div style="display:flex; gap:15px;">
                    <div class="form-group" style="flex:1;">
                        <label>Status</label>
                        <select name="status" id="edit-status" class="form-control">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>Roles</label>
                        <select name="roles" class="form-control">
                            <option value="public">Public</option>
                            <option value="member">Member</option>
                            <option value="admin">Admin</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>Link Order</label>
                        <input type="number" name="link_order" id="edit-link-order" class="form-control" value="0">
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" id="edit-description" class="form-control" rows="2"></textarea>
                </div>
                <div class="form-group">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
                        <label style="margin:0;">Body</label>
                        <span>
                            <button type="button" class="btn btn-xs btn-default body-tab-btn active-body-tab" onclick="switchBodyTab('html')">HTML</button>
                            <button type="button" class="btn btn-xs btn-default body-tab-btn" onclick="switchBodyTab('preview')">Preview</button>
                        </span>
                    </div>
                    <div id="body-html-pane">
                        <textarea name="body" id="edit-body" class="form-control" rows="10" style="font-family:monospace; font-size:12px;"
                            oninput="document.getElementById('body-preview-pane').innerHTML = this.value"></textarea>
                    </div>
                    <div id="body-preview-pane" style="display:none; border:1px solid #ddd; padding:15px; border-radius:3px; min-height:150px; background:#fafafa; overflow-y:auto; max-height:300px;"></div>
                </div>

                <div style="text-align:right;">
                    <button type="button" class="btn btn-default" id="modal-close-btn">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-download"></i> Import This Page
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Handle select all checkbox
    const selectAllCheckbox = document.getElementById('select_all');
    const pageCheckboxes = document.querySelectorAll('.page-checkbox');
    const migrateBtn = document.getElementById('migrate-btn');
    
    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', function() {
            pageCheckboxes.forEach(function(checkbox) {
                if (!checkbox.disabled) {
                    checkbox.checked = selectAllCheckbox.checked;
                }
            });
            updateMigrateButton();
        });
    }
    
    // Handle individual checkboxes
    pageCheckboxes.forEach(function(checkbox) {
        checkbox.addEventListener('change', function() {
            updateMigrateButton();
            
            // Update select all checkbox state
            if (selectAllCheckbox) {
                const checkedCount = document.querySelectorAll('.page-checkbox:checked').length;
                const enabledCount = document.querySelectorAll('.page-checkbox:not(:disabled)').length;
                selectAllCheckbox.checked = checkedCount === enabledCount && enabledCount > 0;
                selectAllCheckbox.indeterminate = checkedCount > 0 && checkedCount < enabledCount;
            }
        });
    });
    
    function updateMigrateButton() {
        if (migrateBtn) {
            const checkedCount = document.querySelectorAll('.page-checkbox:checked').length;
            migrateBtn.disabled = checkedCount === 0;
            migrateBtn.textContent = checkedCount > 0 ? 
                `Migrate ${checkedCount} Selected Page${checkedCount > 1 ? 's' : ''}` : 
                'Migrate Selected Pages';
        }
    }
    
    // Page preview / edit modal
    const modal = document.getElementById('page-preview-modal');

    document.querySelectorAll('.view-page-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const title = btn.dataset.title || btn.dataset.code;
            // Populate preview tab
            document.getElementById('modal-title').textContent = title;
            document.getElementById('modal-site').textContent = btn.dataset.site;
            document.getElementById('modal-code').textContent = btn.dataset.code;
            document.getElementById('modal-menu').textContent = btn.dataset.menu;
            document.getElementById('modal-desc').textContent = btn.dataset.desc || '—';
            document.getElementById('modal-body').innerHTML = btn.dataset.body || '<em style="color:#999">No content</em>';

            // Populate edit form
            document.getElementById('edit-record-id').value  = btn.dataset.id;
            document.getElementById('edit-title').value      = title;
            document.getElementById('edit-page-code').value  = btn.dataset.code;
            document.getElementById('edit-description').value= btn.dataset.desc || '';
            document.getElementById('edit-body').value       = btn.dataset.body || '';
            document.getElementById('edit-link-order').value = btn.dataset.order || '0';

            // Set site dropdown
            const siteEl = document.getElementById('edit-sitename');
            if (siteEl) {
                for (let opt of siteEl.options) {
                    opt.selected = (opt.value === btn.dataset.site);
                }
            }
            // Set menu dropdown (match lowercased)
            const menuEl = document.getElementById('edit-menu');
            if (menuEl) {
                const menuVal = (btn.dataset.menu || '').toLowerCase();
                let matched = false;
                for (let opt of menuEl.options) {
                    if (opt.value.toLowerCase() === menuVal) { opt.selected = true; matched = true; }
                    else opt.selected = false;
                }
                if (!matched && menuEl.options.length > 0) menuEl.options[0].selected = true;
            }
            // Set status
            const statusEl = document.getElementById('edit-status');
            if (statusEl) {
                const isActive = (btn.dataset.status === '1' || btn.dataset.status === 'active');
                statusEl.value = isActive ? 'active' : 'inactive';
            }

            switchTab('view');
            modal.style.display = 'block';
        });
    });

    window.switchBodyTab = function(tab) {
        const isHtml = (tab === 'html');
        document.getElementById('body-html-pane').style.display    = isHtml ? 'block' : 'none';
        document.getElementById('body-preview-pane').style.display = isHtml ? 'none'  : 'block';
        if (!isHtml) {
            document.getElementById('body-preview-pane').innerHTML =
                document.getElementById('edit-body').value || '<em style="color:#999">No content</em>';
        }
        document.querySelectorAll('.body-tab-btn').forEach(function(b) {
            b.classList.toggle('active-body-tab', b.textContent.trim().toLowerCase() === tab);
        });
    };

    window.switchTab = function(tab) {
        document.getElementById('tab-view').style.display = tab === 'view' ? 'block' : 'none';
        document.getElementById('tab-edit').style.display = tab === 'edit' ? 'block' : 'none';
        document.getElementById('tab-view-btn').classList.toggle('active-tab', tab === 'view');
        document.getElementById('tab-edit-btn').classList.toggle('active-tab', tab === 'edit');
    };

    function closeModal() { modal.style.display = 'none'; }
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-close-btn').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

    // Confirmation before migration
    if (migrateBtn) {
        migrateBtn.addEventListener('click', function(e) {
            const checkedCount = document.querySelectorAll('.page-checkbox:checked').length;
            if (!confirm(`Are you sure you want to migrate ${checkedCount} page${checkedCount > 1 ? 's' : ''}? This action cannot be undone.`)) {
                e.preventDefault();
            }
        });
    }
});
</script>

<style>
.table-responsive {
    max-height: 600px;
    overflow-y: auto;
}

.warning {
    background-color: #fcf8e3 !important;
}

.text-success {
    color: #3c763d;
}

.text-warning {
    color: #8a6d3b;
}

.text-danger {
    color: #a94442;
}

#migrate-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}
.modal-tab {
    background: none;
    border: none;
    padding: 10px 18px;
    cursor: pointer;
    color: #555;
    border-bottom: 3px solid transparent;
    margin-bottom: -1px;
    font-size: 14px;
}
.modal-tab.active-tab {
    color: #337ab7;
    border-bottom-color: #337ab7;
    font-weight: bold;
}
.active-body-tab {
    background-color: #337ab7 !important;
    color: #fff !important;
    border-color: #337ab7 !important;
}
</style>