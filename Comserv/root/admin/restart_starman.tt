[% META title = 'Restart Starman Service' %]
[% PageVersion = 'admin/restart_starman.tt,v 1.0 2025/01/27 shanta Exp shanta' %]

<div class="admin-container">
    <div class="admin-header">
        <h1><i class="fas fa-redo"></i> Restart Starman Service</h1>
        <p class="admin-description">
            Restart the Starman web server service. This requires sudo privileges.
        </p>
    </div>

    [% IF success_msg %]
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> [% success_msg %]
        </div>
    [% END %]

    [% IF error_msg %]
        <div class="alert alert-danger">
            <i class="fas fa-times-circle"></i> [% error_msg %]
        </div>
    [% END %]

    [% IF service_status %]
    <div class="admin-section">
        <h2><i class="fas fa-info-circle"></i> Current Service Status</h2>
        <div class="status-grid">
            <div class="status-item">
                <label>Service Status:</label>
                <span class="status-value [% service_status.status_class %]">
                    [% service_status.is_active %]
                </span>
            </div>
            [% IF service_status.uptime_info %]
            <div class="status-item">
                <label>Running Since:</label>
                <span class="status-value">[% service_status.uptime_info %]</span>
            </div>
            [% END %]
            [% IF service_status.error %]
            <div class="status-item">
                <label>Status Error:</label>
                <span class="status-value error">[% service_status.error %]</span>
            </div>
            [% END %]
        </div>
    </div>
    [% END %]

    [% IF show_password_form %]
    <div class="admin-section">
        <h2><i class="fas fa-key"></i> Sudo Authentication Required</h2>
        <p>Please provide your sudo credentials to restart the Starman service:</p>
        
        <form method="POST" class="sudo-form">
            <input type="hidden" name="confirm" value="1">
            <div class="form-group">
                <label for="sudo_username">Username:</label>
                <input type="text" name="sudo_username" id="sudo_username" class="form-control" 
                       value="[% (c.user ? c.user.username : '') %]" required>
            </div>
            <div class="form-group">
                <label for="sudo_password">Password:</label>
                <input type="password" name="sudo_password" id="sudo_password" class="form-control" required>
                <small class="form-text">Your password will not be stored and is only used for this operation.</small>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-warning">
                    <i class="fas fa-redo"></i> Restart Starman Service
                </button>
                <a href="/admin" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
    [% ELSE %]
    <div class="admin-section">
        <h2><i class="fas fa-tools"></i> Restart Service</h2>
        <p>Click the button below to restart the Starman service. You will be prompted for sudo credentials.</p>
        
        <form method="POST" style="display: inline;">
            <input type="hidden" name="show_credentials_form" value="1">
            <button type="submit" class="btn btn-warning btn-large">
                <i class="fas fa-redo"></i> Restart Starman Service
            </button>
        </form>
    </div>
    [% END %]

    [% IF output %]
        <div class="admin-section">
            <h2><i class="fas fa-terminal"></i> Restart Output</h2>
            <div class="output-container">
                <pre class="command-output">[% output %]</pre>
            </div>
        </div>
    [% END %]

    <div class="admin-section">
        <h2><i class="fas fa-link"></i> Related Operations</h2>
        <div class="action-buttons">
            <a href="/admin/starman_diagnostics" class="btn btn-info">
                <i class="fas fa-stethoscope"></i> Run Diagnostics
            </a>
            <a href="/admin/emergency-restore" class="btn btn-danger">
                <i class="fas fa-life-ring"></i> Emergency Restore
            </a>
            <a href="/admin" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Admin
            </a>
        </div>
    </div>
</div>

<style>
.admin-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
}

.admin-header {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    border-left: 4px solid #ffc107;
}

.admin-section {
    background: white;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
}

.status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.status-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    background: #f8f9fa;
    border-radius: 4px;
}

.status-value.active {
    color: #28a745;
    font-weight: bold;
}

.status-value.inactive {
    color: #dc3545;
    font-weight: bold;
}

.status-value.failed {
    color: #dc3545;
    font-weight: bold;
}

.status-value.error {
    color: #dc3545;
    font-size: 12px;
}

.sudo-form {
    max-width: 400px;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: bold;
}

.form-control {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #ced4da;
    border-radius: 4px;
    font-size: 14px;
}

.form-text {
    font-size: 12px;
    color: #666;
    margin-top: 5px;
}

.form-actions {
    display: flex;
    gap: 10px;
    align-items: center;
}

.action-buttons {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.btn {
    padding: 8px 16px;
    border: none;
    border-radius: 4px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-large {
    padding: 12px 24px;
    font-size: 16px;
}

.btn-warning {
    background: #ffc107;
    color: #212529;
}

.btn-info {
    background: #17a2b8;
    color: white;
}

.btn-danger {
    background: #dc3545;
    color: white;
}

.btn-secondary {
    background: #6c757d;
    color: white;
}

.output-container {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 15px;
}

.command-output {
    margin: 0;
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.4;
    white-space: pre-wrap;
    word-wrap: break-word;
}

.alert {
    padding: 12px 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.alert-success {
    background: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
}

.alert-danger {
    background: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
}
</style>