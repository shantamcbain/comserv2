[% META title = 'Starman Diagnostics' %]
[% PageVersion = 'admin/starman_diagnostics.tt,v 1.0 2025/01/27 shanta Exp shanta' %]

<div class="admin-container">
    <div class="admin-header">
        <h1><i class="fas fa-stethoscope"></i> Starman Diagnostics</h1>
        <p class="admin-description">
            Comprehensive diagnostics for the Starman web server service.
        </p>
    </div>

    [% IF success_msg %]
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> [% success_msg %]
        </div>
    [% END %]

    [% IF error_msg %]
        <div class="alert alert-danger">
            <i class="fas fa-times-circle"></i> [% error_msg %]
        </div>
    [% END %]

    <div class="admin-section">
        <h2><i class="fas fa-info-circle"></i> Service Status</h2>
        <div class="status-grid">
            <div class="status-item">
                <label>Service Status:</label>
                <span class="status-value [% service_status.status_class %]">
                    [% service_status.is_active %]
                </span>
            </div>
            [% IF service_status.uptime_info %]
            <div class="status-item">
                <label>Running Since:</label>
                <span class="status-value">[% service_status.uptime_info %]</span>
            </div>
            [% END %]
        </div>
    </div>

    [% IF output %]
        <div class="admin-section">
            <h2><i class="fas fa-terminal"></i> Diagnostic Output</h2>
            <div class="output-container">
                <pre class="command-output">[% output %]</pre>
            </div>
        </div>
    [% END %]

    <div class="admin-section">
        <h2><i class="fas fa-tools"></i> Actions</h2>
        <div class="action-buttons">
            <form method="POST" style="display: inline;">
                <input type="hidden" name="action" value="run_diagnostics">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-play"></i> Run Diagnostics
                </button>
            </form>
            <a href="/admin/restart_starman" class="btn btn-warning">
                <i class="fas fa-redo"></i> Restart Service
            </a>
            <a href="/admin" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Admin
            </a>
        </div>
    </div>
</div>

<style>
.admin-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
}

.admin-header {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    border-left: 4px solid #17a2b8;
}

.admin-section {
    background: white;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
}

.status-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}

.status-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    background: #f8f9fa;
    border-radius: 4px;
}

.status-value.active {
    color: #28a745;
    font-weight: bold;
}

.status-value.inactive {
    color: #dc3545;
    font-weight: bold;
}

.status-value.failed {
    color: #dc3545;
    font-weight: bold;
}

.action-buttons {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.btn {
    padding: 8px 16px;
    border: none;
    border-radius: 4px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-primary {
    background: #007bff;
    color: white;
}

.btn-warning {
    background: #ffc107;
    color: #212529;
}

.btn-secondary {
    background: #6c757d;
    color: white;
}

.output-container {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 4px;
    padding: 15px;
}

.command-output {
    margin: 0;
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.4;
    white-space: pre-wrap;
    word-wrap: break-word;
}

.alert {
    padding: 12px 16px;
    border-radius: 4px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.alert-success {
    background: #d4edda;
    border: 1px solid #c3e6cb;
    color: #155724;
}

.alert-danger {
    background: #f8d7da;
    border: 1px solid #f5c6cb;
    color: #721c24;
}
</style>