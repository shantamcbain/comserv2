[% META
   title        = "Hardware Monitor"
   description  = "System hardware metrics and alerts"
   roles        = "admin"
   TemplateType = "Application"
   category     = "Admin"
   page_version = "0.02"
   last_updated = "2026-03-16"
%]
<script src="/static/js/chart.umd.min.js"></script>
<script src="/static/js/chartjs-adapter-date-fns.bundle.min.js"></script>
<style>
.hw-filter-row   { display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end; margin-bottom:16px; }
.hw-filter-row label { font-size:.85em; font-weight:bold; display:block; margin-bottom:2px; }
.hw-summary-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px; margin-bottom:20px; }
.hw-card         { border:1px solid #ddd; border-radius:6px; padding:12px 16px; background:#fff; }
.hw-card h4      { margin:0 0 4px; font-size:.9em; color:#555; }
.hw-card .value  { font-size:1.4em; font-weight:bold; }
.hw-card .meta   { font-size:.8em; color:#888; margin-top:3px; }
.hw-charts-grid  { display:grid; grid-template-columns:repeat(auto-fill,minmax(520px,1fr)); gap:20px; margin-bottom:24px; }
.hw-chart-box        { background:#fff; border:1px solid #ddd; border-radius:6px; padding:14px; resize:vertical; overflow:hidden; height:260px; display:flex; flex-direction:column; }
.hw-chart-box h4     { margin:0 0 6px; font-size:.95em; color:#444; display:flex; justify-content:space-between; align-items:center; flex-shrink:0; }
.hw-chart-box h4 span { font-size:.75em; color:#aaa; font-weight:normal; }
.hw-chart-wrap       { position:relative; flex:1; min-height:0; }
.level-info      { border-left:4px solid #4caf50; }
.level-warn      { border-left:4px solid #ff9800; background:#fff8e1; }
.level-error     { border-left:4px solid #f44336; background:#fdecea; }
.level-critical  { border-left:4px solid #b71c1c; background:#f8d7da; font-weight:bold; }
.level-debug     { border-left:4px solid #9e9e9e; }
.badge-info      { background:#e8f5e9; color:#2e7d32; padding:2px 6px; border-radius:3px; font-size:.8em; }
.badge-warn      { background:#fff3e0; color:#e65100; padding:2px 6px; border-radius:3px; font-size:.8em; }
.badge-error     { background:#fdecea; color:#c62828; padding:2px 6px; border-radius:3px; font-size:.8em; }
.badge-critical  { background:#b71c1c; color:#fff;    padding:2px 6px; border-radius:3px; font-size:.8em; }
.log-scroll      { max-height:400px; overflow-y:auto; }
.nowrap          { white-space:nowrap; }
</style>

<div class="app-container">
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
        <h1>&#128268; Hardware Monitor</h1>
        <div style="display:flex;gap:8px;align-items:center;">
            <label style="font-size:.85em;font-weight:bold;">Auto-refresh:
                <select id="hw-refresh-sel" style="margin-left:4px;">
                    <option value="0" selected>Off</option>
                    <option value="30">30s</option>
                    <option value="60">1 min</option>
                    <option value="300">5 min</option>
                </select>
            </label>
            <span id="hw-refresh-countdown" style="font-size:.8em;color:#888;min-width:50px;"></span>
            <a href="[% c.uri_for('/admin/logging') %]" class="btn btn-secondary">&#128203; System Logs</a>
        </div>
    </div>
    <script>
    (function(){
        var sel=document.getElementById('hw-refresh-sel');
        var cd=document.getElementById('hw-refresh-countdown');
        var timer=null, countdown=0;
        function start(secs){
            clearInterval(timer);
            if(!secs){cd.textContent='';return;}
            countdown=secs;
            cd.textContent='Refresh in '+countdown+'s';
            timer=setInterval(function(){
                countdown--;
                if(countdown<=0){location.reload();}
                else{cd.textContent='Refresh in '+countdown+'s';}
            },1000);
        }
        sel.addEventListener('change',function(){start(parseInt(sel.value)||0);});
        start(parseInt(sel.value)||0);
    })();
    </script>

    [% IF db_error %]
    <div class="error">
        <strong>Database error:</strong> [% db_error | html %]
        <p>Apply the migration to create the table:
        <code>mysql -h 192.168.1.198 -u &lt;user&gt; -p ency &lt; db/migrations/20260316_create_hardware_metrics.sql</code></p>
    </div>
    [% END %]

    <form method="get" action="[% c.uri_for('/admin/hardware_monitor') %]">
        <div class="hw-filter-row">
            <div>
                <label>Host</label>
                <select name="filter_host">
                    <option value="">All hosts</option>
                    [% FOR h IN hosts %]
                    <option value="[% h | html %]"[% IF filter_host == h %] selected[% END %]>[% h | html %]</option>
                    [% END %]
                </select>
            </div>
            <div>
                <label>Metric</label>
                <select name="filter_metric">
                    <option value="">All metrics</option>
                    [% FOR n IN metric_names %]
                    <option value="[% n | html %]"[% IF filter_metric == n %] selected[% END %]>[% n | html %]</option>
                    [% END %]
                </select>
            </div>
            <div>
                <label>Level</label>
                <select name="filter_level">
                    <option value="">All levels</option>
                    [% FOR lv IN ['critical','error','warn','info','debug'] %]
                    <option value="[% lv %]"[% IF filter_level == lv %] selected[% END %]>[% lv %]</option>
                    [% END %]
                </select>
            </div>
            <div>
                <label>Window</label>
                <select name="filter_hours">
                    [% SET hour_opts = [{v=1,l='1 hr'},{v=2,l='2 hrs'},{v=6,l='6 hrs'},{v=24,l='1 day'},{v=48,l='2 days'},{v=168,l='7 days'}] %]
                    [% FOR opt IN hour_opts %]
                    <option value="[% opt.v %]"[% IF filter_hours == opt.v %] selected[% END %]>[% opt.l %]</option>
                    [% END %]
                </select>
            </div>
            <div style="padding-bottom:2px"><button type="submit" class="btn btn-primary">Filter</button></div>
        </div>
    </form>

    [%# ── Drive Space section ──────────────────────────────────────────────── %]
    [% IF disk_hosts.size %]
    <h3>&#128190; Drive Space — All Devices</h3>
    <style>
    .ds-host       { margin-bottom:18px; border:1px solid #ddd; border-radius:6px; overflow:hidden; }
    .ds-host-head  { display:flex; align-items:center; gap:10px; padding:8px 14px;
                     background:var(--bg-secondary,#f8f9fa); border-bottom:1px solid #ddd; font-weight:bold; }
    .ds-mounts     { padding:8px 14px; display:flex; flex-direction:column; gap:6px; }
    .ds-mount      { display:grid; grid-template-columns:130px 1fr 90px 120px; gap:8px; align-items:center; font-size:.88em; }
    .ds-bar-wrap   { background:#e9ecef; border-radius:4px; height:14px; overflow:hidden; }
    .ds-bar        { height:100%; border-radius:4px; transition:width .3s; }
    .ds-bar.lvl-info     { background:#4caf50; }
    .ds-bar.lvl-warn     { background:#ff9800; }
    .ds-bar.lvl-error    { background:#f44336; }
    .ds-bar.lvl-critical { background:#b71c1c; }
    .ds-pct        { text-align:right; font-weight:bold; min-width:38px; }
    .ds-sizes      { color:#888; font-size:.82em; white-space:nowrap; }
    .ds-ts         { color:#aaa; font-size:.75em; }
    @media(max-width:600px){
        .ds-mount  { grid-template-columns:100px 1fr 60px; }
        .ds-sizes  { display:none; }
    }
    </style>
    [% FOR dh IN disk_hosts %]
    <div class="ds-host">
        <div class="ds-host-head">
            <span class="badge-[% dh.worst_level %]">[% dh.worst_level | upper %]</span>
            &#128187; [% dh.hostname | html %]
            <span style="font-size:.8em;font-weight:normal;color:#888;">[% dh.mounts.size %] mount[% dh.mounts.size != 1 ? 's' : '' %]</span>
        </div>
        <div class="ds-mounts">
        [% FOR d IN dh.mounts %]
        <div class="ds-mount">
            <span style="font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="[% d.device | html %]">[% d.mount | html %]</span>
            <div class="ds-bar-wrap" title="[% d.pct %]% used">
                <div class="ds-bar lvl-[% d.level %]" style="width:[% d.pct || 0 %]%;"></div>
            </div>
            <span class="ds-pct" style="[% IF d.level == 'critical' %]color:#b71c1c[% ELSIF d.level == 'warn' %]color:#e65100[% END %]">[% d.pct || 0 %]%</span>
            <span class="ds-sizes">
                [% IF d.free_mb.defined %]
                    [% SET _free = d.free_mb %]
                    [% SET _tot  = d.total_mb %]
                    [% IF _free >= 1024 %][% _free / 1024 | format('%.1f') %]&thinsp;GB free[% ELSE %][% _free %]&thinsp;MB free[% END %]
                    [% IF _tot.defined %] /
                        [% IF _tot >= 1024 %][% _tot / 1024 | format('%.0f') %]&thinsp;GB[% ELSE %][% _tot %]&thinsp;MB[% END %]
                    [% END %]
                [% END %]
            </span>
        </div>
        [% END %]
        </div>
    </div>
    [% END %]

    <details style="margin-bottom:16px;">
        <summary style="cursor:pointer;font-size:.88em;color:#888;padding:4px 0;">&#128268; Remote agent setup — add any server-room device (one cron line per machine)</summary>
        <div style="margin-top:8px;background:#f8f9fa;border:1px solid #ddd;border-radius:4px;padding:12px;font-size:.85em;">

            <p style="margin:0 0 8px;font-weight:bold;font-size:1.05em;">How it works</p>
            <p style="margin:0 0 6px;">The agent script lives on the NFS server (<strong>192.168.1.175</strong>) and is readable by any machine that mounts the NFS share — no per-machine script copy needed. Each machine runs the script from <em>its own</em> NFS mount point and POSTs metrics to the <strong>production Comserv server</strong> (<code>comserv.computersystemconsulting.ca</code>) which runs 24/7 in Docker — not the dev workstation, which is only up when in use.</p>

            <p style="margin:8px 0 4px;font-weight:bold;">Step 1 — Mount the NFS share (if not already done)</p>
            <p style="margin:0 0 4px;">Add to <code>/etc/fstab</code> on the remote machine, then run <code>mount -a</code>:</p>
            <pre style="background:#222;color:#eee;padding:8px;border-radius:4px;overflow-x:auto;margin:0 0 10px;">192.168.1.175:/mnt/data   /mnt/nfs_data   nfs   defaults,_netdev,nofail   0 0</pre>
            <p style="margin:0 0 6px;color:#555;">After mounting, the agent script is at: <code>/mnt/nfs_data/comserv/scripts/device_agent.sh</code></p>

            <p style="margin:8px 0 4px;font-weight:bold;">Step 2 — Add the cron job</p>
            <p style="margin:0 0 4px;">Create <code>/etc/cron.d/comserv_agent</code> on the remote machine:</p>
            <pre style="background:#222;color:#eee;padding:8px;border-radius:4px;overflow-x:auto;margin:0 0 10px;">*/5 * * * * root INGEST_URL="[% ingest_url | html %]" INGEST_TOKEN="[% ingest_token | html %]" /mnt/nfs_data/comserv/scripts/device_agent.sh</pre>
            <p style="margin:0 0 6px;color:#555;">The script auto-detects the hostname of whichever machine runs it — no edits required. Metrics arrive here within 5 minutes.</p>

            <p style="margin:8px 0 4px;font-weight:bold;">Reference — what each server uses</p>
            <table style="border-collapse:collapse;font-size:.9em;width:100%;">
                <tr style="background:#e9ecef;"><th style="padding:4px 8px;text-align:left;border:1px solid #ddd;">Machine</th><th style="padding:4px 8px;text-align:left;border:1px solid #ddd;">IP</th><th style="padding:4px 8px;text-align:left;border:1px solid #ddd;">Script path (from that machine)</th></tr>
                <tr><td style="padding:4px 8px;border:1px solid #ddd;">workstation (this server)</td><td style="padding:4px 8px;border:1px solid #ddd;">192.168.1.199</td><td style="padding:4px 8px;border:1px solid #ddd;font-family:monospace;">/home/shanta/nfs/comserv/scripts/device_agent.sh</td></tr>
                <tr><td style="padding:4px 8px;border:1px solid #ddd;">proxmox720, proxmoxt210, comservproduction1, DB server, etc.</td><td style="padding:4px 8px;border:1px solid #ddd;">varies</td><td style="padding:4px 8px;border:1px solid #ddd;font-family:monospace;">/mnt/nfs_data/comserv/scripts/device_agent.sh</td></tr>
            </table>
            <p style="margin:8px 0 0;color:#888;">&#128274; Change token: set <code>HW_INGEST_TOKEN=yourtoken</code> in the app environment + update cron lines.<br>&#9881; Override ingest URL: set <code>HW_INGEST_BASE_URL=http://192.168.1.199:3001</code> in the app environment.</p>
        </div>
    </details>
    [% END %]

    [% IF latest.size || power_cards.size %]
    <details style="margin-bottom:12px;">
        <summary style="cursor:pointer;font-weight:bold;font-size:1.05em;padding:6px 0;list-style:none;display:flex;align-items:center;gap:8px;">
            &#128202; Current Status <span style="font-size:.8em;font-weight:normal;color:#888;">(latest readings per host)</span>
        </summary>
        <div class="hw-summary-grid" style="margin-top:10px;">
            [% FOR pc IN power_cards %]
            <div class="hw-card level-[% pc.worst_level %]">
                <h4>[% pc.hostname | html %] &mdash; IPMI / Power</h4>
                [% IF pc.ipmi_power_consumption %]
                <div class="value">[% pc.ipmi_power_consumption.metric_value %]&thinsp;W</div>
                [% END %]
                <div class="meta" style="margin-top:4px;line-height:1.8;">
                    [% IF pc.ipmi_ps1_current %]PS1: [% pc.ipmi_ps1_current.metric_value %]&thinsp;A&emsp;[% END %]
                    [% IF pc.ipmi_ps2_current %]PS2: [% pc.ipmi_ps2_current.metric_value %]&thinsp;A[% END %]
                    [% IF pc.ipmi_ps1_status %]<br>PS1: [% pc.ipmi_ps1_status.metric_text | html %]&emsp;[% END %]
                    [% IF pc.ipmi_ps2_status %]PS2: [% pc.ipmi_ps2_status.metric_text | html %][% END %]
                    [% IF pc.ipmi_ps_redundancy %]<br>Redundancy: [% pc.ipmi_ps_redundancy.metric_text | html %][% END %]
                    [% IF pc.ipmi_inlet_temp %]<br>Inlet: [% pc.ipmi_inlet_temp.metric_value %]&thinsp;&deg;C[% END %]
                </div>
                <div class="meta"><span class="badge-[% pc.worst_level %]">[% pc.worst_level | upper %]</span></div>
            </div>
            [% END %]
            [% FOR m IN latest %]
            <div class="hw-card level-[% m.level %]">
                <h4>[% m.hostname | html %] &mdash; [% m.metric_name | html %]</h4>
                <div class="value">
                    [% IF m.metric_value.defined %][% m.metric_value %][% IF m.unit %]&thinsp;[% m.unit | html %][% END %]
                    [% ELSIF m.metric_text %][% m.metric_text | html %]
                    [% ELSE %]&mdash;[% END %]
                </div>
                <div class="meta">
                    <span class="badge-[% m.level %]">[% m.level | upper %]</span>
                    &nbsp;[% m.timestamp | html %]
                </div>
            </div>
            [% END %]
        </div>
    </details>
    [% END %]

    <details style="margin-bottom:12px;">
        <summary style="cursor:pointer;font-weight:bold;font-size:1.05em;padding:6px 0;list-style:none;display:flex;align-items:center;gap:8px;">
            &#128200; Trend Graphs <span style="font-size:.8em;font-weight:normal;color:#888;">(CPU, memory, disk % over time)</span>
        </summary>
        <div class="hw-charts-grid" id="charts-container" style="margin-top:10px;">
            <p class="muted" id="charts-loading">Loading charts&hellip;</p>
        </div>
    </details>

    <details style="margin-bottom:12px;">
        <summary style="cursor:pointer;font-weight:bold;font-size:1.05em;padding:6px 0;list-style:none;display:flex;align-items:center;gap:8px;">
            &#128203; History <span style="font-size:.8em;font-weight:normal;color:#888;">([% metrics.size %] records in window)</span>
        </summary>
        [% IF metrics.size %]
        <div class="log-scroll" style="margin-top:10px;">
        <table class="data-table">
            <thead>
                <tr><th>Timestamp</th><th>Host</th><th>Metric</th><th>Value</th><th>Level</th><th>Message</th></tr>
            </thead>
            <tbody>
            [% FOR m IN metrics %]
                <tr class="level-[% m.level %]">
                    <td class="nowrap">[% m.timestamp | html %]</td>
                    <td>[% m.hostname | html %]</td>
                    <td>[% m.metric_name | html %]</td>
                    <td>[% IF m.metric_value.defined %][% m.metric_value %][% IF m.unit %] [% m.unit | html %][% END %]
                        [% ELSIF m.metric_text %][% m.metric_text | html %][% ELSE %]&mdash;[% END %]</td>
                    <td><span class="badge-[% m.level %]">[% m.level | upper %]</span></td>
                    <td>[% m.message | html %]</td>
                </tr>
            [% END %]
            </tbody>
        </table>
        </div>
        [% ELSE %]
        <p class="muted" style="margin-top:10px;">No records found. Ensure the migration has been applied and <code>script/hardware_monitor.pl</code> has run at least once.</p>
        [% END %]
    </details>
</div>

<script>
(function() {
    try {
    var rawData = [% chart_data_json %];
    if (!Array.isArray(rawData)) { rawData = []; }
    var container = document.getElementById('charts-container');
    container.innerHTML = '';

    var COLORS = ['#2196f3','#f44336','#4caf50','#ff9800','#9c27b0','#00bcd4','#795548','#607d8b'];

    var HOST_COLORS = {
        'workstation':        '#2196f3',
        'comserv':            '#4caf50',
        'proxmox720':         '#ff9800',
        'proxmoxt210':        '#9c27b0',
        'comservproduction1': '#f44336',
        'production':         '#f44336'
    };

    function hostColor(label) {
        var short = label.replace(/\.computersystemconsulting\.ca$/, '').replace(/\..*$/, '');
        var prefix = short.split(/\s*\u2013\s*/)[0].trim();
        if (HOST_COLORS[prefix]) return HOST_COLORS[prefix];
        var fallback = 0;
        for (var i = 0; i < prefix.length; i++) fallback += prefix.charCodeAt(i);
        return COLORS[fallback % COLORS.length];
    }

    var METRIC_ORDER = [
        'cpu_load_pct','mem_used_pct','swap_used_pct',
        'ipmi_power_consumption','ipmi_ps1_current','ipmi_ps2_current',
        'ipmi_inlet_temp'
    ];
    var METRIC_LABELS = {
        cpu_load_pct:           'CPU Load %',
        mem_used_pct:           'Memory Used %',
        swap_used_pct:          'Swap Used %',
        ipmi_power_consumption: 'Power (W)',
        ipmi_ps1_current:       'PS1 Current (A)',
        ipmi_ps2_current:       'PS2 Current (A)',
        ipmi_inlet_temp:        'Inlet Temperature (°C)'
    };
    var METRIC_UNITS = {
        cpu_load_pct:'%', mem_used_pct:'%', swap_used_pct:'%',
        ipmi_power_consumption:'W', ipmi_ps1_current:'A', ipmi_ps2_current:'A',
        ipmi_inlet_temp:'°C'
    };

    function tsToMs(ts) {
        return new Date(ts.replace(' ', 'T')).getTime();
    }

    function makeDatasets(hostMap) {
        var hosts = Object.keys(hostMap).sort();
        return hosts.map(function(host) {
            var color = hostColor(host);
            return {
                label: host,
                data: hostMap[host].map(function(pt){ return { x: tsToMs(pt[0]), y: pt[1] }; }),
                borderColor: color,
                backgroundColor: color + '22',
                tension: 0.3, fill: false, pointRadius: 2, pointHoverRadius: 5, spanGaps: true
            };
        });
    }

    function makeChart(canvas, hostMap, unit) {
        var datasets = makeDatasets(hostMap);
        new Chart(canvas, {
            type: 'line',
            data: { datasets: datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 12, font: { size: 11 } },
                        onClick: function(e, item, legend) {
                            var meta = legend.chart.getDatasetMeta(item.datasetIndex);
                            meta.hidden = !meta.hidden;
                            legend.chart.update();
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(item){ return item.dataset.label+': '+item.parsed.y+(unit?' '+unit:''); }
                        }
                    }
                },
                scales: {
                    x: {
                        type: 'time',
                        time: { tooltipFormat: 'MMM d HH:mm', displayFormats: { minute: 'HH:mm', hour: 'HH:mm', day: 'MMM d' } },
                        ticks: { maxTicksLimit: 8, maxRotation: 30, font: { size: 10 } }
                    },
                    y: { beginAtZero: false, ticks: { font: { size: 10 } } }
                }
            }
        });
    }

    function addChart(title, hostMap, unit) {
        var box = document.createElement('div');
        box.className = 'hw-chart-box';
        var h4 = document.createElement('h4');
        h4.innerHTML = title + '<span>drag bottom edge to resize</span>';
        box.appendChild(h4);
        var wrap = document.createElement('div');
        wrap.className = 'hw-chart-wrap';
        var canvas = document.createElement('canvas');
        wrap.appendChild(canvas);
        box.appendChild(wrap);
        container.appendChild(box);
        makeChart(canvas, hostMap, unit, 0);
    }

    function addSplitCard(title, topHostMap, topUnit, topLabel, botHostMap, botUnit, botLabel) {
        var box = document.createElement('div');
        box.className = 'hw-chart-box';
        box.style.height = '420px';
        var h4 = document.createElement('h4');
        h4.innerHTML = title + '<span>drag bottom edge to resize</span>';
        box.appendChild(h4);
        [[topLabel, topHostMap, topUnit],[botLabel, botHostMap, botUnit]].forEach(function(cfg){
            var lbl = document.createElement('div');
            lbl.style.cssText = 'font-size:.78em;color:#666;margin:4px 0 2px;';
            lbl.textContent = cfg[0];
            box.appendChild(lbl);
            var wrap = document.createElement('div');
            wrap.className = 'hw-chart-wrap';
            wrap.style.flex = '1';
            var canvas = document.createElement('canvas');
            wrap.appendChild(canvas);
            box.appendChild(wrap);
            makeChart(canvas, cfg[1], cfg[2]);
        });
        container.appendChild(box);
    }

    var byMetric = {};
    rawData.forEach(function(entry){ byMetric[entry.metric] = entry.hosts; });

    var rendered = 0;
    var powerDone = false;

    rawData.forEach(function(entry) {
        var metric = entry.metric, hostMap = entry.hosts;
        if (!hostMap || !Object.keys(hostMap).length) return;

        if (metric === 'ipmi_power_consumption') {
            if (powerDone) return;
            powerDone = true;
            var wHosts = byMetric['ipmi_power_consumption'] || {};
            var aHosts = {};
            ['ipmi_ps1_current','ipmi_ps2_current'].forEach(function(mn, i) {
                var hm = byMetric[mn];
                if (!hm) return;
                Object.keys(hm).forEach(function(host) {
                    aHosts[host+' PS'+(i+1)] = hm[host];
                });
            });
            if (Object.keys(aHosts).length) {
                addSplitCard('Power / PSU Current',
                    wHosts, 'W', 'System Power (W)',
                    aHosts, 'A', 'PSU Current (A)');
            } else {
                addChart(METRIC_LABELS[metric]||metric, wHosts, 'W');
            }
            rendered++;
            return;
        }
        if (metric === 'ipmi_ps1_current' || metric === 'ipmi_ps2_current') return;
        if (metric.match(/_temp$/)) return;

        if (metric.match(/^disk_used_pct/)) {
            var mountPart = metric.replace(/^disk_used_pct/, '') || '_';
            var mountLabel = mountPart.replace(/^_/, '/').replace(/_/g, '/') || '/';
            addChart('Disk % — ' + mountLabel, hostMap, '%');
            rendered++;
            return;
        }

        var unit = METRIC_UNITS[metric] || '';
        addChart(METRIC_LABELS[metric] || metric, hostMap, unit);
        rendered++;
    });

    var combinedTemps = {};
    rawData.forEach(function(entry) {
        if (!entry.metric.match(/_temp$/) || !entry.hosts) return;
        var shortMetric = entry.metric.replace(/_temp$/, '').replace(/_/g, ' ');
        Object.keys(entry.hosts).forEach(function(host) {
            var shortHost = host.replace(/\.computersystemconsulting\.ca$/, '').replace(/\..*$/, '');
            var label = shortHost + ' \u2013 ' + shortMetric;
            combinedTemps[label] = entry.hosts[host];
        });
    });
    if (Object.keys(combinedTemps).length) {
        addChart('Temperatures (\u00b0C)', combinedTemps, '\u00b0C');
        rendered++;
    }

    if (!rendered) {
        container.innerHTML = '<p class="muted">No numeric graph data in the selected window.</p>';
    }
    } catch(e) {
        var dbg = document.getElementById('hw-debug-info');
        if (dbg) dbg.textContent = 'ERROR: ' + e.message;
        var container2 = document.getElementById('charts-container');
        if (container2) container2.innerHTML = '<p class="muted" style="color:#c00">Chart error: ' + e.message + '</p>';
    }
})();
</script>
