[% META
   title        = "Hardware Monitor"
   description  = "System hardware metrics and alerts"
   roles        = "admin"
   TemplateType = "Application"
   category     = "Admin"
   page_version = "0.02"
   last_updated = "2026-03-16"
%]
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<style>
.hw-filter-row   { display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end; margin-bottom:16px; }
.hw-filter-row label { font-size:.85em; font-weight:bold; display:block; margin-bottom:2px; }
.hw-summary-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px; margin-bottom:20px; }
.hw-card         { border:1px solid #ddd; border-radius:6px; padding:12px 16px; background:#fff; }
.hw-card h4      { margin:0 0 4px; font-size:.9em; color:#555; }
.hw-card .value  { font-size:1.4em; font-weight:bold; }
.hw-card .meta   { font-size:.8em; color:#888; margin-top:3px; }
.hw-charts-grid  { display:grid; grid-template-columns:repeat(auto-fill,minmax(480px,1fr)); gap:20px; margin-bottom:24px; }
.hw-chart-box    { background:#fff; border:1px solid #ddd; border-radius:6px; padding:14px; }
.hw-chart-box h4 { margin:0 0 10px; font-size:.95em; color:#444; }
.level-info      { border-left:4px solid #4caf50; }
.level-warn      { border-left:4px solid #ff9800; background:#fff8e1; }
.level-error     { border-left:4px solid #f44336; background:#fdecea; }
.level-critical  { border-left:4px solid #b71c1c; background:#f8d7da; font-weight:bold; }
.level-debug     { border-left:4px solid #9e9e9e; }
.badge-info      { background:#e8f5e9; color:#2e7d32; padding:2px 6px; border-radius:3px; font-size:.8em; }
.badge-warn      { background:#fff3e0; color:#e65100; padding:2px 6px; border-radius:3px; font-size:.8em; }
.badge-error     { background:#fdecea; color:#c62828; padding:2px 6px; border-radius:3px; font-size:.8em; }
.badge-critical  { background:#b71c1c; color:#fff;    padding:2px 6px; border-radius:3px; font-size:.8em; }
.log-scroll      { max-height:400px; overflow-y:auto; }
.nowrap          { white-space:nowrap; }
</style>

<div class="app-container">
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
        <h1>&#128268; Hardware Monitor</h1>
        <a href="[% c.uri_for('/admin/logging') %]" class="btn btn-secondary">&#128203; System Logs</a>
    </div>

    [% IF db_error %]
    <div class="error">
        <strong>Database error:</strong> [% db_error | html %]
        <p>Apply the migration to create the table:
        <code>mysql -h 192.168.1.198 -u &lt;user&gt; -p ency &lt; db/migrations/20260316_create_hardware_metrics.sql</code></p>
    </div>
    [% END %]

    <form method="get" action="[% c.uri_for('/admin/hardware_monitor') %]">
        <div class="hw-filter-row">
            <div>
                <label>Host</label>
                <select name="filter_host">
                    <option value="">All hosts</option>
                    [% FOR h IN hosts %]
                    <option value="[% h | html %]"[% IF filter_host == h %] selected[% END %]>[% h | html %]</option>
                    [% END %]
                </select>
            </div>
            <div>
                <label>Metric</label>
                <select name="filter_metric">
                    <option value="">All metrics</option>
                    [% FOR n IN metric_names %]
                    <option value="[% n | html %]"[% IF filter_metric == n %] selected[% END %]>[% n | html %]</option>
                    [% END %]
                </select>
            </div>
            <div>
                <label>Level</label>
                <select name="filter_level">
                    <option value="">All levels</option>
                    [% FOR lv IN ['critical','error','warn','info','debug'] %]
                    <option value="[% lv %]"[% IF filter_level == lv %] selected[% END %]>[% lv %]</option>
                    [% END %]
                </select>
            </div>
            <div>
                <label>Window</label>
                <select name="filter_hours">
                    [% FOR h IN [1,6,12,24,48,168] %]
                    <option value="[% h %]"[% IF filter_hours == h %] selected[% END %]>
                        [% IF h < 24 %][% h %]h[% ELSIF h == 24 %]24 h[% ELSIF h == 48 %]2 days[% ELSE %]7 days[% END %]
                    </option>
                    [% END %]
                </select>
            </div>
            <div style="padding-bottom:2px"><button type="submit" class="btn btn-primary">Filter</button></div>
        </div>
    </form>

    [% IF latest.size %]
    <h3>Current Status</h3>
    <div class="hw-summary-grid">
        [% FOR m IN latest %]
        <div class="hw-card level-[% m.level %]">
            <h4>[% m.hostname | html %] &mdash; [% m.metric_name | html %]</h4>
            <div class="value">
                [% IF m.metric_value.defined %][% m.metric_value %][% IF m.unit %]&thinsp;[% m.unit | html %][% END %]
                [% ELSIF m.metric_text %][% m.metric_text | html %]
                [% ELSE %]&mdash;[% END %]
            </div>
            <div class="meta">
                <span class="badge-[% m.level %]">[% m.level | upper %]</span>
                &nbsp;[% m.timestamp | html %]
            </div>
            [% IF m.message %]<div class="meta">[% m.message | html %]</div>[% END %]
        </div>
        [% END %]
    </div>
    [% END %]

    <h3>Trend Graphs</h3>
    <div class="hw-charts-grid" id="charts-container">
        <p class="muted" id="charts-loading">Loading charts&hellip;</p>
    </div>

    <h3>History ([% metrics.size %] records)</h3>
    [% IF metrics.size %]
    <div class="log-scroll">
    <table class="data-table">
        <thead>
            <tr><th>Timestamp</th><th>Host</th><th>Metric</th><th>Value</th><th>Level</th><th>Message</th></tr>
        </thead>
        <tbody>
        [% FOR m IN metrics %]
            <tr class="level-[% m.level %]">
                <td class="nowrap">[% m.timestamp | html %]</td>
                <td>[% m.hostname | html %]</td>
                <td>[% m.metric_name | html %]</td>
                <td>[% IF m.metric_value.defined %][% m.metric_value %][% IF m.unit %] [% m.unit | html %][% END %]
                    [% ELSIF m.metric_text %][% m.metric_text | html %][% ELSE %]&mdash;[% END %]</td>
                <td><span class="badge-[% m.level %]">[% m.level | upper %]</span></td>
                <td>[% m.message | html %]</td>
            </tr>
        [% END %]
        </tbody>
    </table>
    </div>
    [% ELSE %]
    <p class="muted">No records found. Ensure the migration has been applied and <code>script/hardware_monitor.pl</code> has run at least once.</p>
    [% END %]
</div>

<script>
(function() {
    var rawData = [% chart_data_json %];
    var container = document.getElementById('charts-container');
    container.innerHTML = '';

    var COLORS = ['#2196f3','#f44336','#4caf50','#ff9800','#9c27b0','#00bcd4'];
    var metricLabels = {
        cpu_load_pct:           'CPU Load %',
        mem_used_pct:           'Memory Used %',
        swap_used_pct:          'Swap Used %',
        ipmi_power_consumption: 'Power Consumption (W)',
        ipmi_inlet_temp:        'Inlet Temperature (°C)'
    };

    var rendered = 0;
    for (var metric in rawData) {
        var hostMap = rawData[metric];
        var allLabels = {};
        for (var host in hostMap) {
            hostMap[host].forEach(function(pt) { allLabels[pt[0]] = true; });
        }
        var labels = Object.keys(allLabels).sort();
        if (!labels.length) continue;

        var datasets = [];
        var ci = 0;
        for (var host in hostMap) {
            var byTs = {};
            hostMap[host].forEach(function(pt) { byTs[pt[0]] = pt[1]; });
            datasets.push({
                label: host,
                data: labels.map(function(l) { return byTs[l] !== undefined ? byTs[l] : null; }),
                borderColor: COLORS[ci % COLORS.length],
                backgroundColor: COLORS[ci % COLORS.length] + '22',
                tension: 0.3,
                fill: false,
                pointRadius: 2,
                spanGaps: true
            });
            ci++;
        }

        var box = document.createElement('div');
        box.className = 'hw-chart-box';
        var title = document.createElement('h4');
        title.textContent = metricLabels[metric] || metric;
        box.appendChild(title);
        var canvas = document.createElement('canvas');
        canvas.height = 180;
        box.appendChild(canvas);
        container.appendChild(box);

        new Chart(canvas, {
            type: 'line',
            data: { labels: labels, datasets: datasets },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } },
                scales: {
                    x: { ticks: { maxTicksLimit: 8, maxRotation: 30 } },
                    y: { beginAtZero: false }
                }
            }
        });
        rendered++;
    }

    if (!rendered) {
        container.innerHTML = '<p class="muted">No numeric graph data in the selected window.</p>';
    }
})();
</script>
