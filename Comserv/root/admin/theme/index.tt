[% META title = 'Theme Management' %]

<div class="container-fluid">
    <h1 class="mb-3">Theme Management</h1>

    [% IF c.flash.message %]
        <div class="alert alert-success alert-dismissible fade show">
            [% c.flash.message %]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    [% END %]

    [% IF c.flash.error %]
        <div class="alert alert-danger alert-dismissible fade show">
            [% c.flash.error %]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    [% END %]

    [% IF info_msg %]
        <div class="alert alert-info">[% info_msg %]</div>
    [% END %]

    <!-- Workflow overview -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Theme Workflow</h4>
                    <a href="[% c.uri_for('/Documentation/CssThemes') %]" class="btn btn-sm btn-light">
                        View Documentation
                    </a>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3">
                            <div class="p-3 border rounded h-100">
                                <div class="display-6 mb-2">1</div>
                                <h5>Choose a Theme</h5>
                                <p class="text-muted small">Select an existing theme for your site from the list below.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 border rounded h-100">
                                <div class="display-6 mb-2">2</div>
                                <h5>Modify a Theme</h5>
                                <p class="text-muted small">Edit CSS variables or raw CSS of any existing theme directly in the browser.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 border rounded h-100">
                                <div class="display-6 mb-2">3</div>
                                <h5>Create a New Theme</h5>
                                <p class="text-muted small">Build a brand-new theme from scratch or based on an existing one.</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="p-3 border rounded h-100">
                                <div class="display-6 mb-2">4</div>
                                <h5>Preview &amp; Apply</h5>
                                <p class="text-muted small">Preview the result live and assign the theme to your site.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 1: Current theme & quick-change -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Step 1 – Active Theme for <em>[% site.name %]</em></h5>
                </div>
                <div class="card-body">
                    <p><strong>Current theme:</strong> <span class="badge bg-secondary fs-6">[% theme_name %]</span></p>

                    <form action="[% c.uri_for('/admin/theme/update') %]" method="POST" class="mt-3">
                        <input type="hidden" name="site_id" value="[% site.id %]">
                        <div class="mb-3">
                            <label for="theme" class="form-label fw-bold">Switch to a different theme:</label>
                            <select name="theme" id="theme" class="form-select">
                                [% FOREACH t IN available_themes %]
                                <option value="[% t %]" [% IF t == theme_name %]selected[% END %]>
                                    [% themes.$t.name || t.ucfirst %]
                                </option>
                                [% END %]
                            </select>
                        </div>
                        <button type="submit" class="btn btn-info">Apply Theme</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Live mini-preview -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Live Colour Preview</h5>
                </div>
                <div class="card-body">
                    <div id="theme-preview-box" class="p-3 rounded border" style="background-color: var(--background-color, #fff);">
                        <p style="color: var(--text-color, #000);">Sample text using <code>--text-color</code></p>
                        <a href="#" style="color: var(--link-color, blue);">Sample link</a> &nbsp;
                        <button class="btn btn-sm" style="background-color: var(--button-bg, #007bff); color: var(--button-text, #fff);">
                            Button
                        </button>
                        <div class="mt-2 p-2 rounded" style="background-color: var(--primary-color, #ccffff);">
                            Primary colour swatch
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2: Edit existing themes -->
    <div class="card mb-4">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0">Step 2 – Modify an Existing Theme</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Theme</th>
                            <th>Description</th>
                            <th>Primary Colour</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        [% FOREACH t IN available_themes %]
                        <tr [% IF t == theme_name %]class="table-active fw-bold"[% END %]>
                            <td>
                                [% themes.$t.name || t.ucfirst %]
                                [% IF t == theme_name %]
                                    <span class="badge bg-success ms-1">Active</span>
                                [% END %]
                            </td>
                            <td class="text-muted small">[% themes.$t.description || '—' %]</td>
                            <td>
                                [% SET pc = themes.$t.variables.item('primary-color') || '#cccccc' %]
                                <div style="display:inline-block; width:24px; height:24px; background:[% pc %]; border:1px solid #999; border-radius:3px; vertical-align:middle;"></div>
                                <code class="ms-1 small">[% pc %]</code>
                            </td>
                            <td class="text-center">
                                <a href="[% c.uri_for('/admin/theme/edit', t) %]" class="btn btn-sm btn-outline-primary me-1">
                                    Edit CSS
                                </a>
                                <a href="[% c.uri_for('/admin/theme/edit_css_interactive', t) %]" class="btn btn-sm btn-outline-info me-1">
                                    Interactive Editor
                                </a>
                                <a href="[% c.uri_for('/admin/theme/details', t) %]" class="btn btn-sm btn-outline-secondary">
                                    Details
                                </a>
                            </td>
                        </tr>
                        [% END %]
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Step 3: Create new theme -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Step 3 – Create a New Theme</h5>
            <a href="[% c.uri_for('/admin/theme/create') %]" class="btn btn-light btn-sm">
                Open Theme Creator
            </a>
        </div>
        <div class="card-body">
            <p>Use the Theme Creator to build a brand-new theme from scratch, or base it on an existing theme and override individual colours and fonts.</p>

            <!-- Quick colour-picker shortcut -->
            <details class="mt-2">
                <summary class="btn btn-outline-success btn-sm">Quick Custom Theme (colour pickers)</summary>
                <div class="mt-3">
                    <form action="[% c.uri_for('/admin/theme/create_custom') %]" method="POST">
                        <input type="hidden" name="site_id" value="[% site.id %]">
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <label class="form-label">Primary Colour</label>
                                <input type="color" name="primary_color" class="form-control form-control-color" value="#ccffff">
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Secondary Colour</label>
                                <input type="color" name="secondary_color" class="form-control form-control-color" value="#e6ffff">
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Accent Colour</label>
                                <input type="color" name="accent_color" class="form-control form-control-color" value="#FF9900">
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Text Colour</label>
                                <input type="color" name="text_color" class="form-control form-control-color" value="#000000">
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Link Colour</label>
                                <input type="color" name="link_color" class="form-control form-control-color" value="#0000FF">
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-success">Generate &amp; Apply Custom Theme</button>
                            </div>
                        </div>
                    </form>
                </div>
            </details>
        </div>
    </div>

    <!-- Step 4: Interactive / Advanced -->
    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Advanced Editors</h5>
        </div>
        <div class="card-body d-flex gap-3 flex-wrap">
            <a href="[% c.uri_for('/admin/theme/edit_css_interactive') %]" class="btn btn-outline-dark">
                Interactive CSS Editor (current theme)
            </a>
            <a href="[% c.uri_for('/Documentation/CssThemes') %]" class="btn btn-outline-secondary">
                Read Theme Documentation
            </a>
        </div>
    </div>

    <!-- Favicon Management -->
    <div class="card mb-4">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Browser Tab Icon (Favicon)</h5>
        </div>
        <div class="card-body">
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    [% IF site_favicon %]
                    <img src="[% site_favicon %]" alt="Current favicon" style="width:32px; height:32px; border:1px solid #ccc;" title="Current favicon">
                    [% ELSE %]
                    <img src="/static/images/favicon.ico" alt="Default favicon" style="width:32px; height:32px; border:1px solid #ccc;" title="Default favicon">
                    [% END %]
                    <div class="form-text">Current icon for <strong>[% site.name %]</strong></div>
                </div>
                <div class="col">
                    <form action="[% c.uri_for('/admin/theme/set_favicon') %]" method="POST" enctype="multipart/form-data" class="row g-2 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label small fw-bold">Upload new icon (.ico, .png, .svg)</label>
                            <input type="file" name="favicon_file" class="form-control form-control-sm" accept=".ico,.png,.svg,.gif">
                        </div>
                        <div class="col-md-5">
                            <label class="form-label small fw-bold">Or enter a URL</label>
                            <input type="text" name="favicon_url" class="form-control form-control-sm"
                                   placeholder="/static/images/my-icon.png" value="[% site_favicon %]">
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-info btn-sm w-100">Set Icon</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Import / Export Themes -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Import &amp; Export Themes</h5>
            <a href="[% c.uri_for('/admin/theme/import') %]" class="btn btn-light btn-sm">
                Import Theme
            </a>
        </div>
        <div class="card-body">
            <p class="mb-2">Import themes created by this system, from another site, or generated by an AI tool. Export any theme as a portable JSON file.</p>
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-light">
                        <tr><th>Theme</th><th>Description</th><th class="text-center">Export</th></tr>
                    </thead>
                    <tbody>
                        [% FOREACH t IN available_themes %]
                        <tr>
                            <td>[% themes.$t.name || t.ucfirst %]</td>
                            <td class="text-muted small">[% themes.$t.description || '—' %]</td>
                            <td class="text-center">
                                <a href="[% c.uri_for('/admin/theme/export', t) %]" class="btn btn-sm btn-outline-secondary">
                                    Download JSON
                                </a>
                            </td>
                        </tr>
                        [% END %]
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
