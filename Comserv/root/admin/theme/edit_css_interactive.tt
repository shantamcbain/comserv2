[% META title = 'Interactive Theme Editor' %]
[% PageVersion = 'admin/theme/edit_css_interactive.tt,v 0.01 2025/01/19 shanta Exp shanta ' %]
[% debug %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
    [% "Debugging HostName: " _ HostName %]
    [%# INCLUDE 'debug.tt' %]
[% END %]

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h1>Interactive Theme Editor - [% theme_name %]</h1>
            <p>Use this interface to edit the CSS for the [% theme_name %] theme.</p>
            
            <div class="theme-editor-interface">
                <div class="row">
                    <div class="col-md-6">
                        <h3>CSS Editor</h3>
                        <textarea id="css-editor" class="form-control" rows="20" style="font-family: monospace;">[% css_content | html %]</textarea>
                        
                        <div class="mt-3">
                            <button id="save-css" class="btn btn-primary">Save Changes</button>
                            <button id="preview-css" class="btn btn-info">Preview</button>
                            <a href="[% c.uri_for('/admin/theme') %]" class="btn btn-secondary">Back to Themes</a>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <h3>Preview</h3>
                        <div id="theme-preview" class="border p-3" style="min-height: 400px;">
                            <p>Preview will be shown here when you click the Preview button.</p>
                        </div>
                        
                        [% IF theme_variables.size > 0 %]
                        <h4>Theme Variables</h4>
                        <div class="theme-variables">
                            [% FOREACH var IN theme_variables.keys %]
                                <div class="form-group">
                                    <label>[% var %]:</label>
                                    <input type="text" class="form-control theme-variable" data-variable="[% var %]" value="[% theme_variables.$var %]">
                                </div>
                            [% END %]
                        </div>
                        [% END %]
                        
                        [% IF available_images.size > 0 %]
                        <h4>Available Images</h4>
                        <div class="available-images">
                            [% FOREACH dir IN available_images.keys %]
                                <h5>[% dir %]</h5>
                                <div class="image-gallery">
                                    [% FOREACH image IN available_images.$dir %]
                                        <img src="/static/images/[% dir %]/[% image %]" alt="[% image %]" class="img-thumbnail" style="max-width: 100px; max-height: 100px; margin: 5px;">
                                    [% END %]
                                </div>
                            [% END %]
                        </div>
                        [% END %]
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
