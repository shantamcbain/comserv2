[% META title = 'Import Theme' %]

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Import Theme</h1>
        <a href="[% c.uri_for('/admin/theme') %]" class="btn btn-secondary">Back to Theme Management</a>
    </div>

    [% IF c.flash.error %]
        <div class="alert alert-danger alert-dismissible fade show">
            [% c.flash.error %]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    [% END %]

    <div class="alert alert-info">
        <strong>Supported formats:</strong>
        <ul class="mb-0 mt-1">
            <li>A <strong>single-theme JSON</strong> export: <code>{"name":"...", "variables":{...}}</code></li>
            <li>A <strong>theme definitions export</strong> (multiple themes): <code>{"themes":{"theme-key":{...}, ...}}</code></li>
        </ul>
        You can export any existing theme via the <em>Export</em> button on the theme list.
    </div>

    <form action="[% c.uri_for('/admin/theme/import') %]" method="POST" enctype="multipart/form-data">

        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Option A — Upload a JSON file</h5>
            </div>
            <div class="card-body">
                <input type="file" name="theme_file" class="form-control" accept=".json,application/json">
                <div class="form-text">Select a <code>.json</code> file exported from this system or generated by an AI tool.</div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Option B — Paste JSON</h5>
            </div>
            <div class="card-body">
                <textarea name="theme_json" class="form-control font-monospace" rows="12"
                          placeholder='{"name": "my-theme", "description": "Imported theme", "variables": {"primary-color": "#007bff", "text-color": "#000"}}'></textarea>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-lg">Import Theme(s)</button>
            <a href="[% c.uri_for('/admin/theme') %]" class="btn btn-secondary btn-lg">Cancel</a>
        </div>
    </form>
</div>
