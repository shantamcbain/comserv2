[%
   title = "Admin Page Management"
   description = "Manage and customize your site pages"
   roles = "admin"
   TemplateType = "Application"
   category = "Admin"
   page_version = "1.00"
   last_updated = "2026-05-25"
%]

<div class="container mt-3">
[% META title = 'Page Management Admin' %]

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; padding-bottom: 10px; border-bottom: 2px solid #eee;">
                <h2 style="margin: 0;">Page Management System</h2>
                <div>
                    <a href="[% c.uri_for('/admin') %]" class="btn btn-default">
                        <i class="fa fa-arrow-left"></i> Back to Dashboard
                    </a>
                    [% UNLESS show_form %]
                        <a href="[% c.uri_for('/admin/pages', { action => 'create' }) %]" class="btn btn-primary">
                            <i class="fa fa-plus"></i> Create New Page
                        </a>
                    [% END %]
                </div>
            </div>

            [% SET display_error = error_msg || c.flash.error_msg %]
            [% IF display_error %]
                <div class="alert alert-danger alert-dismissible" role="alert">
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <strong>Error:</strong> [% display_error %]
                    <a href="[% c.uri_for('/admin/migrate_pages') %]" class="btn btn-info">
                        <i class="fa fa-database"></i> Migrate Legacy Pages
                    </a>
                </div>
            [% END %]

            [% SET display_success = success_msg || c.flash.success_msg %]
            [% IF display_success %]
                <div class="alert alert-success alert-dismissible" role="alert">
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <strong>Success:</strong> [% display_success %]
                </div>
            [% END %]

            [% IF show_form %]
                <div class="panel panel-primary">
                    <div class="panel-heading">
                        <h3 class="panel-title">
                            [% IF show_form == 'edit' %]
                                <i class="fa fa-edit"></i> Edit Page: [% page_item.page_code %]
                            [% ELSE %]
                                <i class="fa fa-plus"></i> Create New Page
                            [% END %]
                        </h3>
                    </div>
                    <div class="panel-body">
                        <form method="post" action="[% c.uri_for('/admin/pages') %]">
                            <input type="hidden" name="action" value="save">
                            [% IF page_item.id %]
                                <input type="hidden" name="id" value="[% page_item.id %]">
                            [% END %]

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="sitename">Site Name <span class="text-danger">*</span></label>
                                        <input type="text" name="sitename" id="sitename" class="form-group form-control" value="[% page_item.sitename || 'CSC' %]" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="menu">Menu Section <span class="text-danger">*</span></label>
                                        <input type="text" name="menu" id="menu" class="form-group form-control" value="[% page_item.menu || 'main' %]" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="page_code">Page Code <span class="text-danger">*</span></label>
                                        <input type="text" name="page_code" id="page_code" class="form-group form-control" value="[% page_item.page_code %]" placeholder="e.g. home, about_us" required [% IF show_form == 'edit' %]readonly[% END %]>
                                        [% IF show_form == 'edit' %]<span class="help-block">Page Code cannot be modified after creation.</span>[% END %]
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label for="title">Page Title <span class="text-danger">*</span></label>
                                        <input type="text" name="title" id="title" class="form-group form-control" value="[% page_item.title %]" placeholder="Enter friendly title for page" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="link_order">Link/Sort Order</label>
                                        <input type="number" name="link_order" id="link_order" class="form-group form-control" value="[% page_item.link_order || 0 %]">
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="body">Page Body (HTML/Text) <span class="text-danger">*</span></label>
                                <textarea name="body" id="body" rows="12" class="form-group form-control" placeholder="Enter HTML or text content for the page" required>[% page_item.body %]</textarea>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="description">SEO Description</label>
                                        <textarea name="description" id="description" rows="3" class="form-group form-control" placeholder="Meta description for search engines">[% page_item.description %]</textarea>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="keywords">SEO Keywords</label>
                                        <input type="text" name="keywords" id="keywords" class="form-group form-control" value="[% page_item.keywords %]" placeholder="comma, separated, keywords">
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="status">Status</label>
                                        <select name="status" id="status" class="form-group form-control">
                                            <option value="active" [% IF page_item.status == 'active' %]selected[% END %]>Active</option>
                                            <option value="inactive" [% IF page_item.status == 'inactive' %]selected[% END %]>Inactive</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="roles">Access Roles <i class="fa fa-question-circle text-info" style="cursor: help; margin-left: 4px;" title="Restricts page access to specific logged-in user roles. Mapped in Catalyst controller and AdminAuth to check session permissions. AI Suggestion: Use 'public' for everyone, 'member' for registered users, or 'admin' for administrators."></i></label>
                                        <select name="roles" id="roles" class="form-group form-control">
                                            [% FOREACH role IN available_roles %]
                                                <option value="[% role %]" [% IF page_item.roles == role %]selected[% END %]>[% role %]</option>
                                            [% END %]
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="row" style="margin-top: 15px; margin-bottom: 15px;">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label>Share Page with Other Sites <i class="fa fa-question-circle text-info" style="cursor: help; margin-left: 4px;" title="Allows users of other sites to view and list this page (e.g. sharing HelpDesk or Beekeeping pages across multiple sites). Select 'all' or check individual sites."></i></label>
                                        <div style="border: 1px solid #ccc; padding: 15px; border-radius: 4px; background: #fafafa;">
                                            <label class="checkbox-inline" style="font-weight: bold; margin-bottom: 10px;">
                                                <input type="checkbox" name="share_all" id="share_all" value="all" onchange="toggleShareAll(this)"> <strong>All Sites</strong>
                                            </label>
                                            <div id="site_checkboxes" style="margin-top: 5px;">
                                                [% FOREACH site IN all_sites %]
                                                    [% IF site != page_item.sitename AND site != current_site %]
                                                        <label class="checkbox-inline" style="margin-right: 15px; margin-bottom: 5px; font-weight: normal;">
                                                            <input type="checkbox" class="site-share-check" name="share_sites" value="[% site %]"> [% site %]
                                                        </label>
                                                    [% END %]
                                                [% END %]
                                            </div>
                                            <!-- Hidden field to send final share_with value to backend -->
                                            <input type="hidden" name="share_with" id="share_with" value="[% page_item.share_with | html %]">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #eee;">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save"></i> Save Page
                                </button>
                                <a href="[% c.uri_for('/admin/pages') %]" class="btn btn-default">Cancel</a>
                            </div>
                        </form>

                        [% PROCESS 'ai/partials/ai_form_assistant.tt'
                           ai_form_entity_label = 'page'
                           ai_form_context      = 'web page management'
                           ai_form_fields       = 'sitename, menu, page_code, title, link_order, body, description, keywords, status, roles'
                        %]
                    </div>
                </div>
            [% ELSE %]
                <!-- Filters / Search -->
                <div class="well">
                    <form method="get" action="[% c.uri_for('/admin/pages') %]" class="form-inline">
                        <input type="hidden" name="action" value="list">

                        <div class="form-group" style="margin-right: 15px;">
                            <label for="search" style="margin-right: 5px;">Search:</label>
                            <input type="text" name="search" id="search" class="form-control" value="[% search %]" placeholder="Title or Code...">
                        </div>

                        [% IF current_site == 'CSC' %]
                        <div class="form-group" style="margin-right: 15px;">
                            <label for="filter_site" style="margin-right: 5px;">Site:</label>
                            <select name="filter_site" id="filter_site" class="form-control">
                                <option value="">-- All Sites --</option>
                                [% FOREACH site IN site_names %]
                                    <option value="[% site %]" [% IF filter_site == site %]selected[% END %]>[% site_display_map.$site || site %]</option>
                                [% END %]
                            </select>
                        </div>
                        [% END %]

                        <div class="form-group" style="margin-right: 15px;">
                            <label for="filter_status" style="margin-right: 5px;">Status:</label>
                            <select name="filter_status" id="filter_status" class="form-control">
                                <option value="">-- All Status --</option>
                                <option value="active" [% IF filter_status == 'active' %]selected[% END %]>Active</option>
                                <option value="inactive" [% IF filter_status == 'inactive' %]selected[% END %]>Inactive</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-info">
                            <i class="fa fa-filter"></i> Apply Filters
                        </button>
                        <a href="[% c.uri_for('/admin/pages') %]" class="btn btn-default">Clear</a>
                    </form>
                </div>

                <!-- Page List Table -->
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h3 class="panel-title"><i class="fa fa-list"></i> Managed Pages</h3>
                    </div>
                <div class="card-body panel-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Site</th>
                                    <th>Menu</th>
                                    <th>Page Code</th>
                                    <th>Title</th>
                                    <th>Sort Order</th>
                                    <th>Status</th>
                                    <th>Roles</th>
                                    <th style="width: 180px; text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% IF pages && pages.size > 0 %]
                                    [% FOREACH page IN pages %]
                                        <tr>
                                            <td>[% site_display_map.${page.sitename} || page.sitename | html %]</td>
                                            <td>[% page.menu | html %]</td>
                                            <td><code>[% page.page_code | html %]</code></td>
                                            <td>[% page.title | html %]</td>
                                            <td>[% page.link_order %]</td>
                                            <td>
                                                [% IF page.status == 'active' %]
                                                    <span class="label label-success badge bg-success">Active</span>
                                                [% ELSIF page.status == 'inactive' %]
                                                    <span class="label label-default badge bg-secondary">Inactive</span>
                                                [% ELSIF page.status == 'draft' %]
                                                    <span class="label label-warning badge bg-warning">Draft</span>
                                                [% ELSE %]
                                                    <span class="label label-warning">[% page.status | html %]</span>
                                                [% END %]
                                            </td>
                                            <td><code>[% page.roles | html %]</code></td>
                                            <td style="text-align: right;">
                                                <a href="[% c.uri_for('/page', page.page_code) %]" class="btn btn-xs btn-info" target="_blank" title="View Page">
                                                    <i class="fa fa-eye"></i> View
                                                </a>
                                                [% IF current_site == 'CSC' || page.sitename == current_site %]
                                                    <a href="[% c.uri_for('/admin/pages', { action => 'edit', id => page.id }) %]" class="btn btn-xs btn-primary" title="Edit Page">
                                                        <i class="fa fa-edit"></i> Edit
                                                    </a>
                                                    <a href="[% c.uri_for('/admin/pages', { action => 'delete', id => page.id }) %]"
                                                       class="btn btn-xs btn-danger delete-page-btn"
                                                       title="Delete Page"
                                                       data-code="[% page.page_code | html %]">
                                                        <i class="fa fa-trash"></i> Delete
                                                    </a>
                                                [% ELSE %]
                                                    <span class="label label-default" style="margin-left: 5px; padding: 4px 8px;">Shared (Read-Only)</span>
                                                    <a href="[% c.uri_for('/admin/pages', { action => 'create', clone_id => page.id }) %]" class="btn btn-xs btn-success" title="Clone / Copy this page to My Site" style="margin-left: 5px;">
                                                        <i class="fa fa-copy"></i> Clone to My Site
                                                    </a>
                                                [% END %]
                                            </td>
                                        </tr>
                                    [% END %]
                                [% ELSE %]
                                    <tr>
                                        <td colspan="8" class="text-center text-muted" style="padding: 20px;">
                                            No pages found in the system. Use "Create New Page" or "Migrate Legacy Pages" to add content.
                                        </td>
                                    </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                </div>
            [% END %]
            </div>
        </div>
    </div>
</div>

[% IF show_form %]
<!-- CKEditor 5 Classic Build CDN -->
<script src="https://cdn.ckeditor.com/ckeditor5/36.0.1/classic/ckeditor.js"></script>

<style>
    /* Ensure the WYSIWYG editor is sufficiently tall */
    .ck-editor__editable_inline {
        min-height: 350px !important;
    }
    /* AI Assistant styling */
    .btn-purple {
        background-color: #6f42c1 !important;
        border-color: #6f42c1 !important;
        color: #fff !important;
    }
    .btn-purple:hover, .btn-purple:focus, .btn-purple:active {
        background-color: #59359a !important;
        border-color: #59359a !important;
        color: #fff !important;
    }
</style>

<script>
    function toggleShareAll(checkbox) {
        var checkboxesDiv = document.getElementById('site_checkboxes');
        if (checkboxesDiv) {
            if (checkbox.checked) {
                checkboxesDiv.style.display = 'none';
                document.getElementById('share_with').value = 'all';
            } else {
                checkboxesDiv.style.display = 'block';
                updateShareWith();
            }
        }
    }

    function updateShareWith() {
        var shareAll = document.getElementById('share_all');
        if (shareAll && shareAll.checked) {
            document.getElementById('share_with').value = 'all';
            return;
        }
        var checkedSites = [];
        var checks = document.querySelectorAll('.site-share-check');
        checks.forEach(function(chk) {
            if (chk.checked) {
                checkedSites.push(chk.value);
            }
        });
        document.getElementById('share_with').value = checkedSites.join(',');
    }

    function openAIFormAssistant() {
        var panel = document.getElementById('ai-form-assistant-panel');
        if (panel) {
            panel.scrollIntoView({ behavior: 'smooth' });
            var inp = document.getElementById('ai-form-entity-name');
            if (inp) {
                inp.focus();
                inp.style.outline = '2px solid #6f42c1';
                setTimeout(() => { inp.style.outline = ''; }, 1500);
            }
        }
    }

    $(document).ready(function() {
        // Initialize Cross-Site Page Sharing checkboxes from hidden value
        var hiddenShareWith = document.getElementById('share_with');
        var shareAllCheck = document.getElementById('share_all');
        var siteChecks = document.querySelectorAll('.site-share-check');
        
        if (hiddenShareWith) {
            var val = hiddenShareWith.value || '';
            if (val === 'all') {
                if (shareAllCheck) shareAllCheck.checked = true;
                var checkboxesDiv = document.getElementById('site_checkboxes');
                if (checkboxesDiv) checkboxesDiv.style.display = 'none';
            } else if (val) {
                var parts = val.split(/\s*,\s*/);
                siteChecks.forEach(function(chk) {
                    if (parts.indexOf(chk.value) !== -1) {
                        chk.checked = true;
                    }
                });
            }
        }
        
        // Add event listeners to site checkboxes
        siteChecks.forEach(function(chk) {
            chk.addEventListener('change', updateShareWith);
        });

        let editorInstance = null;
        const bodyTextarea = document.getElementById('body');
        const toggleBtn = document.getElementById('toggle-editor-mode');
        const statusBadge = document.getElementById('wysiwyg-status-badge');

        if (bodyTextarea) {
            let lastSyncValue = bodyTextarea.value;
            let isWysiwygMode = true;

            // Function to initialize CKEditor 5 Classic
            function initCKEditor() {
                if (editorInstance) return Promise.resolve(editorInstance);

                return ClassicEditor
                    .create(bodyTextarea, {
                        toolbar: [ 'heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'undo', 'redo' ]
                    })
                    .then(editor => {
                        editorInstance = editor;

                        // Keep textarea value perfectly in sync with CKEditor in real-time
                        editor.model.document.on('change:data', () => {
                            const data = editor.getData();
                            bodyTextarea.value = data;
                            lastSyncValue = data; // Prevent loop
                        });

                        return editor;
                    })
                    .catch(error => {
                        console.error('CKEditor 5 initialization error:', error);
                    });
            }

            // Initial load starts in WYSIWYG mode
            initCKEditor();

            // Poller to detect external programmatic updates (e.g. from standard AI Form Fill)
            setInterval(function() {
                const currentVal = bodyTextarea.value;
                if (currentVal !== lastSyncValue) {
                    lastSyncValue = currentVal;
                    if (editorInstance && isWysiwygMode) {
                        editorInstance.setData(currentVal);
                    }
                }
            }, 300);

            // Handle Toggle button click by toggling container visibility (extremely fast and bulletproof)
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const ckEditorContainer = bodyTextarea.parentNode.querySelector('.ck-editor') || bodyTextarea.nextElementSibling;
                    if (isWysiwygMode) {
                        // Switch from WYSIWYG to Raw HTML
                        if (editorInstance) {
                            bodyTextarea.value = editorInstance.getData();
                            lastSyncValue = bodyTextarea.value;
                        }
                        if (ckEditorContainer) {
                            ckEditorContainer.style.display = 'none';
                        }
                        bodyTextarea.style.display = 'block';
                        isWysiwygMode = false;

                        if (statusBadge) {
                            statusBadge.textContent = 'Source HTML Mode';
                            statusBadge.className = 'label label-warning';
                        }
                    } else {
                        // Switch from Raw HTML to WYSIWYG
                        if (editorInstance) {
                            editorInstance.setData(bodyTextarea.value);
                            lastSyncValue = bodyTextarea.value;
                        }
                        bodyTextarea.style.display = 'none';
                        if (ckEditorContainer) {
                            ckEditorContainer.style.display = 'block';
                        }
                        isWysiwygMode = true;

                        if (statusBadge) {
                            statusBadge.textContent = 'Rich Text Mode';
                            statusBadge.className = 'label label-success';
                        }
                    }
                });
            }

            // Form submit helper to ensure editor state is saved on submit
            const form = bodyTextarea.closest('form');
            if (form) {
                form.addEventListener('submit', function() {
                    if (editorInstance && isWysiwygMode) {
                        bodyTextarea.value = editorInstance.getData();
                    }
                });
            }
        }
    });
</script>
[% END %]

<script>
document.addEventListener('DOMContentLoaded', function() {
    const deleteButtons = document.querySelectorAll('.delete-page-btn');
    deleteButtons.forEach(button => {
        button.addEventListener('click', function(e) {
            const pageCode = this.getAttribute('data-code');
            if (!confirm(`Are you sure you want to delete the page '${pageCode}'? This action cannot be undone.`)) {
                e.preventDefault();
            }
        });
    });
});
</script>
