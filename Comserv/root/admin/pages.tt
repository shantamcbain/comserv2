[% META title = 'Page Management Admin' %]

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; padding-bottom: 10px; border-bottom: 2px solid #eee;">
                <h2 style="margin: 0;">Page Management System</h2>
                <div>
                    <a href="[% c.uri_for('/admin') %]" class="btn btn-default">
                        <i class="fa fa-arrow-left"></i> Back to Dashboard
                    </a>
                    [% UNLESS show_form %]
                        <a href="[% c.uri_for('/admin/pages', { action => 'create' }) %]" class="btn btn-primary">
                            <i class="fa fa-plus"></i> Create New Page
                        </a>
                    [% END %]
                </div>
            </div>

            [% IF error_msg %]
                <div class="alert alert-danger alert-dismissible" role="alert">
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <strong>Error:</strong> [% error_msg %]
                </div>
            [% END %]

            [% IF success_msg %]
                <div class="alert alert-success alert-dismissible" role="alert">
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <strong>Success:</strong> [% success_msg %]
                </div>
            [% END %]

            [% IF show_form %]
                <div class="panel panel-primary">
                    <div class="panel-heading">
                        <h3 class="panel-title">
                            [% IF show_form == 'edit' %]
                                <i class="fa fa-edit"></i> Edit Page: [% page_item.page_code %]
                            [% ELSE %]
                                <i class="fa fa-plus"></i> Create New Page
                            [% END %]
                        </h3>
                    </div>
                    <div class="panel-body">
                        <form method="post" action="[% c.uri_for('/admin/pages') %]">
                            <input type="hidden" name="action" value="save">
                            [% IF page_item.id %]
                                <input type="hidden" name="id" value="[% page_item.id %]">
                            [% END %]

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="sitename">Site Name <span class="text-danger">*</span></label>
                                        <input type="text" name="sitename" id="sitename" class="form-group form-control" value="[% page_item.sitename || 'CSC' %]" required [% IF current_site != 'CSC' %]readonly[% END %]>
                                        [% IF current_site != 'CSC' %]
                                            <span class="help-block">This page is locked to [% current_site %].</span>
                                        [% END %]
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="menu">Menu Section <span class="text-danger">*</span></label>
                                        <input type="text" name="menu" id="menu" class="form-group form-control" value="[% page_item.menu || 'main' %]" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="page_code">Page Code <span class="text-danger">*</span></label>
                                        <input type="text" name="page_code" id="page_code" class="form-group form-control" value="[% page_item.page_code %]" placeholder="e.g. home, about_us" required [% IF show_form == 'edit' %]readonly[% END %]>
                                        [% IF show_form == 'edit' %]<span class="help-block">Page Code cannot be modified after creation.</span>[% END %]
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label for="title">Page Title <span class="text-danger">*</span></label>
                                        <input type="text" name="title" id="title" class="form-group form-control" value="[% page_item.title %]" placeholder="Enter friendly title for page" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label for="link_order">Link/Sort Order</label>
                                        <input type="number" name="link_order" id="link_order" class="form-group form-control" value="[% page_item.link_order || 0 %]">
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                    <label for="body" style="margin: 0; font-weight: bold;">Page Body (HTML/Text) <span class="text-danger">*</span></label>
                                    <button type="button" class="btn btn-xs btn-purple" id="ai-assist-btn" style="background: #6f42c1; color: white; border: none; padding: 4px 10px; border-radius: 4px; font-weight: bold; display: inline-flex; align-items: center; gap: 4px; transition: background 0.2s;">
                                        <i class="fa fa-magic"></i> AI Assistant
                                    </button>
                                </div>
                                
                                <!-- AI Assistant Inline Panel -->
                                <div id="ai-assist-panel" class="panel panel-default" style="display: none; margin-bottom: 15px; border-color: #6f42c1; background-color: #fcfaff; box-shadow: 0 2px 8px rgba(111, 66, 193, 0.1);">
                                    <div class="panel-heading" style="background-color: #f3ebff; border-color: #6f42c1; color: #512da8; font-weight: bold; display: flex; justify-content: space-between; align-items: center; padding: 8px 15px;">
                                        <span><i class="fa fa-robot"></i> AI Writing Assistant</span>
                                        <button type="button" class="close" id="ai-assist-close" style="color: #512da8; opacity: 0.8; line-height: 1;">&times;</button>
                                    </div>
                                    <div class="panel-body" style="padding: 15px;">
                                        <div class="row">
                                            <div class="col-md-8">
                                                <div class="form-group" style="margin-bottom: 10px;">
                                                    <label class="control-label" style="font-size: 12px; color: #512da8; font-weight: bold;">What should the AI do?</label>
                                                    <input type="text" id="ai-prompt" class="form-control input-sm" placeholder="e.g. Write a welcome page for Icehorse with site-creation setup steps...">
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group" style="margin-bottom: 10px;">
                                                    <label class="control-label" style="font-size: 12px; color: #512da8; font-weight: bold;">Action Preset</label>
                                                    <select id="ai-preset" class="form-control input-sm">
                                                        <option value="write">Draft Content from Prompt</option>
                                                        <option value="improve">Improve Current Content</option>
                                                        <option value="expand">Expand / Add Details</option>
                                                        <option value="summarize">Summarize Content</option>
                                                        <option value="seo">Suggest SEO Keywords</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="row" style="margin-top: 5px;">
                                            <div class="col-md-12" style="display: flex; align-items: center; gap: 10px;">
                                                <button type="button" class="btn btn-sm btn-purple" id="ai-generate-btn" style="background-color: #6f42c1; color: white; font-weight: bold; border: none; padding: 6px 12px; border-radius: 4px;">
                                                    <i class="fa fa-cog fa-spin" id="ai-spinner" style="display: none; margin-right: 5px;"></i>
                                                    <span id="ai-btn-text">Generate with AI</span>
                                                </button>
                                                <span id="ai-status-msg" style="font-size: 12px; color: #666; font-style: italic;"></span>
                                            </div>
                                        </div>
                                        
                                        <!-- AI Response Preview / Insert -->
                                        <div id="ai-response-container" style="display: none; margin-top: 15px; padding: 12px; background: white; border: 1px dashed #6f42c1; border-radius: 4px;">
                                            <h5 style="margin-top: 0; color: #512da8; font-weight: bold; font-size: 13px; margin-bottom: 8px;">AI Suggestion:</h5>
                                            <div id="ai-response-text" style="font-size: 13px; line-height: 1.5; white-space: pre-wrap; margin-bottom: 12px; max-height: 250px; overflow-y: auto; padding: 8px; background: #fafafa; border: 1px solid #eee; border-radius: 4px;"></div>
                                            <div style="display: flex; gap: 10px;">
                                                <button type="button" class="btn btn-xs btn-success" id="ai-insert-replace-btn" style="font-weight: bold;">Replace Body</button>
                                                <button type="button" class="btn btn-xs btn-info" id="ai-insert-append-btn" style="font-weight: bold;">Append to Body</button>
                                                <button type="button" class="btn btn-xs btn-default" id="ai-discard-btn">Discard</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <textarea name="body" id="body" rows="12" class="form-group form-control" placeholder="Enter HTML or text content for the page" required>[% page_item.body %]</textarea>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="description">SEO Description</label>
                                        <textarea name="description" id="description" rows="3" class="form-group form-control" placeholder="Meta description for search engines">[% page_item.description %]</textarea>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="keywords">SEO Keywords</label>
                                        <input type="text" name="keywords" id="keywords" class="form-group form-control" value="[% page_item.keywords %]" placeholder="comma, separated, keywords">
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="status">Status</label>
                                        <select name="status" id="status" class="form-group form-control">
                                            <option value="active" [% IF page_item.status == 'active' %]selected[% END %]>Active</option>
                                            <option value="inactive" [% IF page_item.status == 'inactive' %]selected[% END %]>Inactive</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="roles">Access Roles</label>
                                        <input type="text" name="roles" id="roles" class="form-group form-control" value="[% page_item.roles || 'public' %]">
                                    </div>
                                </div>
                            </div>

                            <div style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #eee;">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-save"></i> Save Page
                                </button>
                                <a href="[% c.uri_for('/admin/pages') %]" class="btn btn-default">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            [% ELSE %]
                <!-- Filters / Search -->
                <div class="well">
                    <form method="get" action="[% c.uri_for('/admin/pages') %]" class="form-inline">
                        <input type="hidden" name="action" value="list">
                        
                        <div class="form-group" style="margin-right: 15px;">
                            <label for="search" style="margin-right: 5px;">Search:</label>
                            <input type="text" name="search" id="search" class="form-control" value="[% search %]" placeholder="Title or Code...">
                        </div>

                        [% IF current_site == 'CSC' %]
                        <div class="form-group" style="margin-right: 15px;">
                            <label for="filter_site" style="margin-right: 5px;">Site:</label>
                            <select name="filter_site" id="filter_site" class="form-control">
                                <option value="">-- All Sites --</option>
                                [% FOREACH site IN site_names %]
                                    <option value="[% site %]" [% IF filter_site == site %]selected[% END %]>[% site %]</option>
                                [% END %]
                            </select>
                        </div>
                        [% END %]

                        <div class="form-group" style="margin-right: 15px;">
                            <label for="filter_status" style="margin-right: 5px;">Status:</label>
                            <select name="filter_status" id="filter_status" class="form-control">
                                <option value="">-- All Status --</option>
                                <option value="active" [% IF filter_status == 'active' %]selected[% END %]>Active</option>
                                <option value="inactive" [% IF filter_status == 'inactive' %]selected[% END %]>Inactive</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-info">
                            <i class="fa fa-filter"></i> Apply Filters
                        </button>
                        <a href="[% c.uri_for('/admin/pages') %]" class="btn btn-default">Clear</a>
                    </form>
                </div>

                <!-- Page List Table -->
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h3 class="panel-title"><i class="fa fa-list"></i> Managed Pages</h3>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Site</th>
                                    <th>Menu</th>
                                    <th>Page Code</th>
                                    <th>Title</th>
                                    <th>Sort Order</th>
                                    <th>Status</th>
                                    <th>Roles</th>
                                    <th style="width: 150px; text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% IF pages.size > 0 %]
                                    [% FOREACH page IN pages %]
                                        <tr>
                                            <td><span class="label label-info">[% page.sitename %]</span></td>
                                            <td>[% page.menu %]</td>
                                            <td><code>[% page.page_code %]</code></td>
                                            <td>[% page.title %]</td>
                                            <td>[% page.link_order %]</td>
                                            <td>
                                                [% IF page.status == 'active' %]
                                                    <span class="label label-success">Active</span>
                                                [% ELSE %]
                                                    <span class="label label-default">Inactive</span>
                                                [% END %]
                                            </td>
                                            <td><span class="label label-warning">[% page.roles %]</span></td>
                                            <td style="text-align: right;">
                                                <a href="[% c.uri_for('/admin/pages', { action => 'edit', id => page.id }) %]" class="btn btn-xs btn-primary" title="Edit">
                                                    <i class="fa fa-edit"></i>
                                                </a>
                                                <a href="[% c.uri_for('/admin/pages', { action => 'delete', id => page.id }) %]" class="btn btn-xs btn-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this page? This action cannot be undone.');">
                                                    <i class="fa fa-trash"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    [% END %]
                                [% ELSE %]
                                    <tr>
                                        <td colspan="8" class="text-center text-muted" style="padding: 20px;">
                                            No pages found matching the active criteria.
                                        </td>
                                    </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                </div>
            [% END %]
        </div>
    </div>
</div>

[% IF show_form %]
<!-- CKEditor 5 Classic Build CDN -->
<script src="https://cdn.ckeditor.com/ckeditor5/36.0.1/classic/ckeditor.js"></script>

<style>
    /* Ensure the WYSIWYG editor is sufficiently tall */
    .ck-editor__editable_inline {
        min-height: 350px !important;
    }
    /* AI Assistant styling */
    .btn-purple {
        background-color: #6f42c1 !important;
        border-color: #6f42c1 !important;
        color: #fff !important;
    }
    .btn-purple:hover, .btn-purple:focus, .btn-purple:active {
        background-color: #59359a !important;
        border-color: #59359a !important;
        color: #fff !important;
    }
</style>

<script>
    $(document).ready(function() {
        let editorInstance = null;

        // Initialize CKEditor 5 Classic editor on the page body textarea
        ClassicEditor
            .create(document.querySelector('#body'), {
                toolbar: [ 'heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'undo', 'redo' ]
            })
            .then(editor => {
                editorInstance = editor;
            })
            .catch(error => {
                console.error('CKEditor 5 initialization error:', error);
            });

        // Toggle AI Assistant Panel
        $('#ai-assist-btn').on('click', function() {
            $('#ai-assist-panel').slideToggle(200);
        });

        $('#ai-assist-close').on('click', function() {
            $('#ai-assist-panel').slideUp(200);
        });

        // Handle AI Content Generation
        $('#ai-generate-btn').on('click', function() {
            const promptText = $('#ai-prompt').val().trim();
            const preset = $('#ai-preset').val();
            let finalPrompt = '';
            
            // Read current content from CKEditor or fallback textarea
            let currentContent = '';
            if (editorInstance) {
                currentContent = editorInstance.getData();
            } else {
                currentContent = $('#body').val();
            }
            
            // Build the AI instruction prompt
            if (preset === 'write') {
                if (!promptText) {
                    alert('Please enter a prompt describing what you want written.');
                    return;
                }
                finalPrompt = promptText;
            } else if (preset === 'improve') {
                if (!currentContent) {
                    alert('There is no content to improve. Please choose "Draft Content from Prompt" or write something first.');
                    return;
                }
                finalPrompt = "Improve the following text, making it more engaging and professional. Return HTML-ready content:\n\n" + currentContent;
                if (promptText) {
                    finalPrompt += "\n\nAdditional instructions: " + promptText;
                }
            } else if (preset === 'expand') {
                if (!currentContent) {
                    alert('There is no content to expand. Please write some initial text first.');
                    return;
                }
                finalPrompt = "Expand and add professional details to the following content. Return HTML-ready content:\n\n" + currentContent;
                if (promptText) {
                    finalPrompt += "\n\nAdditional instructions: " + promptText;
                }
            } else if (preset === 'summarize') {
                if (!currentContent) {
                    alert('There is no content to summarize.');
                    return;
                }
                finalPrompt = "Provide a concise summary of the following content:\n\n" + currentContent;
            } else if (preset === 'seo') {
                let contentToUse = currentContent || promptText;
                if (!contentToUse) {
                    alert('Please write some content or enter a prompt so I can suggest keywords.');
                    return;
                }
                finalPrompt = "Based on this content, suggest 10 high-quality SEO keywords separated by commas:\n\n" + contentToUse;
            }
            
            // Show loading spinner
            $('#ai-spinner').show();
            $('#ai-btn-text').text('Processing...');
            $('#ai-generate-btn').prop('disabled', true);
            $('#ai-status-msg').text('AI is thinking...');
            $('#ai-response-container').hide();
            
            // Invoke the Zencoder AI generation endpoint
            $.ajax({
                url: '/ai/generate',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    prompt: finalPrompt,
                    provider: 'ollama'
                }),
                success: function(data) {
                    $('#ai-spinner').hide();
                    $('#ai-btn-text').text('Generate with AI');
                    $('#ai-generate-btn').prop('disabled', false);
                    
                    if (data && data.success && data.response) {
                        $('#ai-response-text').text(data.response);
                        $('#ai-response-container').slideDown(200);
                        $('#ai-status-msg').text('Generated suggestion successfully!');
                        
                        // Autofill SEO keywords field if preset is SEO
                        if (preset === 'seo') {
                            const cleanKeywords = data.response.replace(/Keywords:?/i, '').trim();
                            $('#keywords').val(cleanKeywords);
                        }
                    } else {
                        $('#ai-status-msg').text('Failed to generate response.');
                        alert('AI Assistance Error: ' + (data ? data.error : 'Unknown error'));
                    }
                },
                error: function(xhr, status, error) {
                    $('#ai-spinner').hide();
                    $('#ai-btn-text').text('Generate with AI');
                    $('#ai-generate-btn').prop('disabled', false);
                    $('#ai-status-msg').text('Error calling AI service.');
                    
                    let errMsg = 'An error occurred while contacting the AI assistant service.';
                    if (xhr.responseJSON && xhr.responseJSON.error) {
                        errMsg += '\n\nDetails: ' + xhr.responseJSON.error;
                    }
                    alert(errMsg);
                }
            });
        });

        // Insert/Replace & Append handlers
        $('#ai-insert-replace-btn').on('click', function() {
            const aiText = $('#ai-response-text').text();
            if (editorInstance) {
                editorInstance.setData(aiText);
            } else {
                $('#body').val(aiText);
            }
            $('#ai-response-container').slideUp(200);
            $('#ai-status-msg').text('Replaced body with AI suggestion.');
        });

        $('#ai-insert-append-btn').on('click', function() {
            const aiText = $('#ai-response-text').text();
            if (editorInstance) {
                const currentData = editorInstance.getData();
                editorInstance.setData(currentData + '\n' + aiText);
            } else {
                const currentVal = $('#body').val();
                $('#body').val(currentVal + '\n' + aiText);
            }
            $('#ai-response-container').slideUp(200);
            $('#ai-status-msg').text('Appended AI suggestion to body.');
        });

        $('#ai-discard-btn').on('click', function() {
            $('#ai-response-container').slideUp(200);
            $('#ai-status-msg').text('Suggestion discarded.');
        });
    });
</script>
[% END %]
