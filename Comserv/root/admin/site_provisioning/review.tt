<div class="app-container">

<div class="page-header">
    <h1>Review Hosting Request</h1>
    <div class="form-actions">
        <a href="[% c.uri_for('/admin/site_provisioning') %]" class="btn btn-secondary">&#8592; Back</a>
    </div>
</div>

[% IF cf_error %]
<div class="error-message"><strong>Cloudflare API error:</strong> [% cf_error | html %]
    &mdash; <a href="[% c.uri_for('/admin/site_provisioning/cf_settings') %]">Check Cloudflare credentials</a>
</div>
[% END %]

<div class="content-container">
<div class="content-primary">

<div class="data-container">
<div class="form-section">
    <h3>Request Details</h3>
    <table class="data-table">
        <tr><th>Site Name</th><td><strong>[% request.sitename | html %]</strong></td></tr>
        <tr><th>Domain</th><td><code>[% request.domain | html %]</code></td></tr>
        <tr><th>Domain Type</th><td>[% request.domain_type | html %]</td></tr>
        <tr><th>Contact Email</th><td>[% request.contact_email | html %]</td></tr>
        <tr><th>Status</th><td>[% request.status | html %]</td></tr>
        <tr><th>Notes</th><td>[% request.notes | html %]</td></tr>
        <tr><th>Requested Add-ons</th><td>[% request.requested_addons | html %]</td></tr>
        <tr><th>Created</th><td>[% request.created_at | html %]</td></tr>
    </table>
</div>
</div>

[% IF request.status == 'pending' %]
<div class="form-container">
<form method="post" action="[% c.uri_for('/admin/site_provisioning/provision') %]" class="app-form">
    <input type="hidden" name="request_id" value="[% request.id | html %]">

    <div class="form-section">
        <h3>Provision Settings</h3>

        <div class="form-row">
            <div class="form-field">
                <label for="site_name">Site Name <small>(alphanumeric + underscore)</small></label>
                <input type="text" id="site_name" name="site_name" class="form-input"
                       value="[% request.sitename | html %]" required>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label for="display_name">Display Name</label>
                <input type="text" id="display_name" name="display_name" class="form-input"
                       value="[% request.sitename | html %]">
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label for="domain">Full Domain / Subdomain
                    <small>(e.g. icehorse.[% cf_zone_name | html %])</small></label>
                <input type="text" id="domain" name="domain" class="form-input"
                       value="[% suggested_domain | html %]" required
                       placeholder="e.g. icehorse.[% cf_zone_name | html %]">
                [% IF cf_zone_name && request.domain == cf_zone_name %]
                <small class="form-hint" style="color:#b45309;">
                    &#9888; The stored domain is the same as the zone root (<strong>[% cf_zone_name | html %]</strong>).
                    For a subdomain, prefix it — e.g. <strong>icehorse.[% cf_zone_name | html %]</strong>.
                </small>
                [% END %]
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label for="domain_type">Domain Type</label>
                <select id="domain_type" name="domain_type" class="form-input">
                    <option value="subdomain" [% IF request.domain_type == 'subdomain' %]selected[% END %]>Subdomain</option>
                    <option value="custom"    [% IF request.domain_type == 'custom'    %]selected[% END %]>Custom Domain</option>
                    <option value="subpath"   [% IF request.domain_type == 'subpath'   %]selected[% END %]>Subpath</option>
                </select>
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label for="server_ip">Server Public IP <small>(for Cloudflare DNS A record — leave blank to skip)</small></label>
                <input type="text" id="server_ip" name="server_ip" class="form-input"
                       value="[% cf_zone_ip | html %]" placeholder="e.g. 203.0.113.10">
                [% IF cf_zone_name %]
                <small>Auto-filled from Cloudflare zone <strong>[% cf_zone_name | html %]</strong>.
                Provisioning <strong>will</strong> create a new Cloudflare A record pointing this subdomain to the IP above.</small>
                [% ELSE %]
                <small>Leave blank to skip Cloudflare DNS creation.</small>
                [% END %]
            </div>
        </div>

        [% IF cf_a_records.size %]
        <div class="form-row">
            <div class="form-field">
                <label>Existing A Records in <strong>[% cf_zone_name | html %]</strong>
                    <small>(check the subdomain prefix is not already taken)</small></label>
                <div class="table-container" style="max-height:180px;overflow-y:auto;">
                <table class="data-table">
                    <thead><tr><th>Name / Subdomain</th><th>IP Address</th></tr></thead>
                    <tbody>
                    [% FOREACH r IN cf_a_records %]
                    <tr>
                        <td><code>[% r.name | html %]</code></td>
                        <td>[% r.ip | html %]</td>
                    </tr>
                    [% END %]
                    </tbody>
                </table>
                </div>
            </div>
        </div>
        [% END %]

        <div class="form-row">
            <div class="form-field">
                <label for="email">Contact Email</label>
                <input type="email" id="email" name="email" class="form-input"
                       value="[% request.contact_email | html %]">
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary"
                onclick="return confirm('Provision site [% request.sitename | html %]? This will create the site record, domain mapping, and Cloudflare DNS entry.')">
            &#10003; Provision Site
        </button>
        <a href="[% c.uri_for('/admin/site_provisioning') %]" class="btn btn-secondary">Cancel</a>
    </div>
</form>
</div>
[% ELSE %]
<div class="app-section">
    <p>This request has already been provisioned (status: <strong>[% request.status | html %]</strong>).</p>
    <form method="get" action="[% c.uri_for('/admin/site_provisioning/retry_dns', [request.id]) %]" style="margin-top:1rem;">
        <div class="form-row">
            <div class="form-field">
                <label for="retry_ip">Server IP for DNS A record</label>
                <input type="text" name="server_ip" id="retry_ip" class="form-input"
                       value="[% cf_zone_ip | html %]" placeholder="e.g. 203.0.113.10">
            </div>
        </div>
        <button type="submit" class="btn btn-secondary">&#8635; Retry Cloudflare DNS Creation</button>
    </form>
</div>
[% END %]

</div>
</div>

</div>
