}

.field-default {
    font-size: 0.75em;
    color: var(--theme-text-secondary, #6c757d);
    font-style: italic;
}

.schema-field-more {
    text-align: center;
    color: var(--theme-text-secondary, #6c757d);
    font-style: italic;
    padding: 8px;
    font-size: 0.85em;
}

.schema-loading {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--theme-text-secondary, #6c757d);
    font-size: 0.85em;
    padding: 15px;
    justify-content: center;
}

/* Result File Card Styles (for result files without tables) */
.result-file-list {
    padding: 15px;
}

.result-file-card {
    margin-bottom: 15px;
    border: 1px solid #e9ecef;
    border-radius: 6px;
    background: #ffffff;
