/* Table Comparison Card Styles */
.table-comparison-card {
    margin-bottom: 10px;
    border: 1px solid #e9ecef;
    border-radius: 4px;
    background: #ffffff;
    transition: all 0.3s ease;
}

.table-comparison-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.table-comparison-header {
    padding: 10px 15px;
    background: #f8f9fa;
    border-bottom: 1px solid #e9ecef;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.table-comparison-title {
    display: flex;
    align-items: center;
    gap: 10px;
}

.table-comparison-title h4 {
    margin: 0;
    font-size: 0.95em;
    color: #495057;
}

.difference-indicator {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin-left: 8px;
}

.difference-indicator.same {
    background: #28a745;
    border: 2px solid #1e7e34;
}

.difference-indicator.different {
    background: #ffc107;
    border: 2px solid #e0a800;
}

.difference-indicator.missing {
    background: #dc3545;
    border: 2px solid #c82333;
}

.difference-indicator.orphaned {
    background: #6f42c1;
    border: 2px solid #5a2d91;
}

.table-comparison-actions {
    display: flex;
    align-items: center;
    gap: 10px;
}

.sync-btn, .create-btn, .delete-btn {
    padding: 4px 8px;
    border: none;
    border-radius: 4px;
    font-size: 0.8em;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: all 0.3s ease;
}

.sync-btn {
    background: #17a2b8;
    color: white;
}

.sync-btn:hover {
    background: #138496;
}

.create-btn {
    background: #28a745;
    color: white;
}

.create-btn:hover {
    background: #218838;
}

.delete-btn {
    background: #dc3545;
    color: white;
}

.delete-btn:hover {
    background: #c82333;
}

/* Disconnected Database Info Styles */
.disconnected-info {
    padding: 20px;
    text-align: center;
    color: #6c757d;
}

.placeholder-message, .connection-error {
    padding: 20px;
    border-radius: 8px;
}

.placeholder-message {
    background: linear-gradient(135deg, #fff3cd 0%, #ffffff 100%);
    border: 1px solid #ffeaa7;
}

.connection-error {
    background: linear-gradient(135deg, #f8d7da 0%, #ffffff 100%);
    border: 1px solid #f5c6cb;
}

.placeholder-message h4, .connection-error h4 {
    margin-top: 0;
    color: #495057;
}

.placeholder-message ul, .connection-error ul {
    text-align: left;
    margin: 15px 0;
}

/* Responsive adjustments */
@media (max-width: 768px) {
    .status-cards {
        flex-direction: column;
        gap: 12px;
    }
    
    .status-card {
        padding: 12px;
    }
    
    .status-card i {
        font-size: 1.3em;
    }
    
    .database-container-grid {
        grid-template-columns: 1fr;
        gap: 15px;
    }
    
    .server-toggle-btn {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
    }
    
    .server-status-panel {
        justify-content: space-between;
    }
}

@media (max-width: 480px) {
    .table-comparison-header {
        flex-direction: column;
        align-items: stretch;
        gap: 10px;
    }
    
    .table-comparison-actions {
        justify-content: flex-end;
    }
}
