    color: #155724;
}

.status-badge.type-mismatch {
    background: #fff3cd;
    color: #856404;
}

.status-badge.attribute-mismatch {
    background: #ffeaa7;
    color: #6c5914;
}

.status-badge.out-of-sync {
    background: #f8d7da;
    color: #721c24;
}

/* Table Item Card Styles (for tables without results) */
.table-list {
    padding: 15px;
}

.table-item-card {
    margin-bottom: 15px;
    border: 1px solid #e9ecef;
    border-radius: 6px;
    background: #ffffff;
    transition: all 0.3s ease;
}

.table-item-card:hover {
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
    border-color: var(--theme-primary-color, #007bff);
}

.table-item-header {
    padding: 15px 20px;
    display: grid;
    grid-template-columns: auto 2fr auto auto;
    gap: 20px;
    align-items: center;
    border-bottom: 1px solid #f8f9fa;
}

.table-selection {
    display: flex;
    align-items: center;
}

.table-select-cb, .result-select-cb {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: var(--theme-primary-color, #007bff);
}

.table-select-label, .result-select-label {
    margin: 0;
    cursor: pointer;
}

.table-icon.missing {
    color: #ffc107;
}

.table-type-badge, .result-type-badge {
    padding: 3px 8px;
    border-radius: 12px;
    font-size: 0.75em;
    font-weight: 600;
    background: #6c757d;
    color: white;
}

.status-indicator.missing {
    color: #ffc107;
    background: #fff3cd;
    padding: 4px;
    border-radius: 50%;
}

.status-indicator.orphaned {
    color: #dc3545;
    background: #f8d7da;
    padding: 4px;
    border-radius: 50%;
}

.metadata-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.metadata-label {
    font-size: 0.75em;
    color: var(--theme-text-secondary, #6c757d);
    font-weight: 500;
    margin-bottom: 2px;
}

.metadata-value {
    font-size: 0.9em;
    font-weight: 600;
    color: var(--theme-text-primary, #212529);
}

.create-btn, .view-btn, .analyze-btn, .create-table-btn, .view-file-btn, .remove-file-btn {
    padding: 6px 12px;
    border: none;
    border-radius: 4px;
    font-size: 0.8em;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 6px;
}

.create-btn.primary, .create-table-btn.primary {
    background: #28a745;
    color: white;
}

.view-btn.secondary, .view-file-btn.secondary {
    background: #6c757d;
    color: white;
}

.analyze-btn.info {
    background: #17a2b8;
    color: white;
}

.remove-file-btn.danger {
    background: #dc3545;
    color: white;
}

.create-btn:hover, .create-table-btn:hover { background: #218838; transform: translateY(-1px); }
.view-btn:hover, .view-file-btn:hover { background: #545b62; transform: translateY(-1px); }
.analyze-btn:hover { background: #138496; transform: translateY(-1px); }
.remove-file-btn:hover { background: #c82333; transform: translateY(-1px); }

/* Table Schema Preview */
.table-schema-preview {
    display: none;
    padding: 15px 20px;
    background: #f8f9fa;
    border-top: 1px solid #e9ecef;
}

.table-item-card:hover .table-schema-preview {
    display: block;
}

.schema-preview-header {
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--theme-text-primary, #212529);
    font-size: 0.9em;
}

.schema-field-list {
    display: grid;
    gap: 8px;
}

