    }

    .card-header {
        border-radius: 4px 4px 0 0;
    }

    .card-body {
        background-color: rgba(255,255,255,0.88);
    }

    .alert {
        padding: 12px 20px;
        margin-bottom: 20px;
        border: 1px solid transparent;
        border-radius: 4px;
    }

    .alert-warning {
        color: #856404;
        background-color: #fff3cd;
        border-color: #ffeaa7;
    }

    button:hover {
        opacity: 0.9;
    }

    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    h1 {
        color: var(--text-color, #333);
        margin-bottom: 20px;
    }

    h3 {
        color: var(--text-color, #333);
    }
</style>
