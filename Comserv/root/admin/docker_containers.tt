[% META
   title = 'Docker Container Management'
   version = '1.0'
   author = 'AI Assistant'
   date = '2025-12-14'
   last_modified = '2025-12-14'
   category = 'admin'
   tags = 'docker, containers, infrastructure'
%]
[% PageVersion = 'docker_containers.tt,v 1.0 2025/12/14 ai_assistant Exp ai_assistant ' %]

<!-- xterm.js for SSH Terminal -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.css" />
<script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.js"></script>

<style>
.collapsible-header {
    cursor: pointer;
    user-select: none;
}
.collapsible-header:hover {
    background-color: #e9ecef !important;
}
.collapsible-content {
    display: none;
}
.collapsible-content.expanded {
    display: block;
}
.chevron-icon {
    transition: transform 0.2s ease;
}
.chevron-icon.expanded {
    transform: rotate(90deg);
}
</style>

<div class="app-container" style="margin: 20px auto; max-width: 1200px;">
    <div class="page-header">
        <h1><i class="icon-docker"></i> Docker Container Management</h1>
        <hr>
    </div>

    [% IF !docker_available %]
    <div class="alert alert-warning" role="alert">
        <strong>Notice:</strong> Docker container management is not available from within a Docker container.
        Use the host development server:
        <a href="http://workstation.local:3001/admin/docker-containers" style="font-weight:bold;">
            Open Docker Management on port 3001 →
        </a>
        <br><small style="color:#666;">You will need to log in separately at port 3001 (sessions are per-port).</small>
    </div>
    [% ELSE %]
    
    <div class="content-section" style="margin-bottom: 20px;">
        <div class="card">
            <div class="card-header collapsible-header" onclick="toggleSection('container-status')" 
                 style="background-color: #f5f5f5; padding: 15px; border-bottom: 1px solid #ddd;">
                <h3 style="margin: 0; display: flex; align-items: center; justify-content: space-between;">
                    <span>
                        <i class="fas fa-chevron-right chevron-icon" id="chevron-container-status" style="margin-right: 10px; font-size: 0.8em;"></i>
                        <i class="icon-list" style="margin-right: 10px;"></i>
                        Container Status Overview
                    </span>
                    <button onclick="event.stopPropagation(); refreshContainers();" style="padding: 6px 12px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer;">
                        <i class="icon-refresh"></i> Refresh
                    </button>
                </h3>
            </div>
            <div id="container-status" class="card-body collapsible-content" style="padding: 20px;">
                <div id="containers-list" style="display: flex; flex-direction: column; gap: 10px;">
                    <p style="color: #666; text-align: center;">Loading container information...</p>
                </div>
            </div>
        </div>
    </div>

    <div class="content-section" style="margin-bottom: 20px;">
        <div class="card">
            <div class="card-header collapsible-header" onclick="toggleSection('volumes-status')"
                 style="background-color: #f5f5f5; padding: 15px; border-bottom: 1px solid #ddd;">
                <h3 style="margin: 0; display: flex; align-items: center; justify-content: space-between;">
                    <span>
                        <i class="fas fa-chevron-right chevron-icon" id="chevron-volumes-status" style="margin-right: 10px; font-size: 0.8em;"></i>
                        <i class="icon-storage" style="margin-right: 10px;"></i>
                        Volume Status Overview
                    </span>
                    <button onclick="event.stopPropagation(); refreshVolumes();" style="padding: 6px 12px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer;">
                        <i class="icon-refresh"></i> Refresh
                    </button>
                </h3>
            </div>
            <div id="volumes-status" class="card-body collapsible-content" style="padding: 20px;">
                <div id="volumes-list" style="display: flex; flex-direction: column; gap: 10px;">
                    <p style="color: #666; text-align: center;">Loading volume information...</p>
                </div>
            </div>
        </div>
    </div>

    <div class="content-section" style="margin-bottom: 20px;">
        <div class="card">
            <div class="card-header collapsible-header" onclick="toggleSection('container-controls')" 
                 style="background-color: #f5f5f5; padding: 15px; border-bottom: 1px solid #ddd;">
                <h3 style="margin: 0; display: flex; align-items: center;">
                    <i class="fas fa-chevron-right chevron-icon" id="chevron-container-controls" style="margin-right: 10px; font-size: 0.8em;"></i>
                    <i class="icon-tools" style="margin-right: 10px;"></i>
                    Container Controls
                </h3>
            </div>
            <div id="container-controls" class="card-body collapsible-content" style="padding: 20px;">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px;">
                        <div>
                            <label for="service-select" style="display: block; margin-bottom: 8px; font-weight: bold;">
                                Select Service:
                            </label>
                            <select id="service-select" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                                <option value="">-- Select a service --</option>
                                <option value="all">All Services</option>
                            </select>
                        </div>

                        <div>
                            <label style="display: block; margin-bottom: 8px; font-weight: bold;">
                                Actions:
                            </label>
                            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                                <button id="restart-btn" onclick="restartContainer()" 
                                    style="padding: 8px 16px; background-color: #0066cc; color: white; border: none; border-radius: 4px; cursor: pointer;">
                                    <i class="icon-refresh"></i> Restart
                                </button>
                                <button id="rebuild-btn" onclick="rebuildContainer()" 
                                    style="padding: 8px 16px; background-color: #ffc107; color: #333; border: none; border-radius: 4px; cursor: pointer;">
                                    🔨 Rebuild
                                </button>
                                <button id="logs-btn" onclick="viewLogs()" 
                                    style="padding: 8px 16px; background-color: #17a2b8; color: white; border: none; border-radius: 4px; cursor: pointer;">
                                    <i class="icon-log"></i> View Logs
                                </button>
                            </div>
                        </div>

                        <div>
                            <label style="display: block; margin-bottom: 8px; font-weight: bold;">
                                Cleanup:
                            </label>
                            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                                <button id="prune-btn" onclick="pruneDockerSystem()" 
                                    style="padding: 8px 16px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;">
                                    🗑️ Prune Unused
                                </button>
                                <button id="disk-usage-btn" onclick="showDiskUsage()" 
                                    style="padding: 8px 16px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer;">
                                    💾 Disk Usage
                                </button>
                            </div>
                        </div>

                        <div>
                            <label for="force-restart" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                <input type="checkbox" id="force-restart" style="width: 18px; height: 18px;">
                                <span>Force restart (down/up cycle)</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    <div class="content-section" style="margin-bottom: 20px;">
        <div class="card">
            <div class="card-header collapsible-header" onclick="toggleSection('production-deployment')" 
                 style="background-color: #fff3cd; padding: 15px; border: 2px solid #ffc107; border-bottom: 1px solid #ddd;">
                <h3 style="margin: 0; display: flex; align-items: center;">
                    <i class="fas fa-chevron-right chevron-icon" id="chevron-production-deployment" style="margin-right: 10px; font-size: 0.8em;"></i>
                    <i class="fas fa-rocket" style="margin-right: 10px; color: #dc3545;"></i>
                    Production Deployment
                    <span style="margin-left: 10px; background-color: #dc3545; color: white; padding: 2px 8px; border-radius: 3px; font-size: 0.8em;">CAUTION</span>
                </h3>
            </div>
            <div id="production-deployment" class="card-body collapsible-content" style="padding: 20px;">
                <div style="background-color: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; padding: 15px; margin-bottom: 20px;">
                    <h4 style="margin: 0 0 10px 0; color: #856404;">
                        <i class="fas fa-exclamation-triangle"></i> Production Deployment Workflow
                    </h4>
                    <p style="margin: 0; color: #856404;">
                        This will export the Docker container, copy it to production server via SSH, stop the running container,
                        load the new image, and start it. Always verify the image ID matches the local :latest tag before restart.
                        Automatic rollback on failure.
                    </p>
                    <p style="margin: 8px 0 0 0; color: #856404;">
                        Reminder: On production, always <strong>cd /opt/comserv/Comserv</strong> before running any
                        <code>docker compose</code> commands so the correct compose file and mounts are used.
                    </p>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px; margin-bottom: 20px;">
                    <div>
                        <label for="deploy-service-select" style="display: block; margin-bottom: 8px; font-weight: bold;">
                            Service to Deploy:
                        </label>
                        <select id="deploy-service-select" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                            <option value="web-prod">web-prod (Production)</option>
                            <option value="web-dev">web-dev (Development)</option>
                        </select>
                    </div>

                    <div>
                        <label for="ssh-target-select" style="display: block; margin-bottom: 8px; font-weight: bold;">
                            SSH Target:
                        </label>
                        <select id="ssh-target-select" onchange="updateSSHTarget()" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                            <option value="custom">Custom...</option>
                            <option value="ubuntu@192.168.1.126" selected>ubuntu@192.168.1.126 (Production)</option>
                            <option value="shanta@workstation.local">shanta@workstation.local</option>
                        </select>
                    </div>

                    <div>
                        <label for="production-host" style="display: block; margin-bottom: 8px; font-weight: bold;">
                            Production Server:
                        </label>
                        <input type="text" id="production-host" value="ubuntu@192.168.1.126" 
                               style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                        <small style="color: #666;">Format: user@hostname or user@IP</small>
                    </div>

                    <div>
                        <label for="ssh-port" style="display: block; margin-bottom: 8px; font-weight: bold;">
                            SSH Port:
                        </label>
                        <input type="number" id="ssh-port" value="22" min="1" max="65535"
                               style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                    </div>

                    <div>
                        <label for="ssh-password" style="display: block; margin-bottom: 8px; font-weight: bold;">
                            SSH Password:
                        </label>
                        <div style="position: relative;">
                            <input type="password" id="ssh-password" placeholder="Enter SSH password" 
                                   style="width: 100%; padding: 8px 40px 8px 8px; border: 1px solid #ddd; border-radius: 4px;">
                            <button onclick="togglePasswordVisibility()" type="button"
                                    style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #666;">
                                <i id="password-eye-icon" class="fas fa-eye"></i>
                            </button>
                        </div>
                        <small style="color: #666;">Stored securely in ~/.comserv/secrets/ssh_credentials.json</small>
                    </div>

                    <div>
                        <label for="production-directory" style="display: block; margin-bottom: 8px; font-weight: bold;">
                            Production Directory:
                        </label>
                        <input type="text" id="production-directory" value="/opt/comserv/Comserv" 
                               style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;">
                        <small style="color: #666;">Path where docker-compose.yml is located on production server</small>
                    </div>

                    <div style="display: flex; align-items: center; gap: 10px; grid-column: 1 / -1;">
                        <input type="checkbox" id="recreate-volumes" style="width: 18px; height: 18px; cursor: pointer;">
                        <label for="recreate-volumes" style="font-weight: bold; cursor: pointer; color: #dc3545;">
                            Recreate NFS Volumes (CAUTION: Removes and recreates log and workshop volumes)
                        </label>
                    </div>
                </div>

                <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
                    <button onclick="openSSHTerminal()" 
                        style="padding: 10px 20px; background-color: #0066cc; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
                        <i class="fas fa-terminal"></i> Open SSH Terminal
                    </button>

                    <div style="display: flex; align-items: center; gap: 8px;">
                        <button onclick="testSSHConnection()" 
                            style="padding: 10px 20px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
                            <i class="fas fa-network-wired"></i> Test Connection
                        </button>
                        <div id="ssh-status-indicator" style="width: 16px; height: 16px; border-radius: 50%; background-color: #ccc; border: 2px solid #999;" 
                             title="Not tested"></div>
                    </div>

                    <button onclick="saveDockerImage()" 
                        style="padding: 10px 20px; background-color: #17a2b8; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;"
                        title="Saves image to local tar file for manual backup">
                        <i class="fas fa-save"></i> Save Image
                    </button>
                    
                    <button onclick="deployToProduction()" 
                        style="padding: 10px 20px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;"
                        title="Build image → Push to Docker Hub → SSH trigger deploy.sh on production server">
                        <i class="fas fa-rocket"></i> Auto Deploy (Hub)
                    </button>

                    <button onclick="showDeploymentCommands()" 
                        style="padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
                        <i class="fas fa-code"></i> Show Commands
                    </button>
                </div>

                <div style="margin-top: 15px; padding: 10px; background-color: #e7f3ff; border: 1px solid #b3d9ff; border-radius: 4px;">
                    <h5 style="margin: 0 0 8px 0;">
                        <i class="fas fa-info-circle"></i> Manual Deployment Commands (Copy to SSH Terminal):
                    </h5>
                    <div id="quick-commands" style="font-size: 13px; font-family: monospace; background-color: #2d2d2d; color: #00ff00; padding: 12px; border-radius: 4px; margin-top: 10px;">

                        <div style="margin-bottom: 12px; padding: 10px; background-color: #1a3a1a; border: 2px solid #28a745; border-radius: 4px; color: #fff;">
                            <div style="color: #28a745; font-weight: bold; font-size: 1.05em; margin-bottom: 6px;">
                                ℹ️ Deployment Workflow: Build → Push to Docker Hub → Production auto-pulls via cron
                            </div>
                            <div style="color: #ccc; font-size: 0.9em;">
                                All changes (templates, Perl, CSS) are baked into the image on the workstation, pushed to
                                <strong style="color:#7ec8e3">hub.docker.com/r/shantamcsbain/comserv-web-prod</strong>,
                                then the production server's <code>deploy.sh</code> cron checks every 10 minutes and pulls automatically.
                                <br><strong style="color:#ffc107">Step 0 (local rebuild + push) is REQUIRED whenever any file has changed.</strong>
                            </div>
                        </div>

                        <div style="margin-bottom: 8px; color: #28a745; font-weight: bold;">→ Step 0: LOCAL REBUILD + PUSH — Run on Workstation</div>
                        <div style="margin-left: 15px; margin-bottom: 4px; color: #ccc; font-size: 0.88em;">1. Build and test dev container first:</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('cd /home/shanta/PycharmProjects/comserv2 && docker compose build web-dev && docker compose up -d --force-recreate web-dev')" title="Click to copy">
                            cd /home/shanta/PycharmProjects/comserv2 &amp;&amp; docker compose build web-dev &amp;&amp; docker compose up -d --force-recreate web-dev
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; color: #ccc; font-size: 0.88em;">
                            Test at <strong>http://workstation.local:3000</strong> — verify pages, login, etc.
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 4px; color: #ccc; font-size: 0.88em;">2. Once dev confirmed working, build prod image and push to Docker Hub:</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('cd /home/shanta/PycharmProjects/comserv2/Comserv && docker compose -f docker-compose.prod.yml build')" title="Click to copy">
                            cd /home/shanta/PycharmProjects/comserv2/Comserv &amp;&amp; docker compose -f docker-compose.prod.yml build
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 4px; color: #ccc; font-size: 0.88em;">3. Login to Docker Hub (one time — token stored by Docker):</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('docker login')" title="Click to copy">
                            docker login  # username: shantamcsbain — use access token not password
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 4px; color: #ccc; font-size: 0.88em;">4. Push to Docker Hub:</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('cd /home/shanta/PycharmProjects/comserv2/Comserv && docker compose -f docker-compose.prod.yml push')" title="Click to copy">
                            cd /home/shanta/PycharmProjects/comserv2/Comserv &amp;&amp; docker compose -f docker-compose.prod.yml push
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 8px; color: #28a745; font-size: 11px;">
                            ✅ After push, the production cron will detect the new digest within 10 minutes and auto-deploy.
                            Email notification sent to csc@computersystemconsulting.ca on successful deployment.
                        </div>

                        <div style="margin: 14px 0 8px 0; padding: 8px; background-color: #1a1a3a; border: 1px solid #5588cc; border-radius: 4px; color: #aad4ff; font-size: 12px;">
                            <strong>One-time setup on production server</strong> (only needed once per server):
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 4px; color: #ccc; font-size: 0.88em;">Copy deploy files to server (run from workstation):</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('ssh ubuntu@192.168.1.126 &quot;sudo mkdir -p /opt/comserv/Comserv&quot;')" title="Click to copy">
                            ssh ubuntu@192.168.1.126 "sudo mkdir -p /opt/comserv/Comserv"
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('scp /home/shanta/PycharmProjects/comserv2/Comserv/script/docker-compose.server.yml ubuntu@192.168.1.126:/opt/comserv/Comserv/docker-compose.prod.yml')" title="Click to copy">
                            scp Comserv/script/docker-compose.server.yml ubuntu@192.168.1.126:/opt/comserv/Comserv/docker-compose.prod.yml
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('scp /home/shanta/PycharmProjects/comserv2/Comserv/script/deploy.sh ubuntu@192.168.1.126:/opt/comserv/Comserv/deploy.sh')" title="Click to copy">
                            scp Comserv/script/deploy.sh ubuntu@192.168.1.126:/opt/comserv/Comserv/deploy.sh
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 4px; color: #ccc; font-size: 0.88em;">On production server — make executable, install mail, add cron:</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('chmod +x /opt/comserv/Comserv/deploy.sh && sudo apt install -y mailutils')" title="Click to copy">
                            chmod +x /opt/comserv/Comserv/deploy.sh &amp;&amp; sudo apt install -y mailutils
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('( crontab -l 2>/dev/null; echo &quot;*/10 * * * * /opt/comserv/Comserv/deploy.sh >> /var/log/comserv-deploy.log 2>&1&quot; ) | crontab -')" title="Click to copy">
                            ( crontab -l 2>/dev/null; echo "*/10 * * * * /opt/comserv/Comserv/deploy.sh >> /var/log/comserv-deploy.log 2>&1" ) | crontab -
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 10px; color: #aad4ff; font-size: 11px;">
                            Production server pulls from <strong>hub.docker.com/r/shantamcsbain/comserv-web-prod</strong>.
                            No docker save/load needed. Log: <code>tail -f /var/log/comserv-deploy.log</code>
                        </div>

                        <div style="margin-bottom: 8px; color: #fff; font-weight: bold;">→ Production - Check Disk Space</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('df -h /')" title="Click to copy">
                            df -h /
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker system df')" title="Click to copy">
                            sudo docker system df
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker system df -v')" title="Click to copy">
                            sudo docker system df -v  # Verbose: shows container sizes
                        </div>

                        <div style="margin: 12px 0 8px 0; color: #fff; font-weight: bold;">→ Production - Manual Trigger (force immediate deploy)</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('ssh ubuntu@192.168.1.126 &quot;/opt/comserv/Comserv/deploy.sh&quot;')" title="Click to copy">
                            ssh ubuntu@192.168.1.126 "/opt/comserv/Comserv/deploy.sh"
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('ssh ubuntu@192.168.1.126 &quot;tail -50 /var/log/comserv-deploy.log&quot;')" title="Click to copy">
                            ssh ubuntu@192.168.1.126 "tail -50 /var/log/comserv-deploy.log"  # view deploy log
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 10px; color: #ffaa00; font-size: 11px;">
                            ⚠ Do NOT run docker system prune -v — it removes named volumes (logs/workshop data)
                        </div>

                        <div style="margin: 12px 0 8px 0; color: #fff; font-weight: bold;">→ Production - Verify Container Status</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker ps')" title="Click to copy">
                            sudo docker ps
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker inspect --format=&quot;{{.State.Health.Status}}&quot; comserv2-web-prod')" title="Click to copy">
                            sudo docker inspect --format="{{.State.Health.Status}}" comserv2-web-prod
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker images | grep shantamcsbain')" title="Click to copy">
                            sudo docker images | grep shantamcsbain
                        </div>

                        <div style="margin: 12px 0 8px 0; color: #fff; font-weight: bold;">→ Production - Cleanup Old Images</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker image prune -f')" title="Click to copy">
                            sudo docker image prune -f  # Remove dangling images only (safe)
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker rm $(sudo docker ps -a -q -f status=exited) 2>/dev/null || echo &quot;No stopped containers&quot;')" title="Click to copy">
                            sudo docker rm $(sudo docker ps -a -q -f status=exited) 2>/dev/null || echo "No stopped containers"
                        </div>

                        <div style="margin: 12px 0 8px 0; color: #ff5555; font-weight: bold;">→ ROLLBACK (If New Container Fails):</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker stop comserv2-web-prod 2>/dev/null; sudo docker rm comserv2-web-prod 2>/dev/null; sudo docker run -d --name comserv2-web-prod --restart unless-stopped -p 5000:3000 -e COMSERV_SESSION_COOKIE=comserv_session -v /home/ubuntu/.comserv/secrets:/home/comserv/.comserv/secrets:ro -v /home/ubuntu/comserv-logs:/opt/comserv/root/log -v /home/ubuntu/comserv-workshop:/data/nfs comserv-web-prod:backup-prev')" title="Click to copy">
                            sudo docker stop comserv2-web-prod 2>/dev/null; sudo docker rm comserv2-web-prod 2>/dev/null; sudo docker run -d --name comserv2-web-prod --restart unless-stopped -p 5000:3000 -e COMSERV_SESSION_COOKIE=comserv_session -v /home/ubuntu/.comserv/secrets:/home/comserv/.comserv/secrets:ro -v /home/ubuntu/comserv-logs:/opt/comserv/root/log -v /home/ubuntu/comserv-workshop:/data/nfs comserv-web-prod:backup-prev
                        </div>

                        <div style="margin: 12px 0 8px 0; color: #fff; font-weight: bold;">→ Quick Commands:</div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker restart comserv2-web-prod')" title="Click to copy">
                            sudo docker restart comserv2-web-prod  # Restart without rebuild
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker logs --tail 100 comserv2-web-prod')" title="Click to copy">
                            sudo docker logs --tail 100 comserv2-web-prod  # Last 100 log lines
                        </div>
                        <div style="margin-left: 15px; margin-bottom: 5px; cursor: pointer; padding: 5px; background-color: #1e1e1e;" onclick="copyToClipboard('sudo docker system prune -f')" title="Click to copy">
                            sudo docker system prune -f  # Cleanup dangling images/stopped containers
                        </div>

                        <div style="margin-top: 10px; color: #ffc107; font-size: 12px;">
                            💡 Click any command to copy it to clipboard, then paste in SSH terminal
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content-section" style="margin-bottom: 20px;">
        <div class="card">
            <div class="card-header collapsible-header" onclick="toggleSection('ssh-terminal-section')" 
                 style="background-color: #1e1e1e; padding: 15px; border-bottom: 1px solid #444; color: #00ff00;">
                <h3 style="margin: 0; display: flex; align-items: center; justify-content: space-between;">
                    <span>
                        <i class="fas fa-chevron-right chevron-icon" id="chevron-ssh-terminal-section" style="margin-right: 10px; font-size: 0.8em;"></i>
                        <i class="fas fa-terminal" style="margin-right: 10px;"></i>
                        SSH Terminal (Embedded)
                    </span>
                    <span style="font-size: 14px; background-color: #00ff00; color: #1e1e1e; padding: 4px 10px; border-radius: 3px;">
                        INTERACTIVE
                    </span>
                </h3>
            </div>
            <div id="ssh-terminal-section" class="card-body collapsible-content" style="padding: 20px; background-color: #1e1e1e;">
                <div id="ssh-terminal-info" style="background-color: #17a2b8; border: 1px solid #138496; border-radius: 4px; padding: 15px; margin-bottom: 15px; color: white;">
                    <p style="margin: 0; font-size: 14px; font-weight: bold;">
                        ℹ️ Interactive SSH Terminal
                    </p>
                    <p style="margin: 10px 0 0 0; font-size: 13px;">
                        Enter SSH credentials below or use saved credentials from "Test Connection" above.
                    </p>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
                    <div>
                        <label style="display: block; margin-bottom: 8px; font-weight: bold; color: #00ff00;">
                            SSH Target:
                        </label>
                        <input type="text" id="ssh-terminal-target" value="ubuntu@192.168.1.126" 
                               style="width: 100%; padding: 8px; border: 1px solid #00ff00; border-radius: 4px; background-color: #000; color: #00ff00;">
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 8px; font-weight: bold; color: #00ff00;">
                            SSH Password:
                        </label>
                        <div style="position: relative;">
                            <input type="password" id="ssh-terminal-password" placeholder="Enter password" 
                                   style="width: 100%; padding: 8px 40px 8px 8px; border: 1px solid #00ff00; border-radius: 4px; background-color: #000; color: #00ff00;">
                            <button onclick="toggleSSHTerminalPassword()" type="button"
                                    style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: #00ff00;">
                                <i id="ssh-terminal-password-eye" class="fas fa-eye"></i>
                            </button>
                        </div>
                        <small style="color: #ccc;">Leave blank to use saved credentials</small>
                    </div>
                </div>
                
                <div style="display: flex; gap: 10px; margin-bottom: 15px; align-items: center;">
                    <button id="ssh-connect-btn" onclick="connectSSHTerminal()" 
                        style="padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">
                        <i class="fas fa-play"></i> Connect
                    </button>
                    <button id="ssh-disconnect-btn" onclick="disconnectSSHTerminal()" disabled
                        style="padding: 10px 20px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: not-allowed; font-weight: bold; opacity: 0.5;">
                        <i class="fas fa-stop"></i> Disconnect
                    </button>
                    <div id="ssh-connection-status" style="margin-left: 10px; color: #ccc; font-size: 14px;">
                        <i class="fas fa-circle" style="color: #6c757d;"></i> Disconnected
                    </div>
                </div>

                <div id="ssh-terminal-container" style="background-color: #000; border: 2px solid #00ff00; border-radius: 4px; height: 500px; padding: 10px;">
                    <div id="ssh-xterm-terminal"></div>
                </div>

                <div style="margin-top: 15px; padding: 12px; background-color: #2d2d2d; border-radius: 4px; color: #ccc; font-family: monospace; font-size: 13px;">
                    <div style="margin-bottom: 10px; color: #00ff00;"><strong>Alternative - Use PyCharm Terminal:</strong></div>
                    <div>1. PyCharm → Tools → Start SSH Session</div>
                    <div>2. Enter: <code style="color: #ff0;">ubuntu@192.168.1.126</code></div>
                    <div>3. Enter password when prompted</div>
                    <div>4. Copy commands from "Manual Deployment Commands" section above</div>
                    <div style="margin-top: 10px; color: #ff0;">Or click "Auto Deploy" for fully automated deployment</div>
                </div>
            </div>
        </div>
    </div>

    <div class="content-section" style="margin-bottom: 20px;">
        <div class="card">
            <div class="card-header collapsible-header" onclick="toggleSection('output-console-section')" 
                 style="background-color: #f5f5f5; padding: 15px; border-bottom: 1px solid #ddd;">
                <h3 style="margin: 0; display: flex; align-items: center;">
                    <i class="fas fa-chevron-right chevron-icon" id="chevron-output-console-section" style="margin-right: 10px; font-size: 0.8em;"></i>
                    <i class="icon-log" style="margin-right: 10px;"></i>
                    Output/Logs
                </h3>
            </div>
            <div id="output-console-section" class="card-body collapsible-content" style="padding: 20px;">
                <div id="last-deploy-banner" style="display:none; margin-bottom: 10px; padding: 8px 12px; background-color: #e7f3ff; border: 1px solid #b3d9ff; border-radius: 4px; font-size: 12px; font-family: monospace;">
                    <strong>Last deploy log:</strong> <span id="last-deploy-file" style="color:#333;"></span>
                    <button onclick="loadHistoryIntoOutput()" style="margin-left: 12px; padding: 2px 8px; font-size: 11px; background-color:#0066cc; color:white; border:none; border-radius:3px; cursor:pointer;">Show in Output</button>
                </div>
                <div id="output-box" style="background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 4px; padding: 15px; 
                    font-family: monospace; font-size: 12px; max-height: 400px; overflow-y: auto; white-space: pre-wrap; word-wrap: break-word;">
                    Ready for commands...
                </div>
                <div style="margin-top: 10px;">
                    <button onclick="clearOutput()" style="padding: 6px 12px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer;">
                        Clear Output
                    </button>
                </div>
            </div>
        </div>
    </div>

    [% END %]
</div>

<script>
    // Toggle collapsible sections
    function toggleSection(sectionId) {
        const content = document.getElementById(sectionId);
        const chevron = document.getElementById('chevron-' + sectionId);
        
        if (content && chevron) {
            content.classList.toggle('expanded');
            chevron.classList.toggle('expanded');
        }
    }

    // Auto-expand Container Status and Volume Status on page load
    window.addEventListener('DOMContentLoaded', function() {
        const statusSection = document.getElementById('container-status');
        const statusChevron = document.getElementById('chevron-container-status');
        if (statusSection && statusChevron) {
            statusSection.classList.add('expanded');
            statusChevron.classList.add('expanded');
        }
        const volSection = document.getElementById('volumes-status');
        const volChevron = document.getElementById('chevron-volumes-status');
        if (volSection && volChevron) {
            volSection.classList.add('expanded');
            volChevron.classList.add('expanded');
        }
    });
</script>

<script>
    const outputBox = document.getElementById('output-box');
    const containersList = document.getElementById('containers-list');
    let containersData = [];

    function appendOutput(message) {
        const timestamp = new Date().toLocaleTimeString();
        outputBox.textContent += `[${timestamp}] ${message}\n`;
        outputBox.scrollTop = outputBox.scrollHeight;
    }

    // Wrapper for all admin AJAX calls.
    // Handles: session expiry (302 → login page HTML), server errors (5xx HTML), network errors.
    function safeFetch(url, options) {
        const opts = Object.assign({ credentials: 'same-origin', redirect: 'manual' }, options || {});
        return fetch(url, opts).then(function(response) {
            if (response.type === 'opaqueredirect' || response.status === 0 ||
                (response.status >= 300 && response.status < 400)) {
                appendOutput('✗ Session expired — reload the page (Ctrl+Shift+R) and log in again.');
                return Promise.reject(new Error('session-expired'));
            }
            if (!response.ok) {
                appendOutput(`✗ Server error (HTTP ${response.status}) — check server logs.`);
                return Promise.reject(new Error(`HTTP ${response.status}`));
            }
            return response;
        });
    }

    function clearOutput() {
        outputBox.textContent = 'Ready for commands...\n';
    }

    function getSelectedService() {
        const select = document.getElementById('service-select');
        const service = select.value;
        if (!service) {
            alert('Please select a service');
            return null;
        }
        return service;
    }

    function getStateColor(state) {
        const stateColors = {
            'running': '#28a745',
            'up': '#28a745',
            'exited': '#dc3545',
            'exit': '#dc3545',
            'restarting': '#ffc107',
            'paused': '#6c757d',
            'created': '#17a2b8',
            'not_created': '#6c757d',
            'unknown': '#6c757d'
        };
        return stateColors[state.toLowerCase()] || '#6c757d';
    }

    function getStateIcon(state) {
        const stateIcons = {
            'running': '▶',
            'up': '▶',
            'exited': '■',
            'exit': '■',
            'restarting': '↻',
            'paused': '❚❚',
            'created': '○',
            'not_created': '○',
            'unknown': '?'
        };
        return stateIcons[state.toLowerCase()] || '?';
    }

    let _lastDeployContent = '';

    function loadDeployHistory() {
        fetch('/admin/docker-deploy-history', { credentials: 'same-origin' })
            .then(r => r.json())
            .then(data => {
                if (data.success && data.latest_file) {
                    _lastDeployContent = data.latest_content || '';
                    const fname = data.latest_file.split('/').pop();
                    document.getElementById('last-deploy-file').textContent = fname;
                    document.getElementById('last-deploy-banner').style.display = 'block';
                }
            })
            .catch(() => {});
    }

    function loadHistoryIntoOutput() {
        if (_lastDeployContent) {
            outputBox.textContent = '=== Last Deploy Log ===\n' + _lastDeployContent;
            outputBox.scrollTop = outputBox.scrollHeight;
        }
    }

    function loadSavedCredentials() {
        fetch('/admin/docker-load-credentials', { credentials: 'same-origin' })
            .then(r => r.json())
            .then(data => {
                if (data.success && data.ssh_password) {
                    document.getElementById('ssh-password').value = data.ssh_password;
                    document.getElementById('production-host').value = data.ssh_target || 'ubuntu@192.168.1.126';
                    document.getElementById('ssh-port').value = data.ssh_port || 22;
                    if (document.getElementById('ssh-terminal-target'))
                        document.getElementById('ssh-terminal-target').value = data.ssh_target || 'ubuntu@192.168.1.126';
                    if (document.getElementById('ssh-terminal-password'))
                        document.getElementById('ssh-terminal-password').value = data.ssh_password;
                }
            })
            .catch(() => {});
    }

    function refreshContainers() {
        containersList.innerHTML = '<p style="color: #666; text-align: center;">Loading container information...</p>';

        fetch('/admin/docker-list', { credentials: 'same-origin', redirect: 'manual' })
            .then(function(response) {
                if (response.type === 'opaqueredirect' || response.status === 0 || (response.status >= 300 && response.status < 400)) {
                    containersList.innerHTML = '<p style="color: #dc3545; text-align: center;">Session expired — please <a href="/user/login">log in again</a>.</p>';
                    return null;
                }
                if (!response.ok) throw new Error('HTTP ' + response.status);
                return response.json();
            })
            .then(data => {
                if (!data) return;
                if (!data.success) {
                    containersList.innerHTML = `<p style="color: #dc3545; text-align: center;">Error: ${data.error}</p>`;
                    return;
                }

                containersData = data.containers;
                displayContainers(data.containers, data.host);
                updateServiceDropdown(data.containers);
            })
            .catch(error => {
                containersList.innerHTML = `<p style="color: #dc3545; text-align: center;">Error loading containers: ${error.message}</p>`;
            });
    }

    function refreshVolumes() {
        const volumesList = document.getElementById('volumes-list');
        volumesList.innerHTML = '<p style="color: #666; text-align: center;">Loading volume information...</p>';

        fetch('/admin/docker-volumes', { credentials: 'same-origin', redirect: 'manual' })
            .then(function(response) {
                if (response.type === 'opaqueredirect' || response.status === 0 || (response.status >= 300 && response.status < 400)) {
                    volumesList.innerHTML = '<p style="color: #dc3545; text-align: center;">Session expired — please <a href="/user/login">log in again</a>.</p>';
                    return null;
                }
                if (!response.ok) throw new Error('HTTP ' + response.status);
                return response.json();
            })
            .then(data => {
                if (!data) return;
                if (!data.success) {
                    volumesList.innerHTML = `<p style="color: #dc3545; text-align: center;">Error: ${data.error}</p>`;
                    return;
                }
                displayVolumes(data.volumes);
            })
            .catch(error => {
                volumesList.innerHTML = `<p style="color: #dc3545; text-align: center;">Error loading volumes: ${error.message}</p>`;
            });
    }

    function displayVolumes(volumes) {
        const volumesList = document.getElementById('volumes-list');
        if (!volumes || volumes.length === 0) {
            volumesList.innerHTML = '<p style="color: #666; text-align: center;">No volumes found</p>';
            return;
        }

        let html = '';
        volumes.forEach(vol => {
            const isNfs    = vol.is_nfs === true || vol.is_nfs == 1;
            const typeLabel = isNfs ? 'NFS' : (vol.driver || 'local');
            const typeColor = isNfs ? '#17a2b8' : '#6c757d';
            const typeIcon  = isNfs ? '🌐' : '💾';

            const mountDisplay = vol.mountpoint
                ? `<div style="font-size: 12px; color: #666; margin-bottom: 4px;"><strong>Mountpoint:</strong> <code style="font-size: 11px;">${vol.mountpoint}</code></div>`
                : '';

            const nfsDetail = isNfs
                ? `<div style="font-size: 12px; color: #17a2b8; margin-bottom: 4px;">
                       <strong>NFS Server:</strong> ${vol.nfs_server || 'unknown'}
                       &nbsp;|&nbsp;
                       <strong>Export:</strong> ${vol.nfs_device || 'unknown'}
                   </div>`
                : '';

            const labelsDisplay = vol.labels
                ? `<div style="font-size: 11px; color: #999; margin-bottom: 4px;"><strong>Labels:</strong> ${vol.labels}</div>`
                : '';

            html += `
                <div style="border: 1px solid #ddd; border-radius: 4px; padding: 12px; background-color: #fff;">
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                        <strong style="font-size: 14px;">${typeIcon} ${vol.name}</strong>
                        <span style="background-color: ${typeColor}; color: white; padding: 2px 8px; border-radius: 3px; font-size: 11px;">${typeLabel}</span>
                    </div>
                    ${nfsDetail}
                    ${mountDisplay}
                    ${labelsDisplay}
                    <div style="font-size: 11px; color: #999;"><strong>Scope:</strong> ${vol.scope || 'local'}</div>
                </div>`;
        });

        volumesList.innerHTML = html;
    }

    function displayContainers(containers, host) {
        if (!containers || containers.length === 0) {
            containersList.innerHTML = '<p style="color: #666; text-align: center;">No containers found</p>';
            return;
        }

        const hostLabel = host ? `<div style="margin-bottom:10px;padding:6px 10px;background:#e9ecef;border-radius:4px;font-size:13px;"><strong>Server:</strong> ${host}</div>` : '';
        let html = hostLabel;
        containers.forEach(container => {
            const stateColor = getStateColor(container.state);
            const stateIcon = getStateIcon(container.state);
            const isRunning = ['running', 'up'].includes((container.state||'').toLowerCase());
            const displayName = container.name || container.id || '(unnamed)';
            const healthBadge = container.status && container.status.includes('healthy') && !container.status.includes('unhealthy')
                ? '<span style="background:#28a745;color:#fff;padding:1px 6px;border-radius:3px;font-size:11px;margin-left:6px;">healthy</span>'
                : container.status && container.status.includes('unhealthy')
                ? '<span style="background:#dc3545;color:#fff;padding:1px 6px;border-radius:3px;font-size:11px;margin-left:6px;">unhealthy</span>'
                : '';

            html += `
                <div style="border: 1px solid #ddd; border-radius: 4px; padding: 15px; background-color: #fff;">
                    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 10px;">
                        <div style="flex: 1;">
                            <h4 style="margin: 0 0 5px 0; color: #333;">
                                <span style="color: ${stateColor}; margin-right: 8px;">${stateIcon}</span>
                                ${displayName}${healthBadge}
                            </h4>
                            <div style="font-size: 12px; color: #666; margin-bottom: 3px;">
                                <strong>Image:</strong> ${container.image || ''}
                            </div>
                            <div style="font-size: 12px; color: #666; margin-bottom: 3px;">
                                <strong>ID:</strong> <code>${container.id || ''}</code>
                                &nbsp;|&nbsp;<strong>Status:</strong> ${container.status || container.state || ''}
                            </div>
                            ${container.ports ? `<div style="font-size:12px;color:#666;margin-bottom:3px;"><strong>Ports:</strong> ${container.ports}</div>` : ''}
                            <div style="font-size: 12px;">
                                <span style="background-color: ${stateColor}; color: white; padding: 2px 8px; border-radius: 3px; font-weight: bold;">
                                    ${(container.state||'unknown').toUpperCase()}
                                </span>
                            </div>
                        </div>
                        <div style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end;">
                            ${container.state === 'not_created' ? `
                                <button onclick="createContainerDirect('${container.name}')"
                                    style="padding: 6px 12px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    🚀 Create & Start
                                </button>
                            ` : isRunning ? `
                                <button onclick="stopContainerDirect('${container.name}')"
                                    style="padding: 6px 12px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    ■ Stop
                                </button>
                                <button onclick="restartContainerDirect('${container.name}')"
                                    style="padding: 6px 12px; background-color: #0066cc; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    ↻ Restart
                                </button>
                                <button onclick="viewLogsDirect('${container.name}')"
                                    style="padding: 6px 12px; background-color: #17a2b8; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    📋 Logs
                                </button>
                            ` : `
                                <button onclick="startContainerDirect('${container.name}')"
                                    style="padding: 6px 12px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    ▶ Start
                                </button>
                                <button onclick="viewLogsDirect('${container.name}')"
                                    style="padding: 6px 12px; background-color: #17a2b8; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 12px;">
                                    📋 Logs
                                </button>
                            `}
                        </div>
                    </div>
                </div>
            `;
        });

        containersList.innerHTML = html;
    }

    function updateServiceDropdown(containers) {
        const select = document.getElementById('service-select');
        // Clear existing options except the first two
        while (select.options.length > 2) {
            select.remove(2);
        }

        containers.forEach(container => {
            const option = document.createElement('option');
            option.value = container.name;
            option.textContent = container.name;
            select.appendChild(option);
        });
    }

    function createContainerDirect(service) {
        appendOutput(`Creating and starting ${service}...`);

        safeFetch(`/admin/docker-up/${service}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    appendOutput(`✓ ${service} created and started successfully!\n` + (data.stdout || ''));
                    setTimeout(refreshContainers, 2000);
                } else {
                    appendOutput(`✗ Failed to create ${service}:\n` + (data.stderr || data.error || 'Unknown error'));
                }
            })
            .catch(error => {
                appendOutput(`Error: ${error.message}`);
            });
    }

    function startContainerDirect(service) {
        appendOutput(`Starting ${service}...`);

        safeFetch(`/admin/docker-start/${service}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    appendOutput(`✓ ${service} started successfully!\n` + (data.stdout || ''));
                    setTimeout(refreshContainers, 1000);
                } else {
                    appendOutput(`✗ Failed to start ${service}:\n` + (data.stderr || data.error || 'Unknown error'));
                }
            })
            .catch(error => {
                appendOutput(`Error: ${error.message}`);
            });
    }

    function stopContainerDirect(service) {
        if (!confirm(`Are you sure you want to stop ${service}?`)) {
            return;
        }

        appendOutput(`Stopping ${service}...`);

        safeFetch(`/admin/docker-stop/${service}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    appendOutput(`✓ ${service} stopped successfully!\n` + (data.stdout || ''));
                    setTimeout(refreshContainers, 1000);
                } else {
                    appendOutput(`✗ Failed to stop ${service}:\n` + (data.stderr || data.error || 'Unknown error'));
                }
            })
            .catch(error => {
                appendOutput(`Error: ${error.message}`);
