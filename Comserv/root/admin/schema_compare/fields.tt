[%# Schema Compare - Field Comparison (table drill-down)
    Shows fields from both the live table and its Result file.
    Highlights missing fields on either side.
    Allows: add missing field to table / add to result / drop column.
    Follows ApplicationTtTemplate.tt structure and CSS classes.
%]

<div class="app-container">
    <div class="page-header">
        <h1>Fields for [% table.name | html %]</h1>
        <p class="page-subtitle">Database: [% db.name | html %] • Server: [% server.name | html %]</p>
    </div>

    <div class="breadcrumb-container">
        <nav class="breadcrumb">
            <a href="[% c.uri_for('/admin/schema_compare') %]">Schema Compare</a>
            <span>›</span>
            <a href="[% c.uri_for('/admin/schema_compare/server') %]/[% server.name | uri %]">[% server.name | html %]</a>
            <span>›</span>
            <a href="[% c.uri_for('/admin/schema_compare/server') %]/[% server.name | uri %]/db/[% db.name | uri %]">[% db.name | html %]</a>
            <span>›</span>
            <span>[% table.name | html %]</span>
        </nav>
    </div>

    <div class="content-container">
        <div class="content-primary">
            [% IF fields.size %]
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Field Name</th>
                            <th>Table Definition</th>
                            <th>Result File Definition</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        [% FOREACH field IN fields %]
                        <tr data-field="[% field.name | html %]"[% IF field.row_class %] class="[% field.row_class | html %]"[% END %]>
                            <td><strong>[% field.name | html %]</strong></td>
                            <td>
                                [% IF field.in_table %]
                                    <code>[% field.table_def | html %]</code>
                                [% ELSE %]
                                    <span class="text-muted">— (missing in table)</span>
                                [% END %]
                            </td>
                            <td>
                                [% IF field.in_result %]
                                    <code>[% field.result_def | html %]</code>
                                [% ELSE %]
                                    <span class="text-muted">— (missing in result)</span>
                                [% END %]
                            </td>
                            <td>
                                [% IF field.status == 'Match' %]
                                    <span class="status-badge synchronized">Match</span>
                                [% ELSIF field.status == 'Update needed' %]
                                    <span class="status-badge needs-update">Update needed</span>
                                [% ELSIF field.status == 'Table only' %]
                                    <span class="status-badge table-only">Table only</span>
                                [% ELSE %]
                                    <span class="status-badge result-only">Result only</span>
                                [% END %]
                            </td>
                            <td class="action-cell">
                                [% IF field.in_result && !field.in_table %]
                                    <button class="btn btn-sm btn-primary" onclick="addFieldToTable('[% field.name | html %]', '[% table.name | html %]')">
                                        <i class="fas fa-plus"></i> Add to Table
                                    </button>
                                [% END %]
                                [% IF field.in_table && !field.in_result %]
                                    <button class="btn btn-sm btn-secondary" onclick="addFieldToResult('[% field.name | html %]', '[% table.name | html %]')">
                                        <i class="fas fa-file-alt"></i> Add to Result
                                    </button>
                                [% END %]
                                [% IF field.in_table %]
                                    <button class="btn btn-sm btn-delete" onclick="dropColumn('[% field.name | html %]', '[% table.name | html %]'); event.stopPropagation();">
                                        <i class="fas fa-trash"></i> Drop
                                    </button>
                                [% END %]
                            </td>
                        </tr>
                        [% END %]
                    </tbody>
                </table>
            </div>
            [% ELSE %]
            [% IF !db_connected %]
            <div class="empty-state" style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px; padding: 2rem; text-align: center;">
                <p><strong>Could not connect to database server</strong></p>
                <p style="color: #666; margin-top: 0.5rem;">Unable to connect to [% server.name | html %] / [% db.name | html %]. The server may be offline or unreachable.</p>
                <p style="margin-top: 0.5rem;"><a href="[% c.uri_for('/admin/schema_compare/server') %]/[% server.name | uri %]/db/[% db.name | uri %]">← Back to Tables</a></p>
            </div>
            [% ELSIF db_connected && !has_result_file %]
            <div class="empty-state">
                <p>Connected to database, but no Result file found for table <strong>[% table.name | html %]</strong>.</p>
            </div>
            [% ELSE %]
            <div class="empty-state">
                <p>No field comparison data available.</p>
            </div>
            [% END %]
            [% END %]
        </div>
    </div>

    <div class="page-footer">
        <div class="footer-actions">
            <a href="[% c.uri_for('/admin/schema_compare/server') %]/[% server.name | uri %]/db/[% db.name | uri %]" class="btn btn-secondary">← Back to Tables</a>
        </div>
    </div>
</div>

<script>
function addFieldToTable(fieldName, tableName) {
    var dbName = '[% db.name | html %]';
    if (!confirm('Add field "' + fieldName + '" to table "' + tableName + '" from result file?')) return;
    fetch('/schema-comparison/sync_result_to_table', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            table_name: tableName,
            field_name: fieldName,
            database: dbName,
            database_environment: 'development',
            allow_production: 1,
            confirmed: true
        })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            alert('Done: ' + (data.message || 'Field added to table'));
            location.reload();
        } else {
            alert('Error: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(function(err) {
        alert('Request failed: ' + err.message);
    });
}

function addFieldToResult(fieldName, tableName) {
    var dbName = '[% db.name | html %]';
    if (!confirm('Add field "' + fieldName + '" to result file from table "' + tableName + '"?')) return;
    fetch('/schema-comparison/sync_table_to_result', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            table_name: tableName,
            field_name: fieldName,
            database: dbName,
            database_environment: 'development',
            allow_production: 1,
            confirmed: true
        })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            alert('Done: ' + (data.message || 'Field added to result'));
            location.reload();
        } else {
            alert('Error: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(function(err) {
        alert('Request failed: ' + err.message);
    });
}

function dropColumn(fieldName, tableName) {
    var dbName = '[% db.name | html %]';
    if (!confirm('Drop column "' + fieldName + '" from table "' + tableName + '"?')) return;
    fetch('/schema-comparison/remove_field_from_table', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            table_name: tableName,
            field_name: fieldName,
            database: dbName,
            confirmed: true
        })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.success) {
            alert('Done: ' + (data.message || 'Column dropped'));
            location.reload();
        } else {
            alert('Error: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(function(err) {
        alert('Request failed: ' + err.message);
    });
}
</script>