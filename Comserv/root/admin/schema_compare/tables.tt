[%# Schema Compare - Table List (database drill-down)
    Shows tables in the selected database.
    Indicates: has result file / table only / result only.
    Allows add/remove actions and drill to field comparison.
    JS via schema-compare.js (event delegation on data-action attributes)
%]

[% SET fetch_url = c.uri_for('/schema-comparison/create_table_from_result') %]

<div class="app-container">
    <div class="page-header">
        <h1>Tables in [% db.name | html %]</h1>
        <p class="page-subtitle">Server: [% server.name | html %] • Database: [% db.name | html %]</p>
    </div>

    <div class="breadcrumb-container">
        <nav class="breadcrumb">
            <a href="[% c.uri_for('/admin/schema_compare') %]">Schema Compare</a>
            <span>›</span>
            <a href="[% c.uri_for('/admin/schema_compare/server') %]/[% server.name | uri %]">[% server.name | html %]</a>
            <span>›</span>
            <span>[% db.name | html %]</span>
        </nav>
    </div>

    <!-- Result File Discovery Header (Result files vs live DB tables) -->
    <div class="result-discovery-header">
        <h4>
            <i class="fas fa-folder-open"></i> Result Files Discovery
        </h4>
        <p class="result-summary">
            <strong>Result files discovered:</strong> <span class="result-count">[% result_count || 0 %]</span>
            &nbsp;|&nbsp;
            <strong>Live DB tables:</strong> <span class="result-count">[% db_table_count || 0 %]</span>
            &nbsp;|&nbsp;
            <strong>Matched:</strong> <span class="result-count">[% matched_count || 0 %]</span>
            &nbsp;|&nbsp;
            <strong>Result files without a DB table:</strong>
            <span class="result-count[% IF result_only.size %] result-count-warn[% END %]">[% result_only.size || 0 %]</span>
        </p>
        [% IF result_count %]
        <details class="result-file-toggle">
            <summary class="result-file-summary">Show first 20 result files for [% result_schema %]</summary>
            <div class="result-file-scroll">
                [% FOREACH rf IN result_files.splice(0,20) %]
                    <div>[% rf.name | html %]</div>
                [% END %]
            </div>
        </details>
        [% END %]

        [% IF result_extract_failures.size %]
        <details class="result-extract-failures">
            <summary class="result-failure-summary">
                ⚠ Extraction failures: [% result_extract_failures.size %] result files could not be parsed
            </summary>
            <div class="result-failure-scroll">
                [% FOREACH fail IN result_extract_failures %]
                    <div class="result-failure-item">
                        <strong class="result-failure-name">[% fail.name | html %]</strong><br>
                        <span class="result-failure-path">[% fail.path | html %]</span>
                    </div>
                [% END %]
            </div>
        </details>
        [% END %]

        <!-- Diagnostic: why Result files without tables is empty -->
        <details class="debug-section" open>
            <summary>Debug: Result file vs DB table matching (open by default)</summary>
            <div class="debug-content">
                Total result files scanned: <strong>[% result_count %]</strong><br>
                DB tables from information_schema: <strong>[% db_table_count %]</strong><br>
                Result files whose table name matches a DB table: <strong>[% matched_count %]</strong><br>
                Result files whose table name does NOT exist in DB: <strong>[% result_only.size %]</strong><br>
                Result files that FAILED to parse: <strong>[% result_extract_failures.size %]</strong><br>
                <span class="warning-text">Result files without a DB table are listed at the bottom. They mean the live DB this scan is connected to does not contain that table (table not yet deployed, deployed to a different DB, or the scan is pointed at a stale/secondary connection).</span>

                [% IF result_only.size == 0 && result_count > matched_count && result_extract_failures.size == 0 %]
                <div class="debug-warning-block">
                    <strong>WARNING:</strong> [% result_count %] result files but only [% matched_count %] matched, yet none appear in "Result files without tables".<br>
                    The DB table list may be incomplete or the table-name key comparison is failing.
                </div>
                [% ELSIF result_count > matched_count && result_extract_failures.size > 0 %]
                <div class="debug-info-block">
                    <strong>NOTE:</strong> [% result_count %] result files, [% matched_count %] matched, [% result_extract_failures.size %] failed to parse.<br>
                    All unmatched files are accounted for in the extraction failures above.
                </div>
                [% END %]

                [% IF orphaned_result_files.size %]
                <div class="debug-orphan-block">
                    <strong>Orphaned Result files (table name not in DB):</strong><br>
                    [% FOREACH o IN orphaned_result_files %]
                        [% o.result_name | html %] → extracted table name: <code>[% o.extracted_table_name | html %]</code><br>
                    [% END %]
                </div>
                [% END %]
            </div>
        </details>
    </div>

    <div class="content-container">
        <div class="content-primary">
            
            <!-- Section 1: Tables with Result files -->
            <div class="comparison-section">
                <h3 class="section-toggle-h3" data-action="toggle-section">
                    <i class="fas fa-check-circle icon-green"></i> Tables (all have result files) ([% both.size %])
                    <span class="toggle-hint">[click to toggle]</span>
                </h3>
                <div class="section-content">
                    [% IF both.size %]
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Table Name</th>
                                    <th>Rows</th>
                                    <th>Size</th>
                                    <th>Result File</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH table IN both %]
                                <tr>
                                    <td><a href="[% c.uri_for('/admin/schema_compare/server') %]/[% server.name | uri %]/db/[% db.name | uri %]/table/[% table.name | uri %]">[% table.name | html %]</a></td>
                                    <td>[% table.row_count || 0 %]</td>
                                    <td>[% table.size %]</td>
                                    <td>[% table.result_name | html %]
                                        [% IF table.result_rel_path %]
                                            <a href="#" onclick="openAI2EditorWindow('[% table.result_rel_path | html %]');return false" class="btn btn-sm btn-secondary" title="Edit result file in AI editor"><i class="fas fa-edit"></i> Edit</a>
                                        [% END %]
                                    </td>
                                    <td class="action-cell">
                                        <button class="btn btn-sm btn-delete"
                                                data-action="drop-table"
                                                data-table="[% table.name | html %]"
                                                data-db="[% db.name | html %]"><i class="fas fa-trash"></i> Drop</button>
                                    </td>
                                </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                    [% ELSE %]
                    <p class="text-muted">No tables with matching result files.</p>
                    [% END %]
                </div>
            </div>

            <!-- Section 2: Tables without Result files -->
            <div class="comparison-section">
                <h3 class="section-toggle-h3" data-action="toggle-section">
                    <i class="fas fa-exclamation-triangle icon-warning"></i> Tables without Result files ([% table_only.size %])
                    <span class="toggle-hint">[click to toggle]</span>
                </h3>
                <div class="section-content">
                    [% IF table_only.size %]
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Table Name</th>
                                    <th>Rows</th>
                                    <th>Size</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH table IN table_only %]
                                <tr>
                                    <td>[% table.name | html %]</td>
                                    <td>[% table.row_count || 0 %]</td>
                                    <td>[% table.size %]</td>
                                    <td class="action-cell">
                                        <button class="btn btn-sm btn-secondary"
                                                data-action="create-result-from-table"
                                                data-table="[% table.name | html %]"
                                                data-db="[% db.name | html %]"><i class="fas fa-file-alt"></i> Create Result</button>
                                        <button class="btn btn-sm btn-delete"
                                                data-action="drop-table"
                                                data-table="[% table.name | html %]"
                                                data-db="[% db.name | html %]"><i class="fas fa-trash"></i> Drop</button>
                                    </td>
                                </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                    [% ELSE %]
                    <p class="text-muted">All tables have corresponding result files.</p>
                    [% END %]
                </div>
            </div>

            <!-- Section 3: Result files without tables -->
            <div class="comparison-section">
                <h3 class="section-toggle-h3" data-action="toggle-section">
                    <i class="fas fa-file-code icon-info"></i> Result files without tables ([% result_only.size %])
                    <span class="toggle-hint">[click to toggle]</span>
                </h3>
                <div class="section-content">
                    [% IF result_only.size %]
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Result Name</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH res IN result_only %]
                                <tr>
                                    <td>[% res.result_name | html %]
                                        [% IF res.result_rel_path %]
                                            <a href="#" onclick="openAI2EditorWindow('[% res.result_rel_path | html %]');return false" class="btn btn-sm btn-secondary" title="Edit result file in AI editor"><i class="fas fa-edit"></i> Edit</a>
                                        [% END %]
                                    </td>
                                    <td class="action-cell">
                                        <button class="btn btn-sm btn-primary"
                                                data-action="create-table-from-result"
                                                data-result-name="[% res.result_name | html %]"
                                                data-db="[% db.name | html %]"
                                                data-fetch-url="[% fetch_url %]"><i class="fas fa-plus"></i> Create Table</button>
                                    </td>
                                </tr>
                                [% END %]
                            </tbody>
                        </table>
                    </div>
                    [% ELSE %]
                    <p class="text-muted">No orphaned result files.</p>
                    [% END %]
                </div>
            </div>

        </div>
    </div>

    <div class="page-footer">
        <div class="footer-actions">
            <a href="[% c.uri_for('/admin/schema_compare/server') %]/[% server.name | uri %]" class="btn btn-secondary">← Back to Databases</a>
        </div>
    </div>
</div>