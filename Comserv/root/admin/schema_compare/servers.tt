[%# Schema Compare - Server List (top level)
    Shows server groups with their database counts and status.
    Clicking a server tunnels to its DB list.
    JS via schema-compare.js (event delegation on data-action attributes)
%]
<div class="schema-servers" data-base-url="[% c.uri_for('/admin/schema_compare/server') %]" data-refresh-url="[% c.uri_for('/admin/schema_compare/refresh_server') %]">
    <!-- Fixed summary card -->
    <div class="card mb-3 border servers-summary-card">
        <div class="card-body py-2">
            <strong>Configured Database Servers:</strong> [% server_count %] 
            ([% servers.map('name').join(', ') %])
        </div>
    </div>

    <!-- Horizontal server cards -->
    <div class="server-grid">
        [% FOREACH server IN servers %]
        <div class="card border server-card"
             data-action="navigate-server"
             data-server="[% server.server_group | html %]">
            <div class="card-body">
                <h5 class="card-title server-card-title">
                    <i class="fas fa-server me-2"></i>[% server.name | html %]
                </h5>
                <p class="card-text mb-1 server-card-text">
                    <strong>Databases:</strong> [% server.db_count %]
                </p>
                <p class="card-text mb-1 server-card-text">
                    <strong>Types:</strong> [% server.type_display || '—' %]
                </p>
                <p class="card-text mb-1 server-card-text">
                    <strong>Status:</strong> <span class="server-status">[% server.status | ucfirst %]</span>
                </p>
                <button class="btn btn-sm btn-outline-primary refresh-btn" data-action="refresh-server" data-server="[% server.server_group | html %]">
                    <i class="fa fa-sync"></i> Refresh
                </button>
            </div>
        </div>
        [% END %]
    </div>
</div>