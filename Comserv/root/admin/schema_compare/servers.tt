[%# Schema Compare - Server List (top level)
    Shows active servers with container counts.
    Clicking a server tunnels to its DB list.
%]
<div class="schema-servers">
    <!-- Fixed summary card -->
    <div class="card mb-3 border" style="border-color: var(--border-color, #dee2e6); background: var(--bg-secondary, #f8f9fa);">
        <div class="card-body py-2">
            <strong>Configured Database Servers:</strong> [% server_count %] 
            (192.168.1.198, 192.168.1.199, 192.168.1.20, 192.168.1.21)
        </div>
    </div>

    <!-- Horizontal server cards -->
    <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
        [% FOREACH server IN servers %]
        <div class="card border" 
             style="border-color: var(--border-color, #dee2e6); background: var(--bg-secondary, #fff); cursor: pointer; width: auto; min-width: 220px;"
             data-server="[% server.name | html %]">
            <div class="card-body">
                <h5 class="card-title" style="color: var(--text-color, #212529);">
                    <i class="fas fa-server me-2"></i>[% server.name | html %]
                </h5>
                <p class="card-text mb-1" style="color: var(--text-color, #212529);">
                    <strong>Databases:</strong> [% server.db_count %]
                </p>
                <p class="card-text mb-1" style="color: var(--text-color, #212529);">
                    <strong>Types:</strong> [% server.type_display || '—' %]
                </p>
                <p class="card-text mb-1" style="color: var(--text-color, #212529);">
                    <strong>Status:</strong> <span class="server-status">[% server.status | ucfirst %]</span>
                </p>
                <p class="card-text mb-2" style="color: var(--text-color, #212529);">
                    <strong>Tables:</strong> <span class="table-count">[% server.table_count %]</span>
                </p>
                <button class="btn btn-sm btn-outline-primary refresh-btn" data-ip="[% server.ip %]">
                    <i class="fas fa-sync"></i> Refresh
                </button>
            </div>
        </div>
        [% END %]
    </div>
</div>

<script>
function loadServerDatabases(serverName) {
    window.location.href = '[% c.uri_for("/admin/schema_compare/server") %]/' + encodeURIComponent(serverName);
}

// Card click → navigate to database list (but NOT when clicking Refresh)
document.addEventListener('click', function(e) {
    const card = e.target.closest('.card');
    const refreshBtn = e.target.closest('.refresh-btn');

    if (refreshBtn) {
        // Refresh button clicked - handled by the refresh handler below
        return;
    }

    if (card && card.dataset.server) {
        const ip = card.dataset.server;
        window.location.href = '[% c.uri_for("/admin/schema_compare/server") %]/' + encodeURIComponent(ip);
    }
}, true);

// Live refresh handler (calls the new AJAX endpoint)
document.addEventListener('click', function(e) {
    const refreshBtn = e.target.closest('.refresh-btn');
    if (refreshBtn) {
        e.stopImmediatePropagation();
        e.preventDefault();
        const ip = refreshBtn.dataset.ip;
        refreshBtn.disabled = true;
        refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Checking...';

        fetch('/admin/schema_compare/refresh_server/' + encodeURIComponent(ip))
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    const card = refreshBtn.closest('.card');
                    card.querySelector('.server-status').textContent = data.status;
                    card.querySelector('.table-count').textContent = data.table_count;
                } else {
                    alert('Refresh failed: ' + (data.error || 'unknown'));
                }
            })
            .catch(err => alert('Network error: ' + err))
            .finally(() => {
                refreshBtn.disabled = false;
                refreshBtn.innerHTML = '<i class="fas fa-sync"></i> Refresh';
            });
        return false;
    }
}, true); // capture phase
</script>