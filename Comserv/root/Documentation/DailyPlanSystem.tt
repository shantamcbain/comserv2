    }
    
    .project-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-top: 15px;
    }
    
    .meta-item {
        background: rgba(255,255,255,0.1);
        padding: 10px;
        border-radius: 4px;
    }
    
    .phase-container {
        background: #f9f9f9;
        border-left: 4px solid var(--primary-color);
        padding: 15px;
        margin: 15px 0;
        border-radius: 4px;
    }
    
    .success-criteria {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 10px;
        margin: 15px 0;
    }
    
    .criteria-item {
        display: flex;
        align-items: center;
