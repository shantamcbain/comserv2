[% META
        title = "Degradation Pattern Detection - Operations Manual"
   description = "Monitoring, configuration, troubleshooting, and operational procedures for the degradation detection system"
   roles = "admin,developer"
   TemplateType = "Documentation"
   category = "operations"
   page_version = "1.0"
   last_updated = "Sun Nov  2 09:38:03 AM PST 2025"
   site_specific = "false"
%]
[% PageVersion = 'Documentation/degradation_operations_manual.tt,v 1.0 09:38:03 2025-11-02 Zencoder Exp Zencoder - Degradation Pattern Operations' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">Degradation Pattern Detection - Operations Manual</h1>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2025-11-02 | 
        Version: 1.0 | 
        Author: Zencoder | 
        Status: Production Operations
    </div>

    <div class="row">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Overview</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);">This manual provides operational procedures for monitoring, maintaining, and troubleshooting the Degradation Pattern Detection System. It covers daily monitoring tasks, common issues, resolution procedures, and performance optimization.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-50">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">System Status Check</h2>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>Real-time status display</li>
                <li>Anomaly detection status</li>
                <li>Tool restriction levels</li>
                <li>Counter file state</li>
            </ul>
        </div>
        <div class="col-50">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Performance Metrics</h2>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>Script execution time</li>
                <li>Anomaly frequency patterns</li>
                <li>Session degradation trends</li>
                <li>Tool restriction applications</li>
            </ul>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Daily Monitoring</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Check System Status</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Verify the detection system is running correctly:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
# Check counter file exists and is valid YAML
ls -la /Comserv/root/Documentation/session_history/.prompt_counter
cat /Comserv/root/Documentation/session_history/.prompt_counter

# Check audit log for entries
tail -20 /Comserv/root/Documentation/session_history/audit_log.json

# Verify script exists and is executable
ls -la /Comserv/root/Documentation/session_history/detect_degradation_patterns.pl

# Run quick status check
perl /Comserv/root/Documentation/session_history/detect_degradation_patterns.pl \
  /Comserv/root/Documentation/session_history/audit_log.json \
  /Comserv/root/Documentation/session_history/.prompt_counter
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Review Anomaly Patterns</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Identify recurring anomaly patterns in recent sessions:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
# Count anomaly occurrences in current session
grep "Caution Reasons:" -A 10 current_session.md

# Extract file repeats from counter
perl -e '
  use YAML;
  my $counter = YAML::LoadFile(".prompt_counter");
  my $status = $counter->{current_status};
  foreach my $reason (@{$status->{caution_reasons}}) {
    print "$reason\n";
  }
'

# Monitor status transitions over time
tail -50 audit_log.json | grep "status_level"
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Monitor Counter File Changes</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Track how status changes throughout sessions:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
# Watch counter file for changes (every 5 seconds)
watch -n 5 'cat /Comserv/root/Documentation/session_history/.prompt_counter'

# Monitor prompt progression
perl -e '
  use YAML;
  while (1) {
    my $counter = YAML::LoadFile(".prompt_counter");
    my $prompt = $counter->{prompt_tracking}{current_prompt};
    my $status = $counter->{current_status}{status_level};
    print "Prompt: $prompt | Status: $status\n";
    sleep 1;
  }
'
                </code></pre>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Troubleshooting Guide</h2>
            
            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large);">Issue: Script Exits with Error "Cannot load counter file"</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Symptoms:</strong> Script fails immediately, counter file not readable</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Causes:</strong> YAML::XS not installed, permission denied, corrupted YAML syntax</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong></p>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Check YAML module: <code>perl -MYAML -e 'print "OK\n"'</code></li>
                    <li>Verify permissions: <code>ls -la .prompt_counter</code> (should be readable by AI process)</li>
                    <li>Validate YAML syntax: <code>perl -e 'use YAML; YAML::LoadFile(".prompt_counter")'</code></li>
                    <li>Reinstall if needed: <code>cpanm YAML::XS</code></li>
                </ul>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large);">Issue: "Invalid time window for file repeats" Error</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Symptoms:</strong> Script dies with validation error during detection</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Causes:</strong> Counter file has invalid or missing time_window_minutes (≤0 or undefined)</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong></p>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Check counter file: <code>cat .prompt_counter | grep time_window</code></li>
                    <li>Reset counter file: <code>rm .prompt_counter</code> (will auto-initialize on next run)</li>
                    <li>Manually fix: Edit .prompt_counter and set time_window_minutes to positive integer (default: 10, 15)</li>
                </ul>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large);">Issue: JSON Parse Errors in Audit Log</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Symptoms:</strong> "Failed to parse audit log entry" warnings, anomalies not detected properly</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Causes:</strong> Malformed JSON entries, invalid line breaks, missing fields</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong></p>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Validate audit log JSON: <code>perl -e 'use JSON; while(&lt;&gt;) { JSON::decode_json($_) or die "Invalid: $_" }'</code></li>
                    <li>Check formatting: Each entry must be valid JSON on a single line, terminated with newline</li>
                    <li>Remove malformed entries: <code>grep -E '^{' audit_log.json | head -5</code></li>
                    <li>Clear and restart if corrupted: <code>rm audit_log.json</code> (will start fresh)</li>
                </ul>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--info-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--info-color); font-family: var(--header-font); font-size: var(--font-size-large);">Issue: Status Not Updating (Stuck at Same Level)</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Symptoms:</strong> Status always shows "NORMAL" despite anomalies, or status never changes</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Causes:</strong> Audit log not being written, prompt counter not incrementing, time windows too large</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong></p>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Verify audit log is being written: <code>tail -5 audit_log.json</code> (should show recent entries)</li>
                    <li>Check current_prompt counter: <code>grep current_prompt .prompt_counter</code></li>
                    <li>Manually add test entry to audit log: <code>echo '{"action":"ViewFile","timestamp":'$(date +%s)',"file":"test.pm"}' >> audit_log.json</code></li>
                    <li>Adjust time windows if too conservative: Edit .prompt_counter, reduce time_window_minutes values</li>
                </ul>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--info-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--info-color); font-family: var(--header-font); font-size: var(--font-size-large);">Issue: Script Runs Slowly (Timeout)</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Symptoms:</strong> Script takes >5 seconds to execute, or appears hung</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Causes:</strong> Large audit log file, inefficient JSON parsing, file permissions issues</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong></p>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Check audit log size: <code>ls -lh audit_log.json</code> (archive if >100MB)</li>
                    <li>Archive old entries: <code>head -1000 audit_log.json > audit_log.archive.json && tail -100 audit_log.json > audit_log.json</code></li>
                    <li>Run with profiling: <code>perl -d:NYTProf detect_degradation_patterns.pl ... && nytprofhtml</code></li>
                    <li>Check system resources: <code>free -h && df -h</code></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Maintenance Tasks</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Weekly: Archive Audit Log</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Keep audit log manageable by archiving old entries weekly:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
#!/bin/bash
# Archive audit log (keep last 500 entries for analysis)
AUDIT_LOG="/Comserv/root/Documentation/session_history/audit_log.json"
ARCHIVE_DIR="/Comserv/root/Documentation/session_history/archives"

mkdir -p $ARCHIVE_DIR
DATE=$(date +%Y-%m-%d)

# Move old entries to archive
if [ $(wc -l < $AUDIT_LOG) -gt 500 ]; then
  KEEP=$(($(wc -l < $AUDIT_LOG) - 500))
  head -$KEEP $AUDIT_LOG >> $ARCHIVE_DIR/audit_log_$DATE.json
  tail -500 $AUDIT_LOG > $AUDIT_LOG.tmp && mv $AUDIT_LOG.tmp $AUDIT_LOG
fi

# Compress archive
gzip -q $ARCHIVE_DIR/audit_log_$DATE.json &
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Monthly: Run Full Test Suite</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Ensure all detection logic is still working correctly:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
# Run complete test suite
cd /Comserv
perl t/detect_degradation_patterns.t 2>&1 | tee test_results_$(date +%Y-%m-%d).log

# Verify 41/41 assertions pass
if grep -q "ok 7 - Test 7" test_results_*.log; then
  echo "✅ All tests passing"
else
  echo "❌ Test failures detected - review immediately"
fi
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Quarterly: Review Configuration</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Evaluate if thresholds and time windows need adjustment based on observed patterns:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
# Analyze anomaly frequency in recent sessions
perl -e '
  use JSON;
  use YAML;
  
  open my $fh, "<", "audit_log.json";
  my %anomalies = ();
  
  while (<$fh>) {
    my $entry = JSON::decode_json($_);
    $anomalies{$entry->{action}}++ if $entry->{action};
  }
  
  foreach (sort { $anomalies{$b} <=> $anomalies{$a} } keys %anomalies) {
    printf "%s: %d\n", $_, $anomalies{$_};
  }
'

# Compare with current thresholds and adjust if needed
cat .prompt_counter | grep -A 2 "anomaly_threshold"
                </code></pre>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Performance Optimization</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Optimize Audit Log Size</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>Archive entries older than 2 weeks</li>
                <li>Keep working audit log under 10,000 lines</li>
                <li>Use gzip compression for archives</li>
                <li>Consider log rotation if >100MB</li>
            </ul>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Tune Thresholds</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>If too many false positives: Increase anomaly_threshold from 3 to 4-5</li>
                <li>If missing real degradation: Decrease anomaly_threshold from 3 to 2</li>
                <li>Adjust time windows based on typical session duration</li>
                <li>Test changes with full test suite before deploying</li>
            </ul>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Enable Debug Logging</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Modify script to add debug output:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
# Add to script top for debug output
my $DEBUG = $ENV{DEBUG_DEGRADATION} || 0;

# In detection functions
if ($DEBUG) {
  warn "File '$file' checked " . scalar(@{$file_checks{$file}}) . " times\n";
  warn "Command '$cmd' executed " . scalar(@{$cmd_runs{$cmd}}) . " times\n";
}

# Run with debug enabled
DEBUG_DEGRADATION=1 perl detect_degradation_patterns.pl ...
                </code></pre>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Recovery Procedures</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Reset System to Initial State</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">If system becomes unresponsive or corrupted:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
# Stop any running detection processes
pkill -f detect_degradation_patterns

# Back up current state
cp .prompt_counter .prompt_counter.backup
cp audit_log.json audit_log.json.backup

# Reset counter file (will auto-initialize on next run)
rm .prompt_counter

# Clean audit log if corrupted
# WARNING: This loses all history - only if absolutely necessary
# rm audit_log.json

# Verify script still exists and is correct
ls -la /Comserv/root/Documentation/session_history/detect_degradation_patterns.pl

# Run tests to verify recovery
perl /Comserv/t/detect_degradation_patterns.t

# Restart system
perl /Comserv/root/Documentation/session_history/detect_degradation_patterns.pl \
  audit_log.json .prompt_counter
                </code></pre>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <div class="success" style="background-color: var(--light-color); border-left: 4px solid var(--success-color); padding: var(--spacing-medium); margin: var(--spacing-medium) 0;">
                <h2 style="color: var(--success-color); font-family: var(--header-font);">See Also</h2>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li><a href="/Documentation/operations/degradation_system_architecture" style="color: var(--link-color);">System Architecture - Technical Components</a></li>
                    <li><a href="/Documentation/operations/degradation_integration_guide" style="color: var(--link-color);">Integration Guide - Deployment Steps</a></li>
                    <li><a href="/Documentation/operations/degradation_api_reference" style="color: var(--link-color);">API Reference - State Files & Configuration</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <div style="margin-top: var(--spacing-large); padding-top: var(--spacing-medium); border-top: 1px solid var(--border-color); color: var(--text-muted-color); font-size: var(--font-size-small);">
                <p>For operational support or troubleshooting assistance, contact the system administration team.</p>
                <p><em>This documentation is part of the Comserv system. Procedures are based on production experience.</em></p>
            </div>
        </div>
    </div>
</div>