[% META 
   title = "Daily Plan - January 11, 2026 (Live Test: Active Tab Styling + Real Todos)"
   description = "Saturday Week 2: Improved daily plan interface with active tab background color (theme-compliant), text labels (no emoji/characters), real todos from Todo System, and next 5 Master Plan priorities, with add buttons pointing to todo page in new window"
   roles = "admin,developer,devops"
   TemplateType = "Documentation"
   category = "daily-plans,documentation,planning,audits"
   page_version = "0.10"
   last_updated = "Sat Jan 11 18:13:00 UTC 2026"
   site_specific = "false"
%]
[% PageVersion = 'root/Documentation/DailyPlans/Daily_Plans-2026-01-11.tt,v 0.10 2026/01/11 18:13:00 zencoder Exp - Jan 11 Add Button Fix: Updated both task buttons (Add Task to Plan and Add New Todo) to point to /todo/addtodo and open in new window' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<style>
    /* Sticky Header Styles */
    .daily-plan-header {
        position: sticky;
        top: 0;
        background-color: rgba(255, 255, 255, 0.98);
        border-bottom: 3px solid var(--primary-color);
        padding: 10px 15px;
        margin: -20px -20px 20px -20px;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .daily-plan-header h1 {
        margin: 0 0 5px 0;
        font-size: 1.4em;
        color: var(--text-color);
    }
    
    .header-nav {
        display: flex;
        gap: 20px;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85em;
    }
    
    .header-nav-links {
        display: flex;
        gap: 15px;
    }
    
    .header-nav-links a {
        color: var(--primary-color);
        text-decoration: none;
        padding: 5px 10px;
        border-radius: 3px;
    }
    
    .header-nav-links a:hover {
        background-color: var(--bg-secondary);
    }
    
    /* Tab Styles */
    .tab-navigation {
        display: flex;
        border-bottom: 2px solid #ddd;
        margin: 20px 0 0 0;
        gap: 5px;
    }
    
    .tab-button {
        padding: 12px 24px;
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 1em;
        font-weight: 500;
        color: var(--text-muted-color);
        border-bottom: 3px solid transparent;
        transition: all 0.2s ease;
    }
    
    .tab-button:hover {
        color: var(--text-color);
        background-color: #f5f5f5;
    }
    
    .tab-button.active {
        color: var(--text-color) !important;
        background-color: var(--bg-secondary) !important;
        border-bottom-color: var(--primary-color) !important;
        border-bottom-width: 4px !important;
        font-weight: bold;
    }
    
    .tab-content {
        display: none;
    }
    
    .tab-content.active {
        display: block;
    }
    
    /* Task List Styles */
    .task-list {
        background: #f9f9f9;
        border: 1px solid #ddd;
        border-radius: 4px;
        margin: 20px 0;
        overflow: hidden;
    }
    
    .task-list-header {
        padding: 15px;
        background: #f0f0f0;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        font-weight: bold;
    }
    
    .task-list-header:hover {
        background: #e8e8e8;
    }
    
    .task-list-toggle {
        font-size: 0.85em;
        background: var(--primary-color);
        color: white;
        padding: 4px 8px;
        border-radius: 3px;
        font-weight: bold;
        cursor: pointer;
    }
    
    .task-list-toggle.collapsed {
        background: #999;
    }
    
    /* Drag-and-drop styles */
    .task-item.dragging {
        opacity: 0.5;
        background: #f0f0f0;
    }
    
    .task-item.drag-over {
        border-top: 3px solid var(--primary-color);
        padding-top: 7px;
    }
    
    .task-item.sortable {
        cursor: move;
    }
    
    .task-list-items {
        padding: 10px;
    }
    
    .task-list-items.hidden {
        display: none;
    }
    
    .task-item {
        padding: 10px 15px;
        border-bottom: 1px solid #eee;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .task-item:last-child {
        border-bottom: none;
    }
    
    .task-item input[type="checkbox"] {
        cursor: pointer;
        width: 18px;
        height: 18px;
    }
    
    .task-label {
        flex: 1;
        cursor: pointer;
    }
    
    .task-label.completed {
        text-decoration: line-through;
        color: #999;
    }
    
    .task-add-button {
        padding: 10px 15px;
        background-color: var(--success-color);
        color: white;
        border: none;
        border-radius: 3px;
        cursor: pointer;
        font-size: 0.9em;
        margin: 10px 10px 0 10px;
    }
    
    .task-add-button:hover {
        background-color: #45a049;
    }
    
    /* Color coding for sources */
    .master-plan-header {
        background: linear-gradient(to right, #e3f2fd, #f0f0f0);
        border-left: 4px solid #2196f3;
    }
    
    .app-todos-header {
        background: linear-gradient(to right, #e8f5e9, #f0f0f0);
        border-left: 4px solid #4caf50;
    }
    
    .focus-area {
        background: #e3f2fd;
        border-left: 4px solid #2196f3;
        padding: 15px;
        border-radius: 4px;
        margin: 20px 0;
    }
</style>

<div class="container">
    <!-- Sticky Header with Navigation -->
    <div class="daily-plan-header">
        <h1>[DAILY PLAN] [% day_name %], [% month_name %] [% day %], [% year %]</h1>
        <div class="header-nav">
            <div class="header-nav-links">
                <span><strong>Status:</strong> Week 2 - Documentation complete</span>
                <span>|</span>
                [% IF today_date %]<a href="/Documentation/DailyPlans-[% today_date %]">[Jump to Today]</a>[% ELSE %]<a href="#today-work">[Jump to Today]</a>[% END %]
                <a href="/Documentation/MASTER_PLAN_COORDINATION" target="_blank">Master Plans</a>
                <a href="/Documentation">All Docs</a>
                <a href="/todo">Todo System</a>
            </div>
            <div style="text-align: right; color: var(--text-muted-color); font-size: 0.85em;">
                [% IF prev_date_str %]
                    <a href="/Documentation/DailyPlans-[% prev_date_str %]">← Prev Day ([% prev_month_day %])</a>
                    | Today ([% curr_month_day %]) |
                    <a href="/Documentation/DailyPlans-[% next_date_str %]">Next Day ([% next_month_day %]) →</a>
                [% ELSE %]
                    ← Prev Day | Today | Next Day →
                [% END %]
            </div>
        </div>
    </div>

    <!-- Tab Navigation -->
    <div class="tab-navigation">
        <button class="tab-button active" onclick="switchTab(event, 'today-work')">
            [TODAY'S WORK] (Active)
        </button>
        <button class="tab-button" onclick="switchTab(event, 'resources')">
            [RESOURCES & CONTEXT]
        </button>
        <button class="tab-button" onclick="switchTab(event, 'completed')">
            [COMPLETED] (3)
        </button>
    </div>

    <!-- TAB 1: TODAY'S WORK (Default) -->
    <div id="today-work" class="tab-content active">
        <div id="today-work-content">
            <div class="focus-area">
                <h3 style="margin-top: 0;">[TODAY'S FOCUS]</h3>
                <p>Documentation infrastructure complete. Audit infrastructure production-ready. Ready for next initiative: complete remaining 4 .tt files (Option A) OR resume file manager enhancement (Option B) OR new development work (Option C). See Master Plans section for details.</p>
            </div>

            <!-- Master Plan Priorities (Independent Dropdown) -->
            <div class="task-list">
                <div class="task-list-header master-plan-header" onclick="toggleTaskList(this)">
                    <span>[MASTER PLAN PRIORITIES] NEXT 5 ITEMS</span>
                    <span class="task-list-toggle">HIDE</span>
                </div>
                <div class="task-list-items" id="master-plan-items">
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-1">
                        <label for="task-mp-1" class="task-label">[1] A.3: Credentials Audit (CRITICAL - Quick Win) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-2">
                        <label for="task-mp-2" class="task-label">[2] B.3: Theme Handling (HIGH - Quick Win) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-3">
                        <label for="task-mp-3" class="task-label">[3] B.1: Docker Secrets (HIGH - Strategic) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-4">
                        <label for="task-mp-4" class="task-label">[4] B.2: Authentication Fixes (HIGH - Strategic) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-5">
                        <label for="task-mp-5" class="task-label">[5] E.1: AI Chat System Phase 1 (CRITICAL - Strategic) - Status: In Progress</label>
                    </div>
                </div>
                <button class="task-add-button" onclick="window.open('/todo/addtodo', '_blank')">+ Add Task to Plan</button>
            </div>

            <!-- App Todos for Today (Independent Dropdown) -->
            <div class="task-list">
                <div class="task-list-header app-todos-header" onclick="toggleTaskList(this)">
                    <span>[APP TODOS FOR TODAY] FROM TODO SYSTEM [% IF todos_for_today && todos_for_today.size %]([% todos_for_today.size %])[% END %]</span>
                    <span class="task-list-toggle">HIDE</span>
                </div>
                <div class="task-list-items" id="app-todo-items">
                    [% IF todos_for_today && todos_for_today.size %]
                        [% FOREACH todo IN todos_for_today %]
                            <div class="task-item">
                                <input type="checkbox" id="todo-[% todo.record_id %]">
                                <label for="todo-[% todo.record_id %]" class="task-label" style="flex: 1;">
                                    <a href="javascript:void(0)" onclick="window.open('/todo/details?record_id=[% todo.record_id %]', '_blank'); return false;" 
                                       style="color: var(--link-color); text-decoration: none; cursor: pointer;" 
                                       title="[% todo.subject || '(No subject)' %][% IF todo.description %] - [% todo.description | truncate(100) %][% END %]">
                                        <strong>[% todo.sitename || 'CSC' %]:</strong>
                                        [% todo.subject || '(No subject)' %]
                                        [% IF todo.priority %]<span style="color: #f0ad4e; margin-left: 10px;">(P[% todo.priority %])</span>[% END %]
                                    </a>
                                </label>
                            </div>
                        [% END %]
                    [% ELSE %]
                        <div style="padding: 15px; text-align: center; color: #666;">
                            <p>No todos scheduled for today.</p>
                            <p>Create a new todo for today using the button below.</p>
                        </div>
                    [% END %]
                </div>
                <button class="task-add-button" onclick="window.open('/todo/addtodo', '_blank')">+ Add New Todo from Todo System</button>
            </div>

            <div style="background: #fff3cd; border-left: 4px solid #ff9800; padding: 15px; border-radius: 4px; margin: 20px 0;">
                <h4 style="margin-top: 0;">Next Session Recommendations:</h4>
                <ol>
                    <li><strong>Option A (RECOMMENDED):</strong> Complete remaining 4 .tt files (CodeSearchIndex, AiModelConfig, DBSchemaManager, RemoteDB utilities) - Low effort, closes documentation</li>
                    <li><strong>Option B:</strong> Resume file manager enhancement from Sept planning - Medium-High effort</li>
                    <li><strong>Option C:</strong> Start new development initiative - Review recent fixes and identify next features</li>
                </ol>
            </div>
        </div>
    </div>

    <!-- TAB 2: RESOURCES & CONTEXT -->
    <div id="resources" class="tab-content">
        <h3>[RESOURCES & SUPPORTING CONTEXT]</h3>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0;">
            <div style="background: #f5f5f5; padding: 15px; border-radius: 4px;">
                <h4>Related Documentation</h4>
                <ul style="margin: 0; padding-left: 20px;">
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION" style="color: var(--primary-color);">Master Plan Coordination (v0.27)</a></li>
                    <li><a href="/Documentation/session_history/development_plan.md" style="color: var(--primary-color);">Development Plan (Current)</a></li>
                    <li><a href="/Documentation/SECURITY_REMEDIATION_PLAN" style="color: var(--primary-color);">Security Remediation Plan</a></li>
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION#system-features" style="color: var(--primary-color);">System Features Inventory</a></li>
                </ul>
            </div>

            <div style="background: #f5f5f5; padding: 15px; border-radius: 4px;">
                <h4>Quick Links</h4>
                <ul style="margin: 0; padding-left: 20px;">
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION#improvements-tracker" style="color: var(--primary-color);">View Improvements Tracker</a> (5 issues)</li>
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION#dependency-map" style="color: var(--primary-color);">Check Dependencies</a></li>
                    <li><a href="/todo" style="color: var(--primary-color);">Open Todo System (Full View)</a></li>
                    <li><a href="/Documentation/DAILY_PLAN_LAYOUT_REDESIGN.md" style="color: var(--primary-color);">Daily Plan Design Notes</a> (NEW)</li>
                </ul>
            </div>
        </div>

        <h4>Daily Notes for Today:</h4>
        <div style="background: #f9f9f9; border: 1px solid #ddd; border-radius: 4px; padding: 15px; min-height: 150px;">
            <p><em>No notes yet for today. Click to add notes about today's work...</em></p>
        </div>
    </div>

    <!-- TAB 3: COMPLETED TASKS -->
    <div id="completed" class="tab-content">
        <h3>[COMPLETED TASKS] TODAY (3)</h3>
        
        <div style="background: #d4edda; border-left: 4px solid #28a745; padding: 15px; border-radius: 4px; margin: 20px 0;">
            <h4 style="margin-top: 0;">Summary</h4>
            <p><strong>3 major tasks completed today.</strong> Documentation synchronization cycle finished. Master plans updated with completion status and next session options. Application audit found 5 infrastructure issues (documented in improvements tracker). Documentation infrastructure now production-ready for deployment.</p>
        </div>

        <!-- Task 1 -->
        <div style="background: #f0f0f0; padding: 15px; border-radius: 4px; margin: 20px 0; border-left: 4px solid #28a745;">
            <h4 style="margin-top: 0;">[COMPLETED] Task 1: Documentation Synchronization (Chats 51-54)</h4>
            <p><strong>Status: COMPLETE</strong> - Fixed audit script circular dependency and synchronized 13 documentation files. Audit infrastructure now production-ready.</p>
            <div style="background: white; padding: 10px; border-radius: 3px; margin: 10px 0;">
                <strong>What Was Done:</strong>
                <ul style="margin: 5px 0; padding-left: 20px; font-size: 0.95em;">
                    <li><strong>Chat 51:</strong> Fixed documentation_sync_audit.pl bugs (removed .tt file detection, corrected version defaults)</li>
                    <li><strong>Chat 52:</strong> Consolidated 6 .tt files with version bumps (Root, SchemaComparison, Grok, Ollama, RemoteDB, WebSearchResult)</li>
                    <li><strong>Chat 53:</strong> Fixed critical circular dependency (script checking all git sources instead of committed-only)</li>
                    <li><strong>Chat 54:</strong> Validated bilateral audit trail workflow (validation_step0.pl, updateprompt.pl, ask_questions)</li>
                </ul>
            </div>
            <div style="background: white; padding: 10px; border-radius: 3px;">
                <strong>Results:</strong>
                <ul style="margin: 5px 0; padding-left: 20px; font-size: 0.95em;">
                    <li>✅ Audit script: Production-ready (zero false positives)</li>
                    <li>✅ 13 .tt files: Consolidated with version increments + Recent Changes sections</li>
                    <li>✅ 4 NEW .tt files: Ready for creation (audit-identified)</li>
                    <li>✅ Documentation queue: CLEAR (0 files pending)</li>
                    <li>✅ Bilateral audit trail: Validated and logged (90+ prompts)</li>
                </ul>
            </div>
        </div>

        <!-- Task 2 -->
        <div style="background: #f0f0f0; padding: 15px; border-radius: 4px; margin: 20px 0; border-left: 4px solid #28a745;">
            <h4 style="margin-top: 0;">✅ Task 2: Master Plans Update (v0.27)</h4>
            <p><strong>Status: COMPLETE</strong> - Updated master planning documents with documentation sync completion status and reset for future work.</p>
            <div style="background: white; padding: 10px; border-radius: 3px;">
                <strong>Files Updated:</strong>
                <ul style="margin: 5px 0; padding-left: 20px; font-size: 0.95em;">
                    <li><strong>development_plan.md:</strong> Added Chats 51-54 completion details, reset with 3 options for next session</li>
                    <li><strong>MASTER_PLAN_COORDINATION.tt:</strong> v0.26 → v0.27, updated status, daily plan link refreshed</li>
                </ul>
            </div>
        </div>

        <!-- Task 3 -->
        <div style="background: #f0f0f0; padding: 15px; border-radius: 4px; margin: 20px 0; border-left: 4px solid #28a745;">
            <h4 style="margin-top: 0;">✅ Task 3: Application Log Audit & Issues Identification</h4>
            <p><strong>Status: COMPLETE</strong> - Reviewed application.log, server.log, and build.log. Found 5 issues. All documented in improvements tracker for prioritization.</p>
            <div style="background: white; padding: 10px; border-radius: 3px;">
                <strong>5 Issues Found:</strong>
                <ul style="margin: 5px 0; padding-left: 20px; font-size: 0.95em;">
                    <li><strong>#1 Missing CPAN Modules (HIGH):</strong> Catalyst::View::Email & Catalyst::View::Email::Template - affects email functionality</li>
                    <li><strong>#2 Escape Sequence (MEDIUM):</strong> \d in Admin/SchemaComparison.pm:1690 - Perl warning</li>
                    <li><strong>#3 Missing DB Table (MEDIUM):</strong> documentation_role_access - will self-create on first admin request</li>
                    <li><strong>#4 Orphan Docker (LOW):</strong> comserv-database - clean with --remove-orphans</li>
                    <li><strong>#5 Port Conflict (LOW):</strong> Port 3000 - kill stale process</li>
                </ul>
            </div>
            <p><a href="/Documentation/MASTER_PLAN_COORDINATION#improvements-tracker" style="color: var(--primary-color);">View full details in Improvements Tracker</a></p>
        </div>
    </div>
</div>

<div style="color: var(--text-muted-color); font-size: var(--font-size-small); margin-top: 40px; padding: 20px; border-top: 1px solid #ddd;">
    <p><strong>Daily Plan v0.04 | Saturday January 11, 2026 | LIVE TEST: New Tabbed Layout</strong></p>
    <p>This page is a live test of the improved daily plan interface. Feedback welcome. Design spec: <a href="/Documentation/DAILY_PLAN_LAYOUT_REDESIGN.md" style="color: var(--primary-color);">DAILY_PLAN_LAYOUT_REDESIGN.md</a></p>
</div>

<script>
// Global drag variable
let draggedElement = null;

function switchTab(event, tabName) {
    // Hide all tab contents
    const contents = document.querySelectorAll('.tab-content');
    contents.forEach(content => content.classList.remove('active'));
    
    // Deactivate all tab buttons
    const buttons = document.querySelectorAll('.tab-button');
    buttons.forEach(button => button.classList.remove('active'));
    
    // Show selected tab and activate button
    const selectedTab = document.getElementById(tabName);
    if (selectedTab) {
        selectedTab.classList.add('active');
    }
    event.target.classList.add('active');
}

function toggleTaskList(header) {
    const taskList = header.nextElementSibling;
    const toggle = header.querySelector('.task-list-toggle');
    
    if (taskList) {
        taskList.classList.toggle('hidden');
        
        // Update toggle text
        if (toggle) {
            toggle.textContent = taskList.classList.contains('hidden') ? 'SHOW' : 'HIDE';
        }
    }
}

// Drag and drop handlers
function handleDragStart(event) {
    draggedElement = event.currentTarget;
    event.currentTarget.classList.add('dragging');
    event.dataTransfer.effectAllowed = 'move';
}

function handleDrag(event) {
    // Keep drag active
}

function handleDragOver(event) {
    event.preventDefault();
    event.dataTransfer.dropEffect = 'move';
    
    if (event.currentTarget !== draggedElement) {
        event.currentTarget.classList.add('drag-over');
    }
}

function handleDragLeave(event) {
    event.currentTarget.classList.remove('drag-over');
}

function handleDrop(event) {
    event.preventDefault();
    event.currentTarget.classList.remove('drag-over');
    
    if (draggedElement !== event.currentTarget) {
        // Get the parent list
        const draggedParent = draggedElement.parentNode;
        const targetParent = event.currentTarget.parentNode;
        
        // Only allow reordering within same list
        if (draggedParent === targetParent) {
            // Reorder by swapping elements
            targetParent.insertBefore(draggedElement, event.currentTarget);
        }
    }
}

function handleDragEnd(event) {
    draggedElement.classList.remove('dragging');
    
    // Remove all drag-over classes
    const allItems = document.querySelectorAll('.task-item');
    allItems.forEach(item => item.classList.remove('drag-over'));
}

function openTodoSystem(date) {
    // This would redirect to the app's Todo system with the date pre-filled
    // For now, just alert the user
    alert('Button would open Todo system for date: ' + date);
}
</script>
