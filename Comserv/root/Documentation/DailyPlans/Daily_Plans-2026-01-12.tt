                    <span class="task-list-toggle">HIDE</span>
                </div>
                <div class="task-list-items" id="master-plan-items">
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-1">
                        <label for="task-mp-1" class="task-label">[1] A.3: Credentials Audit (CRITICAL - Quick Win) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-2">
                        <label for="task-mp-2" class="task-label">[2] B.3: Theme Handling (HIGH - Quick Win) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-3">
                        <label for="task-mp-3" class="task-label">[3] B.1: Docker Secrets (HIGH - Strategic) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-4">
                        <label for="task-mp-4" class="task-label">[4] B.2: Authentication Fixes (HIGH - Strategic) - Status: Planning</label>
                    </div>
                    <div class="task-item sortable" draggable="true" ondragstart="handleDragStart(event)" ondrag="handleDrag(event)" ondrop="handleDrop(event)" ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)" ondragend="handleDragEnd(event)">
                        <input type="checkbox" id="task-mp-5">
                        <label for="task-mp-5" class="task-label">[5] E.1: AI Chat System Phase 1 (CRITICAL - Strategic) - Status: In Progress</label>
                    </div>
                </div>
                <button class="task-add-button" onclick="window.open('/todo/addtodo', '_blank')">+ Add Task to Plan</button>
            </div>

            <!-- App Todos for Today (Independent Dropdown) -->
            <div class="task-list">
                <div class="task-list-header app-todos-header" onclick="toggleTaskList(this)">
                    <span>[APP TODOS FOR TODAY] FROM TODO SYSTEM</span>
                    <span class="task-list-toggle">HIDE</span>
                </div>
                <div class="task-list-items" id="app-todo-items">
                    <div style="padding: 15px; text-align: center; color: #666;">
                        <p>Todos for today are loaded from the Todo System.</p>
                        <p>View and manage your daily tasks in the Todo System.</p>
                        <p style="margin-top: 10px; font-size: 0.9em; color: #999;">[Dynamic todo list will appear here when Todo System integration is complete]</p>
                    </div>
                </div>
                <button class="task-add-button" onclick="window.open('/todo/addtodo', '_blank')">+ Add New Todo from Todo System</button>
            </div>

            <div style="background: #fff3cd; border-left: 4px solid #ff9800; padding: 15px; border-radius: 4px; margin: 20px 0;">
                <h4 style="margin-top: 0;">Recommended Actions for Today:</h4>
                <ol>
                    <li><strong>Start Master Plan Item A.3 (Credentials Audit):</strong> Quick win that will improve security posture. Estimated 2-4 hours.</li>
                    <li><strong>Alternative: B.3 (Theme Handling):</strong> If A.3 blocked, shift to B.3 for quality improvement.</li>
                    <li><strong>Check Todo System:</strong> Review any blocking issues from previous session and resolve before starting Master Plan work.</li>
                </ol>
            </div>
        </div>
    </div>

    <!-- TAB 2: RESOURCES & CONTEXT -->
    <div id="resources" class="tab-content">
        <h3>[RESOURCES & SUPPORTING CONTEXT]</h3>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0;">
            <div style="background: #f5f5f5; padding: 15px; border-radius: 4px;">
                <h4>Related Documentation</h4>
                <ul style="margin: 0; padding-left: 20px;">
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION.tt" style="color: var(--primary-color);">Master Plan Coordination (Current)</a></li>
                    <li><a href="/Documentation/session_history/development_plan.md" style="color: var(--primary-color);">Development Plan (Current)</a></li>
                    <li><a href="/Documentation/SECURITY_REMEDIATION_PLAN.tt" style="color: var(--primary-color);">Security Remediation Plan</a></li>
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION.tt#system-features" style="color: var(--primary-color);">System Features Inventory</a></li>
                </ul>
            </div>

            <div style="background: #f5f5f5; padding: 15px; border-radius: 4px;">
                <h4>Quick Links</h4>
                <ul style="margin: 0; padding-left: 20px;">
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION.tt#improvements-tracker" style="color: var(--primary-color);">View Improvements Tracker</a></li>
                    <li><a href="/Documentation/MASTER_PLAN_COORDINATION.tt#dependency-map" style="color: var(--primary-color);">Check Dependencies</a></li>
                    <li><a href="/todo" style="color: var(--primary-color);">Open Todo System (Full View)</a></li>
                    <li><a href="/Documentation/DailyPlans" style="color: var(--primary-color);">View All Daily Plans</a></li>
                </ul>
            </div>
        </div>

        <h4>Daily Notes for Today:</h4>
        <div style="background: #f9f9f9; border: 1px solid #ddd; border-radius: 4px; padding: 15px; min-height: 150px;">
            <p><em>No notes yet for today. Click to add notes about today's work...</em></p>
        </div>
    </div>

    <!-- TAB 3: COMPLETED TASKS -->
    <div id="completed" class="tab-content">
        <h3>[COMPLETED TASKS] TODAY (0)</h3>
        
        <div style="background: #e8f4f8; border-left: 4px solid #2196f3; padding: 15px; border-radius: 4px; margin: 20px 0;">
            <h4 style="margin-top: 0;">Summary</h4>
            <p><strong>Day has just started.</strong> Focus on selecting one Master Plan item and executing it to completion. Check blocking issues in Todo System before beginning.</p>
        </div>
    </div>
</div>

<script>
function switchTab(evt, tabName) {
    var i, tabcontent, tabbuttons;
    tabcontent = document.getElementsByClassName("tab-content");
    for (i = 0; i < tabcontent.length; i++) {
        tabcontent[i].classList.remove("active");
    }
    tabbuttons = document.getElementsByClassName("tab-button");
    for (i = 0; i < tabbuttons.length; i++) {
        tabbuttons[i].classList.remove("active");
    }
    document.getElementById(tabName).classList.add("active");
    evt.currentTarget.classList.add("active");
}

function toggleTaskList(element) {
    var items = element.nextElementSibling;
    var toggle = element.querySelector('.task-list-toggle');
    if (items.classList.contains('hidden')) {
        items.classList.remove('hidden');
        toggle.textContent = 'HIDE';
        toggle.classList.remove('collapsed');
    } else {
        items.classList.add('hidden');
        toggle.textContent = 'SHOW';
        toggle.classList.add('collapsed');
    }
}

function handleDragStart(e) {
    e.dataTransfer.effectAllowed = 'move';
    e.target.classList.add('dragging');
}

function handleDrag(e) {
    e.dataTransfer.dropEffect = 'move';
}

function handleDragOver(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    if (e.target.classList.contains('task-item')) {
        e.target.classList.add('drag-over');
    }
}

function handleDragLeave(e) {
    if (e.target.classList.contains('task-item')) {
        e.target.classList.remove('drag-over');
    }
}

function handleDrop(e) {
    e.preventDefault();
    var dragging = document.querySelector('.task-item.dragging');
    if (e.target.classList.contains('task-item') && e.target !== dragging) {
        e.target.parentNode.insertBefore(dragging, e.target);
    }
    e.target.classList.remove('drag-over');
}

function handleDragEnd(e) {
    e.target.classList.remove('dragging');
    var items = document.querySelectorAll('.task-item.drag-over');
    items.forEach(item => item.classList.remove('drag-over'));
}
</script>
