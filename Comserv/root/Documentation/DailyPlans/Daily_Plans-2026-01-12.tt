<style>
    /* Sticky Header Styles */
    .daily-plan-header {
        position: sticky;
        top: 0;
        background-color: rgba(255, 255, 255, 0.98);
        border-bottom: 3px solid var(--primary-color);
        padding: 10px 15px;
        margin: -20px -20px 20px -20px;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .daily-plan-header h1 {
        margin: 0 0 5px 0;
        font-size: 1.4em;
        color: var(--text-color);
    }
    
    .header-nav {
        display: flex;
        gap: 20px;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85em;
    }
    
    .header-nav-links {
        display: flex;
        gap: 15px;
    }
    
    .header-nav-links a {
        color: var(--primary-color);
        text-decoration: none;
        padding: 5px 10px;
        border-radius: 3px;
    }
    
    .header-nav-links a:hover {
        background-color: var(--bg-secondary);
    }
    
    /* Tab Styles */
    .tab-navigation {
        display: flex;
        border-bottom: 2px solid #ddd;
        margin: 20px 0 0 0;
        gap: 5px;
    }
    
    .tab-button {
        padding: 12px 24px;
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 1em;
        font-weight: 500;
        color: var(--text-muted-color);
        border-bottom: 3px solid transparent;
        transition: all 0.2s ease;
    }
    
    .tab-button:hover {
        color: var(--text-color);
        background-color: #f5f5f5;
    }
    
    .tab-button.active {
        color: var(--text-color) !important;
        background-color: var(--bg-secondary) !important;
        border-bottom-color: var(--primary-color) !important;
        border-bottom-width: 4px !important;
        font-weight: bold;
    }
    
    .tab-content {
        display: none;
    }
    
    .tab-content.active {
        display: block;
    }
    
    /* Task List Styles */
    .task-list {
        background: #f9f9f9;
        border: 1px solid #ddd;
        border-radius: 4px;
        margin: 20px 0;
        overflow: hidden;
    }
    
    .task-list-header {
        padding: 15px;
        background: #f0f0f0;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        font-weight: bold;
    }
    
    .task-list-header:hover {
        background: #e8e8e8;
    }
    
    .task-list-toggle {
        font-size: 0.85em;
        background: var(--primary-color);
        color: white;
        padding: 4px 8px;
        border-radius: 3px;
        font-weight: bold;
        cursor: pointer;
    }
    
    .task-list-toggle.collapsed {
        background: #999;
    }
    
    /* Drag-and-drop styles */
    .task-item.dragging {
        opacity: 0.5;
        background: #f0f0f0;
    }
    
    .task-item.drag-over {
        border-top: 3px solid var(--primary-color);
        padding-top: 7px;
    }
    
    .task-item.sortable {
        cursor: move;
    }
    
    .task-list-items {
        padding: 10px;
    }
    
    .task-list-items.hidden {
        display: none;
    }
    
    .task-item {
        padding: 10px 15px;
        border-bottom: 1px solid #eee;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .task-item:last-child {
        border-bottom: none;
    }
    
    .task-item input[type="checkbox"] {
        cursor: pointer;
        width: 18px;
        height: 18px;
    }
    
    .task-label {
        flex: 1;
        cursor: pointer;
    }
    
    .task-label.completed {
        text-decoration: line-through;
        color: #999;
    }
    
    .task-add-button {
        padding: 10px 15px;
        background-color: var(--success-color);
        color: white;
        border: none;
        border-radius: 3px;
        cursor: pointer;
        font-size: 0.9em;
        margin: 10px 10px 0 10px;
    }
    
    .task-add-button:hover {
        background-color: #45a049;
    }
    
    /* Color coding for sources */
    .master-plan-header {
        background: linear-gradient(to right, #e3f2fd, #f0f0f0);
        border-left: 4px solid #2196f3;
    }
    
    .app-todos-header {
        background: linear-gradient(to right, #e8f5e9, #f0f0f0);
        border-left: 4px solid #4caf50;
    }
    
    .focus-area {
        background: #e3f2fd;
        border-left: 4px solid #2196f3;
        padding: 15px;
        border-radius: 4px;
        margin: 20px 0;
    }
</style>

<div class="container">
