        <h3>Result Class Pattern Reference (From Existing Classes)</h3>
        <p>Example pattern from <code>AiMessage.pm</code>:</p>
        <pre><code>package Comserv::Model::Schema::Ency::Result::AiMessage;
use base 'DBIx::Class::Core';
use warnings FATAL => 'all';

__PACKAGE__->table('ai_messages');
__PACKAGE__->add_columns(
    id => { data_type => 'integer', is_auto_increment => 1 },
    conversation_id => { data_type => 'integer', is_nullable => 0 },
    role => { data_type => 'enum', extra => { list => ['user', 'assistant'] } },
    content => { data_type => 'text', is_nullable => 0 },
    created_at => { data_type => 'timestamp', default_value => \'CURRENT_TIMESTAMP' },
);

__PACKAGE__->set_primary_key('id');

__PACKAGE__->belongs_to(
    'conversation' => 'Comserv::Model::Schema::Ency::Result::AiConversation',
    { 'foreign.id' => 'self.conversation_id' }
);

sub is_user_message { my $self = shift; return $self->role eq 'user'; }

1;</code></pre>
    </div>

