[% META
    title = 'Admin Controller - System Management'
    description = 'Comprehensive documentation for the Admin controller including system status, database schema management, service control, backup/restore, software updates, and diagnostics'
    roles = 'admin'
    TemplateType = 'controller'
    category = 'controllers'
    page_version = '1.10'
    last_updated = '2026-01-05'
    site_specific = ''
%]

[% PageVersion = 'Documentation/Admin.tt,v 1.10 2026/01/05 zencoder-docsync Exp ' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h1 id="admin-controller">Admin  - System Management</h1>
            
            <div id="toc" class="alert alert-info">
                <strong>Contents:</strong>
                <ul style="margin: 10px 0 0 20px;">
                    <li><a href="#overview">Overview</a></li>
                    <li><a href="#dashboard">Dashboard & System Status</a></li>
                    <li><a href="#schema-management">Database Schema Management</a></li>
                    <li><a href="#service-management">Service Management (Starman)</a></li>
                    <li><a href="#backup-restore">Backup & Restore</a></li>
                    <li><a href="#software-updates">Software Updates & Deployment</a></li>
                    <li><a href="#diagnostics">Diagnostics & System Health</a></li>
                    <li><a href="#methods-reference">Methods Reference</a></li>
                </ul>
            </div>
            
            <section id="overview">
                <h2>Overview</h2>
                <p>
                    The <code>Admin</code> controller (Comserv/lib/Comserv/Controller/Admin.pm) provides comprehensive 
                    system administration capabilities for Comserv. It handles:
                </p>
                <ul>
                    <li>System monitoring and dashboard</li>
                    <li>Database schema management and synchronization</li>
                    <li>Service (Starman) control and diagnostics</li>
                    <li>Backup creation and file restoration</li>
                    <li>Software updates via Git and deployment</li>
                    <li>System health monitoring and notifications</li>
                </ul>
                <p>
                    <strong>Authentication:</strong> All admin actions require admin role authentication via 
                    <code>AdminAuth</code> utility. Access denied users are redirected to login page.
                </p>
            </section>
            
            <section id="dashboard">
                <h2>Dashboard & System Status</h2>
                
                <h3>Admin Index (<code>index</code>)</h3>
                <p><strong>Route:</strong> <code>GET /admin</code></p>
                <p>
                    Main admin dashboard displaying:
                </p>
                <ul>
                    <li><strong>System Statistics:</strong> User count, disk usage, memory usage, uptime, load average</li>
                    <li><strong>Database Info:</strong> Database size, table counts, Git commits, application version</li>
                    <li><strong>Recent Activity:</strong> Last 10 user logins and content changes</li>
                    <li><strong>System Notifications:</strong> Pending registrations, low disk space, pending comments</li>
                    <li><strong>Software Status:</strong> Current Git branch, uncommitted changes, deployment status</li>
                </ul>
                
                <h3>Helper Methods</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>get_system_stats($c)</code></td>
                        <td>Collects disk usage, memory, uptime, load average, Git info, database statistics</td>
                    </tr>
                    <tr>
                        <td><code>get_recent_activity($c)</code></td>
                        <td>Returns last 10 user logins and content changes from database</td>
                    </tr>
                    <tr>
                        <td><code>get_system_notifications($c)</code></td>
                        <td>Checks for pending registrations, low disk space, pending comments</td>
                    </tr>
                    <tr>
                        <td><code>get_software_management_status($c)</code></td>
                        <td>Git status, uncommitted changes, deployment readiness</td>
                    </tr>
                </table>
            </section>
            
            <section id="schema-management">
                <h2>Database Schema Management</h2>
                
                <p>
                    The Admin controller includes multiple methods for managing database schema synchronization 
                    between MySQL database tables and Perl DBIx::Class Result classes.
                </p>
                
                <h3>Primary Schema Management Endpoints</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Route</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>db_status</code></td>
                        <td><code>GET /admin/db-status</code></td>
                        <td>Display current database status and information</td>
                    </tr>
                    <tr>
                        <td><code>schema_manager</code></td>
                        <td><code>GET /admin/schema_manager</code></td>
                        <td>Central interface for all schema operations</td>
                    </tr>
                    <tr>
                        <td><code>database_config</code></td>
                        <td><code>GET /admin/database-config</code></td>
                        <td>Display and manage database configuration</td>
                    </tr>
                    <tr>
                        <td><code>compare_schema</code></td>
                        <td><code>POST /admin/compare_schema</code></td>
                        <td>Compare database tables vs Result classes</td>
                    </tr>
                </table>
                
                <h3>Schema Synchronization Methods</h3>
                <p>These methods handle syncing between database and code:</p>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Action</th>
                    </tr>
                    <tr>
                        <td><code>sync_fields</code></td>
                        <td>Synchronize individual field definitions</td>
                    </tr>
                    <tr>
                        <td><code>sync_table_to_result</code></td>
                        <td>Create/update Result class from database table</td>
                    </tr>
                    <tr>
                        <td><code>sync_result_to_table</code></td>
                        <td>Create/update database table from Result class</td>
                    </tr>
                    <tr>
                        <td><code>batch_sync_table</code></td>
                        <td>Batch synchronize multiple tables</td>
                    </tr>
                    <tr>
                        <td><code>get_table_schema</code></td>
                        <td>Retrieve table structure from database</td>
                    </tr>
                    <tr>
                        <td><code>get_field_comparison</code></td>
                        <td>Compare specific field definitions</td>
                    </tr>
                </table>
                
                <div class="alert alert-warning" style="margin-top: 15px;">
                    <strong>⚠ Schema Migration Best Practices:</strong>
                    <ul>
                        <li>Always create database backup before schema changes (<code>Emergency Restore</code>)</li>
                        <li>Test migrations in development environment first</li>
                        <li>Review schema comparison results before applying changes</li>
                        <li>Document all schema modifications for audit trail</li>
                    </ul>
                </div>
            </section>
            
            <section id="service-management">
                <h2>Service Management (Starman)</h2>
                
                <p>
                    The Admin controller provides web-safe methods to manage the Starman application server 
                    using sudo commands.
                </p>
                
                <h3>Service Control Methods</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Route</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>restart_starman</code></td>
                        <td><code>GET/POST /admin/restart_starman</code></td>
                        <td>Restart Starman service with sudo credentials</td>
                    </tr>
                    <tr>
                        <td><code>starman_diagnostics</code></td>
                        <td><code>GET/POST /admin/starman_diagnostics</code></td>
                        <td>Run comprehensive Starman diagnostics</td>
                    </tr>
                </table>
                
                <h3>Service Control Implementation</h3>
                <p><strong>Process:</strong></p>
                <ol>
                    <li>User provides sudo username and password via web form</li>
                    <li>Credentials passed to <code>execute_starman_restart()</code></li>
                    <li>Temporary shell script created with credentials</li>
                    <li>Script executes: <code>systemctl restart starman</code></li>
                    <li>Output displayed in web interface</li>
                    <li>Credentials cleared from memory after execution</li>
                </ol>
                
                <h3>Helper Methods</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>execute_starman_restart($c, $sudo_username, $sudo_password)</code></td>
                        <td>Execute systemctl restart via sudo, return success/output</td>
                    </tr>
                    <tr>
                        <td><code>_execute_sudo_command($sudo_password, $command)</code></td>
                        <td>Helper to execute arbitrary sudo commands with password</td>
                    </tr>
                    <tr>
                        <td><code>run_starman_diagnostics($c)</code></td>
                        <td>Comprehensive health check of Starman service</td>
                    </tr>
                    <tr>
                        <td><code>get_starman_service_manager($c)</code></td>
                        <td>Get service manager utility instance</td>
                    </tr>
                </table>
            </section>
            
            <section id="backup-restore">
                <h2>Backup & Emergency Restore</h2>
                
                <h3>Emergency Restore Endpoint</h3>
                <p><strong>Route:</strong> <code>GET /admin/emergency-restore</code></p>
                <p>
                    Provides interface to:
                </p>
                <ul>
                    <li>Scan backup directory for available backup files</li>
                    <li>List available backups with sizes and dates</li>
                    <li>Restore PSGI files from backups</li>
                    <li>Restore arbitrary files from backup archives</li>
                </ul>
                
                <h3>Backup/Restore Methods</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>get_backup_directory_contents($c)</code></td>
                        <td>List all backup files with metadata</td>
                    </tr>
                    <tr>
                        <td><code>scan_backup_directory($backup_dir)</code></td>
                        <td>Scan directory and return backup file details</td>
                    </tr>
                    <tr>
                        <td><code>restore_psgi_file($c, $backup_file, $psgi_filename)</code></td>
                        <td>Restore PSGI file from backup archive</td>
                    </tr>
                    <tr>
                        <td><code>restore_file_from_backup($c, $backup_file, $file_path)</code></td>
                        <td>Restore arbitrary file from backup tar archive</td>
                    </tr>
                </table>
                
                <div class="alert alert-info">
                    <strong>ℹ Backup Format:</strong> Backups are stored as tar archives. Restore operations 
                    extract files using <code>Archive::Tar</code>.
                </div>
            </section>
            
            <section id="software-updates">
                <h2>Software Updates & Deployment</h2>
                
                <h3>Software Update Interface</h3>
                <p><strong>Route:</strong> <code>GET/POST /admin/software-update</code></p>
                <p>
                    Complete software update and deployment interface with:
                </p>
                <ul>
                    <li>Check for available updates from Git remote</li>
                    <li>View pending commits before pulling</li>
                    <li>Execute Git pull with pre-update backup</li>
                    <li>Full deployment (dependencies + service restart)</li>
                    <li>Update history tracking</li>
                    <li>System requirements verification</li>
                </ul>
                
                <h3>Update Methods</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>software_update</code></td>
                        <td>Main update interface and workflow</td>
                    </tr>
                    <tr>
                        <td><code>check_available_updates($c)</code></td>
                        <td>Git fetch and check commits behind remote</td>
                    </tr>
                    <tr>
                        <td><code>execute_git_pull($c, $sudo_user, $sudo_pass)</code></td>
                        <td>Git pull with backup creation</td>
                    </tr>
                    <tr>
                        <td><code>execute_deployment($c, $sudo_user, $sudo_pass)</code></td>
                        <td>Full deployment: check deps, install, restart service</td>
                    </tr>
                    <tr>
                        <td><code>create_pre_update_backup($c)</code></td>
                        <td>Create backup before pulling updates</td>
                    </tr>
                    <tr>
                        <td><code>get_update_history($c)</code></td>
                        <td>Retrieve past update records</td>
                    </tr>
                    <tr>
                        <td><code>check_system_requirements($c)</code></td>
                        <td>Verify Perl, cpanm, Git availability</td>
                    </tr>
                </table>
                
                <h3>Deployment Workflow</h3>
                <pre><code>
1. Check current Git status (branch, uncommitted changes)
2. Create pre-update backup
3. Execute: git pull origin
4. Check available updates: commits behind remote
5. User confirms deployment
6. Step 1: Check Perl dependencies (Makefile.PL)
7. Step 2: Install missing dependencies (cpanm --installdeps)
8. Step 3: Restart Starman service via sudo
9. Display results and update history
                </code></pre>
            </section>
            
            <section id="diagnostics">
                <h2>Diagnostics & System Health</h2>
                
                <h3>System Health Check</h3>
                <p>
                    The Admin controller continuously monitors system health through several diagnostic methods.
                </p>
                
                <table class="table table-bordered">
                    <tr>
                        <th>Check Type</th>
                        <th>Details Collected</th>
                    </tr>
                    <tr>
                        <td>Disk Usage</td>
                        <td>Percentage used, used/total sizes, warning at 80%, critical at 90%</td>
                    </tr>
                    <tr>
                        <td>Memory Usage</td>
                        <td>Total, used, free memory from system</td>
                    </tr>
                    <tr>
                        <td>System Uptime</td>
                        <td>Days/hours up, load average (1, 5, 15 min)</td>
                    </tr>
                    <tr>
                        <td>Database</td>
                        <td>Database size in MB, table count, user count</td>
                    </tr>
                    <tr>
                        <td>Git Repository</td>
                        <td>Total commits, current version tag, branch</td>
                    </tr>
                    <tr>
                        <td>Starman Service</td>
                        <td>Service status (active/inactive), worker processes, memory usage</td>
                    </tr>
                </table>
                
                <h3>Diagnostics Methods</h3>
                <p><strong>Route:</strong> <code>GET/POST /admin/starman_diagnostics</code></p>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>get_starman_diagnostics_util($c)</code></td>
                        <td>Initialize diagnostics utility</td>
                    </tr>
                    <tr>
                        <td><code>run_starman_diagnostics($c)</code></td>
                        <td>Execute full diagnostic suite and return results</td>
                    </tr>
                </table>
            </section>
            
            <section id="methods-reference">
                <h2>Complete Methods Reference</h2>
                
                <h3>Authentication & Initialization</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Type</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>logging()</code></td>
                        <td>Private</td>
                        <td>Get logging utility instance</td>
                    </tr>
                    <tr>
                        <td><code>admin_auth()</code></td>
                        <td>Private</td>
                        <td>Get admin authentication utility instance</td>
                    </tr>
                    <tr>
                        <td><code>begin()</code></td>
                        <td>Private</td>
                        <td>Controller initialization - log entry, setup debug messages</td>
                    </tr>
                    <tr>
                        <td><code>base()</code></td>
                        <td>Action</td>
                        <td>Base chained action - check admin access, setup common data</td>
                    </tr>
                </table>
                
                <h3>Main Actions (Routed Endpoints)</h3>
                <table class="table table-bordered">
                    <tr>
                        <th>Method</th>
                        <th>Route</th>
                        <th>Args</th>
                        <th>Purpose</th>
                    </tr>
                    <tr>
                        <td><code>index</code></td>
                        <td>/admin</td>
                        <td>0</td>
                        <td>Admin dashboard with stats and notifications</td>
                    </tr>
                    <tr>
                        <td><code>db_status</code></td>
                        <td>/admin/db-status</td>
                        <td>0</td>
                        <td>Database status information</td>
                    </tr>
                    <tr>
                        <td><code>schema_manager</code></td>
                        <td>/admin/schema_manager</td>
                        <td>0</td>
                        <td>Central schema management interface</td>
                    </tr>
                    <tr>
                        <td><code>database_config</code></td>
                        <td>/admin/database-config</td>
                        <td>0</td>
                        <td>Database configuration display</td>
                    </tr>
                    <tr>
                        <td><code>restart_starman</code></td>
                        <td>/admin/restart_starman</td>
                        <td>0</td>
                        <td>Starman service restart interface</td>
                    </tr>
                    <tr>
                        <td><code>starman_diagnostics</code></td>
                        <td>/admin/starman_diagnostics</td>
                        <td>0</td>
                        <td>Starman diagnostics interface</td>
                    </tr>
                    <tr>
                        <td><code>software_update</code></td>
                        <td>/admin/software-update</td>
                        <td>0</td>
                        <td>Software update and deployment interface</td>
                    </tr>
                    <tr>
                        <td><code>emergency_restore</code></td>
                        <td>/admin/emergency-restore</td>
                        <td>0</td>
                        <td>Backup restoration interface</td>
                    </tr>
                </table>
                
                <h3>Schema Operations (All Forward to Schema Comparison Controller)</h3>
                <p>These methods delegate to the dedicated SchemaComparison controller:</p>
                <ul>
                    <li><code>compare_schema</code></li>
                    <li><code>get_table_schema</code></li>
                    <li><code>get_field_comparison</code></li>
                    <li><code>sync_fields</code></li>
                    <li><code>batch_sync_table</code></li>
                    <li><code>create_table_from_result</code></li>
                    <li><code>create_result_from_table</code></li>
                    <li><code>sync_table_to_result</code></li>
                    <li><code>sync_result_to_table</code></li>
                </ul>
            </section>
            
            <div class="last-updated" style="margin-top: 40px; padding: 10px; background-color: var(--background-color); border-left: 4px solid var(--primary-color); color: var(--text-color);">
                <strong>Last Updated:</strong> <span id="update-date">2026-01-05</span> (v1.10 - Comprehensive rewrite documenting all 40+ methods)
            </div>
        </div>
    </div>
</div>

<style>
