        <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: 25px;">Environment Variables (Docker Option)</h3>
        <p style="color: var(--text-color); font-family: var(--body-font);">
            If using environment variables instead of K8s Secrets (e.g., with docker-compose):
        </p>
        <pre style="background-color: #f5f5f5; padding: 15px; border: 1px solid #ddd; border-radius: 4px; overflow-x: auto;"><code style="color: #333;">
# Format: COMSERV_DB_{CONNECTION}_{FIELD}=value

# Example: Multiple database connections
COMSERV_DB_PRODUCTION_SERVER_HOST=192.168.1.198
COMSERV_DB_PRODUCTION_SERVER_PORT=3306
COMSERV_DB_PRODUCTION_SERVER_USERNAME=comserv_user
COMSERV_DB_PRODUCTION_SERVER_PASSWORD=secure_pass
COMSERV_DB_PRODUCTION_SERVER_DATABASE=comserv_db
COMSERV_DB_PRODUCTION_SERVER_DB_TYPE=mariadb

COMSERV_DB_SECONDARY_SERVER_HOST=192.168.1.199
COMSERV_DB_SECONDARY_SERVER_PORT=3306
COMSERV_DB_SECONDARY_SERVER_USERNAME=secondary_user
COMSERV_DB_SECONDARY_SERVER_PASSWORD=secondary_pass
COMSERV_DB_SECONDARY_SERVER_DATABASE=secondary_db
COMSERV_DB_SECONDARY_SERVER_DB_TYPE=mariadb
        </code></pre>

