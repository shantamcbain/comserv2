[% META
        title = "Kubernetes Secrets Setup & Configuration"
   description = "Complete guide to setting up Kubernetes Secrets for Comserv database credentials with automated logging and connection testing"
   roles = "admin,developer"
   TemplateType = "Documentation"
   category = "kubernetes,credentials,infrastructure"
   page_version = "1.01"
   last_updated = "Sun Dec 21 03:55:00 UTC 2025"
   site_specific = "false"
%]
[% PageVersion = 'root/Documentation/kubernetes/K8S_SECRETS_SETUP.tt,v 1.01 2025/12/21 shanta Exp - Enhanced template compliance: responsive grid layout, theme CSS variables, back-to-top links, styled See Also section' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">Kubernetes Secrets Setup & Configuration</h1>

    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2025-12-21 03:55 UTC |
        Version: 1.01 |
        Status: ✅ IMPLEMENTATION COMPLETE with comprehensive logging and connection testing |
        Maintained By: Zencoder Infrastructure Agent
    </div>

    <!-- Table of Contents -->
    <div class="row">
        <div class="col-100">
            <nav id="toc" style="margin: var(--spacing-large) 0; padding: var(--spacing-medium); background-color: rgba(255,255,255,0.15); border-left: 4px solid var(--primary-color); border-radius: 4px;">
                <h2 style="margin-top: 0; color: var(--text-color); font-family: var(--header-font);">Quick Navigation</h2>
                <ul style="list-style-type: none; padding-left: 0; color: var(--text-color); font-family: var(--body-font);">
                    <li><a href="#overview" style="color: var(--link-color);">Overview</a></li>
                    <li><a href="#configuration-sources" style="color: var(--link-color);">Configuration Sources (Priority Order)</a></li>
                    <li><a href="#setup-wizard" style="color: var(--link-color);">Using the K8s Secrets Setup Wizard</a></li>
                    <li><a href="#manual-creation" style="color: var(--link-color);">Manual K8s Secrets Creation</a></li>
                    <li><a href="#logging" style="color: var(--link-color);">Logging & Diagnostics</a></li>
                    <li><a href="#troubleshooting" style="color: var(--link-color);">Troubleshooting</a></li>
                    <li><a href="#verification" style="color: var(--link-color);">Verification Checklist</a></li>
                    <li><a href="#reference" style="color: var(--link-color);">Reference Information</a></li>
                    <li><a href="#see-also" style="color: var(--link-color);">See Also</a></li>
                </ul>
            </nav>
        </div>
    </div>

    <!-- OVERVIEW SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="overview" style="color: var(--text-color); font-family: var(--header-font);">Overview</h2>
        
            <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
                <strong>Kubernetes Secrets</strong> provide a secure way to store database credentials and sensitive configuration for Comserv applications running in Kubernetes environments.
            </p>

            <div style="background-color: rgba(255,255,255,0.15); border-left: 4px solid var(--primary-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0; border-radius: 4px;">
                <h3 style="margin-top: 0; color: var(--primary-color); font-family: var(--header-font);">Why K8s Secrets?</h3>
                <ul style="color: var(--text-color); font-family: var(--body-font); margin: var(--spacing-small) 0; line-height: 1.8;">
                    <li><strong>✓ Security</strong>: Credentials stored separately from code and containers</li>
                    <li><strong>✓ Automation</strong>: Automatic credential injection via K8s volume mounts</li>
                    <li><strong>✓ Flexibility</strong>: Support multiple databases per application instance</li>
                    <li><strong>✓ Auditability</strong>: All credential operations logged with timestamps and details</li>
                    <li><strong>✓ Redundancy</strong>: Secrets stored in multiple mount points for reliability</li>
                </ul>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- CONFIGURATION SOURCES SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="configuration-sources" style="color: var(--text-color); font-family: var(--header-font);">Configuration Sources (Priority Order)</h2>

            <p style="color: var(--text-color); font-family: var(--body-font);">
                Comserv checks configuration sources in priority order. The first source found is used. If none exist, the application redirects to the K8s secrets setup page.
            </p>

            <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-large) 0;">
                <thead>
                    <tr style="background-color: rgba(255,255,255,0.15);">
                        <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Priority</th>
                        <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Source</th>
                        <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Location</th>
                        <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Format</th>
                        <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-weight: bold;">1</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>Kubernetes Secrets</strong> (Primary)</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>/var/run/secrets/comserv/dbi/</code></td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">JSON files (one per connection)</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--success-color);"><strong>🟢 PRODUCTION READY</strong></td>
                    </tr>
                    <tr style="background-color: rgba(255,255,255,0.12);">
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-weight: bold;">1B</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>K8s Secrets</strong> (Fallback)</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>/opt/secrets/comserv/dbi/</code></td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">JSON files (one per connection)</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--success-color);"><strong>🟢 SUPPORTED</strong></td>
                    </tr>
                    <tr>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-weight: bold;">2</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>Environment Variables</strong></td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Docker/System ENV</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>COMSERV_DB_{CONNECTION}_{FIELD}=value</code></td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--warning-color);"><strong>🟡 DOCKER ONLY</strong></td>
                    </tr>
                    <tr style="background-color: rgba(255,255,255,0.12);">
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-weight: bold;">3</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>db_config.json</strong></td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>Comserv/db_config.json</code></td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">JSON with all connections</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--error-color);"><strong>❌ DEPRECATED</strong></td>
                    </tr>
                </tbody>
            </table>

            <div style="background-color: rgba(255,255,255,0.15); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0; border-radius: 4px;">
                <h4 style="margin-top: 0; color: var(--warning-color); font-family: var(--header-font);">⚠️ Migration Path</h4>
                <p style="color: var(--text-color); font-family: var(--body-font); margin: 0;">
                    <strong>db_config.json is DEPRECATED</strong> but still supported for backward compatibility. If you have an existing db_config.json:
                </p>
                <ol style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
                    <li>Navigate to <code>/setup/k8s-secrets</code> (development mode only)</li>
                    <li>Your db_config.json will be displayed in a table</li>
                    <li>Click "Create K8s Secrets from db_config.json" to migrate</li>
                    <li>Verify connection test results</li>
                    <li>Once working, you can safely remove db_config.json</li>
                </ol>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- SETUP WIZARD SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="setup-wizard" style="color: var(--text-color); font-family: var(--header-font);">Using the K8s Secrets Setup Wizard</h2>

            <p style="color: var(--text-color); font-family: var(--body-font);">
                The Setup Wizard (<code>/setup/k8s-secrets</code>) is available in development mode and provides three ways to create K8s secrets.
            </p>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Accessing the Setup Wizard</h3>
            <pre style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); border-radius: 4px; overflow-x: auto;"><code style="color: var(--text-color); font-family: monospace;">
# If you see the "Database configuration required" message:
# Click on "Configure K8s Secrets" link OR manually navigate to:
http://localhost:5000/setup/k8s-secrets

# For production, the wizard requires COMSERV_DEV_MODE environment variable:
export COMSERV_DEV_MODE=1
            </code></pre>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Option 1: Create from db_config.json</h3>
            <ol style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
                <li><strong>Automatically Displayed</strong>: All database connections from db_config.json appear in a table</li>
                <li><strong>Review</strong>: Verify all connection details (host, port, database, credentials)</li>
                <li><strong>Create</strong>: Click "Create K8s Secrets from db_config.json"</li>
                <li><strong>Automatic Testing</strong>: The system tests each connection and displays results</li>
                <li><strong>Logging</strong>: All actions logged to <code>root/log/application.log</code></li>
            </ol>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Option 2: Create from Form Input</h3>
            <ol style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
                <li><strong>No db_config.json?</strong> Use this option to manually enter database credentials</li>
                <li><strong>Fill Form</strong>: Enter database type, host, port, credentials, database name</li>
                <li><strong>Create</strong>: Click "Create K8s Secrets"</li>
                <li><strong>Testing</strong>: Automatic connection test after creation</li>
            </ol>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Option 3: Create .env File (Docker)</h3>
            <ol style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
                <li><strong>For Docker</strong>: Creates <code>.env.local</code> file with environment variables</li>
                <li><strong>Fill Form</strong>: Same as Option 2</li>
                <li><strong>Create</strong>: Click "Create .env File"</li>
                <li><strong>Usage</strong>: <code>source .env.local && docker-compose up</code></li>
            </ol>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- MANUAL CREATION SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="manual-creation" style="color: var(--text-color); font-family: var(--header-font);">Manual K8s Secrets Creation</h2>

            <p style="color: var(--text-color); font-family: var(--body-font);">
                If you prefer to create secrets manually (e.g., in production where the Setup Wizard is not available):
            </p>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Step 1: Create Secrets Directory</h3>
            <pre style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); border-radius: 4px; overflow-x: auto;"><code style="color: var(--text-color); font-family: monospace;">
# Primary location (recommended)
mkdir -p /var/run/secrets/comserv/dbi
chmod 700 /var/run/secrets/comserv/dbi

# Fallback location
mkdir -p /opt/secrets/comserv/dbi
chmod 700 /opt/secrets/comserv/dbi
            </code></pre>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Step 2: Create Secret Files</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">
                Create one JSON file per database connection:
            </p>
            <pre style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); border-radius: 4px; overflow-x: auto;"><code style="color: var(--text-color); font-family: monospace;">
# Example: /var/run/secrets/comserv/dbi/production_server.json
{
  "production_server": {
    "db_type": "mariadb",
    "host": "192.168.1.198",
    "port": 3306,
    "username": "comserv_user",
    "password": "secure_password_here",
    "database": "comserv_db",
    "description": "Production Database"
  }
}

# Repeat for each connection (e.g., secondary_server.json, cache.json, etc.)
            </code></pre>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Step 3: Set Proper Permissions</h3>
            <pre style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); border-radius: 4px; overflow-x: auto;"><code style="color: var(--text-color); font-family: monospace;">
# Restrict file permissions to 0600 (read/write for owner only)
chmod 600 /var/run/secrets/comserv/dbi/*.json
chmod 600 /opt/secrets/comserv/dbi/*.json
            </code></pre>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Step 4: Verify (Optional)</h3>
            <pre style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); border-radius: 4px; overflow-x: auto;"><code style="color: var(--text-color); font-family: monospace;">
# List created secrets
ls -la /var/run/secrets/comserv/dbi/
ls -la /opt/secrets/comserv/dbi/

# View a secret (for verification)
cat /var/run/secrets/comserv/dbi/production_server.json | jq .
            </code></pre>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- LOGGING SECTION -->
    <div style="margin: 30px 0;">
        <h2 id="logging" style="color: var(--text-color); font-family: var(--header-font);">Logging & Diagnostics</h2>

        <p style="color: var(--text-color); font-family: var(--body-font);">
            <strong>All K8s secrets operations are logged automatically</strong> with detailed context information for troubleshooting.
        </p>

        <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: 25px;">What Gets Logged?</h3>
        <ul style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
            <li><strong>Configuration Detection</strong>: Which source (K8s Secrets, env vars, db_config.json) was found</li>
            <li><strong>Secret Creation</strong>: Each file created with location and permissions</li>
            <li><strong>Connection Testing</strong>: Each connection test result (✓ or ✗) with full details</li>
            <li><strong>Errors</strong>: Permission issues, JSON parsing errors, connection failures</li>
            <li><strong>Setup Wizard Access</strong>: When setup page is accessed and by whom</li>
        </ul>

        <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: 25px;">Viewing Logs</h3>
        <pre style="background-color: #f5f5f5; padding: 15px; border: 1px solid #ddd; border-radius: 4px; overflow-x: auto;"><code style="color: #333;">
# View application logs
tail -f /home/shanta/PycharmProjects/comserv2/Comserv/root/log/application.log

# Search for K8s secrets operations
grep -i "k8s_secrets\|secret\|configuration" root/log/application.log

# Monitor in real-time during setup
tail -f root/log/application.log | grep -i secret
        </code></pre>

        <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: 25px;">Log Entry Format</h3>
        <pre style="background-color: #f5f5f5; padding: 15px; border: 1px solid #ddd; border-radius: 4px; overflow-x: auto;"><code style="color: #333;">
[2025-12-21 03:45:22] [Setup.pm:320] _create_k8s_secrets - Created K8s secret file: /opt/secrets/comserv/dbi/production_server.json (permissions: 0600)
[2025-12-21 03:45:23] [Setup.pm:388] _test_all_connections - ✓ Connection test PASSED for 'production_server' at 192.168.1.198:3306/comserv_db
        </code></pre>
    </div>

    <!-- TROUBLESHOOTING SECTION -->
    <div style="margin: 30px 0;">
        <h2 id="troubleshooting" style="color: var(--text-color); font-family: var(--header-font);">Troubleshooting</h2>

        <div style="background-color: #ffebee; border-left: 4px solid #d32f2f; padding: 15px; margin: 20px 0; border-radius: 4px;">
            <h3 style="margin-top: 0; color: #c62828;">Problem: "Cannot create directory" error</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Cause:</strong> Missing permissions to create <code>/opt/secrets/</code> or <code>/var/run/secrets/</code></p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong></p>
            <pre style="background-color: #f5f5f5; padding: 10px; border-radius: 3px;"><code style="color: #333;">
# Create directories with proper ownership
sudo mkdir -p /opt/secrets/comserv/dbi
sudo chmod 755 /opt/secrets
sudo chmod 755 /opt/secrets/comserv
sudo chmod 700 /opt/secrets/comserv/dbi

# For Docker containers, ensure volume mount:
# docker-compose.yml:
#   volumes:
#     - /opt/secrets/comserv/dbi:/opt/secrets/comserv/dbi:ro
            </code></pre>
        </div>

        <div style="background-color: #ffebee; border-left: 4px solid #d32f2f; padding: 15px; margin: 20px 0; border-radius: 4px;">
            <h3 style="margin-top: 0; color: #c62828;">Problem: Connection test fails after secret creation</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Cause:</strong> Database unreachable, invalid credentials, or firewall blocking</p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Diagnosis Steps:</strong></p>
            <ol style="color: var(--text-color); font-family: var(--body-font);">
                <li>Check application.log for detailed error message</li>
                <li>Verify database is running: <code>mysql -h 192.168.1.198 -P 3306 -u user -p</code></li>
                <li>Test network connectivity: <code>telnet 192.168.1.198 3306</code></li>
                <li>Verify credentials are correct</li>
                <li>Check firewall rules (may need to allow port 3306 from container IP range)</li>
            </ol>
        </div>

        <div style="background-color: #ffebee; border-left: 4px solid #d32f2f; padding: 15px; margin: 20px 0; border-radius: 4px;">
            <h3 style="margin-top: 0; color: #c62828;">Problem: Application still redirects to setup page after creating secrets</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Cause:</strong> RemoteDB not reloading configuration</p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong> Restart the application container</p>
            <pre style="background-color: #f5f5f5; padding: 10px; border-radius: 3px;"><code style="color: #333;">
# Docker
docker restart comserv_web_1

# Kubernetes
kubectl delete pod -l app=comserv

# Development (Perl)
pkill starman
perl script/comserv_server.pl
            </code></pre>
        </div>

        <div style="background-color: #ffebee; border-left: 4px solid #d32f2f; padding: 15px; margin: 20px 0; border-radius: 4px;">
            <h3 style="margin-top: 0; color: #c62828;">Problem: "K8s configuration tool is only available in development mode"</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Cause:</strong> Setup Wizard requires dev mode (security restriction)</p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong> In production, create secrets manually using the steps in "Manual K8s Secrets Creation" section above</p>
        </div>
    </div>

    <!-- VERIFICATION SECTION -->
    <div style="margin: 30px 0;">
        <h2 id="verification" style="color: var(--text-color); font-family: var(--header-font);">Verification Checklist</h2>

        <p style="color: var(--text-color); font-family: var(--body-font);">
            After creating K8s secrets, verify everything is working correctly:
        </p>

        <div style="background-color: #e8f5e9; border: 1px solid #4caf50; padding: 15px; margin: 20px 0; border-radius: 4px;">
            <h3 style="margin-top: 0; color: #388e3c;">Verification Steps</h3>
            <ol style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
                <li>
                    <strong>✓ Secrets Directory Exists</strong>
                    <pre style="background-color: #f5f5f5; padding: 8px; border-radius: 3px; margin: 5px 0;"><code style="color: #333;">ls -la /var/run/secrets/comserv/dbi/
ls -la /opt/secrets/comserv/dbi/</code></pre>
                    Should list JSON files for each database connection
                </li>
                <li>
                    <strong>✓ Secrets Have Correct Permissions</strong>
                    <pre style="background-color: #f5f5f5; padding: 8px; border-radius: 3px; margin: 5px 0;"><code style="color: #333;">stat /var/run/secrets/comserv/dbi/production_server.json</code></pre>
                    Should show permissions: -rw------- (0600)
                </li>
                <li>
                    <strong>✓ Application Loads Secrets</strong>
                    <p style="margin: 5px 0;">Access application home page - should NOT redirect to /setup/k8s-secrets</p>
                </li>
                <li>
                    <strong>✓ Logs Show Success</strong>
                    <pre style="background-color: #f5f5f5; padding: 8px; border-radius: 3px; margin: 5px 0;"><code style="color: #333;">grep -i "k8s_secrets_found\|configuration loaded" root/log/application.log</code></pre>
                    Should show "K8s Secrets FOUND" or similar success messages
                </li>
                <li>
                    <strong>✓ Connection Testing</strong>
                    <p style="margin: 5px 0;">Check application.log for "✓ Connection test PASSED" messages for each database</p>
                </li>
                <li>
                    <strong>✓ Application Features Work</strong>
                    <p style="margin: 5px 0;">Navigate to /todo, /admin, or other features that require database access</p>
                </li>
            </ol>
        </div>
    </div>

