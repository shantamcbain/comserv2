                </tr>
                <tr style="background-color: var(--secondary-color);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Reformat documentation_system.tt with proper META</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">File Standardization</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">High</td>
