    <!-- USAGE EXAMPLES SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="usage-examples" style="color: var(--text-color); font-family: var(--header-font);">Usage Examples</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font);">Example 1: Create Result File from Table</h3>
            <div style="background-color: var(--code-bg-color); padding: var(--spacing-medium); border-radius: 4px; overflow-x: auto; margin: var(--spacing-medium) 0;">
                <pre style="margin: 0; font-family: monospace; font-size: 12px;"><code>curl -X POST http://localhost:3000/schema-comparison/create_result_from_table \
  -H "Content-Type: application/json" \
  -d '{
    "table_name": "ai_model_config",
    "database": "ency"
  }'</code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: var(--spacing-large);">Example 2: Sync Table Field to Result</h3>
            <div style="background-color: var(--code-bg-color); padding: var(--spacing-medium); border-radius: 4px; overflow-x: auto; margin: var(--spacing-medium) 0;">
                <pre style="margin: 0; font-family: monospace; font-size: 12px;"><code>curl -X POST http://localhost:3000/schema-comparison/sync_table_to_result \
  -H "Content-Type: application/json" \
  -d '{
    "table_name": "ai_model_config",
    "field_name": "model_type",
    "database": "ency"
  }'</code></pre>
            </div>
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
