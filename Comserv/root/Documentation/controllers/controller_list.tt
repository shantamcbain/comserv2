                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: center;">✅ Documented</td>
                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>/lib/Comserv/Controller/Ve7tit.pm</code></td>
                    </tr>
                    <tr style="background-color: var(--secondary-color);">
                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Voip</td>
                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: center;">❌ Missing</td>
                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>/lib/Comserv/Controller/Voip.pm</code></td>
                    </tr>
                    <tr>
                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">WorkShop</td>
                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: center;">❌ Missing</td>
                        <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>/lib/Comserv/Controller/WorkShop.pm</code></td>
                    </tr>
                </tbody>
            </table>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- HOW TO ADD DOCUMENTATION SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="add-docs" style="color: var(--text-color); font-family: var(--header-font);">4. How to Add Documentation</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);">To add documentation for a controller that is marked as "Missing":</p>
            <ol style="color: var(--text-color); font-family: var(--body-font);">
                <li>Create a Template Toolkit file in the <code>/root/Documentation/controllers/</code> directory</li>
                <li>Name the file after the controller (e.g., <code>Root.tt</code> for the Root controller)</li>
                <li>Use the <code>DocumentationTtTemplate.tt</code> as your structural base</li>
                <li>Include the following standard sections:
                    <ul>
                        <li>Overview</li>
                        <li>Current Implemented Features</li>
                        <li>Methods Documentation</li>
                        <li>Access Control</li>
                        <li>Related Files</li>
                    </ul>
                </li>
                <li>Ensure META block contains all required fields</li>
                <li>Add CSS variables instead of inline styles</li>
                <li>Include TOC (Table of Contents) navigation</li>
            </ol>
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- DOCUMENTATION TEMPLATE SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="template" style="color: var(--text-color); font-family: var(--header-font);">5. Documentation Template</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);">Use this template as a starting point for new controller documentation:</p>
            
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0; overflow-x: auto;"><code>[% META
        title = "[Controller Name] Controller Documentation"
   description = "Description of controller purpose"
   roles = "admin,developer"
   TemplateType = "Documentation"
   category = "controllers"
   page_version = "0.01"
   last_updated = "Mon Jan 06 2026"
%]

[% PageVersion = 'controllers/[ControllerName].tt,v 0.01 2026/01/06 author Exp author - Initial documentation' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

&lt;div class="container"&gt;
    &lt;h1 style="color: var(--text-color); font-family: var(--header-font);"&gt;[Controller Name] Controller Documentation&lt;/h1&gt;
    
    &lt;div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);"&gt;
        Last Updated: 2026-01-06 | Version: 0.01 | Author: [Your Name] | Status: Active
    &lt;/div&gt;

    &lt;!-- TABLE OF CONTENTS SECTION --&gt;
    &lt;div id="toc" class="row" style="margin: var(--spacing-large) 0; background-color: var(--light-color); padding: var(--spacing-medium); border-left: 4px solid var(--primary-color); border-radius: 4px;"&gt;
        &lt;div class="col-100"&gt;
            &lt;h2 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;"&gt;Quick Navigation&lt;/h2&gt;
            &lt;div style="display: flex; flex-wrap: wrap; gap: var(--spacing-small);"&gt;
                &lt;a href="#overview" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;"&gt;Overview&lt;/a&gt;
                &lt;a href="#features" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;"&gt;Features&lt;/a&gt;
                &lt;a href="#methods" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;"&gt;Methods&lt;/a&gt;
            &lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;
    
    &lt;!-- OVERVIEW SECTION --&gt;
    &lt;div class="row"&gt;
        &lt;div class="col-100"&gt;
            &lt;h2 id="overview"&gt;1. Overview&lt;/h2&gt;
            &lt;p&gt;Description of controller purpose and functionality.&lt;/p&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- FOOTER SECTION -->
