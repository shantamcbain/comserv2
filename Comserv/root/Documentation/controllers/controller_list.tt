[% META
        title = "Controller Documentation Status"
   description = "Index of all Comserv controllers and their documentation status"
   roles = "admin,developer"
   TemplateType = "Documentation"
   category = "controllers"
   page_version = "0.01"
   last_updated = "Tue Jan 06 2026"
%]

[% PageVersion = 'controllers/controller_list.tt,v 0.01 2026/01/06 admin Exp admin - Converted from Markdown to DocumentationTtTemplate standards with HTML table and TOC navigation' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">Controller Documentation Status</h1>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-01-06 | 
        Version: 0.01 |
        Author: admin | 
        Status: Active
    </div>

    <!-- TABLE OF CONTENTS SECTION -->
    <div id="toc" class="row" style="margin: var(--spacing-large) 0; background-color: var(--light-color); padding: var(--spacing-medium); border-left: 4px solid var(--primary-color); border-radius: 4px;">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;">Quick Navigation</h2>
            <p style="color: var(--text-muted-color); font-family: var(--body-font); font-size: var(--font-size-small);">Jump to section:</p>
            <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-small);">
                <a href="#overview" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Overview</a>
                <a href="#controllers" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Controllers</a>
                <a href="#status-legend" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Status Legend</a>
                <a href="#add-docs" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Add Documentation</a>
                <a href="#template" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Template</a>
            </div>
        </div>
    </div>

    <!-- OVERVIEW SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="overview" style="color: var(--text-color); font-family: var(--header-font);">1. Overview</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);">This document provides a comprehensive index of all controllers in the Comserv application and tracks their documentation status. Use this reference to understand which controllers have been documented and which require additional documentation work.</p>
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- STATUS LEGEND SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="status-legend" style="color: var(--text-color); font-family: var(--header-font);">2. Status Legend</h2>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>✅ Documented</strong>: Controller has comprehensive documentation in the controllers directory</li>
                <li><strong>❌ Missing</strong>: Controller requires documentation to be created</li>
            </ul>
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

