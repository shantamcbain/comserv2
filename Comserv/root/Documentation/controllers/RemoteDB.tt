[% META
   title = "RemoteDB Controller"
   description = "Documentation for the RemoteDB controller managing remote database connections and operations in the Comserv system"
   roles = "admin,developer"
   TemplateType = "Documentation"
   category = "controllers"
   page_version = "0.01"
   last_updated = "2026-01-10"
   site_specific = "false"
%]
[% PageVersion = 'Documentation/controllers/RemoteDB.tt,v 0.01 2026/01/10 zencoder Exp - Initial documentation for RemoteDB controller' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">RemoteDB Controller</h1>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-01-10 | 
        Version: 0.01 |
        Author: Zencoder | 
        Status: New Documentation
    </div>

    <!-- TABLE OF CONTENTS SECTION -->
    <div id="toc" class="row" style="margin: var(--spacing-large) 0; background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border-left: 4px solid var(--primary-color); border-radius: 4px;">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;">Quick Navigation</h2>
            <p style="color: var(--text-muted-color); font-family: var(--body-font); font-size: var(--font-size-small);">Jump to section:</p>
            <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-small);">
                <a href="#overview" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">Overview</a>
                <a href="#prerequisites" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">Prerequisites</a>
                <a href="#features" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">Key Features</a>
                <a href="#getting-started" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">Getting Started</a>
                <a href="#advanced" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">Advanced Usage</a>
                <a href="#troubleshooting" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">Troubleshooting</a>
                <a href="#config-ref" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">Routes & Methods</a>
                <a href="#see-also" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: rgba(255,255,255,0.12); display: inline-block;">See Also</a>
            </div>
        </div>
    </div>

    <!-- OVERVIEW SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="overview" style="color: var(--text-color); font-family: var(--header-font);">1. Overview</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);">The RemoteDB controller manages connections to remote databases within the Comserv system. It provides functionality for adding, viewing, querying, and removing remote database connections, allowing administrators to interact with external databases through a web interface.</p>
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- PREREQUISITES & KEY FEATURES SECTION -->
    <div class="row">
        <div class="col-50">
            <h2 id="prerequisites" style="color: var(--text-color); font-family: var(--header-font);">2. Prerequisites</h2>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>Admin or developer role access</li>
                <li>DBI and database driver modules (DBD::mysql, DBD::Pg, etc.)</li>
                <li>Remote database server access (network connectivity)</li>
                <li>Valid credentials for target databases</li>
            </ul>
        </div>
        <div class="col-50">
            <h2 id="features" style="color: var(--text-color); font-family: var(--header-font);">3. Key Features</h2>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Multi-DB Support</strong>: MySQL, PostgreSQL, SQLite, Oracle</li>
                <li><strong>Connection Management</strong>: Add, test, and remove connections</li>
                <li><strong>Schema Exploration</strong>: View tables and column structures</li>
                <li><strong>Query Execution</strong>: Run custom SQL queries with safety checks</li>
                <li><strong>Configuration Persistence</strong>: Stores connections in db_config.json</li>
            </ul>
        </div>
    </div>

    <div class="row">
        <div class="col-100">
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- GETTING STARTED SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="getting-started" style="color: var(--text-color); font-family: var(--header-font);">4. Getting Started</h2>
            
            <h3 id="gs-step1" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">4.1 Accessing Remote DB Management</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Navigate to the remote database management interface:</p>
            
            <div style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>URL: /remotedb/index</code></pre>
            </div>

            <h3 id="gs-step2" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">4.2 Adding a New Connection</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">From the main page, click "Add Connection" and fill in:</p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>Connection name (unique identifier)</li>
                <li>Database type (MySQL, PostgreSQL, etc.)</li>
                <li>Host, port, database name</li>
                <li>Username and password</li>
            </ul>

            <h3 id="gs-step3" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">4.3 Exploring Database Structure</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Once connected, you can:</p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>View all tables in the database</li>
                <li>Examine table schemas (columns, types)</li>
                <li>Browse sample data (first 10 rows)</li>
            </ul>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- ADVANCED USAGE SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="advanced" style="color: var(--text-color); font-family: var(--header-font);">5. Advanced Usage</h2>
            
            <h3 id="adv-feature1" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">5.1 Executing Custom Queries</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Use the query interface to run custom SQL:</p>

            <div style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
SELECT column1, column2 FROM table_name WHERE condition;
UPDATE table_name SET column = value WHERE id = 1;
                </code></pre>
            </div>

            <h3 id="adv-integration" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">5.2 Configuration File Management</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">Connections are stored in db_config.json under 'remote_connections'. The controller automatically updates this file when connections are added or removed.</p>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- TROUBLESHOOTING SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="troubleshooting" style="color: var(--text-color); font-family: var(--header-font);">6. Troubleshooting</h2>
            
            <div class="warning" style="background-color: rgba(255,255,255,0.15); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="ts-issue1" style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Problem: Connection Failed</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Symptoms:</strong> Cannot establish database connection</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong> Verify host, port, credentials, and network connectivity. Check database server logs.</p>
            </div>

            <div style="background-color: rgba(255,255,255,0.15); border-left: 4px solid var(--info-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="ts-issue2" style="color: var(--info-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Problem: Query Execution Errors</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Symptoms:</strong> SQL queries fail with errors</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution:</strong> Ensure proper SQL syntax for the target database type. Check permissions and table existence.</p>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- ROUTES & METHODS REFERENCE SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="config-ref" style="color: var(--text-color); font-family: var(--header-font);">7. Routes & Methods Reference</h2>
            
            <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
                <tr>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Route</th>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Method</th>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Description</th>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">/remotedb/index</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">GET</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Main page showing configured connections</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.12);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">/remotedb/add</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">GET/POST</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Add new remote database connection</td>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">/remotedb/view/:conn_name</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">GET</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">View tables in a specific connection</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.12);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">/remotedb/table/:conn_name/:table</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">GET</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">View schema and sample data for a table</td>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">/remotedb/query/:conn_name</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">GET/POST</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Execute custom SQL queries</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.12);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">/remotedb/remove/:conn_name</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">GET</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Remove a database connection</td>
                </tr>
            </table>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- SEE ALSO SECTION -->
    <div class="row">
        <div class="col-100">
            <div id="see-also" class="success" style="background-color: rgba(255,255,255,0.15); border-left: 4px solid var(--success-color); padding: var(--spacing-medium); margin: var(--spacing-medium) 0;">
                <h2 style="color: var(--success-color); font-family: var(--header-font); margin-top: 0;">8. See Also</h2>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li><a href="/Documentation/Controllers" style="color: var(--link-color);">Controllers Documentation</a></li>
                    <li><a href="/Documentation/models/RemoteDB" style="color: var(--link-color);">RemoteDB Model</a></li>
                    <li><a href="/admin" style="color: var(--link-color);">Administrative Interface</a></li>
                </ul>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- FOOTER SECTION -->
    <div class="row">
        <div class="col-100">
            <div style="margin-top: var(--spacing-large); padding-top: var(--spacing-medium); border-top: 1px solid var(--border-color); color: var(--text-muted-color); font-size: var(--font-size-small);">
                <p>For technical support or questions about this controller, contact the system administrator.</p>
                <p><em>This documentation is part of the Comserv system.</em></p>
            </div>
        </div>
    </div>
</div>