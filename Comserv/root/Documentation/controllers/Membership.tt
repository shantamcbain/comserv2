                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>subscribe</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/subscribe</td>
