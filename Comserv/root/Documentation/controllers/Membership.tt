    <!-- CONTROLLER ADMIN -->
    <div id="controller-admin" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Comserv::Controller::Membership::Admin</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            Namespace: <code>/membership/admin</code> — requires <code>admin</code> or <code>site_admin</code> role. Checked in <code>auto</code> via <code>_require_admin</code>.
        </p>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Action</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">URL</th>
                </tr>
            </thead>
            <tbody>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>index</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>manage_plans</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/manage_plans</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>create_plan / edit_plan / delete_plan / toggle_plan</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/{action}</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>subscribers</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/subscribers</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>subscriber_details</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/subscriber_details/:id</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>grant_access / revoke_access</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/{action}</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>cost_tracking / add_cost</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/{action}</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>pricing</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/pricing</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>benefactor_contribution</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/benefactor_contribution</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>patreon_settings / paypal_settings</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/admin/{action}</td></tr>
            </tbody>
        </table>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- PAYMENT -->
    <div id="controller-payment" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Comserv::Controller::Payment</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            Namespace: <code>/payment</code> — app-wide, not membership-specific. Handles memberships, workshops, hosting, and any future payable entity via <code>payable_type</code> dispatch.
        </p>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Action</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Description</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>paypal_ipn</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Receives PayPal IPN, posts back to PayPal for verification, activates membership on success. Idempotent on transaction ID.</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>paypal_checkout</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Builds PayPal redirect URL for membership payment</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>paypal_return / paypal_cancel</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Landing pages after PayPal checkout completes or is cancelled</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>patreon_callback</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Exchanges Patreon OAuth2 code for token, links patron to user, updates membership</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>internal_checkout</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">SELECT FOR UPDATE on coin account, deducts coins, activates membership</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>buy_coins / paypal_coins_return</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">PayPal flow specifically for purchasing internal coins</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>success / failed</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Generic success/failure landing pages</td>
                </tr>
            </tbody>
        </table>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- CURRENCY -->
    <div id="controller-currency" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Comserv::Controller::Currency</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            Namespace: <code>/currency</code> — coin wallet management. All balance-changing actions run inside a DB transaction with <code>SELECT ... FOR UPDATE</code> to prevent concurrent race conditions.
        </p>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Action</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Access</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Description</th>
                </tr>
            </thead>
            <tbody>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>balance</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Logged-in user</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Shows current coin balance</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>history</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Logged-in user</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Full transaction history with balance_after snapshots</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>purchase</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Logged-in user</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Initiates PayPal checkout for coin purchase</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>transfer</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Logged-in user</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Transfer coins to another user (transactional, both accounts locked)</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>earn</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Admin only</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Admin grants coins to a user; logged for audit</td></tr>
            </tbody>
        </table>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- GATING -->
    <div id="gating" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Service Gating Integration</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            To gate any controller on a membership service, add to its <code>auto</code> method:
        </p>
        <div style="background-color: rgba(255,255,255,0.15); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0; border-radius: 4px;">
            <pre style="color: var(--text-color); font-family: monospace; margin: 0; overflow-x: auto;"><code>my $user_id = $c->session->{user_id};
unless ($user_id) {
    $c->response->redirect($c->uri_for('/user/login'));
    return 0;
}
my $site_id = $c->stash->{site_id} // $c->model('Site')->get_site_id($c);
my $has_access = eval { $c->model('Membership')->check_access($c, $user_id, 'SERVICE_NAME', $site_id) };
unless ($has_access) {
    $c->flash->{error_msg} = 'This feature requires a membership plan. Please upgrade.';
    $c->response->redirect($c->uri_for('/membership/plans'));
    return 0;
}</code></pre>
        </div>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6; margin-top: var(--spacing-medium);">
            Currently gated controllers:
        </p>
        <ul style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
            <li><code>Controller::Apiary</code> — service name: <code>'beekeeping'</code></li>
            <li><code>Controller::AI</code> — model list filtered by <code>get_allowed_ai_models()</code> (non-blocking: free users get a reduced list, not a hard block)</li>
        </ul>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- TEMPLATES -->
    <div id="templates" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Template Files</h2>
        <ul style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
            <li><code>root/membership/</code> — Index.tt, Plans.tt, PlanDetails.tt, Subscribe.tt, Account.tt, Upgrade.tt, Cancel.tt</li>
            <li><code>root/membership/admin/</code> — Index.tt, ManagePlans.tt, EditPlan.tt, Subscribers.tt, SubscriberDetails.tt, CostTracking.tt, AddCost.tt, Pricing.tt, PatreonSettings.tt, PaypalSettings.tt, BenefactorContribution.tt</li>
            <li><code>root/payment/</code> — PaypalMembershipCheckout.tt, PaypalReturn.tt, PatreonCallback.tt, PatreonCheckout.tt, InternalCheckout.tt, BuyCoins.tt, Success.tt, Failed.tt</li>
            <li><code>root/currency/</code> — Balance.tt, History.tt, Purchase.tt, Transfer.tt, Earn.tt</li>
        </ul>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- ENV -->
    <div id="env" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Environment Variables</h2>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Variable</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Required For</th>
                </tr>
            </thead>
            <tbody>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>PAYPAL_CLIENT_ID</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">PayPal checkout</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>PAYPAL_SECRET</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">PayPal IPN verification</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>PAYPAL_MODE</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>sandbox</code> or <code>live</code></td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>PATREON_CLIENT_ID</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Patreon OAuth2</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>PATREON_CLIENT_SECRET</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Patreon OAuth2</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>PATREON_REDIRECT_URI</code></td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Patreon OAuth2 callback</td></tr>
            </tbody>
        </table>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- TESTS -->
    <div id="tests" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Tests</h2>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Test File</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Tests</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Covers</th>
                </tr>
            </thead>
            <tbody>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">t/controller_Membership.t</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">19</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">can() checks, _is_admin role logic</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">t/controller_Membership_Admin.t</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">28</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">can() checks, _is_admin case-insensitivity</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">t/model_Membership.t</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">20</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">calculate_price (all 3 resolution paths), check_access guards, get_available_plans, get_allowed_ai_models</td></tr>
                <tr style="background-color: rgba(255,255,255,0.15);"><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">t/controller_Payment.t</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">32</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">_require_login, _apply_promo_discount (all discount types)</td></tr>
                <tr><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">t/controller_Currency.t</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">18</td><td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">_require_login, _is_admin role detection</td></tr>
            </tbody>
        </table>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            Run all membership tests: <code>prove Comserv/t/controller_Membership*.t Comserv/t/model_Membership.t Comserv/t/controller_Payment.t Comserv/t/controller_Currency.t</code>
        </p>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

</div>
