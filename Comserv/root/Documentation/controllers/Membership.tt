[% META
        title = "Membership Controller"
   description = "Technical reference for Comserv::Controller::Membership, Comserv::Controller::Membership::Admin, Comserv::Controller::Payment, Comserv::Controller::Currency, and Comserv::Model::Membership"
   roles = "developer,admin"
   TemplateType = "Documentation"
   category = "controllers"
   page_version = "1.0"
   last_updated = "2026-04-03"
   site_specific = "false"
%]
[% PageVersion = 'Documentation/controllers/Membership.tt,v 1.0 2026/04/03 shanta Exp shanta' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--primary-color); font-family: var(--header-font);">Membership System — Technical Reference</h1>

    <div style="color: var(--text-muted-color); font-size: var(--font-size-small); margin-bottom: var(--spacing-large);">
        Last Updated: 2026-04-03 | Version: 1.0 | Audience: Developers, AI assistants | Status: Active
    </div>

    <!-- TABLE OF CONTENTS -->
    <div id="toc" style="background-color: rgba(255,255,255,0.15); border: 1px solid var(--border-color); border-radius: 4px; padding: var(--spacing-large); margin-bottom: var(--spacing-large);">
        <h3 style="margin-top: 0; color: var(--primary-color);">Table of Contents</h3>
        <ul style="list-style-position: inside; color: var(--text-color);">
            <li><a href="#architecture" style="color: var(--link-color); text-decoration: none;">Architecture Overview</a></li>
            <li><a href="#database" style="color: var(--link-color); text-decoration: none;">Database Schema</a></li>
            <li><a href="#model" style="color: var(--link-color); text-decoration: none;">Comserv::Model::Membership</a></li>
            <li><a href="#controller-user" style="color: var(--link-color); text-decoration: none;">Comserv::Controller::Membership (User)</a></li>
            <li><a href="#controller-admin" style="color: var(--link-color); text-decoration: none;">Comserv::Controller::Membership::Admin</a></li>
            <li><a href="#controller-payment" style="color: var(--link-color); text-decoration: none;">Comserv::Controller::Payment</a></li>
            <li><a href="#controller-currency" style="color: var(--link-color); text-decoration: none;">Comserv::Controller::Currency</a></li>
            <li><a href="#gating" style="color: var(--link-color); text-decoration: none;">Service Gating Integration</a></li>
            <li><a href="#templates" style="color: var(--link-color); text-decoration: none;">Template Files</a></li>
            <li><a href="#env" style="color: var(--link-color); text-decoration: none;">Environment Variables</a></li>
            <li><a href="#tests" style="color: var(--link-color); text-decoration: none;">Tests</a></li>
        </ul>
    </div>

    <!-- ARCHITECTURE -->
    <div id="architecture" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Architecture Overview</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            The membership system is composed of four controllers, one business-logic model, and sixteen DBIx::Class result classes. All components are application-wide (not site-specific in code), but plan and pricing data is scoped per site via the <code>site_id</code> foreign key.
        </p>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Component</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Path</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Role</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Model::Membership</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>lib/Comserv/Model/Membership.pm</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Business logic: access checks, pricing, provisioning</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Controller::Membership</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>lib/Comserv/Controller/Membership.pm</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Member-facing pages: plans, subscribe, account, upgrade, cancel</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Controller::Membership::Admin</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>lib/Comserv/Controller/Membership/Admin.pm</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Admin pages: plan CRUD, subscribers, cost tracking, payment config</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Controller::Payment</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>lib/Comserv/Controller/Payment.pm</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">App-wide payment: PayPal IPN, Patreon OAuth2, internal coin checkout</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Controller::Currency</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>lib/Comserv/Controller/Currency.pm</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Coin wallet: balance, history, purchase, transfer, earn</td>
                </tr>
            </tbody>
        </table>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- DATABASE -->
    <div id="database" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Database Schema</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            DDL is in <code>Comserv/sql/membership_schema.sql</code>. Seed data (default plans) is in <code>Comserv/sql/membership_seed_data.sql</code>.
        </p>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Table</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Result Class</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Purpose</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>membership_plans</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">MembershipPlan</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Plan definitions with feature flags and AI model list</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>membership_plan_pricing</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">MembershipPlanPricing</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Regional price overrides (region_code or DEFAULT)</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>user_memberships</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">UserMembership</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Active and expired memberships linking user → plan → site</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>membership_service_access</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">MembershipServiceAccess</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Per-service access rows; checked at runtime by gate logic</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>payment_transactions</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">PaymentTransaction</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Unified payment audit trail (PayPal, Patreon, internal)</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>internal_currency_accounts</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">InternalCurrencyAccount</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Coin wallet per user; SELECT FOR UPDATE on mutations</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>internal_currency_transactions</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">InternalCurrencyTransaction</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Immutable coin ledger with balance_after snapshot</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>system_cost_tracking</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">SystemCostTracking</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Operational expenses per site and period</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>membership_promo_codes</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">MembershipPromoCode</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Discount codes (percent_off, fixed_amount, months_free)</td>
                </tr>
            </tbody>
        </table>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- MODEL -->
    <div id="model" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Comserv::Model::Membership</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            <code>lib/Comserv/Model/Membership.pm</code> — Catalyst::Model with Moose. Contains all business logic. Controllers call this model; they do not query the DB directly for membership decisions.
        </p>

        <h3 style="color: var(--text-color); font-family: var(--header-font);">Public Methods</h3>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Method</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Signature</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Returns</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>check_access</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>($c, $user_id, $service_name, $site_id)</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">1 if active access row exists, 0 otherwise</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>get_active_plan</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>($c, $user_id, $site_id)</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">UserMembership row with plan prefetched, or undef</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>get_available_plans</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>($c, $site_id)</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Arrayref of active MembershipPlan rows ordered by sort_order</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>calculate_price</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>($c, $plan, $region_code)</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Hashref: <code>{monthly, annual, currency}</code></td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>provision_services</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>($c, $membership)</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Writes membership_service_access rows from plan flags</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>expire_membership</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>($c, $membership_id)</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Deactivates service rows, sets grace_period_end</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>get_allowed_ai_models</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>($c, $user_id, $site_id)</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Arrayref of model name strings from plan's ai_models_allowed JSON</td>
                </tr>
            </tbody>
        </table>
        <p style="text-align: right; margin-top: var(--spacing-medium);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>

    <!-- CONTROLLER USER -->
    <div id="controller-user" style="margin-bottom: var(--spacing-large);">
        <h2 style="color: var(--primary-color); font-family: var(--header-font); border-bottom: 2px solid var(--border-color); padding-bottom: var(--spacing-small);">Comserv::Controller::Membership (User-Facing)</h2>
        <p style="color: var(--text-color); font-family: var(--body-font); line-height: 1.6;">
            Namespace: <code>/membership</code>
        </p>
        <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
            <thead>
                <tr style="background-color: var(--primary-color); color: white;">
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Action</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">URL</th>
                    <th style="padding: var(--spacing-small); border: 1px solid var(--border-color); text-align: left;">Template</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>index</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">membership/Index.tt</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>plans</code></td>
