                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>account</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/account</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">membership/Account.tt</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>upgrade</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/upgrade</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">membership/Upgrade.tt</td>
                </tr>
                <tr>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>cancel</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/cancel</td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">membership/Cancel.tt</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><code>autopay_settings</code></td>
                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">/membership/autopay_settings</td>
