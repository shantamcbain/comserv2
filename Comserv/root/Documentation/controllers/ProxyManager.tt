   site_specific = "false"
%]
[% PageVersion = 'Documentation/controllers/ProxyManager.tt,v 1.03 2026/01/09 DocumentationSyncAgent Exp DocumentationSyncAgent - Jan 9 Update: Bug fixes (sub redefinition), Docker/Redis infrastructure consolidation, comprehensive proxy/K8s refactoring sync' %]
