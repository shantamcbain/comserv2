    <!-- CORE METHODS SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="methods" style="color: var(--text-color); font-family: var(--header-font);">3. Core Methods</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">list_tables($c, $database)</h3>
            
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Purpose</strong>: List all tables in a specified database</p>
            
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Parameters</strong>:</p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><code>$c</code> - Catalyst context</li>
                <li><code>$database</code> - Database name ('ENCY' or 'FORAGER')</li>
            </ul>

            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Returns</strong>: Array of table names</p>

            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Example</strong>:</p>
            <div style="background-color: rgba(255,255,255,0.12); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>my @tables = $c->model('DBSchemaManager')->list_tables($c, 'ENCY');
# Returns: ['ai_messages', 'users', 'content', ...]
                </code></pre>
            </div>

            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Database Support</strong>:</p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>ENCY</strong>: Primary application database</li>
                <li><strong>FORAGER</strong>: Herbal/beekeeping database</li>
            </ul>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- USAGE PATTERNS SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="usage-patterns" style="color: var(--text-color); font-family: var(--header-font);">4. Usage Patterns</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Pattern 1: In a Controller (see <a href="/Documentation/Admin" target="_blank" style="color: var(--link-color);">Admin.tt</a>)</h3>
            <div style="background-color: rgba(255,255,255,0.12); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>package Comserv::Controller::Admin;
use base 'Catalyst::Controller';

sub schema_info : Local {
    my ( $self, $c ) = @_;
    
    my $schema_manager = $c->model('DBSchemaManager');
    my @tables = $schema_manager->list_tables($c, 'ENCY');
    
    $c->stash->{tables} = \@tables;
}
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Pattern 2: In a Model Method</h3>
            <div style="background-color: rgba(255,255,255,0.12); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>package Comserv::Model::CustomDB;

sub get_table_list {
    my ($self, $c) = @_;
    return $c->model('DBSchemaManager')->list_tables($c, 'ENCY');
}
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Pattern 3: During Application Initialization</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">DBSchemaManager is invoked automatically during Catalyst's startup phase via initialization methods.</p>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- BEST PRACTICES SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="best-practices" style="color: var(--text-color); font-family: var(--header-font);">5. Best Practices</h2>
            
            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">1. Always Use Catalyst Context</h3>
            <div style="background-color: rgba(255,255,255,0.12); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code># ✅ Good
my @tables = $schema_mgr->list_tables($c, 'ENCY');

# ❌ Bad - Missing context
my @tables = $schema_mgr->list_tables(undef, 'ENCY');
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">2. Handle Database Selection Carefully</h3>
            <div style="background-color: rgba(255,255,255,0.12); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code># ✅ Good - Clear database choice
if ($need_forager) {
    @tables = $schema_mgr->list_tables($c, 'FORAGER');
} else {
    @tables = $schema_mgr->list_tables($c, 'ENCY');
}

# ❌ Bad - Unclear which database
my @tables = $schema_mgr->list_tables($c, $db);
                </code></pre>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">3. Log Operations for Debugging</h3>
            <div style="background-color: rgba(255,255,255,0.12); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>$c->model('DBSchemaManager')->logging->log_with_details(
    $c, 'info', __FILE__, __LINE__, 'method_name', 
    "Listing tables for database: ENCY"
);
                </code></pre>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- TROUBLESHOOTING SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="troubleshooting" style="color: var(--text-color); font-family: var(--header-font);">6. Troubleshooting</h2>
            
            <div class="warning" style="background-color: rgba(255,255,255,0.12); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="ts-config" style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Issue: "Could not load db_config.json"</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Cause</strong>: Configuration file not found in expected locations</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution</strong>: Ensure db_config.json exists in Comserv root directory</p>
            </div>

            <div style="background-color: rgba(255,255,255,0.12); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="ts-database" style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Issue: "Unknown database: INVALID"</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Cause</strong>: Invalid database name passed to list_tables()</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution</strong>: Use only 'ENCY' or 'FORAGER'</p>
            </div>

            <div style="background-color: rgba(255,255,255,0.12); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="ts-connection" style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Issue: Database connection refused</h3>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Cause</strong>: Network/credentials issue</p>
                <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Solution</strong>: Test credentials manually, check network connectivity</p>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

