[% META
    title = 'AI Chat with Documentation Access - Feature Specification'
    description = 'Complete specification for AI Chat widget with documentation search, role-based access, multi-agent support, conversation resume functionality, Grok API integration, and admin model controls. ✅ Phase 1 Database & Model Layer COMPLETE - All tables created and automated startup initialization implemented. NEW: Grok.ai UI design, conversation persistence/resume, admin model selection, Grok API integration.'
    roles = 'admin,developer'
    TemplateType = 'Documentation'
    category = 'ai,features,architecture'
    page_version = '0.05'
    last_updated = 'Mon Jan 06 04:30:00 UTC 2026'
    site_specific = 'false'
    author = 'Development Team'
%]
[% PageVersion = 'Documentation/AI_CHAT_DOCUMENTATION_FEATURE_SPEC.tt,v 0.05 2026/01/06 04:30:00 zencoder Exp - Jan 6 Update: Added Grok API integration, conversation resume page, Grok.ai UI design, admin model/agent controls' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">AI Chat with Documentation Access</h1>
    <h2 style="color: var(--text-muted-color); font-family: var(--body-font); font-size: var(--font-size-large); margin-top: 0;">Feature Specification & Implementation Plan</h2>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-01-06 04:30 | 
        Version: 0.05 |
        Status: ✅ PHASE 1 COMPLETE (Database & Model Layer) - Phase 2-4 updated with NEW features: Grok API, conversation resume, Grok.ai UI design, admin model controls |
        Target Release: Q1 2026 | 
        Next Phase: Backend Services + Grok API integration + Admin Controls
    </div>

    <!-- RECENT CHANGES -->
    <div style="background-color: #d4edda; border-left: 4px solid var(--success-color, #28a745); padding: 15px; margin: 15px 0;">
        <h3 style="margin-top: 0; color: #155724;">Recent Changes (Jan 6, 2026)</h3>
        <ul style="margin: 10px 0; color: #155724;">
            <li><strong>NEW: Grok API Integration (Phase 2)</strong>: Added LLMGrok service for Grok API calls. Grok model support added to model selection dropdown alongside Ollama and XAI.</li>
            <li><strong>NEW: Conversation Resume Page (Phase 3)</strong>: Created /ai/conversations page for users to view, search, filter, and resume previous conversations with full context preservation.</li>
            <li><strong>NEW: Grok.ai UI Design (Phase 3)</strong>: Updated chat widget CSS to match Grok.ai aesthetic with modern dark theme, clean typography, and responsive layout.</li>
            <li><strong>NEW: Admin Model & Agent Controls (Phase 4)</strong>: Extended admin panel to allow dynamic model configuration and agent assignment without code changes.</li>
            <li><strong>Previous (Jan 2)</strong>: Schema regression fixed - metadata column in ai_conversations table now correctly stores conversation data.</li>
        </ul>
    </div>

    <!-- TABLE OF CONTENTS -->
    <div id="toc" style="background: rgba(255,255,255,0.15); padding: var(--spacing-medium); border-radius: 5px; margin: var(--spacing-large) 0;">
        <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;">Table of Contents</h3>
        <ul style="color: var(--text-color); font-family: var(--body-font);">
            <li><a href="#executive-summary">Executive Summary</a></li>
            <li><a href="#feature-requirements">Feature Requirements</a></li>
            <li><a href="#architecture">Architecture Overview</a></li>
            <li><a href="#database-schema">Database Schema</a></li>
            <li><a href="#multi-agent-system">Multi-Agent System</a></li>
            <li><a href="#implementation-plan">Implementation Plan</a></li>
            <li><a href="#security">Security & Kubernetes Compatibility</a></li>
            <li><a href="#verification-workflow">Verification Workflow</a></li>
        </ul>
    </div>

    <!-- EXECUTIVE SUMMARY -->
    <div class="row">
        <div class="col-100">
            <h2 id="executive-summary" style="color: var(--text-color); font-family: var(--header-font);">1. Executive Summary</h2>
            
            <div style="background: var(--info-color, #d1ecf1); border-left: 4px solid var(--info-border, #17a2b8); padding: var(--spacing-medium); margin: var(--spacing-medium) 0; border-radius: 3px;">
                <p style="color: var(--text-color); font-family: var(--body-font); margin: 0;">
                    <strong>Objective:</strong> Add an intelligent AI Chat widget to the Comserv web application that answers user questions by searching documentation and application code, with role-based access control, multi-model support, and comprehensive audit logging.
                </p>
            </div>

            <h3 style="color: var(--text-color); font-family: var(--header-font);">Key Capabilities</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Universal Access:</strong> Chat widget visible to all users (authenticated and non-authenticated)</li>
                <li><strong>Documentation Search:</strong> AI reads from /Documentation/ folder, searches metadata index, returns answers with citations</li>
                <li><strong>Role-Based Access:</strong> Users only see documentation they have permission to access</li>
                <li><strong>Multi-Model Support:</strong> Ollama (local, free) for all users; Ollama + XAI for developers/admins</li>
                <li><strong>Code Search:</strong> Developers and admins can ask AI to find functions, classes, and code patterns in application source</li>
                <li><strong>Web Search Integration:</strong> AI can search the web for current information, with results stored for verification by admins</li>
                <li><strong>Knowledge Base Building:</strong> Verified web search results are added to documentation index for reuse</li>
                <li><strong>Multi-Agent Architecture:</strong> Different AI agents for Documentation, HelpDesk, ENCY (inventory), Beekeeping, Ham Radio, etc.</li>
                <li><strong>Audit Trail:</strong> All conversations logged to database with user, timestamp, model, and sources used</li>
                <li><strong>Docker/Kubernetes Ready:</strong> API keys encrypted, env-compatible, container-aware</li>
            </ul>
        </div>
    </div>

    <!-- FEATURE REQUIREMENTS -->
    <div class="row">
        <div class="col-100">
            <h2 id="feature-requirements" style="color: var(--text-color); font-family: var(--header-font);">2. Feature Requirements</h2>

            <h3 style="color: var(--text-color); font-family: var(--header-font);">2.1 Functional Requirements (Priority-Based)</h3>
            <table style="width: 100%; color: var(--text-color); font-family: var(--body-font); border-collapse: collapse; margin: var(--spacing-medium) 0;">
                <thead>
                    <tr style="background: var(--secondary-color, #0066cc); color: white;">
                        <th style="padding: var(--spacing-small); text-align: left; border: 1px solid var(--border-color);">ID</th>
                        <th style="padding: var(--spacing-small); text-align: left; border: 1px solid var(--border-color);">Requirement</th>
                        <th style="padding: var(--spacing-small); text-align: left; border: 1px solid var(--border-color);">Priority</th>
                        <th style="padding: var(--spacing-small); text-align: left; border: 1px solid var(--border-color);">User Visible</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="background: rgba(255,255,255,0.15);">
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">FR-1</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">Chat widget in lower right, visible to all users (including non-authenticated)</td>
