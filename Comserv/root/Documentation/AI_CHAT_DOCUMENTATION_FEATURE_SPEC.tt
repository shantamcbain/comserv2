                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">FR-2</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">AI automatically searches documentation metadata index</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">🔴 Critical</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">User sees citations</td>
                    </tr>
                    <tr style="background: rgba(255,255,255,0.15);">
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">FR-3</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">Role-based documentation filtering (users can't see admin docs)</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">🔴 Critical</td>
