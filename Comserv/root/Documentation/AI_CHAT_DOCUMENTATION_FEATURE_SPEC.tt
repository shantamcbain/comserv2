                    </tr>
                    <tr style="background: rgba(255,255,255,0.15);">
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">FR-5</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">Model selection: Ollama for all; XAI for dev/admin</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">🟠 High</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">Dropdown selector</td>
                    </tr>
                    <tr>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">FR-6</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">Web search results with verification workflow</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">🟠 High</td>
