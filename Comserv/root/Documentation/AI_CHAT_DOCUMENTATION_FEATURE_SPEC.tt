                    </tr>
                    <tr>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">FR-4</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">All Q&A logged with user/timestamp/model/sources</td>
                        <td style="padding: var(--spacing-small); border: 1px solid var(--border-color);">🔴 Critical</td>
