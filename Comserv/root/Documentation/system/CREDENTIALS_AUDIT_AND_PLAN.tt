    <!-- REFERENCE TABLE SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="reference-table" style="color: var(--text-color); font-family: var(--header-font);">4. Quick Reference Table for All AI Agents</h2>

            <p style="color: var(--text-color); font-family: var(--body-font); font-style: italic;">Use this table before making credential-related changes:</p>

            <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0; font-size: var(--font-size-small);">
                <tr style="background-color: rgba(255,255,255,0.15);">
                    <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Credential Type</th>
                    <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Current Storage</th>
                    <th style="text-align: center; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Security</th>
                    <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Location</th>
                    <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color); font-family: var(--header-font);">Module</th>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Database (ency)</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>db_config.json</code> + env</td>
                    <td style="text-align: center; color: #d32f2f; font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">❌</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>Comserv.pm</code></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">DBIx::Class</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.12);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Database (forager)</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>db_config.json</code> + env</td>
                    <td style="text-align: center; color: #d32f2f; font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">❌</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>Comserv.pm</code></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">DBIx::Class</td>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Proxmox token</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Encrypted file</td>
                    <td style="text-align: center; color: #388e3c; font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">✅</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>config/proxmox_credentials.json</code></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">ProxmoxCredentials</td>
                </tr>
                <tr style="background-color: rgba(255,255,255,0.12);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Redis password</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Environment var</td>
                    <td style="text-align: center; color: #ff9800; font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">⚠️</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><code>docker-compose.yml</code></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Redis service</td>
                </tr>
