    <!-- SECURITY BEST PRACTICES SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="security" style="color: var(--text-color); font-family: var(--header-font);">7. Security Best Practices</h2>

            <div style="background-color: #e8f5e9; border-left: 4px solid #388e3c; padding: var(--spacing-medium); margin: var(--spacing-small) 0; border-radius: 4px;">
                <h3 style="color: #388e3c; margin-top: 0;">✅ DO:</h3>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Encrypt credentials at rest (AES-256)</li>
                    <li>Use environment variables for encryption keys (never commit)</li>
                    <li>Audit all credential access</li>
                    <li>Rotate keys quarterly</li>
                    <li>Use Docker secrets / Kubernetes secrets in production</li>
                    <li>Hash user passwords (bcrypt)</li>
                    <li>Validate database connections before saving</li>
                </ul>
            </div>

            <div style="background-color: #ffebee; border-left: 4px solid #d32f2f; padding: var(--spacing-medium); margin: var(--spacing-small) 0; border-radius: 4px;">
                <h3 style="color: #d32f2f; margin-top: 0;">❌ DON'T:</h3>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Commit passwords to git</li>
                    <li>Log plaintext credentials</li>
                    <li>Use same credentials across environments</li>
                    <li>Hardcode API tokens in code</li>
                    <li>Store encryption keys in config files</li>
                    <li>Use weak/default passwords</li>
                    <li>Skip key rotation</li>
                </ul>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

