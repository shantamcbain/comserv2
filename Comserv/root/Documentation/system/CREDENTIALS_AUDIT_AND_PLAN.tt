    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">Credentials Audit & Unified Management Plan</h1>

    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
