                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">ProxmoxCredentials (AES-256 logic)</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">✅ EXTRACTED - Now uses Encryption.pm</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Encryption.pm('proxmox'); CredentialsManager will use Encryption.pm('database')</td>
                </tr>
