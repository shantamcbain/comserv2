[% PageVersion = 'Documentation/REBUILD_AND_DEPLOY_INSTRUCTIONS.tt,v 1.0 2025/12/19 Zencoder Exp Shanta ' %]

<h1 id="rebuild_top">Docker Container Rebuild & Deployment Instructions</h1>

<div class="toc" id="toc">
<h3>Quick Navigation</h3>
<ul>
    <li><a href="#summary">Summary of Changes</a></li>
    <li><a href="#web_dev_rebuild">web-dev Container - Rebuild Steps</a></li>
    <li><a href="#web_prod_rebuild">web-prod Container - Rebuild Steps</a></li>
