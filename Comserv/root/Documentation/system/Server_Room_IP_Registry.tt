[% META
  title = 'Server Room IP Registry'
  description = 'Complete inventory of all IP addresses in use in the server room and connected networks'
  roles = 'admin,developer'
  TemplateType = 'Documentation'
  category = 'Infrastructure'
  page_version = '0.02'
  last_updated = 'Tue Dec 23 2025'
  site_specific = 'false'
%]

[% PageVersion = 'Documentation/system/Server_Room_IP_Registry.tt,v 0.02 2025/12/23 zencoder Exp docker-agent - Full documentation audit complete; added proxmox hosts, zerotier mappings, and cross-references' %]
[% IF c.session.debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="container">
  <h1 style="color: var(--text-color); font-family: var(--header-font);">Server Room IP Registry</h1>
  
  <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
    Last Updated: 2025-12-23 | 
    Version: 0.02 | 
    Author: Infrastructure Team & Docker Agent | 
    Status: Active |
    Last Audit: Full documentation scan completed - Proxmox hosts and ZeroTier addresses cataloged
  </div>

  <!-- TABLE OF CONTENTS SECTION -->
  <div id="toc" class="row" style="margin: var(--spacing-large) 0; background-color: var(--light-color); padding: var(--spacing-medium); border-left: 4px solid var(--primary-color); border-radius: 4px;">
    <div class="col-100">
      <h2 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;">Quick Navigation</h2>
      <p style="color: var(--text-muted-color); font-family: var(--body-font); font-size: var(--font-size-small);">Jump to section:</p>
      <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-small);">
        <a href="#overview" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Overview</a>
        <a href="#primary-network" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Primary Network</a>
        <a href="#proxmox-hosts" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Proxmox Hosts</a>
        <a href="#secondary-network" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Secondary Network</a>
        <a href="#container-networks" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Container Networks</a>
        <a href="#zerotier-network" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">ZeroTier Network</a>
        <a href="#available-addresses" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Available IPs</a>
        <a href="#scanning-procedure" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Scanning Procedure</a>
      </div>
    </div>
  </div>

  <!-- OVERVIEW SECTION -->
  <div class="row">
    <div class="col-100">
      <h2 id="overview" style="color: var(--text-color); font-family: var(--header-font);">1. Overview</h2>
      <p style="color: var(--text-color); font-family: var(--body-font);">
        Complete inventory of all IP addresses and network devices in the server room, wired and wireless networks, 
        container infrastructure, and VPN overlays. Use this registry to prevent IP conflicts when adding new devices 
        and to maintain accurate network documentation.
      </p>
      <p style="color: var(--text-color); font-family: var(--body-font);">
        <strong>Discovered Networks:</strong> 5 primary networks (2 physical + 3 container overlay) with 21+ active devices
      </p>
      <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
    </div>
  </div>

  <!-- PRIMARY NETWORK SECTION -->
  <div class="row">
    <div class="col-100">
