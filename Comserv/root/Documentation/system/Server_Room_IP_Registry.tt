          <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">VM 103 on proxmoxws (PVE 8.3.0)</td>
          <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><a href="[% c.uri_for('/Documentation/system/PRODUCTION_DB_KUBERNETES_MIGRATION_PLAN') %]" style="color: var(--link-color);">K8s_Migration:369</a></td>
