<!-- DATABASE STRUCTURE SECTION -->
<div class="container info">
    <div class="container-header" id="database_structure">Database Structure</div>
    <div class="container-content">
        <div class="container-content-inner">
            <p>Comprehensive database structure for the [SYSTEM_NAME] system:</p>
            
            <div class="database-structure">
                <div class="table-category">
                    <h3>1. Core System Tables</h3>
                    
                    <div class="table-group">
                        <div class="table-card">
                            <h4>[PRIMARY_TABLE_NAME]</h4>
                            <p class="table-description">Main table for [PRIMARY_DATA_TYPE] storage.</p>
                            <div class="schema-display">
                                <div class="field">[primary_id] <span class="key-type">(Primary Key)</span></div>
                                <div class="field">[field_1]</div>
                                <div class="field">[field_2]</div>
                                <div class="field">[field_3]</div>
                                <div class="field">description</div>
                                <div class="field">status</div>
                                <div class="field">created_by</div>
                                <div class="field">created_date</div>
                                <div class="field">modified_by</div>
                                <div class="field">modified_date</div>
                            </div>
                        </div>
                        
                        <div class="table-card">
                            <h4>[LOOKUP_TABLE_NAME]</h4>
                            <p class="table-description">Lookup table for [LOOKUP_DATA_TYPE].</p>
                            <div class="schema-display">
                                <div class="field">[lookup_id] <span class="key-type">(Primary Key)</span></div>
                                <div class="field">name</div>
                                <div class="field">description</div>
                                <div class="field">sort_order</div>
                                <div class="field">active_flag</div>
                            </div>
                        </div>
                        
                        <div class="table-card">
                            <h4>[RELATIONSHIP_TABLE_NAME]</h4>
                            <p class="table-description">Many-to-many relationship table.</p>
                            <div class="schema-display">
                                <div class="field">[primary_id] <span class="key-type">(Foreign Key to [PRIMARY_TABLE_NAME])</span></div>
                                <div class="field">[lookup_id] <span class="key-type">(Foreign Key to [LOOKUP_TABLE_NAME])</span></div>
                                <div class="field">relationship_type</div>
                                <div class="field">created_date</div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="table-category">
                    <h3>2. Supporting Tables</h3>
                    
                    <div class="table-group">
                        <div class="table-card">
                            <h4>[AUDIT_TABLE_NAME]</h4>
                            <p class="table-description">Audit trail for system changes.</p>
                            <div class="schema-display">
                                <div class="field">audit_id <span class="key-type">(Primary Key)</span></div>
                                <div class="field">table_name</div>
                                <div class="field">record_id</div>
                                <div class="field">action_type</div>
                                <div class="field">old_values</div>
                                <div class="field">new_values</div>
                                <div class="field">changed_by</div>
                                <div class="field">change_date</div>
                            </div>
                        </div>
                        
                        <div class="table-card">
                            <h4>[CONFIG_TABLE_NAME]</h4>
                            <p class="table-description">System configuration settings.</p>
                            <div class="schema-display">
                                <div class="field">config_id <span class="key-type">(Primary Key)</span></div>
                                <div class="field">config_key</div>
                                <div class="field">config_value</div>
                                <div class="field">config_type</div>
                                <div class="field">description</div>
                                <div class="field">modified_by</div>
                                <div class="field">modified_date</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="database-relationships">
                <h3>Table Relationships</h3>
                <div class="relationship-diagram">
                    <p><strong>Primary Relationships:</strong></p>
                    <ul>
                        <li>[PRIMARY_TABLE_NAME] → [RELATIONSHIP_TABLE_NAME] (One-to-Many)</li>
                        <li>[LOOKUP_TABLE_NAME] → [RELATIONSHIP_TABLE_NAME] (One-to-Many)</li>
                        <li>[PRIMARY_TABLE_NAME] → [AUDIT_TABLE_NAME] (One-to-Many)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- API ENDPOINTS SECTION -->
<div class="container secondary">
    <div class="container-header" id="api_endpoints">API Endpoints</div>
    <div class="container-content">
        <div class="container-content-inner">
            <div class="api-section">
                <h3>REST API Endpoints</h3>
                
                <div class="endpoint-group">
                    <h4>[PRIMARY_DATA_TYPE] Management</h4>
                    <div class="endpoint-list">
                        <div class="endpoint-card">
                            <h5>GET /api/[system_name]/[data_type]</h5>
                            <p>Retrieve all [data_type] records</p>
                            <div class="endpoint-details">
                                <strong>Parameters:</strong> page, limit, sort, filter<br>
                                <strong>Returns:</strong> JSON array of [data_type] objects
                            </div>
                        </div>
                        
                        <div class="endpoint-card">
                            <h5>GET /api/[system_name]/[data_type]/{id}</h5>
                            <p>Retrieve specific [data_type] record</p>
                            <div class="endpoint-details">
                                <strong>Parameters:</strong> id (required)<br>
                                <strong>Returns:</strong> JSON [data_type] object
                            </div>
                        </div>
                        
                        <div class="endpoint-card">
                            <h5>POST /api/[system_name]/[data_type]</h5>
                            <p>Create new [data_type] record</p>
                            <div class="endpoint-details">
                                <strong>Body:</strong> JSON [data_type] object<br>
                                <strong>Returns:</strong> Created [data_type] object with ID
                            </div>
                        </div>
                        
                        <div class="endpoint-card">
                            <h5>PUT /api/[system_name]/[data_type]/{id}</h5>
                            <p>Update existing [data_type] record</p>
                            <div class="endpoint-details">
                                <strong>Parameters:</strong> id (required)<br>
                                <strong>Body:</strong> JSON [data_type] object<br>
                                <strong>Returns:</strong> Updated [data_type] object
                            </div>
                        </div>
                        
                        <div class="endpoint-card">
                            <h5>DELETE /api/[system_name]/[data_type]/{id}</h5>
                            <p>Delete [data_type] record</p>
                            <div class="endpoint-details">
                                <strong>Parameters:</strong> id (required)<br>
                                <strong>Returns:</strong> Success/failure status
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="endpoint-group">
                    <h4>Search & Filter Endpoints</h4>
                    <div class="endpoint-list">
                        <div class="endpoint-card">
                            <h5>GET /api/[system_name]/search</h5>
                            <p>Search across all [system_name] data</p>
                            <div class="endpoint-details">
                                <strong>Parameters:</strong> query, fields, limit, offset<br>
                                <strong>Returns:</strong> JSON search results
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- IMPLEMENTATION PLAN SECTION -->
<div class="container warning">
    <div class="container-header" id="implementation_plan">Implementation Plan</div>
    <div class="container-content">
        <div class="container-content-inner">
            <div class="alert alert-warning">
                <h3>⚠️ CRITICAL: Phased Implementation Approach Required</h3>
                <p><strong>This system requires careful implementation planning:</strong></p>
            </div>
            
            <div class="implementation-phases">
                <div class="phase-container">
                    <h4>Phase 1: Foundation (0-3 months)</h4>
                    <ul class="phase-list">
                        <li><strong>Database Design:</strong> Create core database structure</li>
                        <li><strong>Basic Models:</strong> Implement primary data models</li>
                        <li><strong>Core Controllers:</strong> Basic CRUD operations</li>
                        <li><strong>Authentication:</strong> User access control implementation</li>
                    </ul>
                </div>
                
                <div class="phase-container">
                    <h4>Phase 2: Core Features (3-6 months)</h4>
                    <ul class="phase-list">
                        <li><strong>User Interface:</strong> Primary system interface development</li>
                        <li><strong>Search Functionality:</strong> Basic search and filter capabilities</li>
                        <li><strong>Data Validation:</strong> Input validation and error handling</li>
                        <li><strong>API Development:</strong> RESTful API endpoints</li>
                    </ul>
                </div>
                
                <div class="phase-container">
                    <h4>Phase 3: Advanced Features (6-9 months)</h4>
                    <ul class="phase-list">
                        <li><strong>Advanced Search:</strong> Complex queries and filtering</li>
                        <li><strong>Reporting System:</strong> Data analysis and reporting tools</li>
                        <li><strong>Integration APIs:</strong> External system integration</li>
                        <li><strong>Performance Optimization:</strong> Database and query optimization</li>
                    </ul>
                </div>
                
                <div class="phase-container">
                    <h4>Phase 4: Enhancement & Maintenance (9+ months)</h4>
                    <ul class="phase-list">
                        <li><strong>User Feedback Integration:</strong> Feature refinements</li>
                        <li><strong>Advanced Analytics:</strong> Data insights and analytics</li>
                        <li><strong>Mobile Optimization:</strong> Mobile-responsive enhancements</li>
                        <li><strong>System Monitoring:</strong> Performance monitoring and alerting</li>
                    </ul>
                </div>
            </div>
            
            <div class="implementation-requirements">
                <h3>Technical Requirements</h3>
                <div class="requirements-grid">
                    <div class="requirement-card">
                        <h4>Infrastructure</h4>
                        <ul>
                            <li>[DATABASE_REQUIREMENTS]</li>
                            <li>[SERVER_REQUIREMENTS]</li>
                            <li>[STORAGE_REQUIREMENTS]</li>
                        </ul>
                    </div>
                    <div class="requirement-card">
                        <h4>Dependencies</h4>
                        <ul>
                            <li>[PERL_VERSION]</li>
                            <li>[FRAMEWORK_REQUIREMENTS]</li>
                            <li>[EXTERNAL_LIBRARIES]</li>
                        </ul>
                    </div>
                    <div class="requirement-card">
                        <h4>Resources</h4>
                        <ul>
                            <li>[DEVELOPMENT_TEAM_SIZE]</li>
                            <li>[ESTIMATED_TIMELINE]</li>
                            <li>[BUDGET_CONSIDERATIONS]</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

