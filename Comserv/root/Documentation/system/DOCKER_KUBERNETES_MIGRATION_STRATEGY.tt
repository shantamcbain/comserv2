                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">3</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>Example Credentials in .env.example</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: #d32f2f;"><strong>CRITICAL</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">.env.example multiple lines</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Public repository credential leak</td>
            </tr>
            <tr>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">4</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>Multiple Config File Path Resolution</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: #ff6600;"><strong>HIGH</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">RemoteDB.pm lines 58-71</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Unpredictable config loading in K8s</td>
            </tr>
            <tr>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">5</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>Wrong Config Filename in ConfigDatabaseInit</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: #ff6600;"><strong>HIGH</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">ConfigDatabaseInit.pm lines 97-99</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">Searches for dbi_config.json instead of db_config.json</td>
            </tr>
            <tr>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">6</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>DBSchemaManager Fatal on Missing Config</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: #ff6600;"><strong>HIGH</strong></td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">DBSchemaManager.pm line 78</td>
                <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">die() on load fails entire app at startup</td>
            </tr>
