                    <td style="padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);">
                        Dockerfile, docker-compose.*.yml, docker-entrypoint.sh, Comserv.pm, Admin.pm, ProxyManager.pm, EnvironmentVariables.pm, SchemaComparison.pm, .env.example, .gitignore, cpanfile
                    </td>
                </tr>
            </table>
            
            <h3 style="color: #2e7d32; font-family: var(--header-font); margin-top: var(--spacing-large);">K8s Migration Roadmap Status</h3>
            
            <ul style="color: var(--text-color); font-family: var(--body-font); line-height: 1.8;">
