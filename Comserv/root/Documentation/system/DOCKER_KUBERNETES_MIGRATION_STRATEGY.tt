            <h3 style="color: #2e7d32; font-family: var(--header-font); margin-top: var(--spacing-large);">Application Code Status</h3>
            
            <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-small) 0;">
                <tr style="background-color: #f1f8e9;">
                    <th style="text-align: left; padding: var(--spacing-small); border: 1px solid var(--border-color); color: var(--text-color);"><strong>Metric</strong></th>
