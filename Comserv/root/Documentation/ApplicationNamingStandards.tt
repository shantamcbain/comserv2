[% META
        title = "Application Naming Standards"
   description = "Naming conventions and standards for Comserv application development"
   roles = "developer,admin"
   TemplateType = "Documentation"
   category = "standards"
   page_version = "1.00"
   last_updated = "Fri Jan 10 2026"
   site_specific = "false"
%]
[% PageVersion = 'ApplicationNamingStandards.tt,v 1.00 2026/01/10 shanta Exp shanta - Initial conversion from MD to TT format with standards compliance' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">Application Naming Standards for Comserv</h1>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-01-10 | 
        Version: 1.00 |
        Author: Development Team | 
        Status: Published
    </div>

    <!-- TABLE OF CONTENTS SECTION -->
    <div id="toc" class="row" style="margin: var(--spacing-large) 0; background-color: var(--light-color); padding: var(--spacing-medium); border-left: 4px solid var(--primary-color); border-radius: 4px;">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;">Quick Navigation</h2>
            <p style="color: var(--text-muted-color); font-family: var(--body-font); font-size: var(--font-size-small);">Jump to section:</p>
            <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-small);">
                <a href="#overview" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Overview</a>
                <a href="#problem" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Problem Statement</a>
                <a href="#industry-standards" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Industry Standards</a>
                <a href="#naming-convention" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Naming Convention</a>
                <a href="#domain-mapping" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Domain Mapping</a>
                <a href="#implementation" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Implementation</a>
                <a href="#success-criteria" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Success Criteria</a>
            </div>
        </div>
    </div>

    <!-- OVERVIEW SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="overview" style="color: var(--text-color); font-family: var(--header-font);">1. Overview</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Purpose:</strong> Establish clear naming conventions for collaborative development in the Comserv application.</p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Version:</strong> 1.0.0 (Published 2025-12-19)</p>
            <p style="color: var(--text-color); font-family: var(--body-font);">Without clear naming standards, communication becomes ambiguous and development coordination suffers. This document defines industry-standard naming patterns for controllers, models, views, utilities, and documentation across multiple functional domains.</p>
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- PROBLEM STATEMENT SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="problem" style="color: var(--text-color); font-family: var(--header-font);">2. Problem Statement</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);">Our application has multiple functional areas (inventory, project, todo, backup, file, software update) that interact with Catalyst framework components (Controller, Model, View). Without clear naming standards, communication becomes ambiguous and development coordination suffers.</p>
            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- INDUSTRY STANDARDS SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="industry-standards" style="color: var(--text-color); font-family: var(--header-font);">3. Industry Standard Naming Conventions</h2>
            
            <h3 id="arch-layer" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">3.1 Architectural Layer Terminology (MVC Pattern)</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Catalyst Framework Standards:</strong></p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Controller</strong>: Application logic handlers (<code>/lib/Comserv/Controller/</code>)</li>
                <li><strong>Model</strong>: Data access and business logic (<code>/lib/Comserv/Model/</code>)</li>
                <li><strong>View</strong>: Template presentation layer (<code>/root/</code> - .tt files)</li>
                <li><strong>Util</strong>: Shared utility functions (<code>/lib/Comserv/Util/</code>)</li>
            </ul>

            <h3 id="business-domain" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">3.2 Business Domain Naming (Functional Areas)</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Primary Business Domains (Based on existing application structure):</strong></p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Project Management</strong> - Project planning, tracking, documentation</li>
                <li><strong>Inventory Management</strong> - Asset and resource tracking</li>
                <li><strong>Todo Management</strong> - Task and workflow management</li>
                <li><strong>Backup Management</strong> - Data backup and recovery operations</li>
                <li><strong>File Management</strong> - File system operations and organization</li>
                <li><strong>Software Management</strong> - Application updates and maintenance</li>
            </ul>

            <h3 id="component-interaction" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">3.3 Component Interaction Terminology</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Standard Interaction Patterns:</strong></p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Service Layer</strong> - Business logic coordination between domains</li>
                <li><strong>Repository Pattern</strong> - Data access abstraction</li>
                <li><strong>Facade Pattern</strong> - Simplified interfaces for complex subsystems</li>
                <li><strong>Integration Points</strong> - Where domains interact with each other</li>
            </ul>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- NAMING CONVENTION SYSTEM SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="naming-convention" style="color: var(--text-color); font-family: var(--header-font);">4. Proposed Naming Convention System</h2>
            
            <h3 id="ddd-approach" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">4.1 Domain-Driven Design (DDD) Approach</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Format:</strong> <code>[Domain].[Component].[Function]</code></p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Examples:</strong></p>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
Project.Controller.List    → ProjectController with list action
Backup.Util.Manager       → BackupManager utility class  
File.Model.Storage        → FileStorage model
Todo.Service.Workflow     → TodoWorkflow service layer
                </code></pre>
            </div>

            <h3 id="catalyst-implementation" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">4.2 Catalyst-Specific Implementation</h3>
            
            <h4 style="color: var(--text-color); font-family: var(--header-font);">Controllers: <code>[Domain]Controller</code></h4>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
ProjectController.pm     → /lib/Comserv/Controller/Project.pm
BackupController.pm      → /lib/Comserv/Controller/Admin/Backup.pm  
FileController.pm        → /lib/Comserv/Controller/File.pm
                </code></pre>
            </div>

            <h4 style="color: var(--text-color); font-family: var(--header-font);">Models: <code>[Domain]Model</code> or <code>[Domain][Entity]</code></h4>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
ProjectModel.pm          → /lib/Comserv/Model/Project.pm
BackupConfig.pm          → /lib/Comserv/Model/BackupConfig.pm
FileStorage.pm           → /lib/Comserv/Model/File.pm
                </code></pre>
            </div>

            <h4 style="color: var(--text-color); font-family: var(--header-font);">Utilities: <code>[Domain]Manager</code> or <code>[Domain]Util</code></h4>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
BackupManager.pm         → /lib/Comserv/Util/BackupManager.pm
ProjectManager.pm        → /lib/Comserv/Util/ProjectManager.pm
FileSystemUtil.pm        → /lib/Comserv/Util/FileSystem.pm
                </code></pre>
            </div>

            <h4 style="color: var(--text-color); font-family: var(--header-font);">Templates: <code>[domain]/[action].tt</code></h4>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
project/list.tt          → Project listing page
backup/index.tt          → Backup management interface
file/upload.tt           → File upload interface
                </code></pre>
            </div>

            <h3 id="git-branch-standards" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">4.3 Git Branch Naming Standards</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Format:</strong> <code>[type]/[domain]-[feature]</code></p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Types:</strong></p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><code>feature/</code> - New functionality</li>
                <li><code>bugfix/</code> - Bug corrections</li>
                <li><code>refactor/</code> - Code restructuring</li>
                <li><code>docs/</code> - Documentation updates</li>
            </ul>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Examples:</strong></p>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
feature/backup-manager-refactor
bugfix/file-upload-validation
refactor/project-controller-cleanup
docs/api-naming-standards
                </code></pre>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- COMMUNICATION PROTOCOL STANDARDS -->
    <div class="row">
        <div class="col-100">
            <h2 id="communication" style="color: var(--text-color); font-family: var(--header-font);">5. Communication Protocol Standards</h2>
            
            <h3 id="reference-format" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">5.1 Reference Format in Conversations</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>When discussing components:</strong></p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>"The Backup Controller" → <code>Controller::Admin::Backup</code></li>
                <li>"File management system" → <code>File Domain</code> (all file-related components)</li>
                <li>"Project model logic" → <code>Model::Project</code></li>
                <li>"BackupManager utility" → <code>Util::BackupManager</code></li>
            </ul>

            <h3 id="issue-naming" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">5.2 Issue/Task Naming</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Format:</strong> <code>[DOMAIN] - [Component] - [Description]</code></p>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
BACKUP - Controller - Add file restoration endpoint
FILE - Model - Implement storage validation  
PROJECT - View - Update listing template layout
SYSTEM - Util - Create shared logger functionality
                </code></pre>
            </div>

            <h3 id="doc-structure" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">5.3 Documentation Structure</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Format:</strong> <code>[Domain][Component]Documentation.tt</code> (CamelCase)</p>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
BackupControllerAPI.tt       → Backup controller endpoints
FileManagerIntegration.tt    → File management system docs  
ProjectModelSchema.tt        → Project data model documentation
                </code></pre>
            </div>

            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>Configuration Files:</strong> <code>[Component]Config.json</code> (CamelCase)</p>
            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0;">
                <pre style="color: var(--text-color); font-family: monospace; margin: 0;"><code>
DocumentationConfig.json     → Documentation system configuration
DatabaseConfig.json          → Database configuration
ApplicationConfig.json       → Application-wide configuration
                </code></pre>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- DOMAIN MAPPING SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="domain-mapping" style="color: var(--text-color); font-family: var(--header-font);">6. Current Application Domain Mapping</h2>
            
            <h3 id="core-domains" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">6.1 Core Business Domains</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Admin</strong> - System administration (<code>/admin/</code> routes)</li>
                <li><strong>Project</strong> - Project management functionality</li>
                <li><strong>Todo</strong> - Task and workflow management</li>
                <li><strong>Backup</strong> - Data backup and recovery</li>
                <li><strong>File</strong> - File system management</li>
                <li><strong>Documentation</strong> - System documentation</li>
                <li><strong>Navigation</strong> - UI navigation components</li>
            </ul>

            <h3 id="support-domains" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">6.2 Support Domains</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Auth</strong> - Authentication and authorization</li>
                <li><strong>Config</strong> - Configuration management</li>
                <li><strong>Logging</strong> - Application logging</li>
                <li><strong>Git</strong> - Version control integration</li>
            </ul>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- IMPLEMENTATION SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="implementation" style="color: var(--text-color); font-family: var(--header-font);">7. Implementation Roadmap</h2>
            
            <h3 id="phase1" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Phase 1: Documentation Integration (1-2 operations)</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>[ ] Update AI_DEVELOPMENT_GUIDELINES.tt with naming standards reference</li>
                <li>[ ] Create domain mapping document for existing codebase</li>
            </ul>

            <h3 id="phase2" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Phase 2: Codebase Analysis (3-5 operations)</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>[ ] Scan existing controllers and identify current naming patterns</li>
                <li>[ ] Map existing utilities to proposed naming conventions</li>
                <li>[ ] Document deviations and required refactoring</li>
            </ul>

            <h3 id="phase3" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Phase 3: Standard Application (5-8 operations)</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>[ ] Create naming validation checklist for development</li>
                <li>[ ] Update session tracking to use domain.component format</li>
                <li>[ ] Apply standards to current File Manager enhancement plan</li>
            </ul>

            <h3 id="phase4" style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">Phase 4: Communication Protocol (2-3 operations)</h3>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li>[ ] Update development planning templates with domain references</li>
                <li>[ ] Create quick-reference guide for AI-human communication</li>
                <li>[ ] Test naming system with specific implementation examples</li>
            </ul>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- SUCCESS CRITERIA SECTION -->
    <div class="row">
        <div class="col-100">
            <h2 id="success-criteria" style="color: var(--text-color); font-family: var(--header-font);">8. Success Criteria</h2>
            
            <div style="background-color: var(--light-color); border-left: 4px solid var(--info-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="clear-comm" style="color: var(--info-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Clear Communication</h3>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>No ambiguity when referencing system components</li>
                    <li>Consistent terminology across documentation and conversations</li>
                    <li>Easy identification of component interactions</li>
                </ul>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--success-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="dev-efficiency" style="color: var(--success-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Development Efficiency</h3>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Faster code location and understanding</li>
                    <li>Reduced onboarding time for new team members</li>
                    <li>Consistent file organization and naming</li>
                </ul>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--primary-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 id="scalability" style="color: var(--primary-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">Scalability</h3>
                <ul style="color: var(--text-color); font-family: var(--body-font);">
                    <li>Standards support application growth</li>
                    <li>Clear patterns for adding new domains</li>
                    <li>Maintainable naming as complexity increases</li>
                </ul>
            </div>

            <p style="text-align: right; margin-top: var(--spacing-small);"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- FOOTER SECTION -->
    <div class="row">
        <div class="col-100" style="background-color: var(--light-color); border-left: 4px solid var(--primary-color); padding: var(--spacing-medium); margin-top: var(--spacing-large); border-radius: 4px;">
            <h3 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;">Next Session Priority</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>IMMEDIATE TASK:</strong> Apply naming standards to File Manager Enhancement Plan</p>
            <p style="color: var(--text-color); font-family: var(--body-font);"><strong>FOCUS:</strong> Use this document as foundation to clarify File Domain components and their interactions with Backup Domain</p>
            <p style="color: var(--text-muted-color); font-family: var(--body-font); font-style: italic; margin-bottom: 0;">This document establishes the foundation for clear communication and collaborative development. Implementation begins next session.</p>
        </div>
    </div>
</div>
