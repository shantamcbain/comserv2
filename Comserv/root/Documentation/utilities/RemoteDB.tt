<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">RemoteDB Utility Documentation</h1>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-01-11 15:59:00 UTC |
        Version: 0.01 |
