[% META
   title = "Admin: Adding Users Guide"
   description = "Guide for administrators on how to add new users and grant site access"
   roles = "admin"
   TemplateType = "Documentation"
   category = "User"
   page_version = "0.01"
   last_updated = "2026-02-24"
%]
[% PageVersion = 'Documentation/AdminAddUserGuide.tt,v 0.01 2026/02/24 AI Assistant Exp AI Assistant ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">Admin: Adding Users Guide</h1>

    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-02-24 |
        Version: 0.01 |
        Audience: Site Administrators
    </div>

    <!-- TABLE OF CONTENTS -->
    <div id="toc" class="row" style="margin: var(--spacing-large) 0; background-color: var(--light-color); padding: var(--spacing-medium); border-left: 4px solid var(--primary-color); border-radius: 4px;">
        <div class="col-100">
            <h2 style="color: var(--text-color); font-family: var(--header-font); margin-top: 0;">Quick Navigation</h2>
            <div style="display: flex; flex-wrap: wrap; gap: var(--spacing-small);">
                <a href="#overview" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Overview</a>
                <a href="#one-account" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">One Account Per Email</a>
                <a href="#new-user" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Adding a New User</a>
                <a href="#existing-user" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Adding an Existing User</a>
                <a href="#invitation-flow" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Invitation Flow</a>
                <a href="#roles" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Roles Explained</a>
                <a href="#admin-types" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Admin Access Levels</a>
                <a href="#managing-users" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Managing Users</a>
                <a href="#troubleshooting" style="color: var(--link-color); text-decoration: none; padding: 4px 8px; border-radius: 3px; background-color: var(--secondary-color); display: inline-block;">Troubleshooting</a>
            </div>
        </div>
    </div>

    <!-- OVERVIEW -->
    <div class="row">
        <div class="col-100">
            <h2 id="overview" style="color: var(--text-color); font-family: var(--header-font);">1. Overview</h2>
            <p style="color: var(--text-color); font-family: var(--body-font);">
                As an administrator you can add users to your site(s) using the
                <a href="/user/admin_create_user" style="color: var(--link-color);">Create User</a> form.
                The form handles two cases automatically:
            </p>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>Brand-new user</strong> — a new account is created and an invitation email is sent</li>
                <li><strong>Person already has an account</strong> — their existing account is granted access to your site; no new account is created</li>
            </ul>
            <p style="color: var(--text-color); font-family: var(--body-font);">
                You do not need to know in advance whether the person already has an account — just enter their email address and the system handles the rest.
            </p>
            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- ONE ACCOUNT PER EMAIL -->
    <div class="row">
        <div class="col-100">
            <h2 id="one-account" style="color: var(--text-color); font-family: var(--header-font);">2. One Account Per Email Address</h2>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--primary-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0; border-radius: 0 4px 4px 0;">
                <p style="color: var(--text-color); font-family: var(--body-font); margin: 0;">
                    <strong>Key rule:</strong> Each person has <em>one</em> account, identified by their email address.
                    That single account can be a member of <em>multiple sites</em> — for example, joe@gmail.com can be
                    a member of BMaster, CSC, and MCoop simultaneously without needing three separate accounts.
                </p>
            </div>

            <p style="color: var(--text-color); font-family: var(--body-font);">
                Site access is controlled by <strong>Site Roles</strong> — records that link a user's account to a
                specific site with a specific role. Adding a user to your site creates one of these records.
                Removing them deletes it. Their account is unaffected.
            </p>

            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- ADDING A NEW USER -->
    <div class="row">
        <div class="col-100">
            <h2 id="new-user" style="color: var(--text-color); font-family: var(--header-font);">3. Adding a Brand-New User</h2>

            <p style="color: var(--text-color); font-family: var(--body-font);">
                Use this when the person does not yet have an account on this server.
            </p>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">3.1 Fill in the Create User Form</h3>

            <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
                <tr>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color); width: 25%;">Field</th>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color); width: 15%;">Required?</th>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Notes</th>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>First Name</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Yes</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">The user's given name.</td>
                </tr>
                <tr style="background-color: var(--secondary-color);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>Last Name</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Yes</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">The user's family name.</td>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>Email</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Yes</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">The invitation will be sent here. Must be unique per person across all sites.</td>
                </tr>
                <tr style="background-color: var(--secondary-color);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>Username</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">No</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Leave blank — the user sets their own username during account setup.</td>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>Site Access</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Yes</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Check one or more sites this person should have access to. You only see sites you administer.</td>
                </tr>
                <tr style="background-color: var(--secondary-color);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>Roles</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Yes</td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Select the role(s) the user will have. Most new members should be <strong>normal</strong>. See <a href="#roles" style="color: var(--link-color);">Roles Explained</a>.</td>
                </tr>
            </table>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">3.2 What Happens Next</h3>
            <ol style="color: var(--text-color); font-family: var(--body-font);">
                <li>The account is created with status <em>pending setup</em>.</li>
                <li>An invitation email containing a 6-digit code is sent to the user.</li>
                <li>The user logs in with their email address and the code.</li>
                <li>They choose a username and password to complete their account setup.</li>
                <li>Their account becomes active and they can log in normally.</li>
            </ol>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--info-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <p style="color: var(--text-color); font-family: var(--body-font); margin: 0;">
                    <strong>If email cannot be delivered:</strong> The form will show you the 6-digit invitation code directly.
                    You can share it with the user by phone or in person.
                </p>
            </div>

            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- EXISTING USER -->
    <div class="row">
        <div class="col-100">
            <h2 id="existing-user" style="color: var(--text-color); font-family: var(--header-font);">4. Adding a User Who Already Has an Account</h2>

            <p style="color: var(--text-color); font-family: var(--body-font);">
                If the email address you enter already belongs to an existing account (e.g., the person
                is already a member of another site on this server), the system will <strong>not</strong> create a
                duplicate account. Instead it will:
            </p>

            <ol style="color: var(--text-color); font-family: var(--body-font);">
                <li>Find the existing account</li>
                <li>Grant it access to the site(s) and role(s) you selected</li>
                <li>Skip any site/role combinations the user already has</li>
                <li>Show you a success message explaining what was added</li>
            </ol>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--success-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <p style="color: var(--text-color); font-family: var(--body-font); margin: 0;">
                    <strong>Example:</strong> joe@gmail.com is already a member of CSC.
                    You (as BMaster admin) fill in the form with joe@gmail.com and select BMaster + normal role.
                    The system adds Joe to BMaster without touching his CSC membership or requiring him to do anything —
                    he can log in to BMaster immediately with his existing username and password.
                </p>
            </div>

            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- INVITATION FLOW -->
    <div class="row">
        <div class="col-100">
            <h2 id="invitation-flow" style="color: var(--text-color); font-family: var(--header-font);">5. The Invitation Flow (New Users)</h2>

            <p style="color: var(--text-color); font-family: var(--body-font);">When you create a brand-new user, here is what they experience:</p>

            <div style="background-color: var(--light-color); padding: var(--spacing-medium); border: 1px solid var(--border-color); margin: var(--spacing-small) 0; border-radius: 4px;">
                <ol style="color: var(--text-color); font-family: var(--body-font); margin: 0;">
                    <li style="margin-bottom: 8px;"><strong>Receive invitation email</strong> — contains a 6-digit code and a link to the login page.</li>
                    <li style="margin-bottom: 8px;"><strong>Go to login page</strong> — enter their email address and the 6-digit code (not a password — they don't have one yet).</li>
                    <li style="margin-bottom: 8px;"><strong>Choose username and password</strong> — complete their account setup.</li>
                    <li><strong>Log in normally</strong> — using username or email + password.</li>
                </ol>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <p style="color: var(--text-color); font-family: var(--body-font); margin: 0;">
                    <strong>Code expiry:</strong> The invitation code is valid for <strong>24 hours</strong>.
                    If the user does not complete setup in time, you will need to create the user again —
                    or contact the system administrator to generate a new code.
                </p>
            </div>

            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- ROLES -->
    <div class="row">
        <div class="col-100">
            <h2 id="roles" style="color: var(--text-color); font-family: var(--header-font);">6. Roles Explained</h2>

            <table style="width: 100%; border-collapse: collapse; margin: var(--spacing-medium) 0;">
                <tr>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color); width: 20%;">Role</th>
                    <th style="background-color: var(--table-header-bg); color: var(--text-color); font-family: var(--header-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Typical Permissions</th>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>normal</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Standard member access. Read and participate. Use for most new users.</td>
                </tr>
                <tr style="background-color: var(--secondary-color);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>member</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Similar to normal, used for site-specific membership distinctions.</td>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>editor</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Can create and edit content on the site.</td>
                </tr>
                <tr style="background-color: var(--secondary-color);">
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>developer</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Technical access for site configuration and development tasks.</td>
                </tr>
                <tr>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);"><strong>admin</strong></td>
                    <td style="color: var(--text-color); font-family: var(--body-font); padding: var(--spacing-small); border: 1px solid var(--border-color);">Full administrative access to that site. Can manage users, roles, and site settings. Grant with care.</td>
                </tr>
            </table>

            <p style="color: var(--text-color); font-family: var(--body-font);">
                Your site may also have custom roles created by a CSC administrator.
                These appear below the standard roles in the form.
            </p>

            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- ADMIN TYPES -->
    <div class="row">
        <div class="col-50">
            <h2 id="admin-types" style="color: var(--text-color); font-family: var(--header-font);">7. Admin Access Levels</h2>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><strong>CSC Admin</strong> — sees and manages all sites on the server. Can add a user to any site.</li>
                <li><strong>Site Admin</strong> — sees and manages only their own site(s). Can only add users to those sites.</li>
            </ul>
            <p style="color: var(--text-color); font-family: var(--body-font);">
                A CSC admin can grant a site admin access to additional sites via the user edit screen.
            </p>
        </div>
        <div class="col-50">
            <h2 style="color: var(--text-color); font-family: var(--header-font);">Other Admin Actions</h2>
            <ul style="color: var(--text-color); font-family: var(--body-font);">
                <li><a href="/admin/users" style="color: var(--link-color);">User Dashboard</a> — view, search and filter all users</li>
                <li>Edit user — change name, email, roles, site assignments</li>
                <li>Suspend / Activate — disable or re-enable a user's login</li>
                <li>Delete user — permanently remove an account</li>
                <li><a href="/user/admin_role_list" style="color: var(--link-color);">Manage Roles</a> — create custom site roles</li>
            </ul>
        </div>
    </div>
    <div class="row"><div class="col-100"><p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p></div></div>

    <!-- MANAGING USERS -->
    <div class="row">
        <div class="col-100">
            <h2 id="managing-users" style="color: var(--text-color); font-family: var(--header-font);">8. Managing Existing Users</h2>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">8.1 Granting a user access to an additional site</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">
                Use the <a href="/user/admin_create_user" style="color: var(--link-color);">Create User</a> form.
                Enter the user's existing email address, select the new site(s) and role(s), and submit.
                The system recognises the existing account and adds the site access without sending a new invitation.
            </p>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">8.2 Removing a user from a site</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">
                Open the user's edit screen from the
                <a href="/admin/users" style="color: var(--link-color);">User Dashboard</a>.
                Under <em>Site Access</em>, uncheck the site(s) you want to remove and save.
                The user loses access to those sites immediately. Their account is not deleted.
            </p>

            <h3 style="color: var(--text-color); font-family: var(--header-font); font-size: var(--font-size-large);">8.3 Suspending a user</h3>
            <p style="color: var(--text-color); font-family: var(--body-font);">
                Click <strong>Suspend</strong> next to the user in the dashboard.
                The user cannot log in while suspended but their account data and site memberships are preserved.
                Click <strong>Activate</strong> to restore access.
            </p>

            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

    <!-- TROUBLESHOOTING -->
    <div class="row">
        <div class="col-100">
            <h2 id="troubleshooting" style="color: var(--text-color); font-family: var(--header-font);">9. Troubleshooting</h2>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">
                    "User already has an account — no changes made"
                </h3>
                <p style="color: var(--text-color); font-family: var(--body-font);">
                    <strong>Cause:</strong> The user is already a member of all selected sites with all selected roles.
                </p>
                <p style="color: var(--text-color); font-family: var(--body-font);">
                    <strong>Action:</strong> No action needed. If you want to change their role, use the Edit user screen instead.
                </p>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">
                    The invitation email was not delivered
                </h3>
                <p style="color: var(--text-color); font-family: var(--body-font);">
                    If the email cannot be sent, the form shows the 6-digit invitation code.
                    Share the code with the user directly (phone, in person, or another channel).
                    They enter it at the login page along with their email address.
                </p>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">
                    "A user with this username already exists"
                </h3>
                <p style="color: var(--text-color); font-family: var(--body-font);">
                    <strong>Cause:</strong> You pre-filled a username that is already taken by a different account.
                </p>
                <p style="color: var(--text-color); font-family: var(--body-font);">
                    <strong>Solution:</strong> Leave the username field blank — the user will choose their own username during setup.
                </p>
            </div>

            <div style="background-color: var(--light-color); border-left: 4px solid var(--warning-color); padding: var(--spacing-medium); margin: var(--spacing-small) 0;">
                <h3 style="color: var(--warning-color); font-family: var(--header-font); font-size: var(--font-size-large); margin-top: 0;">
                    User's invitation code has expired
                </h3>
                <p style="color: var(--text-color); font-family: var(--body-font);">
                    Invitation codes expire after 24 hours. If the user did not complete setup in time,
                    use the <a href="/user/admin_create_user" style="color: var(--link-color);">Create User</a> form again with the same email address.
                    Because the account already exists, the system will add them to the selected sites directly
                    (no new invitation needed for existing accounts).
                    Contact the system administrator to reset a pending account if needed.
                </p>
            </div>

            <p style="text-align: right;"><a href="#toc" style="color: var(--link-color); font-size: var(--font-size-small);">↑ Back to Top</a></p>
        </div>
    </div>

