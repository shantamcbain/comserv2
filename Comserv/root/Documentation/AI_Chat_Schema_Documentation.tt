[% PageVersion = 'Documentation/AI_Chat_Schema_Documentation.tt,v 0.02 22:06:00 2025/12/25 zencoder Exp - Phase 1 COMPLETE: All Result classes created, tables generated in ENCY database, startup automation implemented' %]
