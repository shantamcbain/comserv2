    <div class="content-section">
        <h2>API Usage Examples</h2>

        <h3>Request: Use Grok Provider</h3>
        <pre><code>POST /ai/generate
Content-Type: application/json

{
  "prompt": "What is quantum computing?",
  "provider": "grok",
  "system": "You are a technical expert",
  "format": "text",
  "conversation_id": 123
}</code></pre>

        <h3>Response: Grok Provider</h3>
        <pre><code>{
  "success": true,
  "response": "Quantum computing leverages quantum mechanics...",
  "model": "grok-beta",
  "provider": "grok",
  "conversation_id": 123,
  "created_at": "2026-01-07T14:00:00Z"
}</code></pre>

        <h3>Request: Default (Ollama)</h3>
        <pre><code>POST /ai/generate
Content-Type: application/json

{
  "prompt": "What is AI?",
  "system": "You are helpful"
}
# No provider specified → defaults to Ollama</code></pre>

        <h3>Error: Missing Grok API Key</h3>
        <pre><code>{
  "success": false,
  "error": "Grok API key not configured. Set GROK_API_KEY environment variable or configure Kubernetes secret.",
  "model": "grok-beta",
  "provider": "grok"
}</code></pre>
    </div>

