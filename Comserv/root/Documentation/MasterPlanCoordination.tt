                    <td style="border: 1px solid var(--border-color);"><code>Setup</code>, <code>Admin</code> Controllers, Utilities: ConfigDatabaseInit, EnvFileManager, DocumentationConfig; Models: <code>EnvVariable</code>, <code>EnvVariableAuditLog</code></td>
                    <td style="border: 1px solid var(--border-color);"><a href="Documentation/Config" class="doc-link">Config</a> | <a href="Documentation/developer/db_config_loading" class="doc-link">✅ DB Init</a> | <a href="Documentation/models/EnvVariable.tt" class="doc-link">📄 EnvVariable.tt</a> | <a href="Documentation/models/EnvVariableAuditLog.tt" class="doc-link">📄 EnvVariableAuditLog.tt</a></td>
                </tr>
