                <tr>
                    <td style="border: 1px solid var(--border-color);"><strong>Admin Tools Suite</strong></td>
                    <td style="border: 1px solid var(--border-color);">Comprehensive administration interface for system management. Includes schema comparison, backup/restore, git operations, credential management, process restart, and diagnostics.</td>
                    <td style="border: 1px solid var(--border-color);"><code>Admin</code> Controller, BackupManager, AdminAuth, StarmanServiceManager Utilities</td>
                    <td style="border: 1px solid var(--border-color);"><a href="Documentation/Admin" class="doc-link">Admin Guide</a> | <a href="Documentation/system/backup_manager_utility" class="doc-link">✅ Backup</a> | <a href="Documentation/system/starman_service_manager" class="doc-link">✅ Starman</a></td>
                </tr>
