                    <td style="border: 1px solid var(--border-color);"><code>Admin</code> Controller, BackupManager Utility</td>
                    <td style="border: 1px solid var(--border-color);"><a href="Documentation/Admin" class="doc-link">Admin Tools</a> | <a href="Documentation/system/backup_manager_utility" class="doc-link">✅ BackupManager</a></td>
                </tr>
                <tr>
                    <td style="border: 1px solid var(--border-color);"><strong>Configuration Management</strong></td>
