                <th style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">Dependency</th>
                <th style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: left;">Timeline (Estimated)</th>
            </tr>
        </thead>
        <tbody>
            <tr style="background: var(--bg-secondary, #fafafa);">
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">#1C.1: CLI Token Setup Endpoint</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">2-3</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">Phase 1B</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">Week 1 (Jan 19-25)</td>
            </tr>
            <tr>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">#1C.2: Token Scope System</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">3-4</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">#1C.1</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">Week 1 (Jan 23-29, parallel with #1C.1)</td>
            </tr>
            <tr style="background: var(--bg-secondary, #fafafa);">
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">#1C.3: CLI Wrapper Script</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">4-5</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">#1C.1 + #1C.2</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">Week 2 (Jan 26-Feb 1)</td>
            </tr>
            <tr>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">#1C.4: Documentation</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">2-3</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd); text-align: center;">All prior</td>
                <td style="padding: 12px; border: 1px solid var(--border-color, #ddd);">Week 2 (Jan 26-Feb 1)</td>
