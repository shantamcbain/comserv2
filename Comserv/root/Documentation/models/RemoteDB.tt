<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h1 id="remotedb-model">RemoteDB Model - Multi-Database Connection Handler</h1>
            
            <div id="toc" class="alert alert-info">
                <strong>Contents:</strong>
                <ul style="margin: 10px 0 0 20px;">
                    <li><a href="#overview">Overview</a></li>
                    <li><a href="#configuration">Configuration (K8s Secrets, Environment, Files)</a></li>
                    <li><a href="#connections">Connection Management</a></li>
                    <li><a href="#api">Public API Methods</a></li>
