[% META
    title = 'Documentation Model - Content Version Control & Tracking'
    description = 'Comprehensive documentation for Documentation model covering version control, audit trail, creator/updater tracking, content management, and usage examples for managing in-database documentation records with change history'
    roles = 'admin,developer,editor'
