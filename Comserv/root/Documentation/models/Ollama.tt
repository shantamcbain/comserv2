[% META
        title = "Ollama Model Documentation"
   description = "Catalyst model for Ollama LLM API integration providing query, chat, model management, streaming responses, server control, and comprehensive error handling for local and remote Ollama instances"
   roles = "admin,developer,editor"
   TemplateType = "model"
   category = "models,ollama,api,llm"
   page_version = "0.02"
   last_updated = "2026-01-11"
   site_specific = ""
%]

[% PageVersion = 'Documentation/models/Ollama.tt,v 0.02 2026/01/11 DocumentationSyncAgent Exp - Version consolidation with current code; all methods validated against HEAD' %]
[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">Ollama Model Documentation</h1>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-01-11 |
        Version: 0.02 |
        Author: Zencoder / DocumentationSyncAgent |
        Status: Code Verified
    </div>

