        <div class="col-md-12">
            <h1 id="documentationroleaccess-model">DocumentationRoleAccess Model - Role-Based Documentation Access Control</h1>
            
            <div id="toc" class="alert alert-info">
                <strong>Contents:</strong>
                <ul style="margin: 10px 0 0 20px;">
                    <li><a href="#overview">Overview</a></li>
