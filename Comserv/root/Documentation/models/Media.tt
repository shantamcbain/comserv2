<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h1 id="media-model">Media Model - File & Asset Management</h1>
            
            <div id="toc" class="alert alert-info">
                <strong>Contents:</strong>
                <ul style="margin: 10px 0 0 20px;">
                    <li><a href="#overview">Overview</a></li>
                    <li><a href="#schema">Database Schema & Fields</a></li>
                    <li><a href="#relationships">Relationships</a></li>
                    <li><a href="#supported-types">Supported Media Types</a></li>
