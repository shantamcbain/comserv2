[% PageVersion = 'README.tt,v 1.00 2025/01/10 shanta Exp shanta' %]

<div class="documentation-content">
    <h1>Model Documentation</h1>
    
    <p>This directory contains documentation for all Comserv models.</p>
    
    <div class="model-overview">
        <h2>Database Models</h2>
        <p>Each model represents a database table or relationship and includes documentation on:</p>
        <ul>
            <li>Table structure and relationships</li>
            <li>Available methods and their usage</li>
            <li>Data validation rules</li>
            <li>Example usage patterns</li>
        </ul>
    </div>
</div>

[% IF debug_mode == 1 %]
    [% PageVersion %]
    [% IF debug_msg.defined && debug_msg.size > 0 %]
        <div class="debug-messages">
            [% FOREACH msg IN debug_msg %]
                <p class="debug">Debug: [% msg %]</p>
            [% END %]
        </div>
    [% END %]
[% END %]