      </tr>
    </table>
  </div>

  <!-- PHASE 5 -->
  <div id="p5" class="content-section" style="background-color: rgba(255,255,255,0.12); border-radius: 6px; padding: 16px; margin-bottom: 20px;">
    <h2 style="color: var(--text-color); margin-top: 0;">Phase 5 — SiteName Templates (DB Project 226)</h2>
    <p style="color: var(--text-color);">Work through each SiteName folder and shared application folders.</p>
    <table style="width: 100%; border-collapse: collapse; font-family: var(--body-font);">
      <tr>
        <th style="background-color: var(--table-header-bg); color: var(--text-color); padding: 8px; border: 1px solid var(--border-color);">Batch</th>
        <th style="background-color: var(--table-header-bg); color: var(--text-color); padding: 8px; border: 1px solid var(--border-color);">Folders</th>
        <th style="background-color: var(--table-header-bg); color: var(--text-color); padding: 8px; border: 1px solid var(--border-color);">Status</th>
        <th style="background-color: var(--table-header-bg); color: var(--text-color); padding: 8px; border: 1px solid var(--border-color);">Date</th>
      </tr>
      <tr>
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);">P5.1</td>
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);">BMaster/ + Apiary/</td>
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);">PENDING</td>
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);"></td>
      </tr>
      <tr style="background-color: rgba(255,255,255,0.08);">
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);">P5.2</td>
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);">CSC/</td>
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);">PENDING</td>
        <td style="color: var(--text-color); padding: 6px 8px; border: 1px solid var(--border-color);"></td>
      </tr>
