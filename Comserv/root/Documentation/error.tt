[% META title = 'Documentation Error' %]
<!-- File: /home/shanta/PycharmProjects/comserv/Comserv/root/Documentation/error.tt -->
[% PageVersion = 'Documentation/error.tt,v 1.0 2025/09/17 AI Exp AI' %]

[% IF c.session.debug_mode == 1 %]
    [% PageVersion %]
[% END %]

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <div class="alert alert-danger">
                <h3><i class="fas fa-exclamation-triangle"></i> Documentation Error</h3>
                <p><strong>[% error_msg || 'An error occurred while accessing documentation.' %]</strong></p>
            </div>

            [% IF page_name %]
            <div class="card">
                <div class="card-header">
                    <h5>Requested Page: <code>[% page_name %]</code></h5>
                </div>
                <div class="card-body">
                    [% IF debug_info %]
                    <h6>Debug Information:</h6>
                    <pre class="bg-light p-3">[% debug_info %]</pre>
                    [% END %]
                    
                    <h6>Possible Solutions:</h6>
                    <ul>
                        <li>Check if the page name is spelled correctly</li>
                        <li>Verify the page exists in the documentation system</li>
                        <li>Contact your system administrator if you believe this is an error</li>
                    </ul>
                </div>
            </div>
            [% END %]

            <div class="mt-3">
                <a href="[% c.uri_for('/Documentation') %]" class="btn btn-primary">
                    <i class="fas fa-arrow-left"></i> Back to Documentation Index
                </a>
            </div>
        </div>
    </div>
</div>