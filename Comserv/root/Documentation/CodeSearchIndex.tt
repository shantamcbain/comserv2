<div class="container">
    <h1 style="color: var(--text-color); font-family: var(--header-font);">CodeSearchIndex Result Class Documentation</h1>
    
    <div class="last-updated" style="color: var(--text-muted-color); font-size: var(--font-size-small);">
        Last Updated: 2026-01-11 16:03:00 UTC |
