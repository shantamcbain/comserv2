[% PageVersion = 'Documentation/proxmox/opnsense_vm_proxmox_k83_setup.tt,v 1.01 2025/12/23 zencoder Exp - Updated for actual Comserv infrastructure: OPNsense runs as VM 103 on proxmoxt210 (PVE 7.4) to provide network routing for 192.168.1.0/24' %]
