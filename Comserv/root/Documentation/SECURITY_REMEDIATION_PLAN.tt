                <td style="padding: 10px; border: 1px solid var(--border-color, #ddd);"><span style="background: #f9a825; color: white; padding: 3px 8px; border-radius: 3px; font-weight: bold;">MEDIUM</span></td>
                <td style="padding: 10px; border: 1px solid var(--border-color, #ddd);">5.3</td>
                <td style="padding: 10px; border: 1px solid var(--border-color, #ddd);">XSS attacks, injection attacks, data corruption</td>
                <td style="padding: 10px; border: 1px solid var(--border-color, #ddd);"><code>Controller/User.pm:611</code> register() only checks field existence, not format/length</td>
            </tr>
            <tr style="background: var(--caution-bg, #fff9c4);">
                <td style="padding: 10px; border: 1px solid var(--border-color, #ddd);"><strong>10</strong></td>
