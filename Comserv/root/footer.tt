[% PageVersion	= 'footer.tt,v 0.04 2026/03/04 shanta Exp shanta '	%]
<footer>
    <div class="footer-content">
        [% USE date %]
        <p>&copy; [% date.format(date.now, '%Y') %] [% site_display_name || SiteDisplayName || SiteName || 'Comserv' %]. All rights reserved.</p>
        [% IF c.session.debug_mode == 1 %]
        <p>[% PageVersion %]</p>
        <p><a href="/reset_session">Reset Session</a></p>
        [% END %]
    </div>
</footer>

<!-- Live chat implementation -->
<script type="text/javascript" src="/static/js/local-chat.js"></script>

<!-- Debug information about the current page -->
[% IF c.session.debug_mode == 1 %]
<div class="debug-footer">
    <details>
        <summary>Debug Information</summary>
        <ul>
            <li>Controller: [% c.session.ControllerName || 'Not defined' %]</li>
            <li>Theme: [% c.session.theme_name || 'Not defined' %]</li>
            <li>SiteName: [% c.session.SiteName || 'Not defined' %]</li>
            <li>Username: [% c.session.username || 'Not logged in' %]</li>
            <li>Session ID: [% c.sessionid || 'Not available' %]</li>
        </ul>
    </details>
</div>
[% END %]
