[% META title = 'Edit Mailing List' %]

<div class="admin-content">
    <div class="admin-header">
        <h1>Edit Mailing List</h1>
        <div class="admin-actions">
            <a href="[% c.uri_for('/mail/lists') %]" class="btn btn-secondary">Back to Lists</a>
        </div>
    </div>

    [% IF c.flash.error_msg %]<div class="alert alert-danger">[% c.flash.error_msg | html %]</div>[% END %]

    <div class="admin-card">
        <form method="POST" action="[% c.uri_for('/mail/lists', list.id, 'edit') %]" class="admin-form">
            <div class="form-group">
                <label for="name">List Name <span style="color:red;">*</span></label>
                <input type="text" id="name" name="name" required value="[% list.name | html %]">
            </div>
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3">[% list.description | html %]</textarea>
            </div>
            <div class="form-group">
                <label for="list_email">List Email Address</label>
                <input type="email" id="list_email" name="list_email" value="[% list.list_email | html %]">
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" name="is_software_only" value="1" [% list.is_software_only ? 'checked' : '' %]>
                    Software-only list (no Virtualmin server list)
                </label>
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" name="is_public" value="1" [% list.is_public ? 'checked' : '' %]>
                    Public list (visible on the subscribe page)
                </label>
                <small class="form-help">Public lists appear on <code>/mail/subscribe</code> for anyone to sign up.</small>
            </div>
            <div class="form-group">
                <label for="list_backend">List Backend</label>
                <select id="list_backend" name="list_backend" class="form-input">
                    [% FOREACH be IN ['local','mailchimp','mailserver','virtualmin'] %]
                    <option value="[% be %]" [% (list.list_backend == be) ? 'selected' : '' %]>
                        [% IF be == 'local' %]Local (application database)
                        [% ELSIF be == 'mailchimp' %]Mailchimp
                        [% ELSIF be == 'mailserver' %]Mail Server (SMTP list)
                        [% ELSIF be == 'virtualmin' %]Virtualmin
                        [% END %]
                    </option>
                    [% END %]
                </select>
            </div>
            <div class="form-group" id="backend_config_group">
                <label for="backend_config">Backend Configuration (JSON)</label>
                <textarea id="backend_config" name="backend_config" rows="3"
                          placeholder='e.g. {"api_key":"abc123","list_id":"xyz"}'>[% list.backend_config | html %]</textarea>
                <small class="form-help">JSON config for the chosen backend (API keys, list IDs, etc.).</small>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="[% c.uri_for('/mail/lists') %]" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
(function(){
    var sel = document.getElementById('list_backend');
    var cfg = document.getElementById('backend_config_group');
    function toggle(){ cfg.style.display = (sel.value !== 'local') ? '' : 'none'; }
    sel.addEventListener('change', toggle);
    toggle();
})();
</script>
