[% META title = 'Site Mailout' %]

<div class="admin-content">
    <div class="admin-header">
        <h1>Site Mailout</h1>
        <div class="admin-actions">
            <a href="[% c.uri_for('/mail/lists') %]" class="btn btn-secondary">Mailing Lists</a>
            <a href="[% c.uri_for('/mail/mail_admin_dashboard') %]" class="btn btn-secondary">Mail Admin</a>
        </div>
    </div>

    [% IF c.flash.success_msg %]
        <div class="alert alert-success">[% c.flash.success_msg | html %]</div>
    [% END %]
    [% IF c.flash.error_msg %]
        <div class="alert alert-danger">[% c.flash.error_msg | html %]</div>
    [% END %]

    <div class="admin-card">
        <form method="POST" action="[% c.uri_for('/mail/send_mass_email') %]" id="mailout-form">

            <div class="form-section">
                <h3>Recipients</h3>
                <div class="form-group">
                    <label><input type="radio" name="group" value="all" checked onchange="updateCount(this)">
                        All site users <strong>([% user_count %])</strong>
                        <small style="color:#666;"> — everyone with a role on this site</small>
                    </label>
                </div>
                <div class="form-group">
                    <label><input type="radio" name="group" value="paid" onchange="updateCount(this)">
                        Paid / active members <strong>([% paid_count %])</strong>
                        <small style="color:#666;"> — active or grace-period memberships</small>
                    </label>
                </div>
                <div class="form-group">
                    <label><input type="radio" name="group" value="custom" onchange="updateCount(this)">
                        Custom addresses only
                        <small style="color:#666;"> — use the field below, no DB users</small>
                    </label>
                </div>

                [% IF mailing_lists.size %]
                <div style="margin-top:8px;padding:10px;background:#f0f4ff;border:1px solid #c5d0e8;border-radius:4px;">
                    <strong style="display:block;margin-bottom:4px;">Named Mailing Lists <small style="font-weight:normal;color:#666;">(check any to add their members)</small>:</strong>
                    [% FOREACH list IN mailing_lists %]
                    <div class="form-group" style="margin:4px 0;">
                        <label><input type="checkbox" name="list_ids" value="[% list.id %]" onchange="updateListCount()"> 
                            [% list.name | html %] <strong>([% list.count %])</strong>
                            <small style="color:#666;"> — named mailing list subscribers</small>
                        </label>
                    </div>
                    [% END %]
                </div>
                [% END %]

                <div class="form-group" style="margin-top:12px;">
                    <label for="custom_addresses">Additional / Custom Addresses:</label>
                    <textarea name="custom_addresses" id="custom_addresses" rows="3"
                              placeholder="extra@example.com, another@example.com"
                              style="width:100%;padding:6px;"></textarea>
                    <small style="color:#666;">Comma, semicolon or space-separated. Added on top of the selected group (or used alone for Custom mode).</small>
                </div>
            </div>

            <div class="form-section" style="margin-top:20px;">
                [% PROCESS 'ai/partials/ai_form_assistant.tt'
                   ai_form_entity_label = 'mass email'
                   ai_form_context      = 'mass email / mailout composition for site users'
                   ai_form_fields       = 'subject, body'
                %]
                <h3>Message</h3>
                <div class="form-group">
                    <label for="subject">Subject <span style="color:red;">*</span></label>
                    <input type="text" name="subject" id="subject" required
                           style="width:100%;padding:6px;" placeholder="Your subject line">
                </div>
                <div class="form-group" style="margin-top:10px;">
                    <label>Message Body <span style="color:red;">*</span></label>

                    <div style="border:1px solid #ccc;border-radius:4px;overflow:hidden;">
                        <!-- Tab bar -->
                        <div style="display:flex;background:#f5f5f5;border-bottom:1px solid #ccc;">
                            <button type="button" id="tab-visual" onclick="switchTab('visual')"
                                style="padding:6px 14px;border:none;border-bottom:2px solid #0d6efd;background:#fff;font-weight:bold;cursor:pointer;">
                                Visual
                            </button>
                            <button type="button" id="tab-source" onclick="switchTab('source')"
                                style="padding:6px 14px;border:none;border-bottom:2px solid transparent;background:transparent;cursor:pointer;">
                                HTML Source
                            </button>
                            <span style="flex:1"></span>
                            <!-- Rich-text toolbar (visual tab only) -->
                            <span id="rich-toolbar" style="display:flex;gap:3px;align-items:center;padding:3px 6px;">
                                <button type="button" onclick="fmt('bold')" title="Bold" style="font-weight:bold;min-width:26px;padding:2px 4px;">B</button>
                                <button type="button" onclick="fmt('italic')" title="Italic" style="font-style:italic;min-width:26px;padding:2px 4px;">I</button>
                                <button type="button" onclick="fmt('underline')" title="Underline" style="text-decoration:underline;min-width:26px;padding:2px 4px;">U</button>
                                <span style="border-left:1px solid #ccc;margin:0 2px;height:18px;display:inline-block;"></span>
                                <button type="button" onclick="fmtBlock('h2')" title="Heading 2" style="min-width:30px;padding:2px 4px;">H2</button>
                                <button type="button" onclick="fmtBlock('h3')" title="Heading 3" style="min-width:30px;padding:2px 4px;">H3</button>
                                <button type="button" onclick="fmtBlock('p')" title="Paragraph" style="min-width:26px;padding:2px 4px;">P</button>
                                <span style="border-left:1px solid #ccc;margin:0 2px;height:18px;display:inline-block;"></span>
                                <button type="button" onclick="fmt('insertUnorderedList')" title="Bullet list" style="min-width:26px;padding:2px 4px;">&#8226;</button>
                                <button type="button" onclick="fmt('insertOrderedList')" title="Numbered list" style="min-width:26px;padding:2px 4px;">1.</button>
                                <button type="button" onclick="insertLink()" title="Insert link" style="min-width:26px;padding:2px 4px;">&#128279;</button>
                                <button type="button" onclick="fmt('removeFormat')" title="Clear formatting" style="padding:2px 6px;font-size:11px;">Clear</button>
                            </span>
                        </div>

                        <!-- Visual editor panel -->
                        <div id="panel-visual">
                            <div id="body-editor" contenteditable="true"
                                 style="min-height:280px;padding:10px;background:#fff;outline:none;overflow-y:auto;font-family:Arial,sans-serif;font-size:14px;line-height:1.5;"></div>
                        </div>

                        <!-- HTML source panel -->
                        <div id="panel-source" style="display:none;">
                            <div style="padding:6px;background:#fffde7;border-bottom:1px solid #eee;font-size:12px;color:#666;">
                                Paste or type raw HTML here, then click <strong>Apply HTML</strong> to render it in the visual editor.
                            </div>
                            <textarea id="source-editor"
                                style="width:100%;min-height:280px;padding:10px;border:none;outline:none;font-family:monospace;font-size:12px;line-height:1.4;box-sizing:border-box;resize:vertical;"
                                placeholder="Paste your HTML email source here..."></textarea>
                            <div style="padding:6px;background:#f5f5f5;border-top:1px solid #eee;display:flex;gap:8px;">
                                <button type="button" onclick="applySource()" class="btn btn-primary" style="padding:4px 16px;">
                                    Apply HTML &#10003;
                                </button>
                                <button type="button" onclick="switchTab('visual')" style="padding:4px 12px;">Cancel</button>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" name="body" id="body-hidden">
                    <small style="color:#666;margin-top:4px;display:block;">
                        Personalisation tags: <code>[FIRST_NAME]</code> <code>[LAST_NAME]</code>
                        <code>[EMAIL]</code> <code>[USERNAME]</code> — replaced per recipient.
                        Use <strong>HTML Source</strong> tab to paste a full HTML email template.
                    </small>
                </div>
            </div>

            <div class="form-section" style="margin-top:20px;background:#fff8e1;border:1px solid #ffc107;padding:14px;border-radius:6px;">
                <p id="confirm-text" style="margin:0 0 8px;">
                    You are about to send to <strong id="recipient-count">[% user_count %]</strong> recipient(s).
                </p>
                <label>
                    <input type="checkbox" id="confirm_send" required>
                    I confirm I want to send this mailout.
                </label>
            </div>

            <div class="form-actions" style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
                <button type="submit" id="send-btn" class="btn btn-primary btn-lg" disabled>
                    Send Mailout
                </button>
                <button type="button" id="test-btn" class="btn btn-secondary"
                        onclick="sendTestPreview()" style="background:#6c757d;color:#fff;">
                    Send Test to Me
                </button>
                <a href="[% c.uri_for('/mail/lists') %]" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>

    [% IF mailing_lists.size %]
    <div class="admin-card" style="margin-top:20px;">
        <h3>Named Mailing Lists</h3>
        <table class="admin-table">
            <thead><tr><th>List</th><th>Actions</th></tr></thead>
            <tbody>
            [% FOREACH list IN mailing_lists %]
            <tr>
                <td><strong>[% list.name | html %]</strong></td>
                <td>
                    <a href="[% c.uri_for('/mail/lists', list.id, 'subscribers') %]" class="btn-small">Subscribers</a>
                    <a href="[% c.uri_for('/mail/lists', list.id, 'edit') %]" class="btn-small">Edit</a>
                </td>
            </tr>
            [% END %]
            </tbody>
        </table>
    </div>
    [% END %]
</div>

<script>
var counts = { all: [% user_count %], paid: [% paid_count %], custom: 0 };

// ── Editor tab switching ──────────────────────────────────────
function switchTab(tab) {
    var isVisual = tab === 'visual';
    document.getElementById('panel-visual').style.display = isVisual ? '' : 'none';
    document.getElementById('panel-source').style.display = isVisual ? 'none' : '';
    document.getElementById('rich-toolbar').style.display  = isVisual ? 'flex' : 'none';
    document.getElementById('tab-visual').style.borderBottom = isVisual ? '2px solid #0d6efd' : '2px solid transparent';
    document.getElementById('tab-visual').style.background   = isVisual ? '#fff' : 'transparent';
    document.getElementById('tab-visual').style.fontWeight   = isVisual ? 'bold' : 'normal';
    document.getElementById('tab-source').style.borderBottom = isVisual ? '2px solid transparent' : '2px solid #0d6efd';
    document.getElementById('tab-source').style.background   = isVisual ? 'transparent' : '#fff';
    document.getElementById('tab-source').style.fontWeight   = isVisual ? 'normal' : 'bold';
    if (!isVisual) {
        // Mirror current visual content into source textarea when switching to source
        document.getElementById('source-editor').value =
            document.getElementById('body-hidden').value;
    }
}

// Apply raw HTML from source textarea → render in visual editor
function applySource() {
    var src = document.getElementById('source-editor').value.trim();
    if (src) {
        setBodyHtml(src);
    }
    switchTab('visual');
}

// ── Inline HTML editor helpers ────────────────────────────────
function fmt(cmd) {
    document.getElementById('body-editor').focus();
    document.execCommand(cmd, false, null);
}
function fmtBlock(tag) {
    document.getElementById('body-editor').focus();
    document.execCommand('formatBlock', false, tag);
}
function insertLink() {
    var url = prompt('Enter URL:', 'https://');
    if (url) {
        document.getElementById('body-editor').focus();
        document.execCommand('createLink', false, url);
    }
}
function syncBody() {
    document.getElementById('body-hidden').value =
        document.getElementById('body-editor').innerHTML;
}
document.getElementById('body-editor').addEventListener('input', syncBody);

// Allow external code (e.g. AI assistant) to set the editor content as rendered HTML
function setBodyHtml(html) {
    // Strip full document wrapper if present — email clients only need inner HTML
    html = html.replace(/^[\s\S]*?<body[^>]*>/i, '').replace(/<\/body>[\s\S]*$/i, '');
    // Strip <!DOCTYPE> and <html> lines that may remain
    html = html.replace(/<!DOCTYPE[^>]*>/gi, '').replace(/<\/?html[^>]*>/gi, '')
               .replace(/<head>[\s\S]*?<\/head>/gi, '').trim();
    document.getElementById('body-editor').innerHTML = html;
    syncBody();
}

// Watch for changes to the hidden body field (AI assistant writes here) and mirror to editor
var _bodyHiddenLast = '';
setInterval(function() {
    var hidden = document.getElementById('body-hidden');
    if (hidden && hidden.value !== _bodyHiddenLast) {
        _bodyHiddenLast = hidden.value;
        var editor = document.getElementById('body-editor');
        if (editor.innerHTML !== hidden.value) {
            editor.innerHTML = hidden.value;
        }
    }
}, 300);

// ── Recipient count ───────────────────────────────────────────
function updateCount(radio) {
    var n = counts[radio.value] !== undefined ? counts[radio.value] : '?';
    document.getElementById('recipient-count').textContent = n;
    updateListCount();
}
function updateListCount() {
    var base = 0;
    var selected = document.querySelector('input[name="group"]:checked');
    if (selected) {
        base = counts[selected.value] !== undefined ? parseInt(counts[selected.value]) : 0;
    }
    var extra = 0;
    document.querySelectorAll('input[name="list_ids"]:checked').forEach(function(cb) {
        extra += parseInt(cb.parentElement.querySelector('strong').textContent.replace(/[()]/g, '')) || 0;
    });
    document.getElementById('recipient-count').textContent = base + extra;
}

// ── Confirm checkbox enables Send button ──────────────────────
document.getElementById('confirm_send').addEventListener('change', function() {
    document.getElementById('send-btn').disabled = !this.checked;
});

// ── Main form submit ──────────────────────────────────────────
document.getElementById('mailout-form').addEventListener('submit', function(e) {
    syncBody();
    var subject  = document.getElementById('subject').value.trim();
    var bodyText = document.getElementById('body-editor').innerText.trim();
    if (!subject || !bodyText) {
        e.preventDefault();
        alert('Please fill in subject and message.');
        return false;
    }
    if (!document.getElementById('confirm_send').checked) {
        e.preventDefault();
        alert('Please tick the confirmation checkbox.');
        return false;
    }
    document.getElementById('send-btn').textContent = 'Sending…';
    document.getElementById('send-btn').disabled = true;
});

// ── Test preview send ─────────────────────────────────────────
function sendTestPreview() {
    syncBody();
    var subject  = document.getElementById('subject').value.trim();
    var body     = document.getElementById('body-hidden').value;
    var bodyText = document.getElementById('body-editor').innerText.trim();
    if (!bodyText) {
        alert('Please write a message body before sending a test.');
        return;
    }
    var btn = document.getElementById('test-btn');
    btn.textContent = 'Sending…';
    btn.disabled = true;

    var data = new URLSearchParams();
    data.append('subject', subject || '(no subject)');
    data.append('body', body);

    fetch('[% c.uri_for('/mail/send_mailout_test') %]', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: data.toString()
    })
    .then(function(r) { return r.json(); })
    .then(function(json) {
        btn.textContent = 'Send Test to Me';
        btn.disabled = false;
        if (json.ok) {
            var box = document.querySelector('.alert.alert-success');
            if (!box) {
                box = document.createElement('div');
                box.className = 'alert alert-success';
                document.querySelector('.admin-card').insertAdjacentElement('beforebegin', box);
            }
            box.textContent = json.msg;
            box.style.display = '';
        } else {
            alert('Test send failed: ' + json.msg);
        }
    })
    .catch(function(err) {
        btn.textContent = 'Send Test to Me';
        btn.disabled = false;
        alert('Test send error: ' + err);
    });
}
</script>
