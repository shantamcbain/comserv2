[% META title = 'Add Mail Configuration' %]

<h1>Add Mail Configuration</h1>

[% IF status_msg %]
  <div class="alert alert-success">[% status_msg | html %]</div>
[% END %]
[% IF debug_msg %]
  <div class="alert alert-warning">[% debug_msg | html %]</div>
[% END %]

<p>Prefer using the <a href="/mail/smtp_settings">SMTP Settings</a> page for managing existing site credentials.</p>

<form method="POST" action="/mail/add_mail_config">
  <table class="table table-bordered" style="max-width:600px;">
    <tr>
      <th>Site Name</th>
      <td><input type="text" name="site_name" class="form-control" placeholder="CSC" required></td>
    </tr>
    <tr>
      <th>SMTP Host</th>
      <td><input type="text" name="smtp_host" class="form-control" placeholder="harper.whc.ca" required></td>
    </tr>
    <tr>
      <th>SMTP Port</th>
      <td><input type="number" name="smtp_port" class="form-control" placeholder="465" required></td>
    </tr>
    <tr>
      <th>SSL Mode</th>
      <td>
        <select name="smtp_ssl" class="form-control">
          <option value="">None (plain)</option>
          <option value="ssl">SSL (implicit, port 465)</option>
          <option value="starttls">STARTTLS (port 587)</option>
        </select>
      </td>
    </tr>
    <tr>
      <th>SMTP User</th>
      <td><input type="text" name="smtp_user" class="form-control" placeholder="user@example.com"></td>
    </tr>
    <tr>
      <th>SMTP Password</th>
      <td><input type="password" name="smtp_password" class="form-control" autocomplete="new-password"></td>
    </tr>
    <tr>
      <th>From Address</th>
      <td><input type="email" name="smtp_from" class="form-control" placeholder="noreply@example.com"></td>
    </tr>
  </table>

  <button type="submit" class="btn btn-primary">Save Configuration</button>
</form>
