[% META title = 'cPanel API Settings' %]

<div class="admin-content">
    <div class="admin-header" style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;">
        <div>
            <h1>cPanel API Settings</h1>
            <nav style="font-size:0.9em;color:var(--text-muted-color);">
                <a href="[% c.uri_for('/mail') %]">Mail</a> &rsaquo;
                <a href="[% c.uri_for('/mail/mail_admin_dashboard') %]">Admin</a> &rsaquo;
                cPanel Settings
            </nav>
        </div>
        <a href="[% c.uri_for('/mail/lists') %]" class="btn btn-secondary">Back to Lists</a>
    </div>

    [% IF c.flash.success_msg %]<div class="alert alert-success">[% c.flash.success_msg | html %]</div>[% END %]
    [% IF page_error %]<div class="alert alert-danger">[% page_error | html %]</div>[% END %]

    <div class="admin-card">
        <p style="color:var(--text-muted-color);line-height:1.55;margin:0 0 18px;">
            Set <strong>once per SiteName</strong> ([% sitename | html %]). These credentials are used for
            all cPanel API actions on this site: creating mailing lists, adding/removing subscribers, etc.
            Individual mailing lists only store their <em>list name</em> and <em>domain</em> — not API keys.
        </p>

        <form method="POST" action="[% c.uri_for('/mail/cpanel_settings') %]" class="admin-form">
            <div class="form-group">
                <label for="host">cPanel host <span style="color:red">*</span></label>
                <input type="text" id="host" name="host" required class="form-control"
                       value="[% cpanel_cfg.host | html %]" placeholder="beemaster.ca or server.whc.ca">
                <small class="form-help">Usually your primary domain or WHC server hostname</small>
            </div>

            <div class="form-group">
                <label for="username">cPanel username <span style="color:red">*</span></label>
                <input type="text" id="username" name="username" required class="form-control"
                       value="[% cpanel_cfg.username | html %]" placeholder="WHC cPanel account username">
            </div>

            <div class="form-group">
                <label for="api_token">API token</label>
                <input type="password" id="api_token" name="api_token" class="form-control"
                       placeholder="[% IF cpanel_cfg.api_token %]Leave blank to keep [% cpanel_cfg.api_token | html %][% ELSE %]From cPanel → Security → Manage API Tokens[% END %]">
                <small class="form-help">Preferred over password. Create in cPanel under Security → Manage API Tokens.</small>
            </div>

            <div class="form-group">
                <label for="password">cPanel password (alternative)</label>
                <input type="password" id="password" name="password" class="form-control"
                       placeholder="[% IF cpanel_cfg.password %]Leave blank to keep existing[% ELSE %]Only if not using API token[% END %]">
            </div>

            <div class="form-group">
                <label for="default_domain">Default mail domain <span style="color:red">*</span></label>
                <input type="text" id="default_domain" name="default_domain" required class="form-control"
                       value="[% cpanel_cfg.default_domain | html %]" placeholder="beemaster.ca">
                <small class="form-help">Used when provisioning lists (newsletter@<strong>this domain</strong>)</small>
            </div>

            <div class="form-group">
                <label for="port">API port</label>
                <input type="number" id="port" name="port" class="form-control"
                       value="[% cpanel_cfg.port || 2083 %]" min="1" max="65535">
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save cPanel Settings</button>
                [% IF cpanel_configured %]
                <a href="[% c.uri_for('/mail/lists/cpanel_provision') %]" class="btn btn-secondary">Provision a List</a>
                [% END %]
            </div>
        </form>

        <p style="margin-top:20px;font-size:0.85em;color:var(--text-muted-color);border-top:1px solid var(--border-color,#ddd);padding-top:14px;">
            Fallback: if nothing is saved here, the app uses the <code>&lt;cPanel&gt;</code> block in
            <code>comserv.conf</code>. Site settings take precedence.
        </p>
    </div>
</div>