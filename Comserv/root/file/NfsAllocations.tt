[% META
   title = "NFS Allocations"
   description = "Manage NFS directory allocations for SiteNames (CSC admin only)"
   roles = "admin"
   TemplateType = "Application"
   category = "FileManagement"
   page_version = "0.01"
   last_updated = "2026-02-28"
%]
[% PageVersion = 'file/NfsAllocations.tt,v 0.01 2026/02/28 AI Exp AI ' %]
[% IF debug_mode == 1 %]
  [% PageVersion %]
[% END %]

<div class="app-container">

  <div class="page-header">
    <h1>NFS Allocations</h1>
  </div>

  [% IF error_msg %]
  <div class="error">[% error_msg | html %]</div>
  [% END %]
  [% IF c.flash.error_msg %]
  <div class="error">[% c.flash.error_msg | html %]</div>
  [% END %]
  [% IF c.flash.success_msg %]
  <div class="success">[% c.flash.success_msg | html %]</div>
  [% END %]

  <div class="content-container">
    <div class="content-primary">

      <div class="content-section">
        <h2>Current Allocations</h2>
        [% IF allocations && allocations.size > 0 %]
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>ID</th>
                <th>SiteName</th>
                <th>NFS Path</th>
                <th>Description</th>
                <th>On Disk</th>
                <th>Active</th>
                <th class="action-cell">Actions</th>
              </tr>
            </thead>
            <tbody>
              [% FOR alloc IN allocations %]
              [% SET path_ok = alloc.fs_exists %]
              <tr>
                <td>[% alloc.id | html %]</td>
                <td>[% alloc.sitename | html %]</td>
                <td><code>[% alloc.nfs_path | html %]</code></td>
                <td>[% alloc.description | html %]</td>
                <td>
                  [% IF alloc.fs_exists %]
                  <span style="color:#2e7d32;font-weight:bold" title="Directory exists on filesystem">&#10003; Yes</span>
                  [% ELSE %]
                  <span style="color:#c62828;font-weight:bold" title="Directory does not exist on filesystem — use Create Dir">&#10007; No</span>
                  [% END %]
                </td>
                <td>[% alloc.is_active ? 'Yes' : 'No' %]</td>
                <td class="action-cell">
                  [% IF alloc.fs_exists %]
                  <a href="[% c.uri_for('/file/admin_browser', { dir_path => alloc.nfs_path }) %]"
                     class="btn btn-primary btn-sm">Browse</a>
                  [% ELSE %]
                  <form method="post" action="[% c.uri_for('/file/nfs_allocation_mkdir', alloc.id) %]"
                        style="display:inline"
                        onsubmit="return confirm('Create directory [% alloc.nfs_path | html %] on the NFS filesystem?')">
                    <button type="submit" class="btn btn-secondary btn-sm" title="Create the directory on the NFS filesystem">Create Dir</button>
                  </form>
                  [% END %]
                  <form method="post" action="[% c.uri_for('/file/nfs_allocation_edit', alloc.id) %]"
                        style="display:inline">
                    <input type="hidden" name="description" value="[% alloc.description | html %]" id="desc_[% alloc.id %]">
                    <input type="hidden" name="is_active" value="[% alloc.is_active ? 1 : 0 %]" id="active_[% alloc.id %]">
                    <button type="button" class="btn btn-secondary btn-sm"
                            onclick="toggleEdit([% alloc.id %])">Edit</button>
                  </form>
                </td>
              </tr>
              <tr id="edit_row_[% alloc.id %]" style="display:none">
                <td colspan="7">
                  <form method="post" action="[% c.uri_for('/file/nfs_allocation_edit', alloc.id) %]"
                        class="app-form" style="padding:12px">
                    <div class="form-section">
                      <div class="form-row">
                        <div class="form-field">
                          <label for="edit_sitename_[% alloc.id %]">SiteName <span class="required">*</span></label>
                          [% IF sites && sites.size > 0 %]
                          <select id="edit_sitename_[% alloc.id %]" name="sitename" class="form-input"
                                  onchange="editSitenameChanged([% alloc.id %], this.value)" required>
                            <option value="">-- Select SiteName --</option>
                            [% FOR site IN sites %]
                            <option value="[% site.name | html %]"
                                    data-id="[% site.id | html %]"
                                    [% 'selected' IF site.name == alloc.sitename %]>[% site.name | html %]</option>
                            [% END %]
                          </select>
                          [% ELSE %]
                          <input type="text" id="edit_sitename_[% alloc.id %]" name="sitename"
                                 value="[% alloc.sitename | html %]" class="form-input" required>
                          [% END %]
                        </div>
                        <div class="form-field">
                          <label for="edit_site_id_[% alloc.id %]">Site ID</label>
                          <input type="text" id="edit_site_id_[% alloc.id %]" name="site_id"
                                 value="[% alloc.site_id | html %]" class="form-input"
                                 placeholder="Optional (numeric only)">
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-field" style="flex:1">
                          <label for="edit_nfs_path_[% alloc.id %]">NFS Path <span class="required">*</span></label>

                          [% IF existing_dirs && existing_dirs.size > 0 %]
                          <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:6px">
                            <label style="font-size:.82rem;font-weight:normal;white-space:nowrap">
                              Pick existing directory:
                            </label>
                            <select id="edit_existing_dir_[% alloc.id %]" class="form-input" style="max-width:340px"
                                    onchange="editPickExisting([% alloc.id %], this.value)">
                              <option value="">-- or choose existing dir --</option>
                              [% FOR d IN existing_dirs %]
                              <option value="[% d.path | html %]"
                                      [% 'selected' IF d.path == alloc.nfs_path %]>[% d.name | html %]</option>
                              [% END %]
                            </select>
                          </div>
                          [% END %]

                          <input type="text" id="edit_nfs_path_[% alloc.id %]" name="nfs_path"
                                 value="[% alloc.nfs_path | html %]" class="form-input"
                                 style="width:100%;max-width:480px"
                                 oninput="editClearPicker([% alloc.id %])" required>
                          <div style="font-size:.75rem;color: var(--text-muted-color, #666);margin-top:3px">
                            Must be an absolute path or relative to NFS root: <code>[% nfs_root | html %]</code>
                          </div>
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-field" style="flex:1">
                          <label for="edit_desc_[% alloc.id %]">Description</label>
                          <input type="text" id="edit_desc_[% alloc.id %]" name="description"
                                 value="[% alloc.description | html %]" class="form-input"
                                 style="width:100%;max-width:480px"
                                 placeholder="Optional description">
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-field">
                          <label>
                            <input type="checkbox" name="is_active" value="1"
                              [% 'checked' IF alloc.is_active %]> Active
                          </label>
                        </div>
                      </div>
                    </div>
                    <div class="form-actions">
                      <button type="submit" class="btn btn-primary">Save Changes</button>
                      <button type="button" class="btn btn-secondary"
                              onclick="toggleEdit([% alloc.id %])">Cancel</button>
                    </div>
                  </form>
                </td>
              </tr>
              [% END %]
            </tbody>
          </table>
        </div>
        [% ELSE %]
        <p class="empty-state">No NFS allocations found.</p>
        [% END %]
      </div>

      <div class="content-section">
        <h2>Create New Allocation</h2>
        <p style="font-size:.85rem;color: var(--text-muted-color, #555);margin-bottom:10px">
          NFS root: <code>[% nfs_root | html %]</code>
        </p>
        <form method="post" action="[% c.uri_for('/file/nfs_allocation_create') %]" class="app-form">
          <div class="form-section">

            [%# ── Row 1: SiteName + Site ID ── %]
            <div class="form-row">
              <div class="form-field">
                <label for="ac_sitename">SiteName <span class="required">*</span></label>
                [% IF sites && sites.size > 0 %]
                <select id="ac_sitename" name="sitename" class="form-input"
                        onchange="acSitenameChanged(this.value)">
                  <option value="">-- Select SiteName --</option>
                  [% FOR site IN sites %]
                  <option value="[% site.name | html %]"
                          data-id="[% site.id | html %]">[% site.name | html %]</option>
                  [% END %]
                </select>
                [% ELSE %]
                <input type="text" id="ac_sitename" name="sitename" class="form-input"
                       placeholder="e.g. MyClientSite"
                       oninput="acSitenameChanged(this.value)">
                [% END %]
              </div>
              <div class="form-field">
                <label for="site_id">Site ID (optional)</label>
                <input type="text" id="site_id" name="site_id" class="form-input"
                       placeholder="Auto-filled from selection">
              </div>
            </div>

            [%# ── Row 2: NFS Path — pick existing OR type new ── %]
            <div class="form-row">
              <div class="form-field" style="flex:1">
                <label for="nfs_path">NFS Path <span class="required">*</span></label>

                [% IF existing_dirs && existing_dirs.size > 0 %]
                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:6px">
                  <label style="font-size:.82rem;font-weight:normal;white-space:nowrap">
                    Pick existing:
                  </label>
                  <select id="ac_existing_dir" class="form-input" style="max-width:340px"
                          onchange="acPickExisting(this.value)">
                    <option value="">-- or choose existing dir --</option>
                    [% FOR d IN existing_dirs %]
                    <option value="[% d.path | html %]">[% d.name | html %]</option>
                    [% END %]
                  </select>
                </div>
                [% END %]

                <input type="text" id="nfs_path" name="nfs_path" class="form-input"
                       placeholder="[% nfs_root | html %]/SiteName"
                       style="width:100%;max-width:480px"
                       oninput="acClearPicker()">
                <div style="font-size:.78rem;color: var(--text-muted-color, #666);margin-top:3px">
                  Selecting a SiteName auto-fills <code>[% nfs_root | html %]/<em>sitename</em></code>.
                  Pick an existing directory above, or type a custom path.
                </div>
              </div>
            </div>

            [%# ── Row 3: Description ── %]
            <div class="form-row">
              <div class="form-field" style="flex:1">
                <label for="ac_description">Description</label>
                <input type="text" id="ac_description" name="description" class="form-input"
                       placeholder="Optional description of this allocation"
                       style="width:100%;max-width:480px">
              </div>
            </div>

          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Create Allocation</button>
            <a href="[% c.uri_for('/file/admin_browser') %]" class="btn btn-secondary">Back to Browser</a>
          </div>
        </form>
      </div>

    </div>
  </div>

</div>

<script>
var _acNfsRoot = '[% nfs_root | html %]';

function acSitenameChanged(val) {
    var pathEl = document.getElementById('nfs_path');
    if (val) {
        pathEl.value = _acNfsRoot + '/' + val;
    } else {
        pathEl.value = '';
    }
    var pickerEl = document.getElementById('ac_existing_dir');
    if (pickerEl) pickerEl.value = '';

    var siteEl = document.getElementById('ac_sitename');
    var siteIdEl = document.getElementById('site_id');
    if (siteEl && siteEl.tagName === 'SELECT') {
        var opt = siteEl.options[siteEl.selectedIndex];
        if (opt && opt.dataset.id) {
            siteIdEl.value = opt.dataset.id;
        } else {
            siteIdEl.value = '';
        }
    }
}

function acPickExisting(path) {
    if (!path) return;
    var pathEl = document.getElementById('nfs_path');
    pathEl.value = path;

    var siteEl = document.getElementById('ac_sitename');
    if (siteEl && siteEl.tagName === 'SELECT') {
        var dirName = path.replace(/^.*\//, '');
        for (var i = 0; i < siteEl.options.length; i++) {
            if (siteEl.options[i].value.toLowerCase() === dirName.toLowerCase()) {
                siteEl.selectedIndex = i;
                var opt = siteEl.options[i];
                if (opt.dataset.id) {
                    document.getElementById('site_id').value = opt.dataset.id;
                }
                break;
            }
        }
    }
}

function acClearPicker() {
    var pickerEl = document.getElementById('ac_existing_dir');
    if (pickerEl) pickerEl.value = '';
}

function toggleEdit(id) {
    var row = document.getElementById('edit_row_' + id);
    if (row.style.display === 'none') {
        row.style.display = '';
    } else {
        row.style.display = 'none';
    }
}

function editSitenameChanged(id, val) {
    var pathEl = document.getElementById('edit_nfs_path_' + id);
    if (val && pathEl) {
        pathEl.value = _acNfsRoot + '/' + val;
    }
    var pickerEl = document.getElementById('edit_existing_dir_' + id);
    if (pickerEl) pickerEl.value = '';

    var siteEl = document.getElementById('edit_sitename_' + id);
    var siteIdEl = document.getElementById('edit_site_id_' + id);
    if (siteEl && siteEl.tagName === 'SELECT') {
        var opt = siteEl.options[siteEl.selectedIndex];
        if (opt && opt.dataset.id) {
            siteIdEl.value = opt.dataset.id;
        } else {
            siteIdEl.value = '';
        }
    }
}

function editPickExisting(id, path) {
    if (!path) return;
    var pathEl = document.getElementById('edit_nfs_path_' + id);
    if (pathEl) pathEl.value = path;

    var siteEl = document.getElementById('edit_sitename_' + id);
    if (siteEl && siteEl.tagName === 'SELECT') {
        var dirName = path.replace(/^.*\//, '');
        for (var i = 0; i < siteEl.options.length; i++) {
            if (siteEl.options[i].value.toLowerCase() === dirName.toLowerCase()) {
                siteEl.selectedIndex = i;
                var opt = siteEl.options[i];
                if (opt.dataset.id) {
                    document.getElementById('edit_site_id_' + id).value = opt.dataset.id;
                }
                break;
            }
        }
    }
}

function editClearPicker(id) {
    var pickerEl = document.getElementById('edit_existing_dir_' + id);
    if (pickerEl) pickerEl.value = '';
}
</script>
