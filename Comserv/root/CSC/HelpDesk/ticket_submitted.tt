[% META title = 'Ticket Submitted' %]
[% PageVersion = 'CSC/HelpDesk/ticket_submitted.tt,v 0.01 2026/03/24 shanta Exp shanta ' %]

[% IF c.session.debug_mode == 1 %]
 <br>[% PageVersion %]</br>
[% END %]

<div class="helpdesk-container">
    <div class="success-box">
        <h1>&#10003; Ticket Submitted Successfully</h1>
        <p>Your support ticket has been created. Our team will review it shortly.</p>

        <div class="ticket-summary">
            <h2>Ticket Summary</h2>
            <table class="summary-table">
                <tr>
                    <th>Ticket Number:</th>
                    <td><strong>[% ticket.ticket_number %]</strong></td>
                </tr>
                <tr>
                    <th>Subject:</th>
                    <td>[% ticket.subject %]</td>
                </tr>
                <tr>
                    <th>Category:</th>
                    <td>[% ticket.category %]</td>
                </tr>
                <tr>
                    <th>Priority:</th>
                    <td>[% ticket.priority %]</td>
                </tr>
                <tr>
                    <th>Status:</th>
                    <td><span class="status-open">Open</span></td>
                </tr>
            </table>
        </div>

        <p class="ticket-note">
            Please save your ticket number: <strong>[% ticket.ticket_number %]</strong>.
            You can use it to check the status of your ticket.
        </p>

        <div class="action-buttons">
            <a href="[% c.uri_for('/HelpDesk/ticket/list') %]" class="btn btn-primary">View My Tickets</a>
            <a href="[% c.uri_for('/HelpDesk') %]" class="btn btn-secondary">Return to HelpDesk</a>
        </div>
    </div>
</div>

<style>
    .helpdesk-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    .success-box {
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
        border-radius: 5px;
        padding: 30px;
        text-align: center;
    }

    .success-box h1 {
        color: #155724;
        margin-bottom: 15px;
    }

    .ticket-summary {
        background-color: #fff;
        border-radius: 5px;
        padding: 20px;
        margin: 20px 0;
        text-align: left;
    }

    .summary-table {
        width: 100%;
        border-collapse: collapse;
    }

    .summary-table th, .summary-table td {
        padding: 10px;
        border-bottom: 1px solid #dee2e6;
    }

    .summary-table th {
        width: 35%;
        color: #495057;
    }

    .status-open {
        color: #28a745;
        font-weight: bold;
    }

    .ticket-note {
        background-color: #fff3cd;
        border: 1px solid #ffeeba;
        border-radius: 4px;
        padding: 10px 15px;
        margin: 15px 0;
    }

    .action-buttons {
        margin-top: 20px;
    }

    .btn {
        display: inline-block;
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 4px;
        margin: 5px;
    }

    .btn-primary {
        background-color: #007bff;
        color: white;
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }
</style>
