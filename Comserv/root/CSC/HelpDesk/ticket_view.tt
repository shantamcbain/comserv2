[% META title = ticket.subject || 'Support Ticket' %]
[% PageVersion = 'CSC/HelpDesk/ticket_view.tt,v 0.01 2026/04/20' %]
[% IF c.session.debug_mode == 1 %]<br>[% PageVersion %]</br>[% END %]

<div class="helpdesk-container">

    <nav class="ticket-breadcrumb">
        <a href="[% c.uri_for('/HelpDesk') %]">HelpDesk</a> &rsaquo;
        [% IF is_staff %]
        <a href="[% c.uri_for('/HelpDesk/admin/tickets/open') %]">Open Tickets</a> &rsaquo;
        [% ELSE %]
        <a href="[% c.uri_for('/HelpDesk/ticket/status') %]">My Tickets</a> &rsaquo;
        [% END %]
        <span>[% ticket.ticket_number %]</span>
    </nav>

    [% IF error_msg %]<div class="alert-error">[% error_msg %]</div>[% END %]
    [% IF success_msg %]<div class="alert-success">[% success_msg %]</div>[% END %]

    <div class="ticket-header-card">
        <div class="ticket-meta-row">
            <span class="ticket-number"><code>[% ticket.ticket_number %]</code></span>
            <span class="ticket-status status-[% ticket.status %]">[% ticket.status | upper %]</span>
            <span class="ticket-priority priority-[% ticket.priority %]">[% ticket.priority || 'medium' %]</span>
            [% IF is_staff %]
            <span class="ticket-site">[% ticket.site_name %]</span>
            [% END %]
        </div>
        <h2 class="ticket-subject">[% ticket.subject %]</h2>
        <div class="ticket-meta-detail">
            <span>Category: <strong>[% ticket.category || 'other' %]</strong></span>
            &bull;
            <span>Submitted by: <strong>[% ticket.username || ticket.email || 'Guest' %]</strong></span>
            &bull;
            <span>Created: <strong>[% ticket.created_at %]</strong></span>
            [% IF ticket.assigned_to %]
            &bull;
            <span>Assigned to: <strong>[% ticket.assigned_to %]</strong></span>
            [% END %]
        </div>
    </div>

    <div class="conversation-thread">
        <div class="message message-user message-original">
            <div class="message-header">
                <span class="message-author">[% ticket.username || ticket.email || 'Customer' %]</span>
                <span class="message-role-badge badge-user">Customer</span>
                <span class="message-time">[% ticket.created_at %]</span>
            </div>
            <div class="message-body">[% ticket.description | html | replace('\n', '<br>') %]</div>
        </div>

        [% FOREACH msg IN messages %]
        <div class="message message-[% msg.sender_type %]">
            <div class="message-header">
                <span class="message-author">[% msg.sender_name || msg.sender_email || msg.sender_type %]</span>
                <span class="message-role-badge badge-[% msg.sender_type %]">
                    [% msg.sender_type == 'staff' ? 'Support Staff' : 'Customer' %]
                </span>
                <span class="message-time">[% msg.created_at %]</span>
            </div>
            <div class="message-body">[% msg.body | html | replace('\n', '<br>') %]</div>
        </div>
        [% END %]
    </div>

    [% IF c.session.username %]
    <div class="reply-box">
        <h3>
            [% IF is_staff %]Reply to Customer[% ELSE %]Add Reply[% END %]
        </h3>
        <form method="post" action="[% c.uri_for('/HelpDesk/ticket/reply/' _ ticket.ticket_number) %]">
            <textarea name="reply_body" rows="5" placeholder="Type your reply..." required
                      class="reply-textarea"></textarea>
            <div class="reply-actions">
                <button type="submit" class="btn btn-primary">
                    [% IF is_staff %]Send Reply &amp; Email Customer[% ELSE %]Send Reply[% END %]
                </button>
                [% IF is_staff %]
                <a href="[% c.uri_for('/HelpDesk/admin/tickets/open') %]" class="btn btn-secondary">
                    &larr; Back to Tickets
                </a>
                [% END %]
            </div>
        </form>
    </div>
    [% ELSE %]
    <div class="reply-box">
        <p><a href="[% c.uri_for('/user/login') %]">Log in</a> to reply to this ticket.</p>
    </div>
    [% END %]

</div>

<style>
.helpdesk-container { max-width: 900px; margin: 0 auto; padding: 20px; }
.ticket-breadcrumb { font-size: 0.9em; margin-bottom: 16px; color: #666; }
.ticket-breadcrumb a { color: #1a7a4a; text-decoration: none; }
.ticket-breadcrumb a:hover { text-decoration: underline; }

.ticket-header-card {
    background: #f8f9fa; border-radius: 6px; padding: 18px 22px;
    border-left: 5px solid #1a7a4a; margin-bottom: 24px;
    box-shadow: 0 1px 4px rgba(0,0,0,.08);
}
.ticket-meta-row { display: flex; gap: 10px; align-items: center; margin-bottom: 8px; flex-wrap: wrap; }
.ticket-number code { font-size: 0.9em; background: #e9ecef; padding: 2px 6px; border-radius: 3px; }
.ticket-subject { margin: 6px 0 10px; font-size: 1.25em; }
.ticket-meta-detail { font-size: 0.85em; color: #555; }

.ticket-status, .ticket-priority { font-size: 0.8em; padding: 2px 8px; border-radius: 10px; font-weight: bold; }
.status-open       { background: #2980b9; color: #fff; }
.status-in_progress{ background: #8e44ad; color: #fff; }
.status-resolved   { background: #27ae60; color: #fff; }
.status-closed     { background: #7f8c8d; color: #fff; }
.priority-critical { background: #c0392b; color: #fff; }
.priority-high     { background: #e67e22; color: #fff; }
.priority-medium   { background: #f39c12; color: #fff; }
.priority-low      { background: #27ae60; color: #fff; }
.ticket-site       { font-size: 0.8em; background: #e9ecef; padding: 2px 8px; border-radius: 10px; }

.conversation-thread { margin-bottom: 24px; }
.message {
    margin-bottom: 14px; border-radius: 6px; padding: 14px 18px;
    box-shadow: 0 1px 3px rgba(0,0,0,.07);
}
.message-original { border-left: 4px solid #2980b9; background: #f0f6ff; }
.message-user      { border-left: 4px solid #27ae60; background: #f0fff4; }
.message-staff     { border-left: 4px solid #8e44ad; background: #f8f0ff; }
.message-header    { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; flex-wrap: wrap; }
.message-author    { font-weight: bold; font-size: 0.95em; }
.message-time      { font-size: 0.8em; color: #888; margin-left: auto; }
.message-body      { font-size: 0.95em; line-height: 1.6; white-space: pre-wrap; }
.message-role-badge { font-size: 0.75em; padding: 1px 7px; border-radius: 8px; }
.badge-user        { background: #27ae60; color: #fff; }
.badge-staff       { background: #8e44ad; color: #fff; }

.reply-box { background: #f8f9fa; border-radius: 6px; padding: 18px 22px; border: 1px solid #ddd; }
.reply-box h3 { margin-top: 0; font-size: 1em; color: #333; }
.reply-textarea {
    width: 100%; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px;
    padding: 10px; font-size: 0.95em; resize: vertical; font-family: inherit;
}
.reply-actions { display: flex; gap: 10px; margin-top: 10px; align-items: center; }
.btn { display: inline-block; padding: 8px 16px; border-radius: 4px; border: none; cursor: pointer; font-size: 0.9em; text-decoration: none; }
.btn-primary   { background: #1a7a4a; color: #fff; }
.btn-secondary { background: #6c757d; color: #fff; }
.alert-error   { background: #f8d7da; color: #721c24; padding: 10px 14px; border-radius: 4px; margin-bottom: 16px; }
.alert-success { background: #d4edda; color: #155724; padding: 10px 14px; border-radius: 4px; margin-bottom: 16px; }
</style>
