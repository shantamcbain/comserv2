<!DOCTYPE html>
<!-- File: /home/shanta/PycharmProjects/comserv/Comserv/root/layout.tt -->
<html data-debug-mode="[% c.session.debug_mode || 0 %]">[% PageVersion = 'layout.tt,v 0.01 2023/08/30 shanta Exp shanta ' %]
[%# DBI is now provided by the application context, no need to include DefaultDBI.tt %]
[% INCLUDE 'setup/DefaultVariables.tt' %]
    [% TRY %]
        [% INCLUDE 'setup/DefaultDBI.tt' %]
    [% CATCH %]
        [% # Silently ignore errors with DefaultDBI.tt %]
    [% END %]
    [% TRY %]
        [% INCLUDE 'setup/DefaultVariables.tt' %]
    [% CATCH %]
        [% # Silently ignore errors with DefaultVariables.tt %]
    [% END %]

[% IF c.session.debug_mode == 1 %]
 [% PageVersion %]
[% END %]
    [% INCLUDE 'Header.tt' %]
<body class="theme-[% theme_name || c.stash.theme_name || c.session.theme_name || 'default' %]">
    [% INCLUDE 'pagetop.tt' %]
[%# INCLUDE 'home.tt' %]
    [% content %]
    [% INCLUDE 'AdminNotes.tt' %]
    
    <!-- Back to Top Button -->
    <button id="back-to-top" title="Back to Top" aria-label="Back to Top">Back to Top</button>
    [% TRY %]
        [% INCLUDE 'footer.tt' %]
    [% CATCH %]
        <!-- Error including footer.tt: [% error.info %] -->
        <footer>
            <div class="footer-content">
                <p>&copy; [% USE date; date.format(date.now, '%Y') %] Comserv. All rights reserved.</p>
                [% IF c.session.debug_mode == 1 %]
                    <p>[% PageVersion %]</p>
                    <p><a href="/reset_session">Reset Session</a></p>
                [% END %]
            </div>
        </footer>
    [% END %]
    

    
    <script>
        function smoothScroll(target, duration) {
            var start = window.scrollY;
            var distance = target - start;
            var startTime = Date.now();
            
            function easeInOutQuad(t) {
                return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
            }
            
            function animateScroll() {
                var elapsed = Date.now() - startTime;
                var progress = Math.min(elapsed / duration, 1);
                var ease = easeInOutQuad(progress);
                
                window.scrollTo(0, start + distance * ease);
                
                if (progress < 1) {
                    requestAnimationFrame(animateScroll);
                }
            }
            
            animateScroll();
        }
        
        window.addEventListener('scroll', function() {
            const backToTop = document.getElementById('back-to-top');
            if (window.pageYOffset > 300) {
                if (backToTop) backToTop.classList.add('show');
            } else {
                if (backToTop) backToTop.classList.remove('show');
            }
        });
        
        const backToTop = document.getElementById('back-to-top');
        if (backToTop) {
            backToTop.addEventListener('click', function(e) {
                e.preventDefault();
                var mainMenu = document.getElementById('main-menu');
                if (mainMenu) {
                    var menuOffset = mainMenu.offsetTop;
                    smoothScroll(menuOffset, 800);
                } else {
                    window.scrollTo({top: 0, behavior: 'smooth'});
                }
            });
            
            backToTop.addEventListener('keypress', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    this.click();
                }
            });
        }
    </script>
</body>
</html>
