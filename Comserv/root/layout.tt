[% IF no_wrapper %]<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"></head><body style="margin:0;padding:0;">[% content %]</body></html>[% RETURN %][% END %]<!DOCTYPE html>
<!-- File: root/layout.tt -->
<html data-debug-mode="[% c.session.debug_mode || 0 %]">[% PageVersion = 'layout.tt,v 0.01 2023/08/30 shanta Exp shanta ' %]
[%# DBI is now provided by the application context, no need to include DefaultDBI.tt %]
[% INCLUDE 'setup/DefaultVariables.tt' %]
    [% TRY %]
        [% INCLUDE 'setup/DefaultDBI.tt' %]
    [% CATCH %]
        [% # Silently ignore errors with DefaultDBI.tt %]
    [% END %]
    [% TRY %]
        [% INCLUDE 'setup/DefaultVariables.tt' %]
    [% CATCH %]
        [% # Silently ignore errors with DefaultVariables.tt %]
    [% END %]

[% IF c.session.debug_mode == 1 %]
 [% PageVersion %]
[% END %]
    [% INCLUDE 'Header.tt' %]
<body class="theme-[% theme_name || c.stash.theme_name || c.session.theme_name || 'default' %][% IF c.stash.has_bg_image %] has-bg-image[% END %]">
[% IF c.stash.no_wrapper %]
    [% content %]
[% ELSIF c.stash.ai_popup_mode %]
    [%# Popup / detached-widget mode: render bare — no nav, no footer, no back-to-top %]
    [% content %]
    [%- SET cv = c.stash.css_v || '1' -%]
    <link rel="stylesheet" href="/static/css/ai-chat.css?v=[% cv %]">
    <script src="/static/js/ai-common.js?v=[% cv %]"></script>
    <script src="/static/js/local-chat.js?v=[% cv %]"></script>
[% ELSE %]
    [% INCLUDE 'pagetop.tt' %]
[%# INCLUDE 'home.tt' %]
    [% TRY %][% INCLUDE 'mail/subscribe_banner.tt' %][% CATCH %][% END %]
    [% content %]
    [% INCLUDE 'AdminNotes.tt' %]
    
    <!-- Back to Top Button -->
    <button id="back-to-top" title="Back to Top" aria-label="Back to Top">
        <i class="fas fa-arrow-up" aria-hidden="true"></i>
    </button>

    <!-- AI2 Code Editor floating button (and right-dock container) -->
    [% TRY %][% INCLUDE 'ai2/editor/code_editor_button.tt' %][% CATCH %][% END %]

    [% TRY %]
        [% INCLUDE 'footer.tt' %]
    [% CATCH %]
        [% IF c.session.debug_mode == 1 %]<!-- footer.tt error: [% error.info %] -->[% END %]
    [% END %]

    [% INCLUDE 'js_load.tt' %]
[% END %]

</body>

</html>
