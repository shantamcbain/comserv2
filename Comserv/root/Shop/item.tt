[% PageVersion = 'Shop/item.tt v0.01 2026/04/16 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<div class="app-container">

<div style="margin-bottom:var(--spacing-medium);font-family:var(--body-font);font-size:var(--font-size-small,0.85rem)">
  <a href="/shop" style="color:var(--primary-color);text-decoration:none"><i class="fas fa-store"></i> Shop</a>
  [% IF item.category %] &rsaquo; <a href="/shop?category=[% item.category | uri %]" style="color:var(--primary-color);text-decoration:none">[% item.category | html %]</a>[% END %]
  &rsaquo; <span style="color:var(--text-muted-color)">[% item.name | html %]</span>
  <span style="float:right">
    [% IF cart_count > 0 %]
    <a href="/Cart" style="color:var(--primary-color)"><i class="fas fa-shopping-cart"></i> Cart ([% cart_count %])</a>
    [% END %]
  </span>
</div>

<div class="content-container">
<div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--spacing-large)">

  <!-- Image column -->
  <div>
    [% IF item.image_path %]
    <img src="[% item.image_path | html %]" alt="[% item.name | html %]"
         style="width:100%;max-height:420px;object-fit:contain;border:1px solid var(--border-color);border-radius:8px;background:var(--secondary-color)">
    [% ELSE %]
    <div style="width:100%;height:280px;background:var(--secondary-color);border:1px solid var(--border-color);border-radius:8px;display:flex;align-items:center;justify-content:center">
      <i class="fas fa-box" style="font-size:4rem;color:var(--text-muted-color)"></i>
    </div>
    [% END %]
  </div>

  <!-- Detail column -->
  <div>
    <h1 style="margin:0 0 0.3em;font-family:var(--header-font);color:var(--text-color)">[% item.name | html %]</h1>
    [% IF item.sku %]
    <p style="font-size:var(--font-size-small,0.85rem);color:var(--text-muted-color);font-family:var(--body-font);margin:0 0 0.5em">
      SKU: [% item.sku | html %]
      [% IF item.barcode %] &bull; Barcode: [% item.barcode | html %][% END %]
    </p>
    [% END %]

    <!-- Price -->
    <div style="margin:0.8em 0">
      [% IF display_price > 0 %]
        [% IF item.discount_percent > 0 %]
        <del style="color:var(--text-muted-color);font-size:1.1rem;font-family:var(--header-font)">$[% display_price | format('%.2f') %]</del>
        <strong style="color:var(--primary-color);font-size:1.8rem;font-family:var(--header-font);margin-left:0.4em">
          $[% sale_price | format('%.2f') %]
        </strong>
        <span style="font-size:0.85rem;background:#d4edda;color:#155724;border-radius:4px;padding:2px 8px;margin-left:0.5em">
          Save [% item.discount_percent %]%
        </span>
        [% ELSE %]
        <strong style="color:var(--primary-color);font-size:1.8rem;font-family:var(--header-font)">$[% display_price | format('%.2f') %]</strong>
        [% END %]
        <span style="font-size:0.85rem;color:var(--text-muted-color);font-family:var(--body-font);margin-left:0.5em">[% item.currency || 'CAD' %] / [% item.unit_of_measure || 'each' %]</span>
      [% ELSE %]
      <em style="color:var(--text-muted-color);font-family:var(--body-font)">Price on request</em>
      [% END %]
    </div>

    <!-- Stock -->
    <p style="font-family:var(--body-font);font-size:var(--font-size-small,0.9rem);margin:0 0 1em">
      [% IF total_stock > 0 %]
      <span style="color:var(--success-color,green)"><i class="fas fa-check-circle"></i> [% total_stock %] in stock</span>
      [% ELSE %]
      <span style="color:var(--text-muted-color)"><i class="fas fa-times-circle"></i> Out of stock</span>
      [% END %]
    </p>

    <!-- Add to Cart form -->
    [% IF display_price > 0 %]
    <form method="POST" action="/Cart/add" id="add-to-cart-form">
      <input type="hidden" name="item_id" value="[% item.id %]">

      [% IF options.size > 0 %]
      <div style="margin-bottom:0.8em">
        [% FOREACH opt IN options %]
        <div style="margin-bottom:0.5em">
          <label style="display:block;font-weight:bold;font-family:var(--body-font);font-size:0.9rem;margin-bottom:0.3em;color:var(--text-color)">[% opt.label | html %]:</label>
          [% IF opt.type == 'select' %]
          <select name="options" style="padding:6px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color);font-family:var(--body-font)">
            [% FOREACH v IN opt.values %]
            <option value="[% v | html %]">[% v | html %]</option>
            [% END %]
          </select>
          [% ELSE %]
          <input type="text" name="options" placeholder="[% opt.placeholder || opt.label | html %]"
                 style="padding:6px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color);font-family:var(--body-font)">
          [% END %]
        </div>
        [% END %]
      </div>
      [% END %]

      <div style="display:flex;gap:0.6em;align-items:center;margin-top:0.5em">
        <label style="font-family:var(--body-font);font-size:0.9rem;color:var(--text-color)">
          Qty:
          <input type="number" name="quantity" value="1" min="1" [% IF total_stock > 0 %]max="[% total_stock %]"[% END %]
                 style="width:65px;padding:6px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color);margin-left:0.3em">
        </label>
        [% IF total_stock > 0 %]
        <button type="submit" style="padding:8px 20px;background:var(--primary-color);color:#fff;border:none;border-radius:4px;cursor:pointer;font-family:var(--body-font);font-size:1rem">
          <i class="fas fa-cart-plus"></i> Add to Cart
        </button>
        [% ELSE %]
        <button type="button" disabled style="padding:8px 20px;background:var(--border-color);color:var(--text-muted-color);border:none;border-radius:4px;font-family:var(--body-font);font-size:1rem;cursor:not-allowed">
          Out of Stock
        </button>
        [% END %]
      </div>
    </form>
    [% ELSE %]
    <a href="mailto:[% sitename %]@cscoop.ca" style="display:inline-block;padding:8px 20px;background:var(--primary-color);color:#fff;border-radius:4px;text-decoration:none;font-family:var(--body-font)">
      <i class="fas fa-envelope"></i> Enquire by email
    </a>
    [% END %]

    [% IF item.list_in_marketplace && item.marketplace_listing_id %]
    <p style="margin-top:0.8em;font-size:var(--font-size-small,0.85rem);font-family:var(--body-font)">
      <a href="/marketplace/view/[% item.marketplace_listing_id %]" style="color:var(--primary-color)">
        <i class="fas fa-globe"></i> Also listed in the Marketplace
      </a>
    </p>
    [% END %]
  </div>
</div>

<!-- Description -->
[% IF item.description %]
<div style="margin-top:var(--spacing-large);padding-top:var(--spacing-medium);border-top:1px solid var(--border-color)">
  <h2 style="font-family:var(--header-font);color:var(--text-color);font-size:1.2rem">Description</h2>
  <p style="font-family:var(--body-font);color:var(--text-color);white-space:pre-line">[% item.description | html %]</p>
</div>
[% END %]

<!-- Item details -->
<div style="margin-top:var(--spacing-medium);padding-top:var(--spacing-medium);border-top:1px solid var(--border-color)">
  <h2 style="font-family:var(--header-font);color:var(--text-color);font-size:1.1rem">Item Details</h2>
  <table style="font-family:var(--body-font);font-size:0.9rem;border-collapse:collapse">
    [% IF item.condition %]
    <tr>
      <td style="padding:4px 12px 4px 0;color:var(--text-muted-color)">Condition:</td>
      <td style="padding:4px 0;color:var(--text-color)">[% item.condition | html %]</td>
    </tr>
    [% END %]
    [% IF item.unit_of_measure %]
    <tr>
      <td style="padding:4px 12px 4px 0;color:var(--text-muted-color)">Unit:</td>
      <td style="padding:4px 0;color:var(--text-color)">[% item.unit_of_measure | html %]</td>
    </tr>
    [% END %]
    [% IF item.category %]
    <tr>
      <td style="padding:4px 12px 4px 0;color:var(--text-muted-color)">Category:</td>
      <td style="padding:4px 0"><a href="/shop?category=[% item.category | uri %]" style="color:var(--primary-color)">[% item.category | html %]</a></td>
    </tr>
    [% END %]
  </table>
</div>

<!-- Admin links -->
[% IF c.stash.is_admin %]
<div style="margin-top:var(--spacing-medium);padding:0.6em 1em;background:var(--secondary-color);border-radius:4px;font-size:var(--font-size-small,0.85rem);font-family:var(--body-font)">
  <strong>Admin:</strong>
  <a href="/shop/admin/edit/[% item.id %]" style="color:var(--primary-color);margin-left:0.5em"><i class="fas fa-edit"></i> Edit Shop Listing</a>
  &bull;
  <a href="/Inventory/item/[% item.id %]" style="color:var(--primary-color);margin-left:0.3em"><i class="fas fa-boxes"></i> Inventory Record</a>
  [% IF !item.list_in_marketplace %]
  &bull;
  <form method="POST" action="/Inventory/push_to_marketplace" style="display:inline">
    <input type="hidden" name="item_id" value="[% item.id %]">
    <button type="submit" style="background:none;border:none;color:var(--primary-color);cursor:pointer;font-size:inherit;padding:0 0 0 0.3em;font-family:var(--body-font)">
      <i class="fas fa-share-alt"></i> Push to Marketplace
    </button>
  </form>
  [% END %]
</div>
[% END %]

</div>
</div>
