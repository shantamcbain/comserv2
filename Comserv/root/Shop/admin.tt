[% PageVersion = 'Shop/admin.tt v0.02 2026/04/16 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<div class="app-container">

<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.5em;margin-bottom:var(--spacing-medium)">
  <h1 style="margin:0;color:var(--text-color);font-family:var(--header-font)">
    <i class="fas fa-store-alt"></i> Shop Admin — [% sitename %]
  </h1>
  <div style="display:flex;gap:0.5em;flex-wrap:wrap">
    <a href="/shop" style="padding:6px 14px;background:var(--primary-color);color:#fff;border-radius:4px;text-decoration:none;font-family:var(--body-font)">
      <i class="fas fa-eye"></i> View Store
    </a>
    <a href="/shop/setup" style="padding:6px 14px;border:1px solid var(--border-color);color:var(--text-color);border-radius:4px;text-decoration:none;font-family:var(--body-font)">
      <i class="fas fa-cog"></i> eCommerce Settings
    </a>
    <a href="/Cart/orders" style="padding:6px 14px;border:1px solid var(--border-color);color:var(--text-color);border-radius:4px;text-decoration:none;font-family:var(--body-font)">
      <i class="fas fa-receipt"></i> Orders
    </a>
    <a href="/Inventory" style="padding:6px 14px;border:1px solid var(--border-color);color:var(--text-color);border-radius:4px;text-decoration:none;font-family:var(--body-font)">
      <i class="fas fa-boxes"></i> Inventory
    </a>
    <a href="/admin" style="padding:6px 14px;border:1px solid var(--border-color);color:var(--text-color);border-radius:4px;text-decoration:none;font-family:var(--body-font)">
      <i class="fas fa-tachometer-alt"></i> Admin Desktop
    </a>
  </div>
</div>

[% IF c.flash.success_msg %]
<div style="background:var(--success-color,#d4edda);color:#155724;border:1px solid #c3e6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.success_msg %]</div>
[% END %]
[% IF c.flash.error_msg || error_msg %]
<div style="background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.error_msg || error_msg %]</div>
[% END %]

[% IF !is_ecommerce %]
<div style="background:var(--schema-alert-warning-bg,#fff3cd);border:1px solid #ffc107;border-radius:4px;padding:0.8em 1em;margin-bottom:1em;font-family:var(--body-font)">
  <i class="fas fa-exclamation-triangle"></i>
  eCommerce is not enabled for <strong>[% sitename %]</strong> — the Shop link is hidden from the nav.
  <a href="/shop/setup" style="color:var(--primary-color);font-weight:bold;margin-left:0.5em">Enable Now &rarr;</a>
</div>
[% END %]

<div class="content-container">

<!-- Filter bar -->
<div style="margin-bottom:var(--spacing-medium);display:flex;gap:0.5em;align-items:center;font-family:var(--body-font);flex-wrap:wrap">
  <form method="GET" action="/shop/admin" style="display:contents">
    <label style="color:var(--text-color)">Status:</label>
    <select name="status" onchange="this.form.submit()" style="padding:5px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
      <option value="all"      [% IF filter_status == 'all'      %]selected[% END %]>All</option>
      <option value="active"   [% IF filter_status == 'active'   %]selected[% END %]>Active</option>
      <option value="inactive" [% IF filter_status == 'inactive' %]selected[% END %]>Inactive</option>
    </select>
    <label style="color:var(--text-color);margin-left:0.4em">Visibility:</label>
    <select name="visibility" onchange="this.form.submit()" style="padding:5px 10px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
      <option value="all"     [% IF filter_visibility == 'all'     %]selected[% END %]>All</option>
      <option value="visible" [% IF filter_visibility == 'visible' %]selected[% END %]>Visible in shop</option>
      <option value="hidden"  [% IF filter_visibility == 'hidden'  %]selected[% END %]>Hidden</option>
    </select>
  </form>
  <span style="margin-left:auto;color:var(--text-muted-color);font-size:0.85rem">
    [% items.size %] item(s)
  </span>
  <form method="POST" action="/shop/admin/reset_visibility"
        onsubmit="return confirm('Hide ALL items from the shop? You can re-enable them one by one.')">
    <button type="submit"
            style="padding:5px 12px;background:#b71c1c;color:#fff;border:none;border-radius:4px;cursor:pointer;font-family:var(--body-font);font-size:0.85rem">
      Hide All
    </button>
  </form>
</div>

[% IF items.size == 0 %]
<div style="text-align:center;padding:40px 20px;color:var(--text-muted-color,#666);font-family:var(--body-font)">
  <i class="fas fa-box-open" style="font-size:2.5rem;opacity:0.3;display:block;margin-bottom:12px"></i>
  <p>No items found. <a href="/Inventory/items/add" style="color:var(--primary-color)">Add an inventory item</a> to get started.</p>
</div>
[% ELSE %]

<div style="overflow-x:auto">
<table style="width:100%;border-collapse:collapse;font-family:var(--body-font);font-size:0.88rem">
  <thead>
    <tr style="border-bottom:2px solid var(--border-color);background:var(--secondary-color)">
      <th style="padding:8px 10px;text-align:left;color:var(--text-color);white-space:nowrap">Image</th>
      <th style="padding:8px 10px;text-align:left;color:var(--text-color)">Name / SKU</th>
      <th style="padding:8px 10px;text-align:left;color:var(--text-color)">Category</th>
      <th style="padding:8px 10px;text-align:right;color:var(--text-color);white-space:nowrap">Price</th>
      <th style="padding:8px 10px;text-align:center;color:var(--text-color);white-space:nowrap">In Shop</th>
      <th style="padding:8px 10px;text-align:center;color:var(--text-color);white-space:nowrap">Hide Stock</th>
      <th style="padding:8px 10px;text-align:center;color:var(--text-color)">Status</th>
      <th style="padding:8px 10px;text-align:center;color:var(--text-color)">Mkt</th>
      <th style="padding:8px 10px;text-align:center;color:var(--text-color)">Actions</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH item IN items %]
    [% display_price = item.unit_price || item.unit_cost || 0 %]
    <tr style="border-bottom:1px solid var(--border-color)">

      <td style="padding:6px 10px">
        [% IF item.image_path %]
        <img src="[% item.image_path | html %]" alt=""
             style="width:44px;height:44px;object-fit:cover;border-radius:4px;border:1px solid var(--border-color)">
        [% ELSE %]
        <div style="width:44px;height:44px;background:var(--secondary-color);border-radius:4px;border:1px solid var(--border-color);display:flex;align-items:center;justify-content:center">
          <i class="fas fa-box" style="color:var(--text-muted-color);font-size:1.2rem"></i>
        </div>
        [% END %]
      </td>

      <td style="padding:6px 10px;color:var(--text-color)">
        <strong>[% item.name | html %]</strong>
        [% IF item.sku %]<br><small style="color:var(--text-muted-color)">[% item.sku | html %]</small>[% END %]
      </td>

      <td style="padding:6px 10px;color:var(--text-muted-color)">[% item.category || '—' %]</td>

      <td style="padding:6px 10px;text-align:right;color:var(--text-color);white-space:nowrap">
        [% IF display_price > 0 %]
          $[% display_price | format('%.2f') %]
          [% IF item.discount_percent > 0 %]<br><small style="color:#155724">[% item.discount_percent %]% off</small>[% END %]
        [% ELSE %]
          <em style="color:var(--text-muted-color)">—</em>
        [% END %]
      </td>

      <!-- In Shop toggle -->
      <td style="padding:6px 10px;text-align:center">
        <form method="POST" action="/shop/admin/toggle/[% item.id %]" style="display:inline">
          <input type="hidden" name="return_to" value="/shop/admin">
          [% IF item.show_in_shop %]
          <button type="submit" title="Click to hide from store"
                  style="padding:3px 10px;background:#d4edda;color:#155724;border:1px solid #c3e6cb;border-radius:4px;cursor:pointer;font-family:var(--body-font);font-size:0.8rem;white-space:nowrap">
            <i class="fas fa-check"></i> Visible
          </button>
          [% ELSE %]
          <button type="submit" title="Click to show in store"
                  style="padding:3px 10px;background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;border-radius:4px;cursor:pointer;font-family:var(--body-font);font-size:0.8rem;white-space:nowrap">
            <i class="fas fa-eye-slash"></i> Hidden
          </button>
          [% END %]
        </form>
      </td>

      <!-- Hide stock count indicator -->
      <td style="padding:6px 10px;text-align:center">
        [% IF item.hide_stock_count %]
        <span title="Stock count hidden from customers" style="color:var(--text-muted-color);font-size:0.8rem"><i class="fas fa-eye-slash"></i> Yes</span>
        [% ELSE %]
        <span style="color:var(--text-muted-color);font-size:0.8rem">—</span>
        [% END %]
      </td>

      <td style="padding:6px 10px;text-align:center">
        [% IF item.status == 'active' %]
        <span style="background:#d4edda;color:#155724;border-radius:3px;padding:2px 7px;font-size:0.78rem">Active</span>
        [% ELSE %]
        <span style="background:#f8d7da;color:#721c24;border-radius:3px;padding:2px 7px;font-size:0.78rem">[% item.status | html %]</span>
        [% END %]
      </td>

      <td style="padding:6px 10px;text-align:center">
        [% IF item.list_in_marketplace %]
        <a href="/marketplace/view/[% item.marketplace_listing_id %]" title="In Marketplace" style="color:var(--primary-color)">
          <i class="fas fa-check-circle"></i>
        </a>
        [% ELSE %]
        <form method="POST" action="/Inventory/push_to_marketplace" style="display:inline">
          <input type="hidden" name="item_id" value="[% item.id %]">
          <button type="submit" title="Push to Marketplace" style="background:none;border:none;cursor:pointer;color:var(--text-muted-color);padding:0">
            <i class="fas fa-share-alt"></i>
          </button>
        </form>
        [% END %]
      </td>

      <td style="padding:6px 10px;text-align:center;white-space:nowrap">
        <a href="/shop/admin/edit/[% item.id %]" title="Edit shop listing" style="color:var(--primary-color);margin:0 3px">
          <i class="fas fa-edit"></i>
        </a>
        <a href="/shop/item/[% item.id %]" title="Preview in store" style="color:var(--text-muted-color);margin:0 3px">
          <i class="fas fa-eye"></i>
        </a>
        <a href="/Inventory/item/[% item.id %]" title="Inventory record" style="color:var(--text-muted-color);margin:0 3px">
          <i class="fas fa-boxes"></i>
        </a>
      </td>
    </tr>
  [% END %]
  </tbody>
</table>
</div>

[% END %]

<div style="margin-top:var(--spacing-large);font-family:var(--body-font);font-size:0.85rem;color:var(--text-muted-color)">
  <p><i class="fas fa-lightbulb"></i>
    <strong>Tip:</strong> Use <em>In Shop</em> to control what customers see.
    Items with <em>Hide Stock</em> show as available without revealing the quantity — ideal for made-to-order items (3D prints, custom work).
    Set a price on the <a href="/Inventory" style="color:var(--primary-color)">Inventory</a> item, then toggle it visible here.
  </p>
</div>

</div>
</div>
