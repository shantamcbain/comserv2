[% META
   title = "Job Board"
   description = "Browse open job postings"
   roles = "any"
   TemplateType = "Application"
   category = "Jobs"
   page_version = "0.01"
   last_updated = "2026-04-04"
%]
[% IF c.flash.error_msg %]<div class="error">[% c.flash.error_msg | html %]</div>[% END %]
[% IF c.flash.success_msg %]<div class="success">[% c.flash.success_msg | html %]</div>[% END %]

<div class="app-container">
  <div class="page-header">
    <h1>Job Board</h1>
    <div class="header-actions">
      <a href="[% c.uri_for('/job/post') %]" class="btn btn-primary">Post a Job</a>
    </div>
  </div>

  <div class="content-container">
    <div class="content-primary">

      [% IF jobs.size %]
      <table class="data-table" style="width:100%">
        <thead>
          <tr>
            <th>Title</th>
            <th>Location</th>
            <th>Payment</th>
            <th>Posted</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          [% FOREACH job IN jobs %]
          <tr>
            <td>
              <a href="[% c.uri_for('/job/view', [job.id]) %]"><strong>[% job.title | html %]</strong></a>
              [% IF job.remote %]<span class="badge badge-info" style="margin-left:0.5em">Remote</span>[% END %]
            </td>
            <td>[% job.location | html || '—' %]</td>
            <td>
              [% IF job.payment_type == 'points' %]
                <span class="badge badge-success">Points ([% job.point_rate | format('%.0f') %]/hr)</span>
              [% ELSIF job.payment_type == 'hybrid' %]
                <span class="badge badge-warning">Hybrid</span>
              [% ELSE %]
                <span class="badge">Cash</span>
              [% END %]
              [% IF job.accept_points_payment %]
                <span class="badge badge-success" title="Poster accepts paying via points" style="margin-left:0.25em">&#9670; Points OK</span>
              [% END %]
            </td>
            <td style="font-size:0.85em;white-space:nowrap">[% job.created_at | html %]</td>
            <td>
              <a href="[% c.uri_for('/job/apply', [job.id]) %]" class="btn btn-sm btn-primary">Apply</a>
            </td>
          </tr>
          [% END %]
        </tbody>
      </table>
      [% ELSE %]
      <div class="content-section">
        <p class="empty-state">No open jobs right now. <a href="[% c.uri_for('/job/post') %]">Post one</a>.</p>
      </div>
      [% END %]

    </div>
  </div>
</div>
