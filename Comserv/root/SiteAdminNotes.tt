[% PageVersion	= 'SiteAdminNotes.tt,v 0.01 2024/01/12 shanta Exp shanta '	%]
[% IF c.session.debug_mode == 1 %]
 [%	PageVersion %]
    [% "Debugging HostName: " _ HostName %]
    [%# INCLUDE 'debug.tt' %]
[% END %]
[%  group = c.session.group %]
[% IF username == 'Shanta' OR
        group   == 'admin' OR
       group   == 'BHN_admin' OR
       group   == 'BMaster_Admin' OR
       group   == 'USBM_admin' OR
  	    group   == 'Apis_Admin' OR
  	    group   == 'AnuCollective_admin' OR
       group   == 'ECF_admin' OR
       group   == 'LumbyThrift_admin' OR
       group   == 'HE_admin' OR
       group   == 'WiseWoman_admin'
%]


  [% FOREACH link = c.stash.dbi.query("SELECT sitename, title AS view_name, id AS record_id, body, status, page_code, keywords, description, updated_at AS lastupdate, '' AS news FROM page WHERE (status = 'active' OR status = '2' OR status = 2) AND page_code = 'SiteAdminNotes' AND sitename = '$SiteName' ORDER BY sitename") %]
               [% PROCESS 'CSC/pagefields.tt' %]
 [% END %]


  <a href="/admin/edit_admin_notes?site=[% SiteName %]"><h3>Edit Admin Notes</h3></a>
   [% AdminNotes   %]
 [% END %]