[% PageVersion = 'Cart/orders.tt v0.01 2026/04/13 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Customer Orders</h1>
<p>Site: <strong>[% sitename %]</strong></p>

[% IF c.flash.success_msg %]<p class="success">[% c.flash.success_msg %]</p>[% END %]
[% IF c.flash.error_msg %]<p class="error">[% c.flash.error_msg %]</p>[% END %]

<form method="GET" action="/Cart/orders" style="margin-bottom:1em">
  <label>Status:
    <select name="status">
      <option value="">— All —</option>
      <option value="new" [% IF status == 'new' %]selected[% END %]>New</option>
      <option value="processing" [% IF status == 'processing' %]selected[% END %]>Processing</option>
      <option value="fulfilled" [% IF status == 'fulfilled' %]selected[% END %]>Fulfilled</option>
      <option value="cancelled" [% IF status == 'cancelled' %]selected[% END %]>Cancelled</option>
    </select>
  </label>
  <input type="submit" value="Filter">
</form>

[% IF invoices.size == 0 %]
  <p>No orders found.</p>
[% ELSE %]
<table border="1" cellpadding="5" cellspacing="0" style="border-collapse:collapse;width:100%">
  <thead style="background:#f5f5f5">
    <tr>
      <th>Invoice #</th>
      <th>Date</th>
      <th>Customer</th>
      <th>Payment</th>
      <th>Pay Status</th>
      <th>Total</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH inv IN invoices %]
    <tr>
      <td><a href="/Cart/order/[% inv.id %]">[% inv.invoice_number %]</a></td>
      <td>[% inv.created_at %]</td>
      <td>[% inv.customer_name || inv.ordered_by || 'Guest' %]</td>
      <td>[% inv.payment_method %]</td>
      <td>[% inv.payment_status %]</td>
      <td>$[% inv.total_amount | format('%.2f') %]</td>
      <td>[% inv.status %]</td>
      <td><a href="/Cart/order/[% inv.id %]">View</a></td>
    </tr>
  [% END %]
  </tbody>
</table>
[% END %]
