[% PageVersion = 'Cart/price_list.tt v0.01 2026/04/13 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>Price List</h1>
<p>Site: <strong>[% sitename %]</strong></p>

[% IF c.flash.success_msg %]<p class="success">[% c.flash.success_msg %]</p>[% END %]
[% IF c.flash.error_msg %]<p class="error">[% c.flash.error_msg %]</p>[% END %]

<div style="margin-bottom:1em">
  <a href="/Cart" style="font-weight:bold">🛒 View Cart ([% cart_count %] items)</a>
</div>

<form method="GET" action="/Cart/price_list" style="margin-bottom:1em">
  <label>Filter by Category:
    <select name="category" onchange="this.form.submit()">
      <option value="">— All Categories —</option>
      [% FOREACH cat IN categories %]
        <option value="[% cat.category %]" [% IF category == cat.category %]selected[% END %]>
          [% cat.category %]
        </option>
      [% END %]
    </select>
  </label>
  <input type="submit" value="Filter">
  [% IF category %]<a href="/Cart/price_list">Clear</a>[% END %]
</form>

[% IF items.size == 0 %]
  <p>No items are currently available. Please check back later.</p>
[% ELSE %]
<table border="1" cellpadding="6" cellspacing="0" style="border-collapse:collapse;width:100%">
  <thead style="background:#f5f5f5">
    <tr>
      <th>SKU</th>
      <th>Item</th>
      <th>Category</th>
      <th>Unit</th>
      <th>Price</th>
      <th>In Stock</th>
      <th>Add to Cart</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH item IN items %]
    [% total_stock = 0 %]
    [% FOREACH sl IN item.stock_levels %]
      [% total_stock = total_stock + sl.quantity_on_hand %]
    [% END %]
    [% display_price = item.unit_price || item.unit_cost || 0 %]
    <tr>
      <td><small>[% item.sku %]</small></td>
      <td>
        <strong>[% item.name %]</strong>
        [% IF item.description %]<br><small>[% item.description | truncate(80) %]</small>[% END %]
      </td>
      <td>[% item.category || '—' %]</td>
      <td>[% item.unit_of_measure %]</td>
      <td>
        [% IF display_price > 0 %]
          <strong>$[% display_price | format('%.2f') %]</strong>
        [% ELSE %]
          <em>Contact for price</em>
        [% END %]
      </td>
      <td>
        [% IF total_stock > 0 %]
          <span style="color:green">[% total_stock %] available</span>
        [% ELSE %]
          <span style="color:#999">Out of stock</span>
        [% END %]
      </td>
      <td>
        [% IF display_price > 0 %]
        <form method="POST" action="/Cart/add">
          <input type="hidden" name="item_id" value="[% item.id %]">
          <input type="hidden" name="category" value="[% category %]">
          <label>Qty: <input type="number" name="quantity" value="1" min="1" style="width:50px"></label>
          [% IF item.description && item.description.match('option|custom|colour|color|material|size') %]
          <br><label>Options: <input type="text" name="options" placeholder="e.g. red, large" style="width:120px"></label>
          [% END %]
          <input type="submit" value="Add to Cart">
        </form>
        [% ELSE %]
          <a href="mailto:[% sitename %]@cscoop.ca">Enquire</a>
        [% END %]
      </td>
    </tr>
  [% END %]
  </tbody>
</table>
[% END %]

<div style="margin-top:1.5em">
  <a href="/Cart">🛒 View Cart ([% cart_count %] items)</a>
</div>
