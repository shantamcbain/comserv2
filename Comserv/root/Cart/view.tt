[% PageVersion = 'Cart/view.tt v0.02 2026/04/13 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<div class="app-container">
<div class="page-header">
  <h1 style="color:var(--text-color);font-family:var(--header-font)"><i class="fas fa-shopping-cart"></i> Your Cart</h1>
</div>

[% IF c.flash.success_msg %]
  <div style="background:var(--success-color,#d4edda);color:#155724;border:1px solid #c3e6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.success_msg %]</div>
[% END %]
[% IF c.flash.error_msg %]
  <div style="background:#f8d7da;color:#721c24;border:1px solid #f5c6cb;border-radius:4px;padding:0.6em 1em;margin-bottom:1em">[% c.flash.error_msg %]</div>
[% END %]

<div class="content-container">

[% cart_keys = cart.keys %]
[% IF cart_keys.size == 0 %]
  <p style="color:var(--text-muted-color);font-family:var(--body-font)">
    Your cart is empty. <a href="/Cart/price_list" style="color:var(--primary-color)">Browse the shop</a>.
  </p>
[% ELSE %]

<form method="POST" action="/Cart/update">
<table style="border-collapse:collapse;width:100%;font-family:var(--body-font)">
  <thead>
    <tr style="background:var(--table-header-bg);color:var(--text-color)">
      <th style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:left">SKU</th>
      <th style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:left">Item</th>
      <th style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:left">Options</th>
      <th style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:right">Unit Price</th>
      <th style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:center">Qty</th>
      <th style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:right">Line Total</th>
      <th style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:center">Remove</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH key IN cart_keys %]
    [% line = cart.$key %]
    [% line_total = line.quantity * line.unit_price %]
    <tr style="color:var(--text-color)">
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color)">
        <small>[% line.sku %]</small>
        [% IF line.item_type == 'workshop' %]<br><span style="font-size:0.75em;color:var(--primary-color)"><i class="fas fa-chalkboard-teacher"></i> Workshop</span>[% END %]
      </td>
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color)">[% line.name %]</td>
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color)"><small style="color:var(--text-muted-color)">[% line.options || '—' %]</small></td>
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:right">$[% line.unit_price | format('%.2f') %]</td>
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:center">
        <input type="number" name="qty_[% key %]" value="[% line.quantity %]" min="0" style="width:55px;padding:3px 6px;border:1px solid var(--border-color);border-radius:4px;background:var(--background-color);color:var(--text-color)">
      </td>
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:right">$[% line_total | format('%.2f') %]</td>
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:center">
        <a href="/Cart/remove/[% key %]" onclick="return confirm('Remove this item?')" style="color:var(--warning-color)">Remove</a>
      </td>
    </tr>
  [% END %]
  </tbody>
  <tfoot>
    <tr style="color:var(--text-color)">
      <td colspan="5" style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:right"><strong>Subtotal:</strong></td>
      <td style="padding:0.5em 0.8em;border:1px solid var(--border-color);text-align:right"><strong>$[% cart_total %]</strong></td>
      <td style="border:1px solid var(--border-color)"></td>
    </tr>
  </tfoot>
</table>

<div style="margin-top:var(--spacing-medium)">
  <button type="submit" style="padding:0.4em 1em;background:var(--secondary-color,#f0f0f0);color:var(--text-color);border:1px solid var(--border-color);border-radius:4px;cursor:pointer;font-family:var(--body-font)">Update Quantities</button>
</div>
</form>

<div style="margin-top:var(--spacing-medium);display:flex;gap:var(--spacing-medium);flex-wrap:wrap;align-items:center">
  <a href="/Cart/price_list" style="color:var(--primary-color);font-family:var(--body-font)">← Continue Shopping</a>
  <a href="/Cart/checkout" style="display:inline-block;padding:0.5em 1.4em;background:var(--primary-color);color:var(--text-color);border:1px solid var(--border-color);border-radius:4px;text-decoration:none;font-family:var(--body-font);font-weight:bold">Proceed to Checkout →</a>
</div>

[% END %]
</div>
</div>
