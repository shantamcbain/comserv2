[% PageVersion = 'Cart/view.tt v0.01 2026/04/13 shanta Exp' %]
[% IF c.session.debug_mode == 1 %][% PageVersion %][% END %]

<h1>🛒 Your Cart</h1>

[% IF c.flash.success_msg %]<p class="success">[% c.flash.success_msg %]</p>[% END %]
[% IF c.flash.error_msg %]<p class="error">[% c.flash.error_msg %]</p>[% END %]

[% cart_keys = cart.keys %]
[% IF cart_keys.size == 0 %]
  <p>Your cart is empty. <a href="/Cart/price_list">Browse the price list</a>.</p>
[% ELSE %]

<form method="POST" action="/Cart/update">
<table border="1" cellpadding="6" cellspacing="0" style="border-collapse:collapse;width:100%">
  <thead style="background:#f5f5f5">
    <tr>
      <th>SKU</th>
      <th>Item</th>
      <th>Options</th>
      <th>Unit Price</th>
      <th>Qty</th>
      <th>Line Total</th>
      <th>Remove</th>
    </tr>
  </thead>
  <tbody>
  [% FOREACH key IN cart_keys %]
    [% line = cart.$key %]
    [% line_total = line.quantity * line.unit_price %]
    <tr>
      <td><small>[% line.sku %]</small></td>
      <td>[% line.name %]</td>
      <td><small>[% line.options || '—' %]</small></td>
      <td>$[% line.unit_price | format('%.2f') %]</td>
      <td>
        <input type="number" name="qty_[% key %]" value="[% line.quantity %]" min="0" style="width:55px">
      </td>
      <td>$[% line_total | format('%.2f') %]</td>
      <td>
        <a href="/Cart/remove/[% key %]" onclick="return confirm('Remove this item?')">Remove</a>
      </td>
    </tr>
  [% END %]
  </tbody>
  <tfoot>
    <tr>
      <td colspan="5" style="text-align:right"><strong>Subtotal:</strong></td>
      <td><strong>$[% cart_total %]</strong></td>
      <td></td>
    </tr>
  </tfoot>
</table>

<div style="margin-top:1em">
  <input type="submit" value="Update Quantities">
</div>
</form>

<div style="margin-top:1em">
  <a href="/Cart/price_list">← Continue Shopping</a>
  &nbsp;&nbsp;
  <a href="/Cart/checkout" style="font-weight:bold;font-size:1.1em">Proceed to Checkout →</a>
</div>

[% END %]
