[%
   title = "Email Unsubscribe"
   description = "Workshop email opt-out"
   TemplateType = "Application"
   category = "WorkShops"
   page_version = "0.01"
   last_updated = "2026-03-26"
%]

<div class="app-container">

    <div class="page-header">
        <h1>Email Preferences</h1>
        [% IF workshop %]
        <h2 class="page-subtitle">Workshop: [% workshop.title | html %]</h2>
        [% END %]
    </div>

    <div class="content-container">
        <div class="content-primary">

            <div class="content-section">
                <p>[% message | html %]</p>
            </div>

            [% IF workshop %]
            <div class="page-footer">
                <div class="footer-actions">
                    <a href="/workshop/details?id=[% workshop.id %]" class="btn btn-secondary">Workshop Details</a>
                </div>
            </div>
            [% END %]

        </div>
    </div>

</div>
