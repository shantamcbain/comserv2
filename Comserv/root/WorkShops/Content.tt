[% META 
   title = "Workshop Content"
   description = "Manage workshop online content sections"
   roles = "admin,workshop_leader"
   TemplateType = "Application"
   category = "WorkShops"
   page_version = "0.01"
   last_updated = "2026-02-16"
%]

[% PageVersion = 'WorkShops/Content.tt,v 0.01 2026/02/16 shanta Exp shanta' %]
[% IF debug_mode == 1 %]
 [% PageVersion %]
[% END %]

<div class="app-container">
    
    <div class="page-header">
        <h1>Workshop Content</h1>
        <h2 class="page-subtitle">[% workshop.title | html %]</h2>
    </div>
    
    <div class="content-container">
        
        <div class="content-primary">
            
            [% IF c.flash.error_msg %]
                <div class="error">[% c.flash.error_msg %]</div>
            [% END %]
            
            [% IF c.flash.success_msg %]
                <div class="success">[% c.flash.success_msg %]</div>
            [% END %]
            
            <div class="form-actions">
                <a href="/workshop/add_content/[% workshop.id %]" class="btn btn-primary">Add Content Section</a>
            </div>
            
            <div class="data-container">
                <h2>Content Sections</h2>
                
                [% IF content_sections.size > 0 %]
                <div class="content-list">
                    [% FOREACH content IN content_sections %]
                    <div class="content-section">
                        <div class="content-header">
                            <h3>
                                <span class="sort-order">#[% content.sort_order || 0 %]</span>
                                [% content.title | html %]
                            </h3>
                            <div class="content-actions">
                                <a href="/workshop/edit_content/[% content.id %]" class="btn btn-sm btn-edit">Edit</a>
                                <form action="/workshop/delete_content/[% content.id %]" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-delete" onclick="return confirm('Are you sure you want to delete this content section?');">Delete</button>
                                </form>
                            </div>
                        </div>
                        <div class="content-body">
                            [% content.content | html %]
                        </div>
                        <div class="content-meta">
                            [% IF content.content_type %]
                            <span class="badge badge-info">[% content.content_type | html %]</span>
                            [% END %]
                            <small>Created: [% content.created_at || 'N/A' | html %]</small>
                            [% IF content.updated_at && content.updated_at != content.created_at %]
                            <small>Updated: [% content.updated_at | html %]</small>
                            [% END %]
                        </div>
                    </div>
                    [% END %]
                </div>
                
                <div class="content-section">
                    <p><strong>Note:</strong> Content sections are displayed in order by their sort order number. To reorder sections, edit the sort order when editing a section.</p>
                </div>
                
                [% ELSE %]
                <div class="empty-state">
                    <p>No content sections have been created yet.</p>
                    <p><a href="/workshop/add_content/[% workshop.id %]" class="btn btn-primary">Create your first content section</a></p>
                </div>
                [% END %]
            </div>
            
            <div class="page-footer">
                <div class="footer-actions">
                    <a href="/workshop/details?id=[% workshop.id %]" class="btn btn-secondary">Back to Workshop</a>
                    <a href="/workshop/files/[% workshop.id %]" class="btn btn-secondary">Manage Files</a>
                </div>
            </div>
            
        </div>
        
    </div>
    
</div>

<style>
.content-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.content-section {
    border: 1px solid var(--border-color, #ddd);
    border-radius: 4px;
    padding: 1rem;
}

.content-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color, #ddd);
}

.content-header h3 {
    margin: 0;
    font-size: 1.25rem;
}

.sort-order {
    color: var(--text-muted-color, #666);
    font-size: 0.9em;
    margin-right: 0.5rem;
}

.content-actions {
    display: flex;
    gap: 0.5rem;
}

.content-body {
    margin-bottom: 1rem;
    padding: 1rem;
    border-radius: 4px;
    white-space: pre-wrap;
}

.content-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-size: 0.9em;
    color: var(--text-muted-color, #666);
}
</style>
