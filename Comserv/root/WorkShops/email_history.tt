[% PageVersion = 'WorkShops/email_history.tt,v 0.01 2026/02/16 shanta Exp shanta ' %]
[% IF debug_mode == 1 %]
[% END %]
 [% PageVersion %]

<h1>Email History</h1>

<h2>Workshop: [% workshop.title %]</h2>

[% IF flash.success_msg %]
<div class="success" style="color: green; padding: 10px; background-color: #eeffee; border: 1px solid green; margin-bottom: 15px;">
    [% flash.success_msg %]
</div>
[% END %]

[% IF flash.warning_msg %]
<div class="warning" style="color: #856404; padding: 10px; background-color: #fff3cd; border: 1px solid #ffc107; margin-bottom: 15px;">
    [% flash.warning_msg %]
</div>
[% END %]

[% IF flash.error_msg %]
<div class="error" style="color: red; padding: 10px; background-color: #ffeeee; border: 1px solid red; margin-bottom: 15px;">
    [% flash.error_msg %]
</div>
[% END %]

<p><a href="/workshop/compose_email/[% workshop.id %]"><button type="button">Compose New Email</button></a></p>

[% IF emails.size > 0 %]
<table border="1" cellpadding="5" cellspacing="0" style="border-collapse: collapse; width: 100%;">
    <thead>
        <tr>
            <th>Date Sent</th>
            <th>Subject</th>
            <th>Recipients</th>
            <th>Status</th>
            <th>Sent By</th>
        </tr>
    </thead>
    <tbody>
        [% FOREACH email IN emails %]
        <tr>
            <td>[% email.sent_at.strftime('%Y-%m-%d %H:%M') %]</td>
            <td>
                <strong>[% email.subject %]</strong><br>
                <small style="color: #666;">[% email.body.substr(0, 100) %][% IF email.body.length > 100 %]...[% END %]</small>
            </td>
            <td>[% email.recipient_count %]</td>
            <td>
                [% IF email.status == 'sent' %]
                    <span style="color: green;">✓ Sent</span>
                [% ELSIF email.status == 'failed' %]
                    <span style="color: red;">✗ Failed</span>
                [% ELSIF email.status == 'partial' %]
                    <span style="color: orange;">⚠ Partial</span>
                [% ELSE %]
                    [% email.status %]
                [% END %]
            </td>
            <td>
                [% IF email.sender %]
                    [% email.sender.username %]
                [% ELSE %]
                    Unknown
                [% END %]
            </td>
        </tr>
        [% END %]
    </tbody>
</table>
[% ELSE %]
<p>No emails have been sent for this workshop yet.</p>
[% END %]

<p><a href="/workshop/details?id=[% workshop.id %]">Back to Workshop</a> | <a href="/workshop/dashboard">Dashboard</a></p>
