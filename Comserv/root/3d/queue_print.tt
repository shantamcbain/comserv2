<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>3D Print Queue — [% sitename | html %]</title>
<style>
  @media print {
    .no-print { display: none !important; }
    body { margin: 10mm; font-size: 9pt; }
    h1 { font-size: 13pt; margin: 0 0 4pt; }
    h2 { font-size: 11pt; margin: 8pt 0 4pt; }
    table { font-size: 8pt; }
    tr { page-break-inside: avoid; }
    .section { page-break-inside: avoid; margin-bottom: 12pt; }
    a { color: inherit; text-decoration: none; }
  }

  body {
    font-family: Arial, sans-serif;
    font-size: 13px;
    margin: 0;
    background: #f5f5f5;
    color: #222;
  }

  .print-bar {
    background: #333;
    color: #fff;
    padding: 8px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .print-bar a { color: #adf; text-decoration: none; font-size: 0.9em; }
  .print-bar button {
    background: #28a745;
    color: #fff;
    border: none;
    padding: 6px 14px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.95em;
    font-weight: bold;
  }
  .print-bar button:hover { background: #218838; }

  .page {
    max-width: 260mm;
    margin: 12px auto;
    background: #fff;
    padding: 12mm 14mm;
    box-shadow: 0 0 8px rgba(0,0,0,0.15);
  }

  .page-header {
    border-bottom: 2px solid #333;
    padding-bottom: 6px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .page-header h1 { margin: 0; font-size: 18px; }
  .page-meta { font-size: 0.78em; color: #666; text-align: right; }

  h2 {
    font-size: 13px;
    border-bottom: 1px solid #aaa;
    padding-bottom: 3px;
    margin: 14px 0 6px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 8px;
  }
  th {
    background: #f0f0f0;
    text-align: left;
    padding: 4px 8px;
    font-size: 0.85em;
    border: 1px solid #ccc;
  }
  td {
    padding: 4px 8px;
    border: 1px solid #ddd;
    vertical-align: top;
    font-size: 0.88em;
  }
  tr:nth-child(even) td { background: #fafafa; }

  .badge {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 8px;
    font-size: 0.78em;
    font-weight: bold;
  }
  .badge-queued   { background: #ffc107; color: #333; }
  .badge-assigned { background: #17a2b8; color: #fff; }
  .badge-printing { background: #007bff; color: #fff; }
  .badge-done     { background: #28a745; color: #fff; }

  .empty { color: #999; font-style: italic; font-size: 0.88em; padding: 4px 0; }
  .section { margin-bottom: 16px; }
</style>
</head>
<body>

<div class="print-bar no-print">
  <button onclick="window.print()">🖶 Print</button>
  <a href="/3d/queue">← Back to Queue</a>
  <a href="/3d/admin">Admin Dashboard</a>
  <span style="margin-left:auto;font-size:0.82em;color:#aaa;">
    Printed: <span id="ts"></span>
  </span>
</div>

<div class="page">
  <div class="page-header">
    <div>
      <h1>3D Print Queue</h1>
      <div style="font-size:0.85em;color:#555;">Site: <strong>[% sitename | html %]</strong></div>
    </div>
    <div class="page-meta">
      Generated: [% print_date %]<br>
      Queued: [% queued_jobs.size %] &nbsp;|&nbsp;
      Active: [% active_jobs.size %] &nbsp;|&nbsp;
      History (last 30): [% recent_completed.size %]
    </div>
  </div>

  <div class="section">
    <h2>Queued — Waiting for Printer ([% queued_jobs.size %])</h2>
    [% IF queued_jobs && queued_jobs.size %]
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Item / Model</th>
          <th>Qty</th>
          <th>Filament</th>
          <th>User</th>
          <th>Queued</th>
          <th style="width:60px">Notes</th>
        </tr>
      </thead>
      <tbody>
      [% FOREACH job IN queued_jobs %]
      <tr>
        <td>[% job.id %]</td>
        <td>
          [% IF job.model_name %][% job.model_name | html %]
          [% ELSIF job.item_name %][% job.item_name | html %]
          [% ELSE %]Job #[% job.id %][% END %]
        </td>
        <td style="text-align:center">[% job.quantity %]</td>
        <td>
          [% IF job.filament_type || job.filament_color %]
            [% job.filament_type | html %] [% job.filament_color | html %]
            [% IF job.filament_name %]<br><small style="color:#888">[% job.filament_name | html %]</small>[% END %]
          [% ELSE %]—[% END %]
        </td>
        <td>[% job.username | html %]</td>
        <td style="white-space:nowrap;font-size:0.82em">[% job.created_at %]</td>
        <td></td>
      </tr>
      [% END %]
      </tbody>
    </table>
    [% ELSE %]
    <div class="empty">No jobs waiting in queue.</div>
    [% END %]
  </div>

  <div class="section">
    <h2>Active — Printing ([% active_jobs.size %])</h2>
    [% IF active_jobs && active_jobs.size %]
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Item / Model</th>
          <th>Qty</th>
          <th>Filament</th>
          <th>Printer</th>
          <th>User</th>
          <th>Started</th>
          <th style="width:60px">Notes</th>
        </tr>
      </thead>
      <tbody>
      [% FOREACH job IN active_jobs %]
      <tr>
        <td>[% job.id %]</td>
        <td>
          [% IF job.model_name %][% job.model_name | html %]
          [% ELSIF job.item_name %][% job.item_name | html %]
          [% ELSE %]Job #[% job.id %][% END %]
          <br><span class="badge badge-[% job.status %]">[% job.status %]</span>
        </td>
        <td style="text-align:center">[% job.quantity %]</td>
        <td>
          [% IF job.filament_type || job.filament_color %]
            [% job.filament_type | html %] [% job.filament_color | html %]
            [% IF job.filament_name %]<br><small style="color:#888">[% job.filament_name | html %]</small>[% END %]
          [% ELSE %]—[% END %]
        </td>
        <td>[% job.printer_name | html %]</td>
        <td>[% job.username | html %]</td>
        <td style="white-space:nowrap;font-size:0.82em">[% job.started_at || job.created_at %]</td>
        <td></td>
      </tr>
      [% END %]
      </tbody>
    </table>
    [% ELSE %]
    <div class="empty">No active print jobs.</div>
    [% END %]
  </div>

  [% IF recent_completed && recent_completed.size %]
  <div class="section">
    <h2>Completed — Cost Summary (last 30)</h2>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Item / Model</th>
          <th>Qty</th>
          <th>Filament</th>
          <th style="text-align:right">g</th>
          <th>Printer</th>
          <th style="text-align:right">Hours</th>
          <th style="text-align:right">Fil $</th>
          <th style="text-align:right">Prtr $</th>
          <th style="text-align:right">Elec $</th>
          <th style="text-align:right">Total $</th>
          <th>Completed</th>
        </tr>
      </thead>
      <tbody>
      [% FOREACH job IN recent_completed %]
      <tr>
        <td>[% job.id %]</td>
        <td>
          [% IF job.model_name %][% job.model_name | html %]
          [% ELSIF job.item_name %][% job.item_name | html %]
          [% ELSE %]#[% job.id %][% END %]
        </td>
        <td style="text-align:center">[% job.quantity %]</td>
        <td style="font-size:0.82em">
          [% job.filament_type | html %] [% job.filament_color | html %]
          [% IF job.filament_name %]<br>[% job.filament_name | html %][% END %]
        </td>
        <td style="text-align:right">[% job.filament_quantity || '—' %]</td>
        <td>[% job.printer_name | html %]</td>
        <td style="text-align:right">[% job.print_hours ? job.print_hours _ 'h' : '—' %]</td>
        <td style="text-align:right">[% job.filament_cost   ? '$' _ job.filament_cost   : '—' %]</td>
        <td style="text-align:right">[% job.printer_cost    ? '$' _ job.printer_cost    : '—' %]</td>
        <td style="text-align:right">[% job.electricity_cost ? '$' _ job.electricity_cost : '—' %]</td>
        <td style="text-align:right;font-weight:bold">[% job.total_cost ? '$' _ job.total_cost : '—' %]</td>
        <td style="white-space:nowrap;font-size:0.82em">[% job.completed_at %]</td>
      </tr>
      [% END %]
      </tbody>
    </table>
  </div>
  [% END %]

</div>

<script>
document.getElementById('ts').textContent = new Date().toLocaleString();
</script>
</body>
</html>
