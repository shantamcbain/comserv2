

[% PageVersion = 'root/pagetop.tt,v 0.030.0 2026/02/09 shanta Exp shanta - Fixed sticky nav menu with higher specificity (header nav#main-menu). Set header position:relative, h1 margin/padding.' %]
[% IF debug_mode == 1 %]
    [% PageVersion %]
[% END %]
[% SET roles = c.stash.user_roles || c.session.roles || [] %]
[% SET is_admin = c.stash.is_admin || roles.grep('admin').size > 0 ? 1 : 0 %]

<!-- Add Font Awesome for the paint brush icon -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<!-- Theme-aware stylesheet -->
<style>
.server-info {
    background-color: rgba(255,255,255,0.12);
    border-bottom: 1px solid var(--border-color);
    padding: 5px 10px;
    font-size: 12px;
    color: var(--text-color);
}

.db-env-indicator {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 3px;
    font-weight: bold;
    font-size: 11px;
    margin-left: 5px;
}

.db-env-production {
    background-color: var(--warning-color, #dc3545);
    color: var(--button-text, #fff);
}

.db-env-staging {
    background-color: var(--caution-color, #ffc107);
    color: var(--text-color, #333);
}

.db-env-dev {
    background-color: var(--success-color, #28a745);
    color: var(--button-text, #fff);
}

.k8s-migration-banner {
    background-color: var(--schema-alert-warning-bg, #fff3cd);
    border-bottom: 2px solid var(--accent-color);
    padding: 12px 15px;
    color: var(--text-color);
    font-family: Arial, sans-serif;
}

.k8s-migration-banner a {
    background-color: var(--accent-color);
    color: white;
    padding: 8px 12px;
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
    font-size: 13px;
    display: inline-block;
}

#css-edit-toggle {
    background: var(--button-bg);
    color: var(--button-text);
    border: 1px solid var(--button-border);
    border-radius: 3px;
    padding: 2px 10px;
    margin-left: 10px;
    cursor: pointer;
    font-size: 12px;
}

#css-edit-toggle:hover {
    background: var(--button-hover-bg);
}

#css-edit-toggle.edit-mode {
    background: var(--warning-color);
    color: white;
    border: 1px solid var(--warning-color);
}

#css-edit-toggle.edit-mode:hover {
    opacity: 0.9;
}


.css-edit-mode * {
    outline: 2px solid rgba(52, 152, 219, 0.3) !important;
    position: relative;
}

.css-edit-mode *:hover {
    outline: 2px solid var(--warning-color) !important;
    cursor: crosshair;
}

.membership-status-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    font-size: 12px;
}

.membership-tier-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-weight: bold;
    font-size: 11px;
    text-decoration: none;
    background-color: var(--accent-color, #4a90d9);
    color: white;
}

.membership-tier-free {
    background-color: var(--border-color, #ccc);
    color: var(--text-color, #555);
}

.coin-balance {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: bold;
    background-color: var(--secondary-color, #f0f0f0);
    color: var(--text-color, #333);
    text-decoration: none;
}

@media (max-width: 768px) {
    .membership-status-bar { font-size: 11px; padding: 2px 8px; }
}

/* Sticky/Floating Main Navigation Menu - Only the nav, not the header */
header {
    position: relative !important;
}

header nav#main-menu {
    position: sticky !important;
    top: 0 !important;
    z-index: 2000 !important;
    background-color: var(--nav-bg, white) !important;
    border-bottom: 2px solid var(--border-color, #ddd) !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1) !important;
    margin: 0 !important;
}

header h1 {
    margin: 0 !important;
    padding: 10px !important;
    font-size: clamp(1rem, 4vw, 1.5rem) !important;
    word-break: break-word !important;
}

/* ---- Mobile nav toggle button ---- */
.nav-toggle {
    display: none;
    background: var(--button-bg, #f0f0f0);
    color: var(--button-text, #333);
    border: 1px solid var(--border-color, #ccc);
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 20px;
    cursor: pointer;
    line-height: 1;
    margin: 4px 8px;
}

@media (max-width: 768px) {
    .nav-toggle { display: inline-block; }
    .server-info { font-size: 11px; }
    .server-info > div {
        text-align: left !important;
        white-space: normal !important;
        word-break: break-word;
        line-height: 1.6;
    }
    #css-edit-toggle { display: block; margin: 4px 0 0 0; }
}
</style>

<!-- CRITICAL: Debug Bar UI - DO NOT REMOVE (lines 7-22)
     This debug bar section displays server info (hostname, IP, database connections)
     to admins and users in debug mode. Removing this breaks diagnostic visibility
     and admin page rendering capability. See Root.pm auto() method and SystemInfo.pm. -->
[% IF is_admin || c.session.debug_mode == 1 %]
<div class="server-info">
    [% IF is_admin || c.session.debug_mode == 1 %]
    <div style="text-align: right;">
        Domain: <strong>[% c.req.uri.host %]</strong> | 
        Client IP: <strong>[% c.req.address %]</strong> | 
        Server: <strong>[% system_identifier || app_workflow %]</strong> | Workflow: [% app_workflow %] ([% c.forward('/get_server_ip') %]) |
        [% IF app_version %]Build: <strong title="Commit: [% app_version.commit %] | Branch: [% app_version.branch %] | Host: [% app_version.build_host %]" style="cursor:help;">[% app_version.build_date | replace('T',' ') | replace(':\d\dZ','') %] UTC</strong> | Git: <strong>[% app_version.branch %]</strong>@<code style="font-size:0.85em;">[% app_version.commit %]</code> | [% END %]
        Databases: [% IF db_connections && db_connections.size > 0 %][% FOREACH db IN db_connections %]<strong>[% db.type %]([% db.name %])@[% db.ip %]</strong>[% UNLESS loop.last %], [% END %][% END %][% ELSE %]<em>none configured</em>[% END %] |
        DB Env: <span class="db-env-indicator db-env-[% active_db_environment || 'production' %]">[% SET env = active_db_environment || 'production' %][% env.upper %]</span>
        [% IF c.session.debug_mode == 1 %] | [% END %] |
        [% IF is_admin %]
        <button id="css-edit-toggle"
                data-theme-name="[% theme_name || 'default' %]"
                title="Click any page element to edit its styles and save to the [% theme_name || 'default' %] theme">
            <i class="fas fa-paint-brush"></i> Theme Editor
        </button>
        [% END %]
    </div>
    [% END %]
</div>
[% END %]

<!-- K8s Migration Warning Banner (Phase 0 - Production Readiness) -->
[% IF k8s_migration_needed && is_admin %]
<div class="k8s-migration-banner">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <strong style="font-size: 14px;">⚠️ K8s Migration Ready</strong>
            <p style="margin: 5px 0 0 0; font-size: 13px;">
                [% k8s_migration_message %]
            </p>
        </div>
        <div style="margin-left: 15px;">
            <a href="[% k8s_setup_url %]">
                Migrate to K8s Secrets
            </a>
        </div>
    </div>
</div>
[% END %]

<!-- Include Debug Template - shows session/stash when debug_mode=1 -->
[% IF c.session.debug_mode == 1 %]
[% INCLUDE 'debug.tt' %]
[% END %]

<!-- Include Theme Editor JavaScript -->
[% IF is_admin %]
<script src="[% c.uri_for('/static/js/theme-editor.js') %]"></script>
[% END %]

<script>
document.addEventListener('DOMContentLoaded', function() {
    // --- Hamburger nav toggle ---
    const navToggle = document.querySelector('.nav-toggle');
    const menuList  = document.getElementById('main-menu-list');
    if (navToggle && menuList) {
        navToggle.addEventListener('click', function() {
            const open = menuList.classList.toggle('nav-open');
            navToggle.setAttribute('aria-expanded', open);
            navToggle.textContent = open ? '\u2715' : '\u2630';
        });
        // Touch-friendly dropdown: tap dropbtn to open, tap outside to close
        document.querySelectorAll('.dropbtn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                if (window.innerWidth > 768) return;
                const li = btn.closest('.horizontal-dropdown');
                const wasOpen = li.classList.contains('touch-open');
                document.querySelectorAll('.horizontal-dropdown.touch-open').forEach(function(el) {
                    el.classList.remove('touch-open');
                });
                if (!wasOpen) { li.classList.add('touch-open'); e.preventDefault(); }
            });
        });
        document.addEventListener('click', function(e) {
            if (!e.target.closest('#main-menu')) {
                document.querySelectorAll('.horizontal-dropdown.touch-open').forEach(function(el) {
                    el.classList.remove('touch-open');
                });
            }
        });
    }

    // --- Theme editor toggle ---
    const toggleBtn = document.getElementById('css-edit-toggle');
    if (toggleBtn) {
        toggleBtn.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();

            if (typeof ThemeEditor === 'undefined') {
                alert('Theme Editor script failed to load. Please reload the page.');
                return;
            }

            if (!window.themeEditor) {
                window.themeEditor = new ThemeEditor();
                window.themeEditor.init();
            }

            window.themeEditor.toggleInspector();

            const isActive = window.themeEditor.isInspectorActive;
            document.body.classList.toggle('css-edit-mode', isActive);
            this.innerHTML = isActive
                ? '<i class="fas fa-times"></i> Close Editor'
                : '<i class="fas fa-paint-brush"></i> Theme Editor';
            this.classList.toggle('edit-mode', isActive);
        });
    }
});
</script>

<header>
    <h1>
        Welcome [% IF c.session.username %]
[% c.session.first_name || c.session.username %] [% c.session.last_name %][% IF is_admin %] Administrator[% END %]
[% ELSE %]
 Guest
[% END %] to [% site_display_name || SiteDisplayName || c.stash.site_display_name || c.stash.SiteDisplayName || c.session.site_display_name || SiteName || c.session.SiteName || 'this site' %]!
    </h1>

[% IF c.session.user_id %]
[% TRY %]
[% SET _uid = c.session.user_id %]
[% SET _sid = c.session.SiteID %]
[% SET _mem_rs = c.model('DBEncy').resultset('UserMembership') %]
[% SET _active_mem = _mem_rs.search({'me.user_id' => _uid, 'me.site_id' => _sid, 'me.status' => 'active'}, {prefetch => 'plan', rows => 1, order_by => {'me.started_at' => 'DESC'}}).first %]
[% IF NOT _active_mem %][% SET _active_mem = _mem_rs.search({'me.user_id' => _uid, 'me.site_id' => _sid, 'me.status' => 'grace'}, {prefetch => 'plan', rows => 1, order_by => {'me.started_at' => 'DESC'}}).first %][% END %]
[% SET _coin_acct = c.model('DBEncy').resultset('InternalCurrencyAccount').find({user_id => _uid}) %]
<div class="membership-status-bar">
    [% IF _active_mem AND _active_mem.plan %]
        <a href="/membership/account" class="membership-tier-badge membership-tier-[% _active_mem.plan.slug | html %]" title="Your membership plan">[% _active_mem.plan.name | html %]</a>
    [% ELSE %]
        <a href="/membership/plans" class="membership-tier-badge membership-tier-free" title="Upgrade your membership for more features">Free &mdash; Upgrade</a>
    [% END %]
    [% IF _coin_acct AND _coin_acct.balance > 0 %]
        <a href="/currency/balance" class="coin-balance" title="Your coin balance">&#9679; [% _coin_acct.balance | format('%.2f') %]</a>
    [% END %]
</div>
[% CATCH %][% END %]
[% END %]



    <!-- Main Menu -->
    <nav id="main-menu">
        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="main-menu-list">&#9776;</button>
        <ul class="horizontal-menu" id="main-menu-list">
            <li class="horizontal-dropdown">
                <a href="[% c.session.return_url %]" class="dropbtn">Back</a>
            </li>
        [% INCLUDE 'Navigation/TopDropListMain.tt' %]
        [% IF site_has_shop || c.stash.enabled_modules.ecommerce %][% INCLUDE 'Navigation/TopDropListShop.tt' %][% END %]
        [% INCLUDE 'Navigation/TopDropListLogin.tt' %]
        [%# Global discontinued — Mail/Jobs/Join moved to Main %]
        [% IF 0 %][% INCLUDE 'Navigation/TopDropListGlobal.tt' %][% END %]
        [% IF c.session.SiteName == 'CSC' %][% INCLUDE 'Navigation/TopDropListHosted.tt' %][% END %]
        [% INCLUDE 'Navigation/TopDropListMember.tt' %]
        [% INCLUDE 'Navigation/TopDropListENCY.tt' %]
        [% INCLUDE 'Navigation/TopDropListWeather.tt' %]
        [%# IT discontinued — IT content moved to HelpDesk submenu %]
        [% IF 0 %][% INCLUDE 'Navigation/TopDropListIT.tt' %][% END %]
        [%# Coop removed and merged into admintopmenu.tt %]

        [% IF is_admin %]
            [% INCLUDE 'Navigation/admintopmenu.tt' %]
        [% END %]
        [% INCLUDE 'Navigation/TopDropListPlanning.tt' %]
        [% INCLUDE 'Navigation/TopDropListHelpDesk.tt' %]
        [% INCLUDE 'Navigation/TopDropListWorkshop.tt' %]
        [% INCLUDE 'Navigation/TopDropListBeekeeping.tt' %]
        [% IF c.stash.enabled_modules.item('printing_3d') %]
            [% INCLUDE 'Navigation/TopDropList3d.tt' %]
        [% END %]
        </ul>
    </nav>


</header>
[% IF error_msg %]
<p class="error">Error: [% error_msg %]</p>
[% END %]

[% IF success_msg %]
<p class="success">Success: [% success_msg %]</p>
[% END %]
    [% IF is_admin && c.stash.debug_msg %]
        [% FOREACH msg IN c.stash.debug_msg %]
        <p class="debug">Debug: [% msg %]</p>
        [% END %]
    [% END %]

[% # Admin role check is now done at the top of the file %]