[% IF error_msg %]<div class="error-message">[% error_msg | html %]</div>[% END %]

<div class="container">

<h1>[% is_edit ? 'Edit' : 'Add' %] Database Server</h1>

[% IF !is_edit %]
<p style="color:var(--text-muted,#666);margin-bottom:1em;">
    <strong>Tip:</strong> Common defaults: MariaDB/MySQL 3306 &nbsp;· MySQL Docker 3307 &nbsp;· PostgreSQL 5432 &nbsp;· PostgreSQL Docker 5433.
</p>
[% END %]

<form method="post"
      action="[% is_edit ? c.uri_for('/remotedb/edit') _ '/' _ conn_name : c.uri_for('/remotedb/add') %]"
      style="max-width:660px;">

    <fieldset style="border:1px solid var(--border-color,#ccc);padding:1em;border-radius:4px;margin-bottom:1em;">
        <legend style="font-weight:bold;padding:0 0.4em;">Identity</legend>

        [% UNLESS is_edit %]
        <p style="margin:0 0 0.6em;">
            <label for="conn_name" style="display:block;font-weight:bold;margin-bottom:3px;">Connection Name *</label>
            <input type="text" id="conn_name" name="conn_name"
                   value="[% form_data.conn_name | html %]"
                   placeholder="e.g. db_production_mysql"
                   pattern="[a-zA-Z0-9_]+" title="Letters, numbers, underscores only"
                   required>
            <small style="color:var(--text-muted,#666);">Unique key — lowercase, underscores only.</small>
        </p>
        [% END %]

        <p style="margin:0;">
            <label for="description" style="display:block;font-weight:bold;margin-bottom:3px;">Description</label>
            <input type="text" id="description" name="description"
                   value="[% form_data.description | html %]"
                   placeholder="e.g. Production MariaDB on Dell R710">
        </p>
    </fieldset>

    <fieldset style="border:1px solid var(--border-color,#ccc);padding:1em;border-radius:4px;margin-bottom:1em;">
        <legend style="font-weight:bold;padding:0 0.4em;">Connection</legend>

        <p style="margin:0 0 0.6em;">
            <label for="db_type" style="display:block;font-weight:bold;margin-bottom:3px;">Database Type *</label>
            <select id="db_type" name="db_type" required onchange="setDefaultPort(this.value)">
                [% FOREACH t IN db_types %]
                <option value="[% t | html %]"
                    [% IF form_data.db_type == t || (!form_data.db_type && t == 'mariadb') %]selected[% END %]>
                    [% t | html %]
                </option>
                [% END %]
            </select>
        </p>

        <p style="margin:0 0 0.6em;">
            <label for="host" style="display:block;font-weight:bold;margin-bottom:3px;">Host *</label>
            <input type="text" id="host" name="host"
                   value="[% form_data.host || 'localhost' %]"
                   placeholder="192.168.1.x or hostname" required>
        </p>

        <p style="margin:0 0 0.6em;">
            <label for="port" style="display:block;font-weight:bold;margin-bottom:3px;">Port *</label>
            <input type="number" id="port" name="port"
                   value="[% form_data.port || 3306 %]"
                   min="1" max="65535" required>
            <small style="color:var(--text-muted,#666);">MariaDB/MySQL: 3306 &nbsp;· MySQL Docker: 3307 &nbsp;· PG: 5432 &nbsp;· PG Docker: 5433</small>
        </p>

        <p style="margin:0 0 0.6em;">
            <label for="database" style="display:block;font-weight:bold;margin-bottom:3px;">Database Name *</label>
            <input type="text" id="database" name="database"
                   value="[% form_data.database | html %]"
                   list="known_databases_list"
                   placeholder="Type or choose from list"
                   required>
            <datalist id="known_databases_list">
                [% SET db_seen = {} %]
                [% FOREACH cname IN connections.keys.sort %]
                    [% SET db = connections.$cname.config.database %]
                    [% IF db && !db_seen.$db %]
                        <option value="[% db | html %]">
                        [% db_seen.$db = 1 %]
                    [% END %]
                [% END %]
            </datalist>
            <small style="color:var(--text-muted,#666);">Choose an existing database name or type a new one.</small>
        </p>

        <p style="margin:0 0 0.6em;">
            <label for="username" style="display:block;font-weight:bold;margin-bottom:3px;">Username *</label>
            <input type="text" id="username" name="username"
                   value="[% form_data.username | html %]"
                   placeholder="e.g. root or shanta_forager" required>
        </p>

        <p style="margin:0 0 0.6em;">
            <label for="password" style="display:block;font-weight:bold;margin-bottom:3px;">Password[% IF is_edit %] (leave blank to keep current)[% END %]</label>
            <input type="password" id="password" name="password"
                   placeholder="[% is_edit ? '(unchanged)' : 'Enter password' %]"
                   [% UNLESS is_edit %]required[% END %]>
        </p>

        <p style="margin:0;">
            <label style="cursor:pointer;">
                <input type="checkbox" name="localhost_override" value="1"
                       [% IF form_data.localhost_override %]checked[% END %]>
                <strong>Localhost Override</strong> — treat as local server for fallback logic
            </label>
        </p>
    </fieldset>

    <fieldset style="border:1px solid var(--border-color,#ccc);padding:1em;border-radius:4px;margin-bottom:1em;">
        <legend style="font-weight:bold;padding:0 0.4em;">Classification</legend>

        <p style="margin:0 0 0.6em;">
            <label for="environment" style="display:block;font-weight:bold;margin-bottom:3px;">Environment</label>
            <select id="environment" name="environment">
                [% FOREACH e IN environments %]
                <option value="[% e | html %]"
                    [% IF form_data.environment == e || (!form_data.environment && e == 'production') %]selected[% END %]>
                    [% e | html %]
                </option>
                [% END %]
            </select>
        </p>

        <p style="margin:0 0 0.6em;">
            <label for="role" style="display:block;font-weight:bold;margin-bottom:3px;">Role</label>
            <select id="role" name="role">
                [% FOREACH r IN roles %]
                <option value="[% r | html %]"
                    [% IF form_data.role == r || (!form_data.role && r == 'primary') %]selected[% END %]>
                    [% r | html %]
                </option>
                [% END %]
            </select>
        </p>

        <p style="margin:0;">
            <label for="priority" style="display:block;font-weight:bold;margin-bottom:3px;">Priority</label>
            <input type="number" id="priority" name="priority"
                   value="[% form_data.priority || 5 %]"
                   min="1" max="999" style="width:100px;">
            <small style="color:var(--text-muted,#666);">1 = highest priority. App tries lowest number first.</small>
        </p>
    </fieldset>

    <p>
        <button type="submit" class="btn btn-primary">
            [% is_edit ? 'Save Changes' : 'Add Server' %]
        </button>
        &nbsp;
        <a href="[% c.uri_for('/remotedb') %]" class="btn btn-secondary">Cancel</a>
    </p>

</form>

</div>

<script>
function setDefaultPort(dbType) {
    var portField = document.getElementById('port');
    var defaults = { mariadb: 3306, mysql: 3307, postgresql: 5432, sqlite: '' };
    if (!portField.value || portField.value == 3306 || portField.value == 3307 || portField.value == 5432) {
        portField.value = defaults[dbType] || 3306;
    }
}
</script>
