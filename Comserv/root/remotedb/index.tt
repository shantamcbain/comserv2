[% META title = 'Database Server Management' %]

[% IF success_msg %]<div class="success-message">[% success_msg | html %]</div>[% END %]
[% IF error_msg %]<div class="error-message">[% error_msg | html %]</div>[% END %]

<div class="page-header">
    <h1>Database Server Management</h1>
    <a href="[% c.uri_for('/remotedb/add') %]" class="btn btn-primary">+ Add Database Server</a>
</div>

<p class="help-text">
    Servers are stored in <code>~/.comserv/secrets/dbi/</code> — shared across all branches, no per-branch reconfiguration needed.
</p>

[% SET conn_keys = connections.keys.sort %]
[% IF conn_keys.size > 0 %]

<table class="data-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Host : Port</th>
            <th>Database</th>
            <th>Environment</th>
            <th>Role</th>
            <th>Priority</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    [% FOREACH name IN conn_keys %]
        [% SET conn = connections.$name %]
        [% SET cfg  = conn.config %]
        <tr>
            <td>
                <a href="[% c.uri_for('/remotedb/detail') %]/[% name | uri %]"
                   title="Click to view details and edit settings for [% name | html %]"
                   class="detail-link">
                    [% name | html %]
                </a>
            </td>
            <td><code>[% cfg.db_type | html %]</code></td>
            <td><code>[% cfg.host | html %]:[% cfg.port | html %]</code></td>
            <td><code>[% cfg.database | html %]</code></td>
            <td>
                [% SET env_class = cfg.environment == 'production'  ? 'badge-danger'  :
                                   cfg.environment == 'development' ? 'badge-info'    :
                                   cfg.environment == 'staging'     ? 'badge-warning' :
                                                                      'badge-default' %]
                <span class="badge [% env_class %]">[% cfg.environment | html %]</span>
            </td>
            <td>[% cfg.role | html %]</td>
            <td>[% cfg.priority | html %]</td>
            <td>
                <a href="[% c.uri_for('/remotedb/test') %]/[% name | uri %]"
                   title="Test TCP connectivity to [% cfg.host | html %]:[% cfg.port | html %]"
                   class="btn btn-sm btn-outline-success">&#9889; Test</a>
            </td>
        </tr>
    [% END %]
    </tbody>
</table>

[% ELSE %]
<div class="info-message">
    No database servers configured yet.
    <a href="[% c.uri_for('/remotedb/add') %]">Add the first one.</a>
</div>
[% END %]

<div class="info-box">
    <h3>How the connection system works</h3>
    <ul>
        <li><strong>Priority 1</strong> = highest priority (tried first for a given database name)</li>
        <li>The app tests each connection in priority order and uses the first one that responds</li>
        <li>Files live at <code>~/.comserv/secrets/dbi/&lt;name&gt;.json</code> — one file per server</li>
        <li>This directory is shared across all branches — set once, works everywhere</li>
        <li>For Docker containers: use the <em>external</em> mapped port (e.g. 3307, 5433) not the internal port</li>
    </ul>
</div>
