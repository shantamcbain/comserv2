
<div class="app-container">

[% IF success_msg %]<div class="success-message">[% success_msg | html %]</div>[% END %]
[% IF error_msg %]<div class="error-message">[% error_msg | html %]</div>[% END %]

<div class="page-header">
    <h1>[% conn_name | html %]</h1>
    <div class="form-actions">
        <a href="[% c.uri_for('/remotedb/edit') %]/[% conn_name | uri %]" class="btn btn-primary">Edit Settings</a>
        <a href="[% c.uri_for('/remotedb/test') %]/[% conn_name | uri %]"
           class="btn btn-secondary"
           title="Test TCP connectivity to [% conn.config.host | html %]:[% conn.config.port | html %]">Test Connection</a>
        <a href="[% c.uri_for('/remotedb/view') %]/[% conn_name | uri %]" class="btn btn-secondary">Browse Tables</a>
        <a href="[% c.uri_for('/remotedb/migrate') %]?target=[% conn_name | uri %]" class="btn btn-secondary">&#8658; Migrate To/From</a>
        <a href="[% c.uri_for('/remotedb/remove') %]/[% conn_name | uri %]"
           class="btn btn-delete"
           onclick="return confirm('Remove [% conn_name | html %]? This cannot be undone.')">Remove</a>
        <a href="[% c.uri_for('/remotedb') %]" class="btn btn-secondary">&#8592; Back</a>
    </div>
</div>

<div class="content-container">
<div class="data-container">

    <div class="form-section">
        <h3>Connection</h3>
        <div class="table-container">
        <table class="data-table">
            <tbody>
                <tr><th>Type</th><td><code>[% conn.config.db_type | html %]</code></td></tr>
                <tr><th>Host</th><td><code>[% conn.config.host | html %]</code></td></tr>
                <tr><th>Port</th><td><code>[% conn.config.port | html %]</code></td></tr>
                <tr><th>Database</th><td><code>[% conn.config.database | html %]</code></td></tr>
                <tr><th>Username</th><td>[% conn.config.username | html %]</td></tr>
                <tr><th>Password</th><td>&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679;&#9679; (stored securely)</td></tr>
            </tbody>
        </table>
        </div>
    </div>

    <div class="form-section">
        <h3>Classification</h3>
        <div class="table-container">
        <table class="data-table">
            <tbody>
                <tr><th>Environment</th><td>[% conn.config.environment | html %]</td></tr>
                <tr><th>Role</th><td>[% conn.config.role | html %]</td></tr>
                <tr><th>Priority</th><td>[% conn.config.priority | html %] (1 = highest)</td></tr>
                <tr><th>Localhost Override</th><td>[% conn.config.localhost_override ? 'Yes' : 'No' %]</td></tr>
            </tbody>
        </table>
        </div>
    </div>

    [% IF conn.config.description %]
    <div class="form-section">
        <h3>Description</h3>
        <p>[% conn.config.description | html %]</p>
    </div>
    [% END %]

</div>
</div>

</div>
