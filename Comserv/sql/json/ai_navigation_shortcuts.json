{
  "table_name": "ai_navigation_shortcuts",
  "description": "DB-driven AI navigation shortcuts and trigger phrases (site/user scoped, public or private)",
  "columns": {
    "id": {
      "data_type": "integer",
      "is_auto_increment": true,
      "is_nullable": false,
      "description": "Primary key"
    },
    "label": {
      "data_type": "varchar",
      "size": 100,
      "is_nullable": false,
      "description": "Display label for the shortcut"
    },
    "url": {
      "data_type": "varchar",
      "size": 512,
      "is_nullable": false,
      "description": "Application path or URL"
    },
    "trigger_phrases": {
      "data_type": "text",
      "is_nullable": true,
      "description": "JSON array of natural-language trigger phrases"
    },
    "category": {
      "data_type": "varchar",
      "size": 50,
      "is_nullable": true,
      "description": "Optional menu category (Main_links, Member_links, etc.)"
    },
    "sitename": {
      "data_type": "varchar",
      "size": 50,
      "is_nullable": false,
      "default_value": "All",
      "description": "Site scope or All for global"
    },
    "is_private": {
      "data_type": "tinyint",
      "size": 1,
      "is_nullable": false,
      "default_value": 0,
      "description": "1 = visible only to owner (and admins for management)"
    },
    "owner_username": {
      "data_type": "varchar",
      "size": 100,
      "is_nullable": true,
      "description": "Owner username when is_private=1"
    },
    "min_role": {
      "data_type": "varchar",
      "size": 20,
      "is_nullable": false,
      "default_value": "user",
      "description": "Minimum role: guest, user, or admin"
    },
    "link_order": {
      "data_type": "integer",
      "is_nullable": true,
      "default_value": 0,
      "description": "Sort order within category"
    },
    "status": {
      "data_type": "tinyint",
      "is_nullable": false,
      "default_value": 1,
      "description": "1 = active, 0 = inactive"
    },
    "source": {
      "data_type": "varchar",
      "size": 30,
      "is_nullable": true,
      "default_value": "manual",
      "description": "manual, ai_learned, or migrated"
    },
    "created_at": {
      "data_type": "datetime",
      "is_nullable": true,
      "default_value": "CURRENT_TIMESTAMP"
    },
    "updated_at": {
      "data_type": "datetime",
      "is_nullable": true,
      "default_value": "CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"
    }
  },
  "primary_key": ["id"],
  "indexes": [
    {
      "name": "idx_ai_nav_shortcut_site",
      "columns": ["sitename"]
    },
    {
      "name": "idx_ai_nav_shortcut_owner",
      "columns": ["owner_username"]
    },
    {
      "name": "idx_ai_nav_shortcut_private",
      "columns": ["is_private"]
    },
    {
      "name": "idx_ai_nav_shortcut_status",
      "columns": ["status"]
    }
  ],
  "relationships": [],
  "sample_data": []
}